<atom:ControlThemesProvider xmlns="https://github.com/avaloniaui"
                            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                            xmlns:atom="https://atomui.net"
                            x:Class="AtomUIGallery.Controls.GalleryControlThemesProvider"
                            Id="AtomUIGallery.Controls">
    <atom:ControlThemesProvider.ControlThemes>
        <ResourceInclude Source="ShowCaseItemTheme.axaml" />
        <ResourceInclude Source="ShowCasePanelTheme.axaml" />
        <ResourceInclude Source="ColorItemControlTheme.axaml" />
        <ResourceInclude Source="ColorListControlTheme.axaml" />
        <ResourceInclude Source="IconGalleryTheme.axaml" />
        <ResourceInclude Source="IconInfoItemTheme.axaml" />
    </atom:ControlThemesProvider.ControlThemes>
</atom:ControlThemesProvider>