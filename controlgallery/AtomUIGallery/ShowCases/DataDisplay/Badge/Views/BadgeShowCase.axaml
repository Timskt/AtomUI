<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AtomUIGallery.ShowCases.Badge"
             x:Class="AtomUIGallery.ShowCases.Badge.BadgeShowCase"
             x:DataType="vm:BadgeViewModel"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem Title="{gallery:BadgeShowCaseLangResource BasicTitle}"
                              Description="{gallery:BadgeShowCaseLangResource BasicDescription}">
            <StackPanel Orientation="Horizontal" Spacing="20">
                <atom:CountBadge Count="5">
                    <Border Width="40"
                            Height="40"
                            Background="rgb(191,191,191)"
                            CornerRadius="8" />
                </atom:CountBadge>
                <atom:CountBadge Count="0" IsZeroVisible="True">
                    <Border Width="40"
                            Height="40"
                            Background="rgb(191,191,191)"
                            CornerRadius="8" />
                </atom:CountBadge>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:BadgeShowCaseLangResource OverflowCountTitle}"
                              Description="{gallery:BadgeShowCaseLangResource OverflowCountDescription}">
            <StackPanel Orientation="Horizontal" Spacing="20">
                <atom:CountBadge Count="99">
                    <Border Width="40"
                            Height="40"
                            Background="rgb(191,191,191)"
                            CornerRadius="8" />
                </atom:CountBadge>
                <atom:CountBadge Count="100">
                    <Border Width="40"
                            Height="40"
                            Background="rgb(191,191,191)"
                            CornerRadius="8" />
                </atom:CountBadge>
                <atom:CountBadge Count="99" OverflowCount="10">
                    <Border Width="40"
                            Height="40"
                            Background="rgb(191,191,191)"
                            CornerRadius="8" />
                </atom:CountBadge>
                <atom:CountBadge Count="1000" OverflowCount="999">
                    <Border Width="40"
                            Height="40"
                            Background="rgb(191,191,191)"
                            CornerRadius="8" />
                </atom:CountBadge>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:BadgeShowCaseLangResource OffsetTitle}"
                              Description="{gallery:BadgeShowCaseLangResource OffsetDescription}">
            <StackPanel Orientation="Horizontal" Spacing="20">
                <atom:CountBadge Count="5" Offset="10, 10">
                    <Border Width="40"
                            Height="40"
                            Background="rgb(191,191,191)"
                            CornerRadius="8" />
                </atom:CountBadge>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:BadgeShowCaseLangResource SizeTitle}" Description="{gallery:BadgeShowCaseLangResource SizeDescription}">
            <StackPanel Orientation="Horizontal" Spacing="20">
                <atom:CountBadge Count="5">
                    <Border Width="40"
                            Height="40"
                            Background="rgb(191,191,191)"
                            CornerRadius="8" />
                </atom:CountBadge>
                <atom:CountBadge Count="5" Size="Small">
                    <Border Width="40"
                            Height="40"
                            Background="rgb(191,191,191)"
                            CornerRadius="8" />
                </atom:CountBadge>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:BadgeShowCaseLangResource StandaloneTitle}" Description="{gallery:BadgeShowCaseLangResource StandaloneDescription}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <atom:ToggleSwitch IsChecked="{Binding StandaloneSwitchChecked}" />
                <atom:CountBadge BadgeColor="#faad14"
                                 Count="{Binding StandaloneBadgeCount1}"
                                 IsZeroVisible="True" />
                <atom:CountBadge Count="{Binding StandaloneBadgeCount2}" />
                <atom:CountBadge BadgeColor="#52c41a" Count="{Binding StandaloneBadgeCount3}" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:BadgeShowCaseLangResource DynamicTitle}" Description="{gallery:BadgeShowCaseLangResource DynamicDescription}">
            <StackPanel Orientation="Vertical" Spacing="20">
                <StackPanel Orientation="Horizontal" Spacing="20">
                    <atom:CountBadge Count="{Binding DynamicBadgeCount}" OverflowCount="99">
                        <Border Width="40"
                                Height="40"
                                Background="rgb(191,191,191)"
                                CornerRadius="8" />
                    </atom:CountBadge>
                    <StackPanel VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="10">
                        <atom:Button Command="{Binding AddDynamicBadgeCount}" SizeType="Small" Content="{gallery:BadgeShowCaseLangResource P2ContentAdd}" />
                        <atom:Button Command="{Binding SubDynamicBadgeCount}" SizeType="Small" Content="{gallery:BadgeShowCaseLangResource P2ContentSub}" />
                        <atom:Button Command="{Binding RandomDynamicBadgeCount}" SizeType="Small" Content="{gallery:BadgeShowCaseLangResource P2ContentRandom}" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="20">
                    <atom:CountBadge BadgeIsVisible="{Binding DynamicDotBadgeVisible}" Count="9">
                        <Border Width="40"
                                Height="40"
                                Background="rgb(191,191,191)"
                                CornerRadius="8" />
                    </atom:CountBadge>
                    <atom:DotBadge BadgeIsVisible="{Binding DynamicDotBadgeVisible}">
                        <Border Width="40"
                                Height="40"
                                Background="rgb(191,191,191)"
                                CornerRadius="8" />
                    </atom:DotBadge>
                    <atom:ToggleSwitch VerticalAlignment="Center"
                                       IsChecked="{Binding DynamicDotBadgeVisible, Mode=TwoWay}" />
                </StackPanel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:BadgeShowCaseLangResource RedBadgeTitle}"
                              Description="{gallery:BadgeShowCaseLangResource RedBadgeDescription}">
            <StackPanel Orientation="Vertical" Spacing="20">
                <StackPanel Orientation="Horizontal">
                    <atom:DotBadge Offset="-7,8">
                        <atom:Button ButtonType="Link" Icon="{antdicons:AntDesignIconProvider Kind=NotificationOutlined}" />
                    </atom:DotBadge>
                    <atom:DotBadge Offset="-14,12">
                        <atom:Button ButtonType="Link" Content="{gallery:BadgeShowCaseLangResource P2ContentLinkSomething}" />
                    </atom:DotBadge>
                    <atom:Button ButtonType="Link" Content="{gallery:BadgeShowCaseLangResource P2ContentLinkSomething}" />
                </StackPanel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:BadgeShowCaseLangResource StatusTitle}" Description="{gallery:BadgeShowCaseLangResource StatusDescription}">
            <StackPanel Orientation="Vertical" Spacing="20">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <atom:DotBadge Status="Success" />
                    <atom:DotBadge Status="Error" />
                    <atom:DotBadge Status="Default" />
                    <atom:DotBadge Status="Processing" />
                    <atom:DotBadge Status="Warning" />
                </StackPanel>
                <StackPanel Orientation="Vertical" Spacing="10">
                    <atom:DotBadge Status="Success" Text="{gallery:BadgeShowCaseLangResource P2TextSuccess}" />
                    <atom:DotBadge Status="Error" Text="{gallery:BadgeShowCaseLangResource P2TextError}" />
                    <atom:DotBadge Status="Default" Text="{gallery:BadgeShowCaseLangResource P2TextDefault}" />
                    <atom:DotBadge Status="Processing" Text="{gallery:BadgeShowCaseLangResource P2TextProcessing}" />
                    <atom:DotBadge Status="Warning" Text="{gallery:BadgeShowCaseLangResource P2TextWarning}" />
                </StackPanel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:BadgeShowCaseLangResource RibbonTitle}" Description="{gallery:BadgeShowCaseLangResource RibbonDescription}">
            <StackPanel Margin="20,0,20,0"
                        Orientation="Vertical"
                        Spacing="20">
                <atom:RibbonBadge Text="{gallery:BadgeShowCaseLangResource P2TextPolishExperience}">
                    <Border
                        Padding="10,0,10,0"
                        BorderBrush="#d9d9d9"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel Orientation="Vertical">
                            <atom:TextBlock Height="38"
                                            FontWeight="Bold"
                                            LineHeight="38" Text="{gallery:BadgeShowCaseLangResource P2TextPushesOpenTheWindow}" />
                            <atom:Separator LineColor="#d9d9d9" Orientation="Horizontal" />
                            <atom:TextBlock Margin="0,10,0,0" Text="{gallery:BadgeShowCaseLangResource P2TextAndRaisesTheSpyglass}" />
                        </StackPanel>
                    </Border>
                </atom:RibbonBadge>

                <atom:RibbonBadge RibbonColor="Pink" Text="{gallery:BadgeShowCaseLangResource P2TextJiachenPlan}">
                    <Border
                        Padding="10,0,10,0"
                        BorderBrush="#d9d9d9"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Height="38"
                                       FontWeight="Bold"
                                       LineHeight="38" Text="{gallery:BadgeShowCaseLangResource P2TextPushesOpenTheWindow}" />
                            <atom:Separator LineColor="#d9d9d9" Orientation="Horizontal" />
                            <TextBlock Margin="0,10,0,0" Text="{gallery:BadgeShowCaseLangResource P2TextAndRaisesTheSpyglass}" />
                        </StackPanel>
                    </Border>
                </atom:RibbonBadge>

                <atom:RibbonBadge RibbonColor="Cyan" Text="{gallery:BadgeShowCaseLangResource P2TextAvaloniaExcellent}">
                    <Border
                        Padding="10,0,10,0"
                        BorderBrush="#d9d9d9"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Height="38"
                                       FontWeight="Bold"
                                       LineHeight="38" Text="{gallery:BadgeShowCaseLangResource P2TextPushesOpenTheWindow}" />
                            <atom:Separator LineColor="#d9d9d9" Orientation="Horizontal" />
                            <TextBlock Margin="0,10,0,0" Text="{gallery:BadgeShowCaseLangResource P2TextAndRaisesTheSpyglass}" />
                        </StackPanel>
                    </Border>
                </atom:RibbonBadge>

                <atom:RibbonBadge RibbonColor="Green" Text="{gallery:BadgeShowCaseLangResource P2TextHippies}">
                    <Border
                        Padding="10,0,10,0"
                        BorderBrush="#d9d9d9"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Height="38"
                                       FontWeight="Bold"
                                       LineHeight="38" Text="{gallery:BadgeShowCaseLangResource P2TextPushesOpenTheWindow}" />
                            <atom:Separator LineColor="#d9d9d9" Orientation="Horizontal" />
                            <TextBlock Margin="0,10,0,0" Text="{gallery:BadgeShowCaseLangResource P2TextAndRaisesTheSpyglass}" />
                        </StackPanel>
                    </Border>
                </atom:RibbonBadge>

                <atom:RibbonBadge Placement="Start"
                                  RibbonColor="purple"
                                  Text="{gallery:BadgeShowCaseLangResource P2TextHippies}">
                    <Border
                        Padding="10,0,10,0"
                        BorderBrush="#d9d9d9"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Height="38"
                                       FontWeight="Bold"
                                       LineHeight="38" Text="{gallery:BadgeShowCaseLangResource P2TextPushesOpenTheWindow}" />
                            <atom:Separator LineColor="#d9d9d9" Orientation="Horizontal" />
                            <TextBlock Margin="0,10,0,0" Text="{gallery:BadgeShowCaseLangResource P2TextAndRaisesTheSpyglass}" />
                        </StackPanel>
                    </Border>
                </atom:RibbonBadge>

                <atom:RibbonBadge Placement="Start"
                                  RibbonColor="volcano"
                                  Text="{gallery:BadgeShowCaseLangResource P2TextHippies}">
                    <Border
                        Padding="10,0,10,0"
                        BorderBrush="#d9d9d9"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Height="38"
                                       FontWeight="Bold"
                                       LineHeight="38" Text="{gallery:BadgeShowCaseLangResource P2TextPushesOpenTheWindow}" />
                            <atom:Separator LineColor="#d9d9d9" Orientation="Horizontal" />
                            <TextBlock Margin="0,10,0,0" Text="{gallery:BadgeShowCaseLangResource P2TextAndRaisesTheSpyglass}" />
                        </StackPanel>
                    </Border>
                </atom:RibbonBadge>

                <atom:RibbonBadge Placement="Start"
                                  RibbonColor="magenta"
                                  Text="{gallery:BadgeShowCaseLangResource P2TextHippies}">
                    <Border
                        Padding="10,0,10,0"
                        BorderBrush="#d9d9d9"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Height="38"
                                       FontWeight="Bold"
                                       LineHeight="38" Text="{gallery:BadgeShowCaseLangResource P2TextPushesOpenTheWindow}" />
                            <atom:Separator LineColor="#d9d9d9" Orientation="Horizontal" />
                            <TextBlock Margin="0,10,0,0" Text="{gallery:BadgeShowCaseLangResource P2TextAndRaisesTheSpyglass}" />
                        </StackPanel>
                    </Border>
                </atom:RibbonBadge>

            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:BadgeShowCaseLangResource ColorfulBadgeTitle}"
                              Description="{gallery:BadgeShowCaseLangResource ColorfulBadgeDescription}">
            <StackPanel Orientation="Vertical" Spacing="20">
                <atom:Separator Title="{gallery:BadgeShowCaseLangResource P2TitlePresets}"
                                FontWeight="SemiBold"
                                TitlePosition="Left" />
                <StackPanel Orientation="Vertical" Spacing="10">
                    <atom:DotBadge DotColor="Pink" Text="{gallery:BadgeShowCaseLangResource P2TextPink}" />
                    <atom:DotBadge DotColor="Red" Text="{gallery:BadgeShowCaseLangResource P2TextRed}" />
                    <atom:DotBadge DotColor="Yellow" Text="{gallery:BadgeShowCaseLangResource P2TextYellow}" />
                    <atom:DotBadge DotColor="Orange" Text="{gallery:BadgeShowCaseLangResource P2TextOrange}" />
                    <atom:DotBadge DotColor="Cyan" Text="{gallery:BadgeShowCaseLangResource P2TextCyan}" />
                    <atom:DotBadge DotColor="Green" Text="{gallery:BadgeShowCaseLangResource P2TextGreen}" />
                    <atom:DotBadge DotColor="Blue" Text="{gallery:BadgeShowCaseLangResource P2TextBlue}" />
                    <atom:DotBadge DotColor="Purple" Text="{gallery:BadgeShowCaseLangResource P2TextPurple}" />
                    <atom:DotBadge DotColor="GeekBlue" Text="{gallery:BadgeShowCaseLangResource P2TextGeekblue}" />
                    <atom:DotBadge DotColor="Magenta" Text="{gallery:BadgeShowCaseLangResource P2TextMagenta}" />
                    <atom:DotBadge DotColor="Volcano" Text="{gallery:BadgeShowCaseLangResource P2TextVolcano}" />
                    <atom:DotBadge DotColor="Gold" Text="{gallery:BadgeShowCaseLangResource P2TextGold}" />
                    <atom:DotBadge DotColor="Lime" Text="{gallery:BadgeShowCaseLangResource P2TextLime}" />
                </StackPanel>
                <atom:Separator Title="{gallery:BadgeShowCaseLangResource P2TitleCustom}"
                                FontWeight="SemiBold"
                                TitlePosition="Left" />
                <StackPanel Orientation="Vertical" Spacing="10">
                    <atom:DotBadge DotColor="#f50" Text="#f50" />
                    <atom:DotBadge DotColor="rgb(45, 183, 245)" Text="{gallery:BadgeShowCaseLangResource P2TextRgbN45N183N245}" />
                    <atom:DotBadge DotColor="hsl(102, 53%, 61%)" Text="{gallery:BadgeShowCaseLangResource P2TextHslN102N53N61}" />
                    <atom:DotBadge DotColor="rgb(15, 141, 230)" Text="{gallery:BadgeShowCaseLangResource P2TextRgbN15N141N230}" />
                </StackPanel>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
