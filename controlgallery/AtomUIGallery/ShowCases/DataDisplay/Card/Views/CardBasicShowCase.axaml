<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Card.CardBasicShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.Card"
             x:DataType="vm:CardViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem Title="{gallery:CardShowCaseLangResource BasicTitle}"
                              Description="{gallery:CardShowCaseLangResource BasicDescription}"
                              IsOccupyEntireRow="True">
            <WrapPanel ItemSpacing="20" LineSpacing="20">
                <atom:Card Header="{gallery:CardShowCaseLangResource P2HeaderLargeSizeCard}" SizeType="Large" Width="300">
                    <atom:Card.Extra>
                        <atom:HyperLinkButton Content="{gallery:CardShowCaseLangResource P2ContentMore}" />
                    </atom:Card.Extra>
                    <StackPanel Orientation="Vertical" Spacing="3">
                        <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                        <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                        <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                    </StackPanel>
                </atom:Card>

                <atom:Card Header="{gallery:CardShowCaseLangResource P2HeaderDefaultSizeCard}" SizeType="Middle" Width="300">
                    <atom:Card.Extra>
                        <atom:HyperLinkButton Content="{gallery:CardShowCaseLangResource P2ContentMore}" />
                    </atom:Card.Extra>
                    <StackPanel Orientation="Vertical" Spacing="3">
                        <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                        <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                        <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                    </StackPanel>
                </atom:Card>

                <atom:Card Header="{gallery:CardShowCaseLangResource P2HeaderSmallSizeCard}" SizeType="Small" Width="300">
                    <atom:Card.Extra>
                        <atom:HyperLinkButton Content="{gallery:CardShowCaseLangResource P2ContentMore}" />
                    </atom:Card.Extra>
                    <StackPanel Orientation="Vertical" Spacing="3">
                        <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                        <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                        <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                    </StackPanel>
                </atom:Card>
            </WrapPanel>

        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:CardShowCaseLangResource NoBorderTitle}"
                              Description="{gallery:CardShowCaseLangResource NoBorderDescription}"
                              IsOccupyEntireRow="True">
            <Border Padding="20" Background="{Binding BorderlessFrameBg}">
                <atom:Card Header="{gallery:CardShowCaseLangResource P2HeaderCardTitle}" Width="300" StyleVariant="Borderless" HorizontalAlignment="Left">
                    <atom:Card.Extra>
                        <atom:HyperLinkButton Content="{gallery:CardShowCaseLangResource P2ContentMore}" />
                    </atom:Card.Extra>
                    <StackPanel Orientation="Vertical" Spacing="3">
                        <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                        <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                        <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                    </StackPanel>
                </atom:Card>
            </Border>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:CardShowCaseLangResource SimpleCardTitle}"
                              Description="{gallery:CardShowCaseLangResource SimpleCardDescription}"
                              IsOccupyEntireRow="True">
            <atom:Card Width="300" HorizontalAlignment="Left">
                <StackPanel Orientation="Vertical" Spacing="3">
                    <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                    <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                    <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                </StackPanel>
            </atom:Card>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:CardShowCaseLangResource CustomizedContentTitle}"
                              Description="{gallery:CardShowCaseLangResource CustomizedContentDescription}"
                              IsOccupyEntireRow="True">
            <atom:Card Width="240" IsHoverable="True" HorizontalAlignment="Left">
                <atom:Card.Cover>
                    <Image Source="/Assets/CardShowCase/Cover1.png" />
                </atom:Card.Cover>
                <atom:CardMetaContent Header="{gallery:CardShowCaseLangResource P2HeaderEuropeStreetBeat}"
                                      Content="www.instagram.com" />
            </atom:Card>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
