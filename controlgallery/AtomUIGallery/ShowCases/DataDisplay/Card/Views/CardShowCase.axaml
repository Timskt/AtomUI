<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Card.CardShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.Card"
             x:DataType="vm:CardViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem Title="{gallery:CardShowCaseLangResource BasicTitle}"
                              Description="{gallery:CardShowCaseLangResource BasicDescription}"
                              IsOccupyEntireRow="True">
            <WrapPanel ItemSpacing="20" LineSpacing="20">
                <atom:Card Header="{gallery:CardShowCaseLangResource P2HeaderLargeSizeCard}" SizeType="Large" Width="300">
                    <atom:Card.Extra>
                        <atom:HyperLinkButton Content="{gallery:CardShowCaseLangResource P2ContentMore}" />
                    </atom:Card.Extra>
                    <StackPanel Orientation="Vertical" Spacing="3">
                        <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                        <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                        <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                    </StackPanel>
                </atom:Card>

                <atom:Card Header="{gallery:CardShowCaseLangResource P2HeaderDefaultSizeCard}" SizeType="Middle" Width="300">
                    <atom:Card.Extra>
                        <atom:HyperLinkButton Content="{gallery:CardShowCaseLangResource P2ContentMore}" />
                    </atom:Card.Extra>
                    <StackPanel Orientation="Vertical" Spacing="3">
                        <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                        <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                        <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                    </StackPanel>
                </atom:Card>

                <atom:Card Header="{gallery:CardShowCaseLangResource P2HeaderSmallSizeCard}" SizeType="Small" Width="300">
                    <atom:Card.Extra>
                        <atom:HyperLinkButton Content="{gallery:CardShowCaseLangResource P2ContentMore}" />
                    </atom:Card.Extra>
                    <StackPanel Orientation="Vertical" Spacing="3">
                        <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                        <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                        <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                    </StackPanel>
                </atom:Card>
            </WrapPanel>

        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:CardShowCaseLangResource NoBorderTitle}"
                              Description="{gallery:CardShowCaseLangResource NoBorderDescription}"
                              IsOccupyEntireRow="True">
            <Border Padding="20" Background="{Binding BorderlessFrameBg}">
                <atom:Card Header="{gallery:CardShowCaseLangResource P2HeaderCardTitle}" Width="300" StyleVariant="Borderless" HorizontalAlignment="Left">
                    <atom:Card.Extra>
                        <atom:HyperLinkButton Content="{gallery:CardShowCaseLangResource P2ContentMore}" />
                    </atom:Card.Extra>
                    <StackPanel Orientation="Vertical" Spacing="3">
                        <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                        <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                        <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                    </StackPanel>
                </atom:Card>
            </Border>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:CardShowCaseLangResource SimpleCardTitle}"
                              Description="{gallery:CardShowCaseLangResource SimpleCardDescription}"
                              IsOccupyEntireRow="True">
            <atom:Card Width="300" HorizontalAlignment="Left">
                <StackPanel Orientation="Vertical" Spacing="3">
                    <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                    <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                    <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                </StackPanel>
            </atom:Card>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:CardShowCaseLangResource CustomizedContentTitle}"
                              Description="{gallery:CardShowCaseLangResource CustomizedContentDescription}"
                              IsOccupyEntireRow="True">
            <atom:Card Width="240" IsHoverable="True" HorizontalAlignment="Left">
                <atom:Card.Cover>
                    <Image Source="/Assets/CardShowCase/Cover1.png" />
                </atom:Card.Cover>
                <atom:CardMetaContent Header="{gallery:CardShowCaseLangResource P2HeaderEuropeStreetBeat}"
                                      Content="www.instagram.com" />
            </atom:Card>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:CardShowCaseLangResource CardInColumnTitle}"
                              Description="{gallery:CardShowCaseLangResource CardInColumnDescription}"
                              IsOccupyEntireRow="True">
            <Border Padding="20" Background="{Binding BorderlessFrameBg}">
                <Grid RowDefinitions="*" ColumnDefinitions="*, *, *" ColumnSpacing="20">
                    <atom:Card Header="{gallery:CardShowCaseLangResource P2HeaderCardTitle}" StyleVariant="Borderless" Grid.Row="0" Grid.Column="0"
                               HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Vertical" Spacing="3">
                            <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                            <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                            <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                        </StackPanel>
                    </atom:Card>
                    <atom:Card Header="{gallery:CardShowCaseLangResource P2HeaderCardTitle}" StyleVariant="Borderless" Grid.Row="0" Grid.Column="1"
                               HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Vertical" Spacing="3">
                            <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                            <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                            <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                        </StackPanel>
                    </atom:Card>
                    <atom:Card Header="{gallery:CardShowCaseLangResource P2HeaderCardTitle}" StyleVariant="Borderless" Grid.Row="0" Grid.Column="2"
                               HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Vertical" Spacing="3">
                            <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                            <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                            <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                        </StackPanel>
                    </atom:Card>
                </Grid>
            </Border>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:CardShowCaseLangResource LoadingCardTitle}"
                              Description="{gallery:CardShowCaseLangResource LoadingCardDescription}"
                              IsOccupyEntireRow="True">
            <StackPanel Orientation="Vertical" Spacing="20">
                <atom:ToggleSwitch IsChecked="{Binding IsLoading, Mode=TwoWay}" />
                <atom:Card MinWidth="300" IsLoading="{Binding IsLoading}" HorizontalAlignment="Left">
                    <atom:CardMetaContent Header="{gallery:CardShowCaseLangResource P2HeaderCardTitle}">
                        <atom:CardMetaContent.Avatar>
                            <atom:Avatar Src="avares://AtomUIGallery/Assets/AvatarShowCase/PeopleAvatar1.svg" />
                        </atom:CardMetaContent.Avatar>
                        <StackPanel Orientation="Vertical" Spacing="3">
                            <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextThisIsTheDescription}" />
                            <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextThisIsTheDescription}" />
                        </StackPanel>
                    </atom:CardMetaContent>
                    <atom:Card.Actions>
                        <atom:CardActionButton Icon="{antdicons:AntDesignIconProvider Kind=EditOutlined}" />
                        <atom:CardActionButton Icon="{antdicons:AntDesignIconProvider Kind=SettingOutlined}" />
                        <atom:CardActionButton Icon="{antdicons:AntDesignIconProvider Kind=EllipsisOutlined}" />
                    </atom:Card.Actions>
                </atom:Card>

                <atom:Card MinWidth="300" IsLoading="{Binding IsLoading}" HorizontalAlignment="Left">
                    <atom:CardMetaContent Header="{gallery:CardShowCaseLangResource P2HeaderCardTitle}">
                        <atom:CardMetaContent.Avatar>
                            <atom:Avatar Src="avares://AtomUIGallery/Assets/AvatarShowCase/PeopleAvatar2.svg" />
                        </atom:CardMetaContent.Avatar>
                        <StackPanel Orientation="Vertical" Spacing="3">
                            <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextThisIsTheDescription}" />
                            <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextThisIsTheDescription}" />
                        </StackPanel>
                    </atom:CardMetaContent>
                    <atom:Card.Actions>
                        <atom:CardActionButton Icon="{antdicons:AntDesignIconProvider Kind=EditOutlined}" />
                        <atom:CardActionButton Icon="{antdicons:AntDesignIconProvider Kind=SettingOutlined}" />
                        <atom:CardActionButton Icon="{antdicons:AntDesignIconProvider Kind=EllipsisOutlined}" />
                    </atom:Card.Actions>
                </atom:Card>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:CardShowCaseLangResource GridCardTitle}"
                              Description="{gallery:CardShowCaseLangResource GridCardDescription}"
                              IsOccupyEntireRow="True">
            <atom:Card HorizontalAlignment="Stretch" Header="{gallery:CardShowCaseLangResource P2HeaderCardTitle2}" SizeType="Large">
                <atom:CardGridContent ColumnDefinitions="*, *, *, *"
                                      RowDefinitions="Auto, Auto">
                    <atom:CardGridItem Row="0" Column="0" Content="{gallery:CardShowCaseLangResource P2ContentContent}" />
                    <atom:CardGridItem Row="0" Column="1" IsHoverable="False" Content="{gallery:CardShowCaseLangResource P2ContentContent}" />
                    <atom:CardGridItem Row="0" Column="2" Content="{gallery:CardShowCaseLangResource P2ContentContent}" />
                    <atom:CardGridItem Row="0" Column="3" Content="{gallery:CardShowCaseLangResource P2ContentContent}" />
                    <atom:CardGridItem Row="1" Column="0" Content="{gallery:CardShowCaseLangResource P2ContentContent}" />
                    <atom:CardGridItem Row="1" Column="1" Content="{gallery:CardShowCaseLangResource P2ContentContent}" />
                    <atom:CardGridItem Row="1" Column="2" Content="{gallery:CardShowCaseLangResource P2ContentContent}" />
                </atom:CardGridContent>
            </atom:Card>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:CardShowCaseLangResource InnerCardTitle}"
                              Description="{gallery:CardShowCaseLangResource InnerCardDescription}"
                              IsOccupyEntireRow="True">
            <atom:Card Header="{gallery:CardShowCaseLangResource P2HeaderCardTitle}" HorizontalAlignment="Stretch" SizeType="Large">
                <StackPanel Orientation="Vertical" Spacing="20">
                    <atom:Card Header="{gallery:CardShowCaseLangResource P2HeaderCardTitle}" HorizontalAlignment="Stretch" IsInnerMode="True">
                        <atom:Card.Extra>
                            <atom:HyperLinkButton Content="{gallery:CardShowCaseLangResource P2ContentMore}" />
                        </atom:Card.Extra>
                        <StackPanel Orientation="Vertical" Spacing="3">
                            <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                            <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                            <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                        </StackPanel>
                    </atom:Card>

                    <atom:Card Header="{gallery:CardShowCaseLangResource P2HeaderCardTitle}" HorizontalAlignment="Stretch" IsInnerMode="True">
                        <atom:Card.Extra>
                            <atom:HyperLinkButton Content="{gallery:CardShowCaseLangResource P2ContentMore}" />
                        </atom:Card.Extra>
                        <StackPanel Orientation="Vertical" Spacing="3">
                            <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                            <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                            <atom:TextBlock Text="{gallery:CardShowCaseLangResource P2TextCardContent}" />
                        </StackPanel>
                    </atom:Card>
                </StackPanel>
            </atom:Card>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:CardShowCaseLangResource WithTabsTitle}"
                              Description="{gallery:CardShowCaseLangResource WithTabsDescription}"
                              IsOccupyEntireRow="True">
            <StackPanel Orientation="Vertical" Spacing="20">
                <atom:Card Header="{gallery:CardShowCaseLangResource P2HeaderCardTitle}" HorizontalAlignment="Stretch" SizeType="Large">
                    <atom:Card.Extra>
                        <atom:HyperLinkButton Content="{gallery:CardShowCaseLangResource P2ContentMore}" />
                    </atom:Card.Extra>
                    <atom:CardTabsContent>
                        <atom:TabItem Header="{gallery:CardShowCaseLangResource P2HeaderTab1}" Content="{gallery:CardShowCaseLangResource P2ContentContent1}" />
                        <atom:TabItem Header="{gallery:CardShowCaseLangResource P2HeaderTab2}" Content="{gallery:CardShowCaseLangResource P2ContentContent2}" />
                    </atom:CardTabsContent>
                </atom:Card>

                <atom:Card HorizontalAlignment="Stretch">
                    <atom:CardTabsContent>
                        <atom:CardTabsContent.TabBarExtraContent>
                            <atom:HyperLinkButton Content="{gallery:CardShowCaseLangResource P2ContentMore}" />
                        </atom:CardTabsContent.TabBarExtraContent>
                        <atom:TabItem Header="{gallery:CardShowCaseLangResource P2HeaderArticle}" Content="{gallery:CardShowCaseLangResource P2ContentArticleContent}" />
                        <atom:TabItem Header="{gallery:CardShowCaseLangResource P2HeaderApp}" Content="{gallery:CardShowCaseLangResource P2ContentAppContent}" />
                        <atom:TabItem Header="{gallery:CardShowCaseLangResource P2HeaderProject}" Content="{gallery:CardShowCaseLangResource P2ContentProjectContent}" />
                    </atom:CardTabsContent>
                </atom:Card>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:CardShowCaseLangResource MoreContentConfigurationTitle}"
                              Description="{gallery:CardShowCaseLangResource MoreContentConfigurationDescription}"
                              IsOccupyEntireRow="True">
            <atom:Card Width="300" HorizontalAlignment="Left">
                <atom:Card.Cover>
                    <Image Source="/Assets/CardShowCase/Cover2.png" />
                </atom:Card.Cover>

                <atom:CardMetaContent Header="{gallery:CardShowCaseLangResource P2HeaderCardTitle}"
                                      Content="{gallery:CardShowCaseLangResource P2ContentThisIsTheDescription}">
                    <atom:CardMetaContent.Avatar>
                        <atom:Avatar Src="avares://AtomUIGallery/Assets/AvatarShowCase/PeopleAvatar1.svg" />
                    </atom:CardMetaContent.Avatar>
                </atom:CardMetaContent>
                <atom:Card.Actions>
                    <atom:CardActionButton Icon="{antdicons:AntDesignIconProvider Kind=EditOutlined}" />
                    <atom:CardActionButton Icon="{antdicons:AntDesignIconProvider Kind=SettingOutlined}" />
                    <atom:CardActionButton Icon="{antdicons:AntDesignIconProvider Kind=EllipsisOutlined}" />
                </atom:Card.Actions>
            </atom:Card>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
