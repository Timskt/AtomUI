<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Card.CardShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.Card"
             x:DataType="vm:CardViewModel">
    <atom:TabControl Name="ScenarioTabs"
                     SizeType="Large"
                     SelectedIndex="0">
        <atom:TabItem Header="{gallery:CardShowCaseLangResource ScenarioBasic}" Tag="Basic" />
        <atom:TabItem Header="{gallery:CardShowCaseLangResource ScenarioLayout}" Tag="Layout" />
        <atom:TabItem Header="{gallery:CardShowCaseLangResource ScenarioAdvanced}" Tag="Advanced" />
    </atom:TabControl>
</UserControl>
