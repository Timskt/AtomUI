<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Collapse.CollapseShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.Collapse"
             x:DataType="vm:CollapseViewModel">
    <atom:TabControl Name="ScenarioTabs"
                     SizeType="Large"
                     SelectedIndex="0">
        <atom:TabItem Header="{gallery:CollapseShowCaseLangResource ScenarioBasic}" Tag="Basic" />
        <atom:TabItem Header="{gallery:CollapseShowCaseLangResource ScenarioAppearance}" Tag="Appearance" />
        <atom:TabItem Header="{gallery:CollapseShowCaseLangResource ScenarioBehavior}" Tag="Behavior" />
    </atom:TabControl>
</UserControl>
