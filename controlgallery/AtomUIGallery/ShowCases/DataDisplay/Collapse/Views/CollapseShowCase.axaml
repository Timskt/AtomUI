<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Collapse.CollapseShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.Collapse"
             x:DataType="vm:CollapseViewModel">

    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:CollapseShowCaseLangResource CollapseTitle}"
            Description="{gallery:CollapseShowCaseLangResource CollapseDescription}">
            <atom:Collapse>
                <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN1}">
                    <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                </atom:CollapseItem>
                <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN2}">
                    <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                </atom:CollapseItem>
                <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN3}">
                    <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                </atom:CollapseItem>
            </atom:Collapse>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:CollapseShowCaseLangResource SizeTitle}"
            Description="{gallery:CollapseShowCaseLangResource SizeDescription}">
            <StackPanel Orientation="Vertical" Spacing="20" >
                <atom:Separator Title="{gallery:CollapseShowCaseLangResource P2TitleDefaultSize}" TitlePosition="Left" FontWeight="Bold" />
                <atom:Collapse SizeType="Middle">
                    <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsDefaultSizePanelHeader}">
                        <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                    </atom:CollapseItem>
                </atom:Collapse>
                <atom:Separator Title="{gallery:CollapseShowCaseLangResource P2TitleSmallSize}" TitlePosition="Left" FontWeight="Bold" />
                <atom:Collapse SizeType="Small">
                    <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsSmallSizePanelHeader}">
                        <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                    </atom:CollapseItem>
                </atom:Collapse>
                <atom:Separator Title="{gallery:CollapseShowCaseLangResource P2TitleLargeSize}" TitlePosition="Left" FontWeight="Bold" />
                <atom:Collapse SizeType="Large">
                    <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsLargeSizePanelHeader}">
                        <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                    </atom:CollapseItem>
                </atom:Collapse>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:CollapseShowCaseLangResource AccordionTitle}"
            Description="{gallery:CollapseShowCaseLangResource AccordionDescription}">
            <atom:Collapse IsAccordion="True">
                <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN1}">
                    <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                </atom:CollapseItem>
                <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN2}">
                    <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                </atom:CollapseItem>
                <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN3}">
                    <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                </atom:CollapseItem>
            </atom:Collapse>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:CollapseShowCaseLangResource NestedPanelTitle}"
            Description="{gallery:CollapseShowCaseLangResource NestedPanelDescription}" >
            <atom:Collapse>
                <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN1}">
                    <atom:Collapse>
                        <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN1}">
                            <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                        </atom:CollapseItem>
                    </atom:Collapse>
                </atom:CollapseItem>
                <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN2}">
                    <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                </atom:CollapseItem>
                <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN3}">
                    <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                </atom:CollapseItem>
            </atom:Collapse>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:CollapseShowCaseLangResource BorderlessTitle}"
            Description="{gallery:CollapseShowCaseLangResource BorderlessDescription}" >
            <atom:Collapse IsBorderless="True">
                <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN1}">
                    <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                </atom:CollapseItem>
                <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN2}">
                    <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                </atom:CollapseItem>
                <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN3}">
                    <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                </atom:CollapseItem>
            </atom:Collapse>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:CollapseShowCaseLangResource NoArrowTitle}"
            Description="{gallery:CollapseShowCaseLangResource NoArrowDescription}"
            >
            <atom:Collapse>
                <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN1}">
                    <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                </atom:CollapseItem>
                <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN2}" IsShowExpandIcon="False">
                    <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                </atom:CollapseItem>
            </atom:Collapse>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:CollapseShowCaseLangResource ExpandIconLocationTitle}"
            Description="{gallery:CollapseShowCaseLangResource ExpandIconLocationDescription}" >
            <StackPanel Orientation="Vertical" Spacing="20">
                <atom:Collapse ExpandIconPosition="{Binding CollapseExpandIconPosition}">
                    <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN1}"
                                       AddOnContent="{antdicons:AntDesignIconProvider Kind=SettingOutlined}">
                        <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                    </atom:CollapseItem>
                    <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN2}"
                                       AddOnContent="{antdicons:AntDesignIconProvider Kind=SettingOutlined}">
                        <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                    </atom:CollapseItem>
                    <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN3}"
                                       AddOnContent="{antdicons:AntDesignIconProvider Kind=SettingOutlined}">
                        <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                    </atom:CollapseItem>
                </atom:Collapse>

                <StackPanel Orientation="Horizontal" Spacing="5">
                    <atom:TextBlock VerticalAlignment="Center" Text="{gallery:CollapseShowCaseLangResource P2TextExpandIconPosition}" />
                    <atom:OptionButtonGroup ButtonStyle="Outline" Name="ExpandButtonPosGroup">
                        <atom:OptionButton IsChecked="True" Content="{gallery:CollapseShowCaseLangResource P2ContentStart}" />
                        <atom:OptionButton Content="{gallery:CollapseShowCaseLangResource P2ContentEnd}" />
                    </atom:OptionButtonGroup>
                </StackPanel>
            </StackPanel>

        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:CollapseShowCaseLangResource GhostCollapseTitle}"
            Description="{gallery:CollapseShowCaseLangResource GhostCollapseDescription}" >
            <atom:Collapse IsGhostStyle="True">
                <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN1}">
                    <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                </atom:CollapseItem>
                <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN2}">
                    <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                </atom:CollapseItem>
                <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN3}">
                    <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                </atom:CollapseItem>
            </atom:Collapse>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:CollapseShowCaseLangResource CollapsibleTitle}"
            Description="{gallery:CollapseShowCaseLangResource CollapsibleDescription}" >
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Collapse>
                    <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisPanelCanOnlyBeCollapsedByClicking}">
                        <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                    </atom:CollapseItem>
                </atom:Collapse>
                <atom:Collapse TriggerType="Icon">
                    <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisPanelCanOnlyBeCollapsedByClicking2}">
                        <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                    </atom:CollapseItem>
                </atom:Collapse>

                <atom:Collapse IsEnabled="False">
                    <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisPanelCanTBeCollapsed}">
                        <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                    </atom:CollapseItem>
                </atom:Collapse>

                <atom:Collapse IsEnabled="False">
                    <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisPanelCanTBeCollapsed}" IsSelected="True">
                        <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                    </atom:CollapseItem>
                </atom:Collapse>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:CollapseShowCaseLangResource CustomPaddingTitle}"
            Description="{gallery:CollapseShowCaseLangResource CustomPaddingDescription}">
            <StackPanel Orientation="Vertical" Spacing="20">
                <atom:Collapse ItemHeaderPadding="5" ItemContentPadding="5">
                    <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN1}">
                        <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                    </atom:CollapseItem>
                    <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN2}">
                        <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                    </atom:CollapseItem>
                    <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN3}">
                        <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                    </atom:CollapseItem>
                </atom:Collapse>

                <atom:Collapse ItemHeaderPadding="0" ItemContentPadding="0" IsGhostStyle="True">
                    <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN1}">
                        <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                    </atom:CollapseItem>
                    <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN2}">
                        <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                    </atom:CollapseItem>
                    <atom:CollapseItem Header="{gallery:CollapseShowCaseLangResource P2HeaderThisIsPanelHeaderN3}">
                        <atom:TextBlock TextWrapping="Wrap" Text="{gallery:CollapseShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                    </atom:CollapseItem>
                </atom:Collapse>
            </StackPanel>
        </gallery:ShowCaseItem>

    </gallery:ShowCasePanel>
</UserControl>
