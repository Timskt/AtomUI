<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.DataGrid.DataGridBasicShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.DataGrid">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem Title="{gallery:DataGridShowCaseLangResource BasicTitle}"
                              Description="{gallery:DataGridShowCaseLangResource BasicDescription}"
                              IsOccupyEntireRow="True">
            <atom:DataGrid x:Name="BasicCaseGrid"
                           IsHideOnSinglePage="True"
                           x:DataType="vm:DataGridBaseInfo">
                <atom:DataGrid.Columns>
                    <atom:DataGridTemplateColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderName}">
                        <atom:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="vm:DataGridBaseInfo">
                                <atom:HyperLinkTextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </atom:DataGridTemplateColumn.CellTemplate>
                    </atom:DataGridTemplateColumn>
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAge}" Binding="{Binding Age}" CanUserResize="True" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAddress}" Binding="{Binding Address}" />
                    <atom:DataGridTemplateColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderTags}">
                        <atom:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="vm:DataGridBaseInfo">
                                <ItemsControl ItemsSource="{Binding Tags}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="5" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:TagInfo">
                                            <atom:Tag Text="{Binding Name}" TagColor="{Binding Color}"></atom:Tag>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </atom:DataGridTemplateColumn.CellTemplate>
                    </atom:DataGridTemplateColumn>
                    <atom:DataGridTemplateColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAction}">
                        <atom:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="15">
                                    <atom:HyperLinkTextBlock Text="{gallery:DataGridShowCaseLangResource P2TextInvite}" />
                                    <atom:HyperLinkTextBlock Text="{gallery:DataGridShowCaseLangResource P2TextModify}" />
                                    <atom:HyperLinkTextBlock Text="{gallery:DataGridShowCaseLangResource P2TextDelete}" />
                                </StackPanel>
                            </DataTemplate>
                        </atom:DataGridTemplateColumn.CellTemplate>
                    </atom:DataGridTemplateColumn>
                </atom:DataGrid.Columns>
            </atom:DataGrid>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
