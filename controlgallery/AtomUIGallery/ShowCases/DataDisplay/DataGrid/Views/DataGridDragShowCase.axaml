<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.DataGrid.DataGridDragShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.DataGrid">
    <gallery:ShowCasePanel>

        <gallery:ShowCaseItem Title="{gallery:DataGridShowCaseLangResource DragColumnSortingTitle}"
                              Description="{gallery:DataGridShowCaseLangResource DragColumnSortingDescription}"
                              IsOccupyEntireRow="True">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Separator Title="{gallery:DataGridShowCaseLangResource P2TitleNormal}" TitlePosition="Left"
                                FontWeight="Bold" />
                <atom:DataGrid x:Name="DragColumnDataGrid1"
                               CanUserReorderColumns="True"
                               x:DataType="vm:DragColumnDataType">
                    <atom:DataGrid.Columns>
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderGender}" Binding="{Binding Gender}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderEmail}" Binding="{Binding Email}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderName}" Binding="{Binding Name}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderAddress}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAge}" Binding="{Binding Age}" />
                    </atom:DataGrid.Columns>
                </atom:DataGrid>

                <atom:Separator Title="{gallery:DataGridShowCaseLangResource P2TitleManyColumns}" TitlePosition="Left" Margin="0, 20, 0, 0"
                                FontWeight="Bold" />
                <atom:DataGrid x:Name="DragColumnDataGrid2"
                               CanUserReorderColumns="True"
                               x:DataType="vm:DragColumnDataType">
                    <atom:DataGrid.Columns>
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderGender}" Binding="{Binding Gender}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderEmail}" Binding="{Binding Email}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderName}" Binding="{Binding Name}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderAddress}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderAge}" Binding="{Binding Age}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderColumn1}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderColumn2}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderColumn3}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderColumn4}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderColumn5}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderColumn6}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderColumn7}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderColumn8}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderColumn9}" Binding="{Binding Address}" />
                    </atom:DataGrid.Columns>
                </atom:DataGrid>

                <atom:Separator Title="{gallery:DataGridShowCaseLangResource P2TitleDragReorderWithFrozenColumns}" TitlePosition="Left" Margin="0, 20, 0, 0"
                                FontWeight="Bold" />
                <atom:DataGrid x:Name="DragColumnDataGrid3"
                               CanUserReorderColumns="True"
                               LeftFrozenColumnCount="2"
                               RightFrozenColumnCount="2"
                               x:DataType="vm:DragColumnDataType">
                    <atom:DataGrid.Columns>
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderGender}" Binding="{Binding Gender}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderEmail}" Binding="{Binding Email}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderName}" Binding="{Binding Name}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderAddress}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderAge}" Binding="{Binding Age}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderColumn1}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderColumn2}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderColumn3}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderColumn4}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderColumn5}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderColumn6}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderColumn7}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderColumn8}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="{gallery:DataGridShowCaseLangResource P2HeaderColumn9}" Binding="{Binding Address}" />
                    </atom:DataGrid.Columns>
                </atom:DataGrid>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:DataGridShowCaseLangResource DragSortingWithHandlerTitle}"
                              Description="{gallery:DataGridShowCaseLangResource DragSortingWithHandlerDescription}"
                              IsOccupyEntireRow="True">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Separator Title="{gallery:DataGridShowCaseLangResource P2TitleNormal}" TitlePosition="Left"
                                FontWeight="Bold" />
                <atom:DataGrid x:Name="DragRowDataGrid1"
                               CanUserReorderRows="True"
                               x:DataType="vm:DataGridBaseInfo">
                    <atom:DataGrid.Columns>
                        <atom:DataGridRowReorderColumn />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderName}" Binding="{Binding Name}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAddress}" Binding="{Binding Name}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAge}" Binding="{Binding Address}" />
                    </atom:DataGrid.Columns>
                </atom:DataGrid>

                <atom:Separator Title="{gallery:DataGridShowCaseLangResource P2TitleNormal}" TitlePosition="Left"
                                FontWeight="Bold"
                                Margin="0, 20, 0, 0" />
                <atom:DataGrid x:Name="DragRowDataGrid2"
                               CanUserReorderRows="True"
                               Height="400"
                               x:DataType="vm:DataGridBaseInfo">
                    <atom:DataGrid.Columns>
                        <atom:DataGridRowReorderColumn />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderName}" Binding="{Binding Name}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAddress}" Binding="{Binding Name}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAge}" Binding="{Binding Address}" />
                    </atom:DataGrid.Columns>
                </atom:DataGrid>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
