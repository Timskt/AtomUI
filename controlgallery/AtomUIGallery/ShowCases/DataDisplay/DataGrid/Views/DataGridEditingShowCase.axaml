<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.DataGrid.DataGridEditingShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.DataGrid">
    <gallery:ShowCasePanel>

        <gallery:ShowCaseItem Title="Custom empty and loading"
                              Description="Custom empty status and loading."
                              IsOccupyEntireRow="True">
            <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <atom:Button ButtonType="Primary" Click="HandleToggleEmptyGridItemsSource">Toggle Data</atom:Button>
                    <atom:Button ButtonType="Primary" Click="HandleToggleLoadingState">Toggle Loading</atom:Button>
                </StackPanel>
                <atom:DataGrid x:Name="CustomEmptyDataGrid"
                               CanUserReorderRows="True"
                               x:DataType="vm:DataGridBaseInfo">
                    <atom:DataGrid.Columns>
                        <atom:DataGridTextColumn Header="Name" Binding="{Binding Name}" />
                        <atom:DataGridTextColumn Header="Age" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="Address" Binding="{Binding Name}" />
                    </atom:DataGrid.Columns>
                </atom:DataGrid>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="Editable Cells"
                              Description="Table with editable cells."
                              IsOccupyEntireRow="True">
            <StackPanel Spacing="10">
                <atom:Button ButtonType="Primary" Click="HandleAddARowToCellsEditableGrid">Add a row</atom:Button>
                <atom:DataGrid x:Name="EditableCellsDataGrid"
                                       x:DataType="vm:DataGridBaseInfo">
                    <atom:DataGrid.Columns>
                        <atom:DataGridTextColumn Header="Name" Binding="{Binding Name}" />
                        <atom:DataGridNumericColumn Header="Age" Binding="{Binding Age}" FormatString="0" />
                        <atom:DataGridTextColumn Header="Address" Binding="{Binding Address}" />
                        <atom:DataGridTemplateColumn Header="Action">
                            <atom:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="15">
                                        <atom:PopupConfirm
                                            Title="Sure to delete?"
                                            Confirmed="HandleRemoveRowCellsEditableGrid"
                                            DataContext="{Binding Index, RelativeSource={RelativeSource AncestorType=atom:DataGridRow}}">
                                            <atom:HyperLinkTextBlock Text="Delete" />
                                        </atom:PopupConfirm>
                                    </StackPanel>
                                </DataTemplate>
                            </atom:DataGridTemplateColumn.CellTemplate>
                        </atom:DataGridTemplateColumn>
                    </atom:DataGrid.Columns>
                </atom:DataGrid>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
