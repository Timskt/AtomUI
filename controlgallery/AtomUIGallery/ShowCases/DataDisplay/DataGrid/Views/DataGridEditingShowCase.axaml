<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.DataGrid.DataGridEditingShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.DataGrid">
    <gallery:ShowCasePanel>

        <gallery:ShowCaseItem Title="{gallery:DataGridShowCaseLangResource CustomEmptyAndLoadingTitle}"
                              Description="{gallery:DataGridShowCaseLangResource CustomEmptyAndLoadingDescription}"
                              IsOccupyEntireRow="True">
            <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <atom:Button ButtonType="Primary" Click="HandleToggleEmptyGridItemsSource" Content="{gallery:DataGridShowCaseLangResource P2ContentToggleData}" />
                    <atom:Button ButtonType="Primary" Click="HandleToggleLoadingState" Content="{gallery:DataGridShowCaseLangResource P2ContentToggleLoading}" />
                </StackPanel>
                <atom:DataGrid x:Name="CustomEmptyDataGrid"
                               CanUserReorderRows="True"
                               x:DataType="vm:DataGridBaseInfo">
                    <atom:DataGrid.Columns>
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderName}" Binding="{Binding Name}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAge}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAddress}" Binding="{Binding Name}" />
                    </atom:DataGrid.Columns>
                </atom:DataGrid>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:DataGridShowCaseLangResource EditableCellsTitle}"
                              Description="{gallery:DataGridShowCaseLangResource EditableCellsDescription}"
                              IsOccupyEntireRow="True">
            <StackPanel Spacing="10">
                <atom:Button ButtonType="Primary" Click="HandleAddARowToCellsEditableGrid" Content="{gallery:DataGridShowCaseLangResource P2ContentAddARow}" />
                <atom:DataGrid x:Name="EditableCellsDataGrid"
                                       x:DataType="vm:DataGridBaseInfo">
                    <atom:DataGrid.Columns>
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderName}" Binding="{Binding Name}" />
                        <atom:DataGridNumericColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAge}" Binding="{Binding Age}" FormatString="0" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAddress}" Binding="{Binding Address}" />
                        <atom:DataGridTemplateColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAction}">
                            <atom:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="15">
                                        <atom:PopupConfirm
                                            Title="{gallery:DataGridShowCaseLangResource P2TitleSureToDelete}"
                                            Confirmed="HandleRemoveRowCellsEditableGrid"
                                            DataContext="{Binding Index, RelativeSource={RelativeSource AncestorType=atom:DataGridRow}}">
                                            <atom:HyperLinkTextBlock Text="{gallery:DataGridShowCaseLangResource P2TextDelete}" />
                                        </atom:PopupConfirm>
                                    </StackPanel>
                                </DataTemplate>
                            </atom:DataGridTemplateColumn.CellTemplate>
                        </atom:DataGridTemplateColumn>
                    </atom:DataGrid.Columns>
                </atom:DataGrid>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
