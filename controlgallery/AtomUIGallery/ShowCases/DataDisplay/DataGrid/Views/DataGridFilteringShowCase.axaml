<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.DataGrid.DataGridFilteringShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.DataGrid">
    <gallery:ShowCasePanel>

        <gallery:ShowCaseItem Title="Filter and sorter"
                              Description="Use filters to generate filter menu in columns, onFilter to determine filtered result, and filterMultiple to indicate whether it's multiple or single selection, filterOnClose to specify whether to trigger filter when the filter menu closes.Use defaultFilteredValue to make a column filtered by default."
                              IsOccupyEntireRow="True">
            <atom:DataGrid x:Name="FilterAndSortGrid" CanUserFilterColumns="True"
                                       x:DataType="vm:DataGridBaseInfo">
                <atom:DataGrid.Columns>
                    <atom:DataGridTemplateColumn Header="Name"
                                                 CanUserSort="True"
                                                 SupportedSortDirections="Descending"
                                                 SortMemberPath="Name"
                                                 FilterMemberPath="Name">
                        <atom:DataGridTemplateColumn.Filters>
                            <atom:DataGridFilterItem Text="Joe" Value="Joe" />
                            <atom:DataGridFilterItem Text="Jim" Value="Jim" />
                            <atom:DataGridFilterItem Text="Submenu" Value="Submenu">
                                <atom:DataGridFilterItem Text="Green" Value="Green" />
                                <atom:DataGridFilterItem Text="Black" Value="Black" />
                            </atom:DataGridFilterItem>
                        </atom:DataGridTemplateColumn.Filters>
                        <atom:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="vm:DataGridBaseInfo">
                                <atom:HyperLinkTextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </atom:DataGridTemplateColumn.CellTemplate>
                    </atom:DataGridTemplateColumn>
                    <atom:DataGridTextColumn Header="Age" Binding="{Binding Age}"
                                             SupportedSortDirections="All"
                                             CanUserSort="True">
                    </atom:DataGridTextColumn>
                    <atom:DataGridTextColumn Header="Address"
                                             Binding="{Binding Address}"

                                             CanUserSort="True"
                                             IsMultipleFilterEnabled="True"
                                             SupportedSortDirections="Ascending">
                        <atom:DataGridTextColumn.Filters>
                            <atom:DataGridFilterItem Text="London" Value="London" />
                            <atom:DataGridFilterItem Text="New York" Value="New York" />
                        </atom:DataGridTextColumn.Filters>
                    </atom:DataGridTextColumn>
                </atom:DataGrid.Columns>
            </atom:DataGrid>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="Filter in Tree"
                              Description="You can use filterMode to change default filter interface, options: menu(default) and tree."
                              IsOccupyEntireRow="True">
            <atom:DataGrid x:Name="FilterInTreeGrid" CanUserFilterColumns="True"
                                       x:DataType="vm:DataGridBaseInfo">
                <atom:DataGrid.Columns>
                    <atom:DataGridTemplateColumn Header="Name"
                                                 CanUserSort="True"
                                                 SupportedSortDirections="Descending"
                                                 SortMemberPath="Name"
                                                 FilterMode="Tree"
                                                 FilterMemberPath="Name">
                        <atom:DataGridTemplateColumn.Filters>
                            <atom:DataGridFilterItem Text="Joe" Value="Joe" />
                            <atom:DataGridFilterItem Text="Jim" Value="Jim" />
                            <atom:DataGridFilterItem Text="Submenu" Value="Submenu">
                                <atom:DataGridFilterItem Text="Green" Value="Green" />
                                <atom:DataGridFilterItem Text="Black" Value="Black" />
                            </atom:DataGridFilterItem>
                        </atom:DataGridTemplateColumn.Filters>
                        <atom:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="vm:DataGridBaseInfo">
                                <atom:HyperLinkTextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </atom:DataGridTemplateColumn.CellTemplate>
                    </atom:DataGridTemplateColumn>
                    <atom:DataGridTextColumn Header="Age" Binding="{Binding Age}"

                                             CanUserSort="True">
                    </atom:DataGridTextColumn>
                    <atom:DataGridTextColumn Header="Address"
                                             Binding="{Binding Address}"

                                             CanUserSort="True"
                                             IsMultipleFilterEnabled="True"
                                             SupportedSortDirections="Ascending">
                        <atom:DataGridTextColumn.Filters>
                            <atom:DataGridFilterItem Text="London" Value="London" />
                            <atom:DataGridFilterItem Text="New York" Value="New York" />
                        </atom:DataGridTextColumn.Filters>
                    </atom:DataGridTextColumn>
                </atom:DataGrid.Columns>
            </atom:DataGrid>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="Multiple sorter"
                              Description="column.sorter support multiple to config the priority of sort columns. Though sorter.compare to customize compare function. You can also leave it empty to use the interactive only."
                              IsOccupyEntireRow="True">
            <atom:DataGrid x:Name="MultiSorterDataGrid" CanUserFilterColumns="True"
                                       x:DataType="vm:MultiSorterDataType">
                <atom:DataGrid.Columns>
                    <atom:DataGridTextColumn Header="Name"
                                             Binding="{Binding Name}"

                                             CanUserSort="True" />
                    <atom:DataGridTextColumn Header="Chinese Score"
                                             Binding="{Binding Chinese}"

                                             CanUserSort="True" />
                    <atom:DataGridTextColumn Header="Math Score"
                                             Binding="{Binding Math}"

                                             CanUserSort="True" />
                    <atom:DataGridTextColumn Header="English Score"
                                             Binding="{Binding English}"

                                             CanUserSort="True" />
                </atom:DataGrid.Columns>
            </atom:DataGrid>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="Reset filters and sorters"
                              Description="Control filters and sorters by API."
                              IsOccupyEntireRow="True">
            <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <atom:Button ButtonType="Default" x:Name="SortAgeBtn">Sort age</atom:Button>
                    <atom:Button ButtonType="Default" x:Name="ClearFiltersBtn">Clear filters</atom:Button>
                    <atom:Button ButtonType="Default" x:Name="ClearFiltersAndSortersBtn">Clear filters and sorters</atom:Button>
                </StackPanel>
                <atom:DataGrid x:Name="ResetFilterAndSortGrid" CanUserFilterColumns="True"
                                       x:DataType="vm:DataGridBaseInfo">
                    <atom:DataGrid.Columns>
                        <atom:DataGridTextColumn Header="Name"
                                                 Binding="{Binding Name}"
                                                 CanUserSort="True"
                                                 IsMultipleFilterEnabled="True">
                            <atom:DataGridTextColumn.Filters>
                                <atom:DataGridFilterItem Text="Joe" Value="Joe" />
                                <atom:DataGridFilterItem Text="Jim" Value="Jim" />
                                <atom:DataGridFilterItem Text="Submenu" Value="Submenu">
                                    <atom:DataGridFilterItem Text="Green" Value="Green" />
                                    <atom:DataGridFilterItem Text="Black" Value="Black" />
                                </atom:DataGridFilterItem>
                            </atom:DataGridTextColumn.Filters>
                        </atom:DataGridTextColumn>
                        <atom:DataGridTextColumn Header="Age" Binding="{Binding Age}"

                                                 CanUserSort="True">
                        </atom:DataGridTextColumn>
                        <atom:DataGridTextColumn Header="Address"
                                                 Binding="{Binding Address}"

                                                 CanUserSort="True"
                                                 IsMultipleFilterEnabled="True">
                            <atom:DataGridTextColumn.Filters>
                                <atom:DataGridFilterItem Text="London" Value="London" />
                                <atom:DataGridFilterItem Text="New York" Value="New York" />
                            </atom:DataGridTextColumn.Filters>
                        </atom:DataGridTextColumn>
                    </atom:DataGrid.Columns>
                </atom:DataGrid>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
