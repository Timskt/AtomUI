<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.DataGrid.DataGridFilteringShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.DataGrid">
    <gallery:ShowCasePanel>

        <gallery:ShowCaseItem Title="{gallery:DataGridShowCaseLangResource FilterAndSorterTitle}"
                              Description="{gallery:DataGridShowCaseLangResource FilterAndSorterDescription}"
                              IsOccupyEntireRow="True">
            <atom:DataGrid x:Name="FilterAndSortGrid" CanUserFilterColumns="True"
                                       x:DataType="vm:DataGridBaseInfo">
                <atom:DataGrid.Columns>
                    <atom:DataGridTemplateColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderName}"
                                                 CanUserSort="True"
                                                 SupportedSortDirections="Descending"
                                                 SortMemberPath="Name"
                                                 FilterMemberPath="Name">
                        <atom:DataGridTemplateColumn.Filters>
                            <atom:DataGridFilterItem Text="{gallery:DataGridShowCaseLangResource P2TextJoe}" Value="Joe" />
                            <atom:DataGridFilterItem Text="{gallery:DataGridShowCaseLangResource P2TextJim}" Value="Jim" />
                            <atom:DataGridFilterItem Text="{gallery:DataGridShowCaseLangResource P2TextSubmenu}" Value="Submenu">
                                <atom:DataGridFilterItem Text="{gallery:DataGridShowCaseLangResource P2TextGreen}" Value="Green" />
                                <atom:DataGridFilterItem Text="{gallery:DataGridShowCaseLangResource P2TextBlack}" Value="Black" />
                            </atom:DataGridFilterItem>
                        </atom:DataGridTemplateColumn.Filters>
                        <atom:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="vm:DataGridBaseInfo">
                                <atom:HyperLinkTextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </atom:DataGridTemplateColumn.CellTemplate>
                    </atom:DataGridTemplateColumn>
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAge}" Binding="{Binding Age}"
                                             SupportedSortDirections="All"
                                             CanUserSort="True">
                    </atom:DataGridTextColumn>
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAddress}"
                                             Binding="{Binding Address}"

                                             CanUserSort="True"
                                             IsMultipleFilterEnabled="True"
                                             SupportedSortDirections="Ascending">
                        <atom:DataGridTextColumn.Filters>
                            <atom:DataGridFilterItem Text="{gallery:DataGridShowCaseLangResource P2TextLondon}" Value="London" />
                            <atom:DataGridFilterItem Text="{gallery:DataGridShowCaseLangResource P2TextNewYork}" Value="New York" />
                        </atom:DataGridTextColumn.Filters>
                    </atom:DataGridTextColumn>
                </atom:DataGrid.Columns>
            </atom:DataGrid>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:DataGridShowCaseLangResource FilterInTreeTitle}"
                              Description="{gallery:DataGridShowCaseLangResource FilterInTreeDescription}"
                              IsOccupyEntireRow="True">
            <atom:DataGrid x:Name="FilterInTreeGrid" CanUserFilterColumns="True"
                                       x:DataType="vm:DataGridBaseInfo">
                <atom:DataGrid.Columns>
                    <atom:DataGridTemplateColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderName}"
                                                 CanUserSort="True"
                                                 SupportedSortDirections="Descending"
                                                 SortMemberPath="Name"
                                                 FilterMode="Tree"
                                                 FilterMemberPath="Name">
                        <atom:DataGridTemplateColumn.Filters>
                            <atom:DataGridFilterItem Text="{gallery:DataGridShowCaseLangResource P2TextJoe}" Value="Joe" />
                            <atom:DataGridFilterItem Text="{gallery:DataGridShowCaseLangResource P2TextJim}" Value="Jim" />
                            <atom:DataGridFilterItem Text="{gallery:DataGridShowCaseLangResource P2TextSubmenu}" Value="Submenu">
                                <atom:DataGridFilterItem Text="{gallery:DataGridShowCaseLangResource P2TextGreen}" Value="Green" />
                                <atom:DataGridFilterItem Text="{gallery:DataGridShowCaseLangResource P2TextBlack}" Value="Black" />
                            </atom:DataGridFilterItem>
                        </atom:DataGridTemplateColumn.Filters>
                        <atom:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="vm:DataGridBaseInfo">
                                <atom:HyperLinkTextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </atom:DataGridTemplateColumn.CellTemplate>
                    </atom:DataGridTemplateColumn>
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAge}" Binding="{Binding Age}"

                                             CanUserSort="True">
                    </atom:DataGridTextColumn>
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAddress}"
                                             Binding="{Binding Address}"

                                             CanUserSort="True"
                                             IsMultipleFilterEnabled="True"
                                             SupportedSortDirections="Ascending">
                        <atom:DataGridTextColumn.Filters>
                            <atom:DataGridFilterItem Text="{gallery:DataGridShowCaseLangResource P2TextLondon}" Value="London" />
                            <atom:DataGridFilterItem Text="{gallery:DataGridShowCaseLangResource P2TextNewYork}" Value="New York" />
                        </atom:DataGridTextColumn.Filters>
                    </atom:DataGridTextColumn>
                </atom:DataGrid.Columns>
            </atom:DataGrid>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:DataGridShowCaseLangResource MultipleSorterTitle}"
                              Description="{gallery:DataGridShowCaseLangResource MultipleSorterDescription}"
                              IsOccupyEntireRow="True">
            <atom:DataGrid x:Name="MultiSorterDataGrid" CanUserFilterColumns="True"
                                       x:DataType="vm:MultiSorterDataType">
                <atom:DataGrid.Columns>
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderName}"
                                             Binding="{Binding Name}"

                                             CanUserSort="True" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderChineseScore}"
                                             Binding="{Binding Chinese}"

                                             CanUserSort="True" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderMathScore}"
                                             Binding="{Binding Math}"

                                             CanUserSort="True" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderEnglishScore}"
                                             Binding="{Binding English}"

                                             CanUserSort="True" />
                </atom:DataGrid.Columns>
            </atom:DataGrid>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:DataGridShowCaseLangResource ResetFiltersAndSortersTitle}"
                              Description="{gallery:DataGridShowCaseLangResource ResetFiltersAndSortersDescription}"
                              IsOccupyEntireRow="True">
            <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <atom:Button ButtonType="Default" x:Name="SortAgeBtn" Content="{gallery:DataGridShowCaseLangResource P2ContentSortAge}" />
                    <atom:Button ButtonType="Default" x:Name="ClearFiltersBtn" Content="{gallery:DataGridShowCaseLangResource P2ContentClearFilters}" />
                    <atom:Button ButtonType="Default" x:Name="ClearFiltersAndSortersBtn" Content="{gallery:DataGridShowCaseLangResource P2ContentClearFiltersAndSorters}" />
                </StackPanel>
                <atom:DataGrid x:Name="ResetFilterAndSortGrid" CanUserFilterColumns="True"
                                       x:DataType="vm:DataGridBaseInfo">
                    <atom:DataGrid.Columns>
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderName}"
                                                 Binding="{Binding Name}"
                                                 CanUserSort="True"
                                                 IsMultipleFilterEnabled="True">
                            <atom:DataGridTextColumn.Filters>
                                <atom:DataGridFilterItem Text="{gallery:DataGridShowCaseLangResource P2TextJoe}" Value="Joe" />
                                <atom:DataGridFilterItem Text="{gallery:DataGridShowCaseLangResource P2TextJim}" Value="Jim" />
                                <atom:DataGridFilterItem Text="{gallery:DataGridShowCaseLangResource P2TextSubmenu}" Value="Submenu">
                                    <atom:DataGridFilterItem Text="{gallery:DataGridShowCaseLangResource P2TextGreen}" Value="Green" />
                                    <atom:DataGridFilterItem Text="{gallery:DataGridShowCaseLangResource P2TextBlack}" Value="Black" />
                                </atom:DataGridFilterItem>
                            </atom:DataGridTextColumn.Filters>
                        </atom:DataGridTextColumn>
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAge}" Binding="{Binding Age}"

                                                 CanUserSort="True">
                        </atom:DataGridTextColumn>
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAddress}"
                                                 Binding="{Binding Address}"

                                                 CanUserSort="True"
                                                 IsMultipleFilterEnabled="True">
                            <atom:DataGridTextColumn.Filters>
                                <atom:DataGridFilterItem Text="{gallery:DataGridShowCaseLangResource P2TextLondon}" Value="London" />
                                <atom:DataGridFilterItem Text="{gallery:DataGridShowCaseLangResource P2TextNewYork}" Value="New York" />
                            </atom:DataGridTextColumn.Filters>
                        </atom:DataGridTextColumn>
                    </atom:DataGrid.Columns>
                </atom:DataGrid>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
