<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.DataGrid.DataGridFixedShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.DataGrid">
    <gallery:ShowCasePanel>

        <gallery:ShowCaseItem Title="{gallery:DataGridShowCaseLangResource FixedHeaderTitle}"
                              Description="{gallery:DataGridShowCaseLangResource FixedHeaderDescription}"
                              IsOccupyEntireRow="True">
            <atom:DataGrid x:Name="FixedHeaderDataGrid" Height="400"
                                       x:DataType="vm:DataGridBaseInfo">
                <atom:DataGrid.Columns>
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderName}" Binding="{Binding Name}" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAge}" Binding="{Binding Address}" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAddress}" Binding="{Binding Name}" />
                </atom:DataGrid.Columns>
            </atom:DataGrid>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:DataGridShowCaseLangResource FixedColumnsTitle}"
                              Description="{gallery:DataGridShowCaseLangResource FixedColumnsDescription}"
                              IsOccupyEntireRow="True">

            <StackPanel Orientation="Vertical" Spacing="20">
                <atom:DataGrid x:Name="FixedColumnsDataGrid1"
                               LeftFrozenColumnCount="2"
                               RightFrozenColumnCount="2"
                               HeadersVisibility="All"
                               x:DataType="vm:DataGridBaseInfo">
                    <atom:DataGrid.RowHeaderContentTemplate>
                        <DataTemplate>
                            <atom:TextBlock Text="{Binding $parent[atom:DataGridRow].LogicIndex}" />
                        </DataTemplate>
                    </atom:DataGrid.RowHeaderContentTemplate>
                    <atom:DataGrid.Columns>
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderName}" Binding="{Binding Name}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAge}" Binding="{Binding Age}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN1}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN2}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN3}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN4}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN5}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN6}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN7}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN8}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN9}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN10}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN11}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN12}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN13}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN14}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN15}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN16}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN17}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN18}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN19}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN20}" Binding="{Binding Address}" />
                        <atom:DataGridTemplateColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAction}">
                            <atom:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="15">
                                        <atom:HyperLinkTextBlock Text="{gallery:DataGridShowCaseLangResource P2TextModify}" />
                                    </StackPanel>
                                </DataTemplate>
                            </atom:DataGridTemplateColumn.CellTemplate>
                        </atom:DataGridTemplateColumn>
                    </atom:DataGrid.Columns>
                </atom:DataGrid>

                <atom:DataGrid x:Name="FixedColumnsDataGrid2"
                               LeftFrozenColumnCount="2"
                               RightFrozenColumnCount="1"
                               HeadersVisibility="All"
                               x:DataType="vm:DataGridBaseInfo">
                    <atom:DataGrid.RowHeaderContentTemplate>
                        <DataTemplate>
                            <atom:TextBlock Text="{Binding $parent[atom:DataGridRow].LogicIndex}" />
                        </DataTemplate>
                    </atom:DataGrid.RowHeaderContentTemplate>
                    <atom:DataGrid.Columns>
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderName}" Binding="{Binding Name}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAge}" Binding="{Binding Age}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN1}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN2}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN3}" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN4}" Binding="{Binding Address}" />
                        <atom:DataGridTemplateColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAction}">
                            <atom:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="15">
                                        <atom:HyperLinkTextBlock Text="{gallery:DataGridShowCaseLangResource P2TextModify}" />
                                    </StackPanel>
                                </DataTemplate>
                            </atom:DataGridTemplateColumn.CellTemplate>
                        </atom:DataGridTemplateColumn>
                    </atom:DataGrid.Columns>
                </atom:DataGrid>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:DataGridShowCaseLangResource FixedColumnsAndHeadersTitle}"
                              Description="{gallery:DataGridShowCaseLangResource FixedColumnsAndHeadersDescription}"
                              IsOccupyEntireRow="True">

            <atom:DataGrid x:Name="FixedColumnsAndHeadersDataGrid"
                           LeftFrozenColumnCount="2"
                           RightFrozenColumnCount="1"
                           HeadersVisibility="All"
                           Height="400"
                           x:DataType="vm:DataGridBaseInfo">
                <atom:DataGrid.RowHeaderContentTemplate>
                    <DataTemplate>
                        <atom:TextBlock Text="{Binding $parent[atom:DataGridRow].LogicIndex}" />
                    </DataTemplate>
                </atom:DataGrid.RowHeaderContentTemplate>
                <atom:DataGrid.Columns>
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderName}" Binding="{Binding Name}" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAge}" Binding="{Binding Age}" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN1}" Binding="{Binding Address}" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN2}" Binding="{Binding Address}" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN3}" Binding="{Binding Address}" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN4}" Binding="{Binding Address}" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN5}" Binding="{Binding Address}" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN6}" Binding="{Binding Address}" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN7}" Binding="{Binding Address}" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN8}" Binding="{Binding Address}" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN9}" Binding="{Binding Address}" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN10}" Binding="{Binding Address}" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN11}" Binding="{Binding Address}" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN12}" Binding="{Binding Address}" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN13}" Binding="{Binding Address}" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN14}" Binding="{Binding Address}" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN15}" Binding="{Binding Address}" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN16}" Binding="{Binding Address}" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN17}" Binding="{Binding Address}" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN18}" Binding="{Binding Address}" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN19}" Binding="{Binding Address}" />
                    <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderColumnN20}" Binding="{Binding Address}" />
                    <atom:DataGridTemplateColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAction}">
                        <atom:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="15">
                                    <atom:HyperLinkTextBlock Text="{gallery:DataGridShowCaseLangResource P2TextModify}" />
                                </StackPanel>
                            </DataTemplate>
                        </atom:DataGridTemplateColumn.CellTemplate>
                    </atom:DataGridTemplateColumn>
                </atom:DataGrid.Columns>
            </atom:DataGrid>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
