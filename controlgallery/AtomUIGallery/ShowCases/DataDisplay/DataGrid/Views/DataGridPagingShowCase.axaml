<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.DataGrid.DataGridPagingShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.DataGrid">
    <gallery:ShowCasePanel>

        <gallery:ShowCaseItem Title="{gallery:DataGridShowCaseLangResource BasicPagingTitle}"
                              Description="{gallery:DataGridShowCaseLangResource BasicPagingDescription}"
                              IsOccupyEntireRow="True">
            <StackPanel Spacing="20">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <atom:TextBlock Width="180" VerticalAlignment="Center" Text="{gallery:DataGridShowCaseLangResource P2TextPaginationvisibility}" />
                        <atom:CheckBox Name="ShowTopPaginationCheckBox" Content="{gallery:DataGridShowCaseLangResource P2ContentTopPagination}" />
                        <atom:CheckBox Name="ShowBottomPaginationCheckBox" IsChecked="True" Content="{gallery:DataGridShowCaseLangResource P2ContentBottomPagination}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <atom:TextBlock Width="180" VerticalAlignment="Center" Text="{gallery:DataGridShowCaseLangResource P2TextTopPaginationAlign}" />
                        <atom:OptionButtonGroup ButtonStyle="Solid" Name="TopPaginationOptionGroup">
                            <atom:OptionButton Content="{gallery:DataGridShowCaseLangResource P2ContentStart}" />
                            <atom:OptionButton Content="{gallery:DataGridShowCaseLangResource P2ContentCenter}" />
                            <atom:OptionButton IsChecked="True" Content="{gallery:DataGridShowCaseLangResource P2ContentEnd}" />
                        </atom:OptionButtonGroup>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <atom:TextBlock Width="180" VerticalAlignment="Center" Text="{gallery:DataGridShowCaseLangResource P2TextBottomPaginationAlign}" />
                        <atom:OptionButtonGroup ButtonStyle="Solid" Name="BottomPaginationOptionGroup">
                            <atom:OptionButton Content="{gallery:DataGridShowCaseLangResource P2ContentStart}" />
                            <atom:OptionButton Content="{gallery:DataGridShowCaseLangResource P2ContentCenter}" />
                            <atom:OptionButton IsChecked="True" Content="{gallery:DataGridShowCaseLangResource P2ContentEnd}" />
                        </atom:OptionButtonGroup>
                    </StackPanel>

                </StackPanel>
                <atom:DataGrid x:Name="BasicPagingCaseGrid" Height="400" PaginationVisibility="Bottom"
                               PageSize="10"
                               x:DataType="vm:DataGridBaseInfo">
                    <atom:DataGrid.Columns>
                        <atom:DataGridTemplateColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderName}">
                            <atom:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:DataGridBaseInfo">
                                    <atom:HyperLinkTextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </atom:DataGridTemplateColumn.CellTemplate>
                        </atom:DataGridTemplateColumn>
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAge}" Binding="{Binding Age}" />
                        <atom:DataGridTextColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAddress}" Binding="{Binding Address}" />
                        <atom:DataGridTemplateColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderTags}">
                            <atom:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:DataGridBaseInfo">
                                    <ItemsControl ItemsSource="{Binding Tags}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="5" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:TagInfo">
                                                <atom:Tag Text="{Binding Name}" TagColor="{Binding Color}"></atom:Tag>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DataTemplate>
                            </atom:DataGridTemplateColumn.CellTemplate>
                        </atom:DataGridTemplateColumn>
                        <atom:DataGridTemplateColumn Header="{gallery:DataGridShowCaseLangResource P2HeaderAction}">
                            <atom:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="15">
                                        <atom:HyperLinkTextBlock Text="{gallery:DataGridShowCaseLangResource P2TextInvite}" />
                                        <atom:HyperLinkTextBlock Text="{gallery:DataGridShowCaseLangResource P2TextModify}" />
                                        <atom:HyperLinkTextBlock Text="{gallery:DataGridShowCaseLangResource P2TextDelete}" />
                                    </StackPanel>
                                </DataTemplate>
                            </atom:DataGridTemplateColumn.CellTemplate>
                        </atom:DataGridTemplateColumn>
                    </atom:DataGrid.Columns>
                </atom:DataGrid>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
