<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.DataGrid.DataGridShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.DataGrid"
             x:DataType="vm:DataGridViewModel">
    <atom:TabControl Name="ScenarioTabs"
                     SizeType="Large"
                     SelectedIndex="0">
        <atom:TabItem Header="{gallery:DataGridShowCaseLangResource ScenarioBasic}" Tag="Basic" />
        <atom:TabItem Header="{gallery:DataGridShowCaseLangResource ScenarioInteraction}" Tag="Interaction" />
        <atom:TabItem Header="{gallery:DataGridShowCaseLangResource ScenarioFiltering}" Tag="Filtering" />
        <atom:TabItem Header="{gallery:DataGridShowCaseLangResource ScenarioStructure}" Tag="Structure" />
        <atom:TabItem Header="{gallery:DataGridShowCaseLangResource ScenarioFixed}" Tag="Fixed" />
        <atom:TabItem Header="{gallery:DataGridShowCaseLangResource ScenarioDrag}" Tag="Drag" />
        <atom:TabItem Header="{gallery:DataGridShowCaseLangResource ScenarioEditing}" Tag="Editing" />
        <atom:TabItem Header="{gallery:DataGridShowCaseLangResource ScenarioPaging}" Tag="Paging" />
    </atom:TabControl>
</UserControl>
