<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Expander.ExpanderBehaviorShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.Expander"
             x:DataType="vm:ExpanderViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:ExpanderShowCaseLangResource ExpandingDirectionTitle}"
            Description="{gallery:ExpanderShowCaseLangResource ExpandingDirectionDescription}">
            <DockPanel Margin="0, 0, 0, 0" Height="300">
                <StackPanel Orientation="Horizontal" Spacing="5" DockPanel.Dock="Top">
                    <atom:TextBlock VerticalAlignment="Center" Text="{gallery:ExpanderShowCaseLangResource P2TextExpandDirection}" />
                    <atom:OptionButtonGroup ButtonStyle="Outline"
                                            OptionCheckedChanged="HandleExpandDirectionOptionCheckedChanged">
                        <atom:OptionButton IsChecked="True" Content="{gallery:ExpanderShowCaseLangResource P2ContentDown}" />
                        <atom:OptionButton Content="{gallery:ExpanderShowCaseLangResource P2ContentUp}" />
                        <atom:OptionButton Content="{gallery:ExpanderShowCaseLangResource P2ContentLeft}" />
                        <atom:OptionButton Content="{gallery:ExpanderShowCaseLangResource P2ContentRight}" />
                    </atom:OptionButtonGroup>
                </StackPanel>

                <Panel Margin="0, 20, 0, 0">
                    <atom:Expander Header="{gallery:ExpanderShowCaseLangResource P2HeaderThisIsPanelHeader}"
                                   ExpandDirection="{Binding ExpandDirection}"
                                   Name="DirectionDemoExpander">
                        <atom:TextBlock TextWrapping="Wrap" Text="{gallery:ExpanderShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                    </atom:Expander>
                </Panel>
            </DockPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ExpanderShowCaseLangResource NestedPanelTitle}"
            Description="{gallery:ExpanderShowCaseLangResource NestedPanelDescription}">
            <atom:Expander Header="{gallery:ExpanderShowCaseLangResource P2HeaderThisIsPanelHeaderN1}">
                <atom:Expander Header="{gallery:ExpanderShowCaseLangResource P2HeaderThisIsNestedPanelHeader}">
                    <atom:TextBlock TextWrapping="Wrap" Text="{gallery:ExpanderShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                </atom:Expander>
            </atom:Expander>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ExpanderShowCaseLangResource NoArrowTitle}"
            Description="{gallery:ExpanderShowCaseLangResource NoArrowDescription}">
            <atom:Expander Header="{gallery:ExpanderShowCaseLangResource P2HeaderThisIsPanelHeaderN1}" IsShowExpandIcon="False">
                <atom:TextBlock TextWrapping="Wrap" Text="{gallery:ExpanderShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
            </atom:Expander>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ExpanderShowCaseLangResource ExpandIconLocationTitle}"
            Description="{gallery:ExpanderShowCaseLangResource ExpandIconLocationDescription}">
            <StackPanel Orientation="Vertical" Spacing="20">
                <atom:Expander Header="{gallery:ExpanderShowCaseLangResource P2HeaderThisIsPanelHeaderN1}"
                               AddOnContent="{antdicons:AntDesignIconProvider Kind=SettingOutlined}"
                               ExpandIconPosition="{Binding ToggleIconPosition}">
                    <atom:TextBlock TextWrapping="Wrap" Text="{gallery:ExpanderShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                </atom:Expander>

                <StackPanel Orientation="Horizontal" Spacing="5">
                    <atom:TextBlock VerticalAlignment="Center" Text="{gallery:ExpanderShowCaseLangResource P2TextExpandIconPosition}" />
                    <atom:OptionButtonGroup ButtonStyle="Outline"
                                            OptionCheckedChanged="HandleExpandButtonPosOptionCheckedChanged">
                        <atom:OptionButton IsChecked="True" Content="{gallery:ExpanderShowCaseLangResource P2ContentStart}" />
                        <atom:OptionButton Content="{gallery:ExpanderShowCaseLangResource P2ContentEnd}" />
                    </atom:OptionButtonGroup>
                </StackPanel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ExpanderShowCaseLangResource CollapsibleTitle}"
            Description="{gallery:ExpanderShowCaseLangResource CollapsibleDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Expander Header="{gallery:ExpanderShowCaseLangResource P2HeaderThisPanelCanOnlyBeCollapsedByClicking}">
                    <atom:TextBlock TextWrapping="Wrap" Text="{gallery:ExpanderShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                </atom:Expander>
                <atom:Expander TriggerType="Icon" Header="{gallery:ExpanderShowCaseLangResource P2HeaderThisPanelCanOnlyBeCollapsedByClicking2}">
                    <atom:TextBlock TextWrapping="Wrap" Text="{gallery:ExpanderShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                </atom:Expander>

                <atom:Expander IsEnabled="False" Header="{gallery:ExpanderShowCaseLangResource P2HeaderThisPanelCanTBeCollapsed}">
                    <atom:TextBlock TextWrapping="Wrap" Text="{gallery:ExpanderShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                </atom:Expander>

                <atom:Expander IsEnabled="False" Header="{gallery:ExpanderShowCaseLangResource P2HeaderThisPanelCanTBeCollapsed}" IsExpanded="True">
                    <atom:TextBlock TextWrapping="Wrap" Text="{gallery:ExpanderShowCaseLangResource P2TextADogIsATypeOfDomesticatedAnimal}" />
                </atom:Expander>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
