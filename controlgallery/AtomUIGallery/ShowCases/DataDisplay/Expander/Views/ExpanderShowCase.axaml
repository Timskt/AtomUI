<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Expander.ExpanderShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.Expander"
             x:DataType="vm:ExpanderViewModel">
    <atom:TabControl Name="ScenarioTabs"
                     SizeType="Large"
                     SelectedIndex="0">
        <atom:TabItem Header="{gallery:ExpanderShowCaseLangResource ScenarioBasic}" Tag="Basic" />
        <atom:TabItem Header="{gallery:ExpanderShowCaseLangResource ScenarioAppearance}" Tag="Appearance" />
        <atom:TabItem Header="{gallery:ExpanderShowCaseLangResource ScenarioBehavior}" Tag="Behavior" />
    </atom:TabControl>
</UserControl>
