<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.ImagePreviewer.ImagePreviewerShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:ImagePreviewerShowCaseLangResource BasicUsageTitle}"
            Description="{gallery:ImagePreviewerShowCaseLangResource BasicUsageDescription}">
            <atom:ImagePreviewer Name="BasicPreviewer" Width="200"/>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ImagePreviewerShowCaseLangResource FaultTolerantTitle}"
            Description="{gallery:ImagePreviewerShowCaseLangResource FaultTolerantDescription}">
            <atom:ImagePreviewer Name="FaultTolerantPreviewer" Width="200"/>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ImagePreviewerShowCaseLangResource PreviewFromOneImageTitle}"
            Description="{gallery:ImagePreviewerShowCaseLangResource PreviewFromOneImageDescription}">
            <atom:ImagePreviewer Name="FromOnImagePreviewer" Width="200"/>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ImagePreviewerShowCaseLangResource CustomPreviewImageTitle}"
            Description="{gallery:ImagePreviewerShowCaseLangResource CustomPreviewImageDescription}">
            <atom:ImagePreviewer Name="CustomImagePreviewer" Width="200"/>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ImagePreviewerShowCaseLangResource MultipleImagePreviewTitle}"
            Description="{gallery:ImagePreviewerShowCaseLangResource MultipleImagePreviewDescription}"
            IsOccupyEntireRow="True">
            <atom:ImageGroupPreviewer Name="MultiImagesPreviewer" CoverWidth="200" CoverHeight="200"/>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
