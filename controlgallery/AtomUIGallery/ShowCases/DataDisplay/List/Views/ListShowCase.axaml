<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AtomUIGallery.ShowCases.List"
             x:Class="AtomUIGallery.ShowCases.List.ListShowCase"
             x:DataType="vm:ListViewModel"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery">
    <gallery:ShowCasePanel>

        <gallery:ShowCaseItem
            Title="{gallery:ListShowCaseLangResource BasicUsageTitle}"
            Description="{gallery:ListShowCaseLangResource BasicUsageDescription}">
            <atom:ListView ItemsSource="{Binding ListItems}" />
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ListShowCaseLangResource SelectionTitle}"
            Description="{gallery:ListShowCaseLangResource SelectionDescription}">
            <StackPanel Spacing="20">
                <StackPanel Orientation="Horizontal" Spacing="5" DockPanel.Dock="Top">
                    <atom:TextBlock VerticalAlignment="Center">Selection Mode:</atom:TextBlock>
                    <atom:OptionButtonGroup ButtonStyle="Solid" Name="SelectionModeOptionGroup">
                        <atom:OptionButton IsChecked="True" Tag="{x:Static SelectionMode.Single}">Single</atom:OptionButton>
                        <atom:OptionButton Tag="{x:Static SelectionMode.Multiple}">Multiple</atom:OptionButton>
                        <atom:OptionButton Tag="{x:Static SelectionMode.Toggle}">Toggle</atom:OptionButton>
                    </atom:OptionButtonGroup>
                </StackPanel>
                <atom:ListView SelectionMode="{Binding SelectionMode}"
                               ItemsSource="{Binding SelectionListItems}"
                               IsShowSelectedIndicator="True" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ListShowCaseLangResource GroupTitle}"
            Description="{gallery:ListShowCaseLangResource GroupDescription}">
            <atom:ListView ItemsSource="{Binding GroupListItems}"
                           IsGroupEnabled="True"
                           Height="300" />
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ListShowCaseLangResource ItemDisabledTitle}"
            Description="{gallery:ListShowCaseLangResource ItemDisabledDescription}">
            <atom:ListView ItemsSource="{Binding ListItemsWidthDisabled}" />
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ListShowCaseLangResource EmptyTitle}"
            Description="{gallery:ListShowCaseLangResource EmptyDescription}">
            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <atom:Button Content="Add Item"
                                 Click="HandleAddEmptyItemClicked" />
                    <atom:Button Content="Remove Item"
                                 Click="HandleRemoveEmptyItemClicked" />
                </StackPanel>
                <atom:ListView
                    ItemsSource="{Binding EmptyDemoItems}"
                    IsShowEmptyIndicator="True"
                    IsGroupEnabled="False" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ListShowCaseLangResource FilterTitle}"
            Description="{gallery:ListShowCaseLangResource FilterDescription}">
            <atom:ListView Name="FilteredList"
                           ItemsSource="{Binding FilteredGroupListItems}"
                           IsGroupEnabled="False"
                           Filter="{atom:ValueFilterProvider Contains}"
                           FilterValue="a"/>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ListShowCaseLangResource OrderedTitle}"
            Description="{gallery:ListShowCaseLangResource OrderedDescription}">
            <atom:ListView Name="OrderedList"
                           ItemsSource="{Binding OrderedGroupListItems}"
                           IsGroupEnabled="True" />
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ListShowCaseLangResource SimpleListBoxTitle}"
            Description="{gallery:ListShowCaseLangResource SimpleListBoxDescription}">
            <atom:ListBox>
                <atom:ListBoxItem>Racing car sprays burning fuel into crowd.</atom:ListBoxItem>
                <atom:ListBoxItem>Japanese princess to wed commoner.</atom:ListBoxItem>
                <atom:ListBoxItem>Australian walks 100km after outback crash.</atom:ListBoxItem>
                <atom:ListBoxItem>Man charged over missing wedding girl.</atom:ListBoxItem>
                <atom:ListBoxItem>Los Angeles battles huge wildfires.</atom:ListBoxItem>
            </atom:ListBox>

        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ListShowCaseLangResource SimpleListBoxItemsSourceTitle}"
            Description="{gallery:ListShowCaseLangResource SimpleListBoxItemsSourceDescription}">
            <atom:ListBox ItemsSource="{Binding BasicListBoxItems}"
                          IsShowSelectedIndicator="True"/>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ListShowCaseLangResource SearchableTitle}"
            Description="{gallery:ListShowCaseLangResource SearchableDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:SearchEdit PlaceholderText="Search"
                                 SearchButtonClick="HandleFilterListBoxClicked"/>
                <atom:ListBox Name="SearchListBox">
                    <atom:ListBoxItem>Racing car sprays burning fuel into crowd.</atom:ListBoxItem>
                    <atom:ListBoxItem>Japanese princess to wed commoner.</atom:ListBoxItem>
                    <atom:ListBoxItem>Australian walks 100km after outback crash.</atom:ListBoxItem>
                    <atom:ListBoxItem>Man charged over missing wedding girl.</atom:ListBoxItem>
                    <atom:ListBoxItem>Los Angeles battles huge wildfires.</atom:ListBoxItem>
                </atom:ListBox>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ListShowCaseLangResource PaginationListTitle}"
            Description="{gallery:ListShowCaseLangResource PaginationListDescription}">
            <atom:ListView
                ItemsSource="{Binding PaginationListItems}"
                PaginationVisibility="Bottom"
                SelectionMode="Multiple"
                Height="400"
                PageSize="100">
                <atom:ListView.BottomPagination>
                    <atom:Pagination />
                </atom:ListView.BottomPagination>
            </atom:ListView>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
