<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AtomUIGallery.ShowCases.List"
             x:Class="AtomUIGallery.ShowCases.List.ListShowCase"
             x:DataType="vm:ListViewModel"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery">
    <atom:TabControl Name="ScenarioTabs"
                     SizeType="Large"
                     SelectedIndex="0">
        <atom:TabItem Header="{gallery:ListShowCaseLangResource ScenarioBasic}" Tag="Basic" />
        <atom:TabItem Header="{gallery:ListShowCaseLangResource ScenarioAdvanced}" Tag="Advanced" />
    </atom:TabControl>
</UserControl>
