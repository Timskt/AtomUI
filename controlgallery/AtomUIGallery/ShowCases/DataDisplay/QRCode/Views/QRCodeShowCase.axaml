<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.QRCode.QRCodeShowCase"
             xmlns:vm="using:AtomUIGallery.ShowCases.QRCode"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             x:DataType="vm:QRCodeViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem Title="{gallery:QRCodeShowCaseLangResource BasicUsageTitle}"
                              Description="{gallery:QRCodeShowCaseLangResource BasicUsageDescription}">
            <StackPanel Orientation="Vertical">
                <atom:QRCode Value="{Binding QRCodeInput}" />
                <atom:LineEdit Text="{Binding QRCodeInput}" Margin="0,20,0,0" />
                <ListBox>
                    <ListBox.ItemTemplate></ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </gallery:ShowCaseItem>
        <gallery:ShowCaseItem Title="{gallery:QRCodeShowCaseLangResource WithIconTitle}"
                              Description="{gallery:QRCodeShowCaseLangResource WithIconDescription}">
            <StackPanel Orientation="Vertical">
                <atom:QRCode Value="https://atomui.net" Icon="avares://AtomUIGallery/Assets/ATOMUI-LOGO.png" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:QRCodeShowCaseLangResource DifferentStatusTitle}"
                              Description="{gallery:QRCodeShowCaseLangResource DifferentStatusDescription}">
            <WrapPanel ItemSpacing="20" LineSpacing="20" Orientation="Horizontal">
                <atom:QRCode Value="https://atomui.net" Status="Loading" />
                <atom:QRCode Value="https://atomui.net" Status="Expired" />
                <atom:QRCode Value="https://atomui.net" Status="Scanned" />
            </WrapPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:QRCodeShowCaseLangResource CustomStatusRendererTitle}"
                              Description="{gallery:QRCodeShowCaseLangResource CustomStatusRendererDescription}">
            <WrapPanel ItemSpacing="20" LineSpacing="20" Orientation="Horizontal">
                <atom:QRCode Value="https://atomui.net" Status="Loading">
                    <atom:QRCode.LoadingContent>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <atom:Spin IsSpinning="True" HorizontalAlignment="Center" />
                            <atom:TextBlock Text="{gallery:QRCodeShowCaseLangResource P2TextLoading}" />
                        </StackPanel>
                    </atom:QRCode.LoadingContent>
                </atom:QRCode>
                <atom:QRCode Value="https://atomui.net" Status="Expired">
                    <atom:QRCode.ExpiredContent>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                        VerticalAlignment="Center" Spacing="5">
                                <antdicons:CloseCircleFilled FillBrush="Red" Width="16" Height="16" />
                                <atom:TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{gallery:QRCodeShowCaseLangResource P2TextQRCodeExpired}" />
                            </StackPanel>
                            <atom:Button HorizontalAlignment="Center"
                                         Icon="{antdicons:AntDesignIconProvider Kind=ReloadOutlined}" ButtonType="Link" Content="{gallery:QRCodeShowCaseLangResource P2ContentClickToRefresh}" />
                        </StackPanel>
                    </atom:QRCode.ExpiredContent>
                </atom:QRCode>
                <atom:QRCode Value="https://atomui.net" Status="Scanned">
                    <atom:QRCode.ScannedContent>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="5">
                            <antdicons:CheckCircleFilled FillBrush="Green" Width="16" Height="16" />
                            <atom:TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{gallery:QRCodeShowCaseLangResource P2TextScanned}" />
                        </StackPanel>
                    </atom:QRCode.ScannedContent>
                </atom:QRCode>
            </WrapPanel>
        </gallery:ShowCaseItem>
        <gallery:ShowCaseItem Title="{gallery:QRCodeShowCaseLangResource CustomSizeTitle}"
                              Description="{gallery:QRCodeShowCaseLangResource CustomSizeDescription}">
            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,16">
                    <atom:Button Name="SmallerBtn" 
                                 Icon="{antdicons:AntDesignIconProvider Kind=MinusOutlined}" Content="{gallery:QRCodeShowCaseLangResource P2ContentSmaller}" />
                    <atom:Button Name="LargerBtn" 
                                 Icon="{antdicons:AntDesignIconProvider Kind=PlusOutlined}" Content="{gallery:QRCodeShowCaseLangResource P2ContentLarger}" />
                </StackPanel>
                <atom:QRCode Value="https://atomui.net" Icon="avares://AtomUIGallery/Assets/ATOMUI-LOGO.png"
                             Size="{Binding Size}" IconSize="{Binding IconSize}" />
            </StackPanel>
        </gallery:ShowCaseItem>
        <gallery:ShowCaseItem Title="{gallery:QRCodeShowCaseLangResource CustomColorTitle}"
                              Description="{gallery:QRCodeShowCaseLangResource CustomColorDescription}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <atom:QRCode Value="https://atomui.net"
                             Color="{atom:SharedTokenResource ColorSuccessText}" />
                <atom:QRCode Value="https://atomui.net"
                             Color="{atom:SharedTokenResource ColorInfoText}"
                             Background="{atom:SharedTokenResource ColorBgLayout}" />
            </StackPanel>
        </gallery:ShowCaseItem>
        <gallery:ShowCaseItem Title="{gallery:QRCodeShowCaseLangResource ErrorLevelTitle}"
                              Description="{gallery:QRCodeShowCaseLangResource ErrorLevelDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:QRCode Value="https://gw.alipayobjects.com/zos/rmsportal/KDpgvguMpGfqaHPjicRK.svg"
                             EccLevel="{Binding #EccLevelSegmented.SelectedItem}" />
                <atom:Segmented Name="EccLevelSegmented" />
            </StackPanel>
        </gallery:ShowCaseItem>
        <gallery:ShowCaseItem Title="{gallery:QRCodeShowCaseLangResource AdvancedUsageTitle}"
                              Description="{gallery:QRCodeShowCaseLangResource AdvancedUsageDescription}">
            <atom:FlyoutHost Trigger="Hover">
                <atom:FlyoutHost.Flyout>
                    <atom:Flyout>
                        <atom:QRCode Value="https://atomui.net" IsBordered="False" />
                    </atom:Flyout>
                </atom:FlyoutHost.Flyout>
                <atom:Button ButtonType="Primary" Content="{gallery:QRCodeShowCaseLangResource P2ContentHoverMe}" />
            </atom:FlyoutHost>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>