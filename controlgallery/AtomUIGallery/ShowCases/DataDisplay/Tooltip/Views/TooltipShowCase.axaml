<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Tooltip.TooltipShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.Tooltip"
             x:DataType="vm:TooltipViewModel">

    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:TooltipShowCaseLangResource BasicTitle}"
            Description="{gallery:TooltipShowCaseLangResource BasicDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:TextBlock
                    HorizontalAlignment="Left"
                    atom:ToolTip.Tip="{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}" Text="{gallery:TooltipShowCaseLangResource P2TextTooltipWillShowOnMouseEnter}" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TooltipShowCaseLangResource PlacementTitle}"
            Description="{gallery:TooltipShowCaseLangResource PlacementDescription}">
            <Grid>
                <Grid.Styles>
                    <Style Selector="atom|Button">
                        <Setter Property="Margin" Value="5" />
                        <Setter Property="Width" Value="80" />
                    </Style>
                </Grid.Styles>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <atom:Button Grid.Row="1" Grid.Column="0" Content="{gallery:TooltipShowCaseLangResource P2ContentLT}">
                    <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                    <atom:ToolTip.Placement>LeftEdgeAlignedTop</atom:ToolTip.Placement>
                </atom:Button>
                <atom:Button Grid.Row="2" Grid.Column="0" Content="{gallery:TooltipShowCaseLangResource P2ContentLeft}">
                    <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                    <atom:ToolTip.Placement>Left</atom:ToolTip.Placement>
                </atom:Button>
                <atom:Button Grid.Row="3" Grid.Column="0" Content="{gallery:TooltipShowCaseLangResource P2ContentLB}">
                    <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                    <atom:ToolTip.Placement>LeftEdgeAlignedBottom</atom:ToolTip.Placement>
                </atom:Button>

                <atom:Button Grid.Row="0" Grid.Column="1" Content="{gallery:TooltipShowCaseLangResource P2ContentTL}">
                    <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                    <atom:ToolTip.Placement>TopEdgeAlignedLeft</atom:ToolTip.Placement>
                </atom:Button>
                <atom:Button Grid.Row="0" Grid.Column="2" Content="{gallery:TooltipShowCaseLangResource P2ContentTop}">
                    <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                    <atom:ToolTip.Placement>Top</atom:ToolTip.Placement>
                </atom:Button>
                <atom:Button Grid.Row="0" Grid.Column="3" Content="{gallery:TooltipShowCaseLangResource P2ContentTR}">
                    <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                    <atom:ToolTip.Placement>TopEdgeAlignedRight</atom:ToolTip.Placement>
                </atom:Button>

                <atom:Button Grid.Row="1" Grid.Column="4" Content="{gallery:TooltipShowCaseLangResource P2ContentRT}">
                    <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                    <atom:ToolTip.Placement>RightEdgeAlignedTop</atom:ToolTip.Placement>
                </atom:Button>
                <atom:Button Grid.Row="2" Grid.Column="4" Content="{gallery:TooltipShowCaseLangResource P2ContentRight}">
                    <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                    <atom:ToolTip.Placement>Right</atom:ToolTip.Placement>
                </atom:Button>
                <atom:Button Grid.Row="3" Grid.Column="4" Content="{gallery:TooltipShowCaseLangResource P2ContentRB}">
                    <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                    <atom:ToolTip.Placement>RightEdgeAlignedBottom</atom:ToolTip.Placement>
                </atom:Button>

                <atom:Button Grid.Row="4" Grid.Column="1" Content="{gallery:TooltipShowCaseLangResource P2ContentBL}">
                    <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                    <atom:ToolTip.Placement>BottomEdgeAlignedLeft</atom:ToolTip.Placement>
                </atom:Button>
                <atom:Button Grid.Row="4" Grid.Column="2" Content="{gallery:TooltipShowCaseLangResource P2ContentBottom}">
                    <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                    <atom:ToolTip.Placement>Bottom</atom:ToolTip.Placement>
                </atom:Button>
                <atom:Button Grid.Row="4" Grid.Column="3" Content="{gallery:TooltipShowCaseLangResource P2ContentBR}">
                    <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                    <atom:ToolTip.Placement>BottomEdgeAlignedRight</atom:ToolTip.Placement>
                </atom:Button>

            </Grid>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TooltipShowCaseLangResource ArrowTitle}"
            Description="{gallery:TooltipShowCaseLangResource ArrowDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Segmented x:Name="ArrowSegmented">
                    <atom:SegmentedItem Content="{gallery:TooltipShowCaseLangResource P2ContentShow}" />
                    <atom:SegmentedItem Content="{gallery:TooltipShowCaseLangResource P2ContentHide}" />
                    <atom:SegmentedItem Content="{gallery:TooltipShowCaseLangResource P2ContentCenter}" />
                </atom:Segmented>
                <Grid>
                    <Grid.Styles>
                        <Style Selector="atom|Button">
                            <Setter Property="Margin" Value="5" />
                            <Setter Property="Width" Value="80" />
                        </Style>
                    </Grid.Styles>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <atom:Button Grid.Row="1" Grid.Column="0" Content="{gallery:TooltipShowCaseLangResource P2ContentLT}"
                                 atom:ToolTip.IsArrowVisible="{Binding ShowArrow}"
                                 atom:ToolTip.IsPointAtCenter="{Binding IsPointAtCenter}">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>LeftEdgeAlignedTop</atom:ToolTip.Placement>
                    </atom:Button>
                    <atom:Button Grid.Row="2" Grid.Column="0" Content="{gallery:TooltipShowCaseLangResource P2ContentLeft}"
                                 atom:ToolTip.IsArrowVisible="{Binding ShowArrow}"
                                 atom:ToolTip.IsPointAtCenter="{Binding IsPointAtCenter}">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>Left</atom:ToolTip.Placement>
                    </atom:Button>
                    <atom:Button Grid.Row="3" Grid.Column="0" Content="{gallery:TooltipShowCaseLangResource P2ContentLB}"
                                 atom:ToolTip.IsArrowVisible="{Binding ShowArrow}"
                                 atom:ToolTip.IsPointAtCenter="{Binding IsPointAtCenter}">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>LeftEdgeAlignedBottom</atom:ToolTip.Placement>
                    </atom:Button>

                    <atom:Button Grid.Row="0" Grid.Column="1" Content="{gallery:TooltipShowCaseLangResource P2ContentTL}"
                                 atom:ToolTip.IsArrowVisible="{Binding ShowArrow}"
                                 atom:ToolTip.IsPointAtCenter="{Binding IsPointAtCenter}">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>TopEdgeAlignedLeft</atom:ToolTip.Placement>
                    </atom:Button>
                    <atom:Button Grid.Row="0" Grid.Column="2" Content="{gallery:TooltipShowCaseLangResource P2ContentTop}"
                                 atom:ToolTip.IsArrowVisible="{Binding ShowArrow}"
                                 atom:ToolTip.IsPointAtCenter="{Binding IsPointAtCenter}">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>Top</atom:ToolTip.Placement>
                    </atom:Button>
                    <atom:Button Grid.Row="0" Grid.Column="3" Content="{gallery:TooltipShowCaseLangResource P2ContentTR}"
                                 atom:ToolTip.IsArrowVisible="{Binding ShowArrow}"
                                 atom:ToolTip.IsPointAtCenter="{Binding IsPointAtCenter}">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>TopEdgeAlignedRight</atom:ToolTip.Placement>
                    </atom:Button>

                    <atom:Button Grid.Row="1" Grid.Column="4" Content="{gallery:TooltipShowCaseLangResource P2ContentRT}"
                                 atom:ToolTip.IsArrowVisible="{Binding ShowArrow}"
                                 atom:ToolTip.IsPointAtCenter="{Binding IsPointAtCenter}">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>RightEdgeAlignedTop</atom:ToolTip.Placement>
                    </atom:Button>

                    <atom:Button Grid.Row="2" Grid.Column="4" Content="{gallery:TooltipShowCaseLangResource P2ContentRight}"
                                 atom:ToolTip.IsArrowVisible="{Binding ShowArrow}"
                                 atom:ToolTip.IsPointAtCenter="{Binding IsPointAtCenter}">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>Right</atom:ToolTip.Placement>
                    </atom:Button>

                    <atom:Button Grid.Row="3" Grid.Column="4" Content="{gallery:TooltipShowCaseLangResource P2ContentRB}"
                                 atom:ToolTip.IsArrowVisible="{Binding ShowArrow}"
                                 atom:ToolTip.IsPointAtCenter="{Binding IsPointAtCenter}">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>RightEdgeAlignedBottom</atom:ToolTip.Placement>
                    </atom:Button>

                    <atom:Button Grid.Row="4" Grid.Column="1" Content="{gallery:TooltipShowCaseLangResource P2ContentBL}"
                                 atom:ToolTip.IsArrowVisible="{Binding ShowArrow}"
                                 atom:ToolTip.IsPointAtCenter="{Binding IsPointAtCenter}">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>BottomEdgeAlignedLeft</atom:ToolTip.Placement>
                    </atom:Button>

                    <atom:Button Grid.Row="4" Grid.Column="2" Content="{gallery:TooltipShowCaseLangResource P2ContentBottom}"
                                 atom:ToolTip.IsArrowVisible="{Binding ShowArrow}"
                                 atom:ToolTip.IsPointAtCenter="{Binding IsPointAtCenter}">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>Bottom</atom:ToolTip.Placement>
                    </atom:Button>

                    <atom:Button Grid.Row="4" Grid.Column="3" Content="{gallery:TooltipShowCaseLangResource P2ContentBR}"
                                 atom:ToolTip.IsArrowVisible="{Binding ShowArrow}"
                                 atom:ToolTip.IsPointAtCenter="{Binding IsPointAtCenter}">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>BottomEdgeAlignedRight</atom:ToolTip.Placement>
                    </atom:Button>

                </Grid>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TooltipShowCaseLangResource ColorfulTooltipTitle}"
            Description="{gallery:TooltipShowCaseLangResource ColorfulTooltipDescription}">
            <gallery:ShowCaseItem.Styles>
                <Style Selector="atom|Button">
                    <Setter Property="Margin" Value="5" />
                </Style>
            </gallery:ShowCaseItem.Styles>
            <StackPanel Orientation="Vertical">
                <TextBlock FontWeight="Bold" FontSize="14" Margin="0, 0, 0, 10" Text="{gallery:TooltipShowCaseLangResource P2TextPresets}" />
                <WrapPanel HorizontalAlignment="Left">
                    <atom:Button Content="{gallery:TooltipShowCaseLangResource P2ContentBlue}" atom:ToolTip.PresetColor="Blue">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>Top</atom:ToolTip.Placement>
                    </atom:Button>
                    <atom:Button Content="{gallery:TooltipShowCaseLangResource P2ContentRed}" atom:ToolTip.PresetColor="Red">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>Top</atom:ToolTip.Placement>
                    </atom:Button>

                    <atom:Button Content="{gallery:TooltipShowCaseLangResource P2ContentVolcano}" atom:ToolTip.PresetColor="Volcano">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>Top</atom:ToolTip.Placement>
                    </atom:Button>

                    <atom:Button Content="{gallery:TooltipShowCaseLangResource P2ContentOrange}" atom:ToolTip.PresetColor="Orange">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>Top</atom:ToolTip.Placement>
                    </atom:Button>

                    <atom:Button Content="{gallery:TooltipShowCaseLangResource P2ContentGold}" atom:ToolTip.PresetColor="Gold">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>Top</atom:ToolTip.Placement>
                    </atom:Button>

                    <atom:Button Content="{gallery:TooltipShowCaseLangResource P2ContentYellow}" atom:ToolTip.PresetColor="Yellow">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>Top</atom:ToolTip.Placement>
                    </atom:Button>

                    <atom:Button Content="{gallery:TooltipShowCaseLangResource P2ContentLime}" atom:ToolTip.PresetColor="Lime">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>Top</atom:ToolTip.Placement>
                    </atom:Button>

                    <atom:Button Content="{gallery:TooltipShowCaseLangResource P2ContentGreen}" atom:ToolTip.PresetColor="Green">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>Top</atom:ToolTip.Placement>
                    </atom:Button>

                    <atom:Button Content="{gallery:TooltipShowCaseLangResource P2ContentCyan}" atom:ToolTip.PresetColor="Cyan">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>Top</atom:ToolTip.Placement>
                    </atom:Button>

                    <atom:Button Content="{gallery:TooltipShowCaseLangResource P2ContentGeekBlue}" atom:ToolTip.PresetColor="GeekBlue">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>Top</atom:ToolTip.Placement>
                    </atom:Button>

                    <atom:Button Content="{gallery:TooltipShowCaseLangResource P2ContentPurple}" atom:ToolTip.PresetColor="Purple">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>Top</atom:ToolTip.Placement>
                    </atom:Button>

                    <atom:Button Content="{gallery:TooltipShowCaseLangResource P2ContentPink}" atom:ToolTip.PresetColor="Pink">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>Top</atom:ToolTip.Placement>
                    </atom:Button>

                    <atom:Button Content="{gallery:TooltipShowCaseLangResource P2ContentMagenta}" atom:ToolTip.PresetColor="Magenta">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>Top</atom:ToolTip.Placement>
                    </atom:Button>

                    <atom:Button Content="{gallery:TooltipShowCaseLangResource P2ContentGrey}" atom:ToolTip.PresetColor="Grey">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>Top</atom:ToolTip.Placement>
                    </atom:Button>
                </WrapPanel>

                <TextBlock FontWeight="Bold" FontSize="14" Margin="0, 20, 0, 10" Text="{gallery:TooltipShowCaseLangResource P2TextCustom}" />
                <WrapPanel HorizontalAlignment="Left">
                    <atom:Button Content="#f50" atom:ToolTip.Color="#f50">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>Top</atom:ToolTip.Placement>
                    </atom:Button>

                    <atom:Button Content="#2db7f5" atom:ToolTip.Color="#2db7f5">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>Top</atom:ToolTip.Placement>
                    </atom:Button>

                    <atom:Button Content="#87d068" atom:ToolTip.Color="#87d068">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>Top</atom:ToolTip.Placement>
                    </atom:Button>

                    <atom:Button Content="#108ee9" atom:ToolTip.Color="#108ee9">
                        <atom:ToolTip.Tip>{gallery:TooltipShowCaseLangResource P2ToolTipTipPromptText}</atom:ToolTip.Tip>
                        <atom:ToolTip.Placement>Top</atom:ToolTip.Placement>
                    </atom:Button>
                </WrapPanel>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
