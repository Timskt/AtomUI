<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Tour.TourShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.Tour"
             xmlns:views="using:AtomUIGallery.ShowCases.Tour"
             x:DataType="vm:TourViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:TourShowCaseLangResource BasicTitle}"
            Description="{gallery:TourShowCaseLangResource BasicDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Button ButtonType="Primary" Click="HandleBasicBeginTour" Content="{gallery:TourShowCaseLangResource P2ContentBeginTour}" />
                <atom:Separator />
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <atom:Button Name="BasicCaseUpload" Content="{gallery:TourShowCaseLangResource P2ContentUpload}" />
                    <atom:Button ButtonType="Primary" Name="BasicCaseSave" Content="{gallery:TourShowCaseLangResource P2ContentSave}" />
                    <atom:Button Name="BasicCaseEllipsis"
                                 Icon="{antdicons:AntDesignIconProvider EllipsisOutlined}" />
                </StackPanel>
                <atom:Tour IsOpen="{Binding BasicCaseTourOpened, Mode=TwoWay}">
                    <atom:TourStep Target="{Binding ElementName=BasicCaseUpload}"
                                   Title="{gallery:TourShowCaseLangResource P2TitleUploadFile}"
                                   Description="{gallery:TourShowCaseLangResource P2DescriptionPutYourFilesHere}">
                        <atom:TourStep.Cover>
                            <Image Source="/Assets/TourShowCase/Cover.png"
                                   Width="400" />
                        </atom:TourStep.Cover>
                    </atom:TourStep>
                    <atom:TourStep Target="{Binding ElementName=BasicCaseSave}"
                                   Title="{gallery:TourShowCaseLangResource P2TitleSave}"
                                   Description="{gallery:TourShowCaseLangResource P2DescriptionSaveYourChanges}" />
                    <atom:TourStep Target="{Binding ElementName=BasicCaseEllipsis}"
                                   Title="{gallery:TourShowCaseLangResource P2TitleOtherActions}"
                                   Description="{gallery:TourShowCaseLangResource P2DescriptionClickToSeeOtherActions}" />
                </atom:Tour>
            </StackPanel>

        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TourShowCaseLangResource NonModalTitle}"
            Description="{gallery:TourShowCaseLangResource NonModalDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Button ButtonType="Primary" Click="HandleNonMaskBeginTour" Content="{gallery:TourShowCaseLangResource P2ContentBeginNonModalTour}" />
                <atom:Separator />
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <atom:Button Name="NonMaskCaseUpload" Content="{gallery:TourShowCaseLangResource P2ContentUpload}" />
                    <atom:Button ButtonType="Primary" Name="NonMaskSave" Content="{gallery:TourShowCaseLangResource P2ContentSave}" />
                    <atom:Button Name="NonMaskEllipsis"
                                 Icon="{antdicons:AntDesignIconProvider EllipsisOutlined}" />
                </StackPanel>
                <atom:Tour IsOpen="{Binding NonMaskTourOpened, Mode=TwoWay}" IsShowMask="False" StyleType="Primary">
                    <atom:TourStep Target="{Binding ElementName=NonMaskCaseUpload}"
                                   Title="{gallery:TourShowCaseLangResource P2TitleUploadFile}"
                                   Description="{gallery:TourShowCaseLangResource P2DescriptionPutYourFilesHere}">
                        <atom:TourStep.Cover>
                            <Image Source="/Assets/TourShowCase/Cover.png"
                                   Width="400" />
                        </atom:TourStep.Cover>
                    </atom:TourStep>
                    <atom:TourStep Target="{Binding ElementName=NonMaskSave}"
                                   Title="{gallery:TourShowCaseLangResource P2TitleSave}"
                                   Description="{gallery:TourShowCaseLangResource P2DescriptionSaveYourChanges}" />
                    <atom:TourStep Target="{Binding ElementName=NonMaskEllipsis}"
                                   Title="{gallery:TourShowCaseLangResource P2TitleOtherActions}"
                                   Description="{gallery:TourShowCaseLangResource P2DescriptionClickToSeeOtherActions}" />
                </atom:Tour>
            </StackPanel>

        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TourShowCaseLangResource PlacementTitle}"
            Description="{gallery:TourShowCaseLangResource PlacementDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Button ButtonType="Primary" Click="HandlePlacementBeginTour" Name="PlacementBeginTour" Content="{gallery:TourShowCaseLangResource P2ContentBeginTour}" />
                <atom:Tour IsOpen="{Binding PlacementTourOpened, Mode=TwoWay}" IsShowMask="True">
                    <atom:TourStep Title="{gallery:TourShowCaseLangResource P2TitleCenter}"
                                   Description="{gallery:TourShowCaseLangResource P2DescriptionDisplayedInTheCenterOfScreen}" />
                    <atom:TourStep Title="{gallery:TourShowCaseLangResource P2TitleRight}"
                                   Description="{gallery:TourShowCaseLangResource P2DescriptionOnTheRightOfTarget}"
                                   Placement="Right"
                                   Target="{Binding ElementName=PlacementBeginTour}" />
                    <atom:TourStep Title="{gallery:TourShowCaseLangResource P2TitleTop}"
                                   Description="{gallery:TourShowCaseLangResource P2DescriptionOnTheTopOfTarget}"
                                   Placement="Top"
                                   Target="{Binding ElementName=PlacementBeginTour}" />
                    <atom:TourStep Title="{gallery:TourShowCaseLangResource P2TitleLeft}"
                                   Description="{gallery:TourShowCaseLangResource P2DescriptionOnTheLeftOfTarget}"
                                   Placement="Left"
                                   Target="{Binding ElementName=PlacementBeginTour}" />
                </atom:Tour>
            </StackPanel>

        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TourShowCaseLangResource CustomIndicatorTitle}"
            Description="{gallery:TourShowCaseLangResource CustomIndicatorDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Button ButtonType="Primary" Click="HandleCustomIndicatorBeginTour" Content="{gallery:TourShowCaseLangResource P2ContentBeginTour}" />
                <atom:Separator />
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <atom:Button Name="CustomIndicatorUpload" Content="{gallery:TourShowCaseLangResource P2ContentUpload}" />
                    <atom:Button ButtonType="Primary" Name="CustomIndicatorSave" Content="{gallery:TourShowCaseLangResource P2ContentSave}" />
                    <atom:Button Name="CustomIndicatorEllipsis"
                                 Icon="{antdicons:AntDesignIconProvider EllipsisOutlined}" />
                </StackPanel>
                <atom:Tour IsOpen="{Binding CustomIndicatorTourOpened, Mode=TwoWay}">
                    <atom:Tour.Indicator>
                        <atom:TextTourIndicator />
                    </atom:Tour.Indicator>
                    <atom:TourStep Target="{Binding ElementName=CustomIndicatorUpload}"
                                   Title="{gallery:TourShowCaseLangResource P2TitleUploadFile}"
                                   Description="{gallery:TourShowCaseLangResource P2DescriptionPutYourFilesHere}">
                        <atom:TourStep.Cover>
                            <Image Source="/Assets/TourShowCase/Cover.png"
                                   Width="400" />
                        </atom:TourStep.Cover>
                    </atom:TourStep>
                    <atom:TourStep Target="{Binding ElementName=CustomIndicatorSave}"
                                   Title="{gallery:TourShowCaseLangResource P2TitleSave}"
                                   Description="{gallery:TourShowCaseLangResource P2DescriptionSaveYourChanges}" />
                    <atom:TourStep Target="{Binding ElementName=CustomIndicatorEllipsis}"
                                   Title="{gallery:TourShowCaseLangResource P2TitleOtherActions}"
                                   Description="{gallery:TourShowCaseLangResource P2DescriptionClickToSeeOtherActions}" />
                </atom:Tour>
            </StackPanel>

        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TourShowCaseLangResource CustomMaskTitle}"
            Description="{gallery:TourShowCaseLangResource CustomMaskDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Button ButtonType="Primary" Click="HandleCustomMaskBeginTour" Content="{gallery:TourShowCaseLangResource P2ContentBeginTour}" />
                <atom:Separator />
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <atom:Button Name="CustomMaskUpload" Content="{gallery:TourShowCaseLangResource P2ContentUpload}" />
                    <atom:Button ButtonType="Primary" Name="CustomMaskSave" Content="{gallery:TourShowCaseLangResource P2ContentSave}" />
                    <atom:Button Name="CustomMaskEllipsis"
                                 Icon="{antdicons:AntDesignIconProvider EllipsisOutlined}" />
                </StackPanel>
                <atom:Tour IsOpen="{Binding CustomMaskTourOpened, Mode=TwoWay}"
                           MaskColor="#6650FFFF">
                    <atom:TourStep Target="{Binding ElementName=CustomMaskUpload}"
                                   Title="{gallery:TourShowCaseLangResource P2TitleUploadFile}"
                                   Description="{gallery:TourShowCaseLangResource P2DescriptionPutYourFilesHere}">
                        <atom:TourStep.Cover>
                            <Image Source="/Assets/TourShowCase/Cover.png"
                                   Width="400" />
                        </atom:TourStep.Cover>
                    </atom:TourStep>
                    <atom:TourStep Target="{Binding ElementName=CustomMaskSave}"
                                   Title="{gallery:TourShowCaseLangResource P2TitleSave}"
                                   Description="{gallery:TourShowCaseLangResource P2DescriptionSaveYourChanges}"
                                   MaskColor="#662800FF"/>
                    <atom:TourStep Target="{Binding ElementName=CustomMaskEllipsis}"
                                   Title="{gallery:TourShowCaseLangResource P2TitleOtherActions}"
                                   Description="{gallery:TourShowCaseLangResource P2DescriptionClickToSeeOtherActions}"
                                   IsShowMask="False"/>
                </atom:Tour>
            </StackPanel>

        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TourShowCaseLangResource CustomActionTitle}"
            Description="{gallery:TourShowCaseLangResource CustomActionDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Button ButtonType="Primary" Click="HandleCustomActionBeginTour" Content="{gallery:TourShowCaseLangResource P2ContentBeginTour}" />
                <atom:Separator />
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <atom:Button Name="CustomActionUpload" Content="{gallery:TourShowCaseLangResource P2ContentUpload}" />
                    <atom:Button ButtonType="Primary" Name="CustomActionSave" Content="{gallery:TourShowCaseLangResource P2ContentSave}" />
                    <atom:Button Name="CustomActionEllipsis"
                                 Icon="{antdicons:AntDesignIconProvider EllipsisOutlined}" />
                </StackPanel>
                <atom:Tour IsOpen="{Binding CustomActionTourOpened, Mode=TwoWay}">
                    <atom:Tour.CustomActions>
                        <views:SkipTourActionButton Content="{gallery:TourShowCaseLangResource P2ContentSkip}" />
                    </atom:Tour.CustomActions>
                    <atom:TourStep Target="{Binding ElementName=CustomActionUpload}"
                                   Title="{gallery:TourShowCaseLangResource P2TitleUploadFile}"
                                   Description="{gallery:TourShowCaseLangResource P2DescriptionPutYourFilesHere}">
                        <atom:TourStep.Cover>
                            <Image Source="/Assets/TourShowCase/Cover.png"
                                   Width="400" />
                        </atom:TourStep.Cover>
                    </atom:TourStep>
                    <atom:TourStep Target="{Binding ElementName=CustomActionSave}"
                                   Title="{gallery:TourShowCaseLangResource P2TitleSave}"
                                   Description="{gallery:TourShowCaseLangResource P2DescriptionSaveYourChanges}" />
                    <atom:TourStep Target="{Binding ElementName=CustomActionEllipsis}"
                                   Title="{gallery:TourShowCaseLangResource P2TitleOtherActions}"
                                   Description="{gallery:TourShowCaseLangResource P2DescriptionClickToSeeOtherActions}" />
                </atom:Tour>
            </StackPanel>

        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TourShowCaseLangResource CustomHighlightedAreaStyleTitle}"
            Description="{gallery:TourShowCaseLangResource CustomHighlightedAreaStyleDescription}"
            IsOccupyEntireRow="True">
            <StackPanel Orientation="Vertical" Margin="50, 0, 50, 0">
                <StackPanel Orientation="Vertical" Spacing="10" Name="CustomGapControl">
                    <atom:Button ButtonType="Primary" Click="HandleCustomGapBeginTour" Content="{gallery:TourShowCaseLangResource P2ContentBeginTour}" />
                    <DockPanel LastChildFill="True">
                        <TextBlock Width="200" DockPanel.Dock="Left" Text="{gallery:TourShowCaseLangResource P2TextRadius}" />
                        <atom:Slider Minimum="0" Maximum="100" Value="{Binding CustomGapRadius, Mode=TwoWay}"/>
                    </DockPanel>
                    <DockPanel LastChildFill="True">
                        <TextBlock Width="200" DockPanel.Dock="Left" Text="{gallery:TourShowCaseLangResource P2TextHorizontalOffset}" />
                        <atom:Slider Minimum="1" Maximum="50" Value="{Binding CustomGapOffsetX, Mode=TwoWay}"/>
                    </DockPanel>
                    <DockPanel LastChildFill="True">
                        <TextBlock Width="200" DockPanel.Dock="Left" Text="{gallery:TourShowCaseLangResource P2TextVerticalOffset}" />
                        <atom:Slider Minimum="1" Maximum="50" Value="{Binding CustomGapOffsetY, Mode=TwoWay}"/>
                    </DockPanel>
                </StackPanel>

                <atom:Tour IsOpen="{Binding CustomGapTourOpened, Mode=TwoWay}" Placement="Top"
                           GapRadius="{Binding CustomGapRadius}"
                           GapOffsetX="{Binding CustomGapOffsetX}"
                           GapOffsetY="{Binding CustomGapOffsetY}">
                    <atom:TourStep Target="{Binding ElementName=CustomGapControl}"
                                   Title="{gallery:TourShowCaseLangResource P2TitleUploadFile}"
                                   Description="{gallery:TourShowCaseLangResource P2DescriptionPutYourFilesHere}">
                        <atom:TourStep.Cover>
                            <Image Source="/Assets/TourShowCase/Cover.png"
                                   Width="400" />
                        </atom:TourStep.Cover>
                    </atom:TourStep>
                </atom:Tour>
            </StackPanel>

        </gallery:ShowCaseItem>


    </gallery:ShowCasePanel>
</UserControl>
