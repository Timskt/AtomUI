<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.TreeView.TreeViewShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.TreeView"
             x:DataType="vm:TreeViewViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:TreeViewShowCaseLangResource BasicTitle}"
            Description="{gallery:TreeViewShowCaseLangResource BasicDescription}">
            <atom:TreeView Name="BasicTree" ToggleType="CheckBox">
                <atom:TreeViewItem Header="parent 1" ItemKey="0-0">
                    <atom:TreeViewItem Header="parent 1-0" ItemKey="0-0-0">
                        <atom:TreeViewItem Header="leaf" ItemKey="0-0-0-0" IsEnabled="False" />
                        <atom:TreeViewItem Header="leaf" ItemKey="0-0-0-1" />
                    </atom:TreeViewItem>
                    <atom:TreeViewItem Header="parent 1-1" ItemKey="0-0-1">
                        <atom:TreeViewItem Header="sss" ItemKey="0-0-1-0">
                            <atom:TreeViewItem Header="ccc" ItemKey="0-0-1-0-0" />
                        </atom:TreeViewItem>
                        <atom:TreeViewItem Header="xxx" ItemKey="0-0-1-1">
                            <atom:TreeViewItem Header="aaaa" ItemKey="0-0-1-1-0" />
                        </atom:TreeViewItem>
                    </atom:TreeViewItem>
                </atom:TreeViewItem>
            </atom:TreeView>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TreeViewShowCaseLangResource GenerateByTemplateTitle}"
            Description="{gallery:TreeViewShowCaseLangResource GenerateByTemplateDescription}">
            <atom:TreeView Name="BasicTplTree" ToggleType="CheckBox">
                <atom:TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}" DataType="atom:ITreeItemNode">
                        <atom:TextBlock Text="{Binding Header}" />
                    </TreeDataTemplate>
                </atom:TreeView.ItemTemplate>
            </atom:TreeView>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TreeViewShowCaseLangResource BlockNodeTitle}"
            Description="{gallery:TreeViewShowCaseLangResource BlockNodeDescription}">
            <atom:TreeView ToggleType="CheckBox" IsDefaultExpandAll="True" NodeHoverMode="Block">
                <atom:TreeViewItem Header="parent">
                    <atom:TreeViewItem Header="child 1" IsEnabled="False" />
                    <atom:TreeViewItem Header="child 2" IsIndicatorEnabled="False" />
                </atom:TreeViewItem>
            </atom:TreeView>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TreeViewShowCaseLangResource TreeWithLineTitle}"
            Description="{gallery:TreeViewShowCaseLangResource TreeWithLineDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock VerticalAlignment="Center">showLine:</TextBlock>
                    <atom:ToggleSwitch VerticalAlignment="Center"
                                       IsChecked="{Binding ShowLineSwitchChecked,Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock VerticalAlignment="Center">showIcon:</TextBlock>
                    <atom:ToggleSwitch VerticalAlignment="Center"
                                       IsChecked="{Binding ShowIconSwitchChecked,Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock VerticalAlignment="Center">ShowLeafIcon:</TextBlock>
                    <atom:ToggleSwitch VerticalAlignment="Center"
                                       IsChecked="{Binding ShowLeafIconSwitchChecked,Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock VerticalAlignment="Center">Node hover mode:</TextBlock>
                    <atom:RadioButton IsChecked="True" IsCheckedChanged="HandleHoverModeChanged"
                                      Tag="{x:Static atom:TreeItemHoverMode.Default}">
                        Default
                    </atom:RadioButton>
                    <atom:RadioButton IsCheckedChanged="HandleHoverModeChanged"
                                      Tag="{x:Static atom:TreeItemHoverMode.Block}">
                        Block
                    </atom:RadioButton>
                    <atom:RadioButton IsCheckedChanged="HandleHoverModeChanged"
                                      Tag="{x:Static atom:TreeItemHoverMode.WholeLine}">
                        WholeLine
                    </atom:RadioButton>
                </StackPanel>

                <atom:TreeView IsShowLine="{Binding ShowLineSwitchChecked}"
                               IsShowIcon="{Binding ShowIconSwitchChecked}"
                               IsShowLeafIcon="{Binding ShowLeafIconSwitchChecked}"
                               NodeHoverMode="{Binding TreeViewNodeHoverMode}"
                               IsSwitcherRotation="{Binding ShowLineSwitchChecked, Converter={x:Static BoolConverters.Not}}">
                    <atom:TreeViewItem Header="parent 1" Icon="{antdicons:AntDesignIconProvider Kind=CarryOutOutlined}"
                                       IsExpanded="True">
                        <atom:TreeViewItem Header="parent 1-0"
                                           Icon="{antdicons:AntDesignIconProvider Kind=CarryOutOutlined}"
                                           IsExpanded="True">
                            <atom:TreeViewItem Header="leaf 1"
                                               Icon="{antdicons:AntDesignIconProvider Kind=CarryOutOutlined}" />
                            <atom:TreeViewItem Header="leaf 2"
                                               Icon="{antdicons:AntDesignIconProvider Kind=CarryOutOutlined}" />
                        </atom:TreeViewItem>
                        <atom:TreeViewItem Header="parent 1-1">
                            <atom:TreeViewItem Header="leaf"
                                               Icon="{antdicons:AntDesignIconProvider Kind=CarryOutOutlined}" />
                        </atom:TreeViewItem>
                        <atom:TreeViewItem Header="parent 1-2">
                            <atom:TreeViewItem Header="leaf 1"
                                               Icon="{antdicons:AntDesignIconProvider Kind=CarryOutOutlined}" />
                            <atom:TreeViewItem Header="leaf 2"
                                               Icon="{antdicons:AntDesignIconProvider Kind=CarryOutOutlined}" />
                        </atom:TreeViewItem>
                    </atom:TreeViewItem>
                    <atom:TreeViewItem Header="parent 2">
                        <atom:TreeViewItem Header="parent 2-0"
                                           Icon="{antdicons:AntDesignIconProvider Kind=CarryOutOutlined}">
                            <atom:TreeViewItem Header="leaf 1"
                                               Icon="{antdicons:AntDesignIconProvider Kind=CarryOutOutlined}" />
                            <atom:TreeViewItem Header="leaf 2"
                                               Icon="{antdicons:AntDesignIconProvider Kind=CarryOutOutlined}" />
                        </atom:TreeViewItem>
                    </atom:TreeViewItem>
                </atom:TreeView>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TreeViewShowCaseLangResource DraggableTitle}"
            Description="{gallery:TreeViewShowCaseLangResource DraggableDescription}">
            <atom:TreeView IsDraggable="True" NodeHoverMode="Block">
                <atom:TreeViewItem Header="0-0">
                    <atom:TreeViewItem Header="0-0-0">
                        <atom:TreeViewItem Header="0-0-0-0" />
                        <atom:TreeViewItem Header="0-0-0-1" />
                        <atom:TreeViewItem Header="0-0-0-2" />
                    </atom:TreeViewItem>
                    <atom:TreeViewItem Header="0-0-1">
                        <atom:TreeViewItem Header="0-0-1-0" />
                        <atom:TreeViewItem Header="0-0-1-1" />
                        <atom:TreeViewItem Header="0-0-1-2" />
                    </atom:TreeViewItem>
                    <atom:TreeViewItem Header="0-0-2" />
                </atom:TreeViewItem>
                <atom:TreeViewItem Header="0-1">
                    <atom:TreeViewItem Header="0-1-0">
                        <atom:TreeViewItem Header="0-1-0-0" />
                        <atom:TreeViewItem Header="0-1-0-1" />
                        <atom:TreeViewItem Header="0-1-0-2" />
                    </atom:TreeViewItem>
                    <atom:TreeViewItem Header="0-1-1">
                        <atom:TreeViewItem Header="0-1-1-0" />
                        <atom:TreeViewItem Header="0-1-1-1" />
                        <atom:TreeViewItem Header="0-1-1-2" />
                    </atom:TreeViewItem>
                    <atom:TreeViewItem Header="0-1-2" />
                </atom:TreeViewItem>
                <atom:TreeViewItem Header="0-2" />
            </atom:TreeView>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TreeViewShowCaseLangResource CustomizeExpandIconTitle}"
            Description="{gallery:TreeViewShowCaseLangResource CustomizeExpandIconDescription}">
            <atom:TreeView Name="CustomizeCollapseExpandTree"
                           DefaultExpandedPaths="{Binding CustomizeCollapseExpandTreeDefaultExpandedPaths}"
                           IsSwitcherRotation="True">
                <atom:TreeView.SwitcherRotationIcon>
                    <atom:IconTemplate>
                        <antdicons:RightOutlined />
                    </atom:IconTemplate>
                </atom:TreeView.SwitcherRotationIcon>
                <atom:TreeViewItem Header="parent 1" ItemKey="0-0">
                    <atom:TreeViewItem Header="parent 1-0" ItemKey="0-0-0">
                        <atom:TreeViewItem Header="leaf" ItemKey="0-0-0-0" />
                        <atom:TreeViewItem Header="leaf" ItemKey="0-0-0-1" />
                        <atom:TreeViewItem Header="leaf" ItemKey="0-0-0-2" />
                    </atom:TreeViewItem>
                    <atom:TreeViewItem Header="parent 1-1" ItemKey="0-0-1">
                        <atom:TreeViewItem Header="leaf" ItemKey="0-0-1-0" />
                    </atom:TreeViewItem>
                    <atom:TreeViewItem Header="parent 1-2" ItemKey="0-0-2">
                        <atom:TreeViewItem Header="leaf" ItemKey="0-0-2-0" />
                        <atom:TreeViewItem Header="leaf" ItemKey="0-0-2-1" />
                    </atom:TreeViewItem>
                </atom:TreeViewItem>
            </atom:TreeView>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TreeViewShowCaseLangResource AsyncLoadDataTitle}"
            Description="{gallery:TreeViewShowCaseLangResource AsyncLoadDataDescription}">
            <atom:TreeView Name="AsyncLoadTree">
                <atom:TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}" DataType="atom:ITreeItemNode">
                        <atom:TextBlock Text="{Binding Header}" />
                    </TreeDataTemplate>
                </atom:TreeView.ItemTemplate>
            </atom:TreeView>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TreeViewShowCaseLangResource SearchableByTemplateTitle}"
            Description="{gallery:TreeViewShowCaseLangResource SearchableByTemplateDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:SearchEdit PlaceholderText="Search"
                                 SearchButtonClick="HandleFilterItemsSourceTreeClicked" />
                <atom:TreeView Name="SearchTreeViewByItemsSource">
                    <atom:TreeView.ItemTemplate>
                        <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="atom:ITreeItemNode">
                            <atom:TextBlock Text="{Binding Header}" />
                        </TreeDataTemplate>
                    </atom:TreeView.ItemTemplate>
                </atom:TreeView>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TreeViewShowCaseLangResource SearchableTitle}"
            Description="{gallery:TreeViewShowCaseLangResource SearchableDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:SearchEdit PlaceholderText="Search"
                                 SearchButtonClick="HandleFilterTreeClicked" />
                <atom:TreeView Name="SearchTreeView">
                    <atom:TreeViewItem Header="0-0">
                        <atom:TreeViewItem Header="0-0-0">
                            <atom:TreeViewItem Header="0-0-0-0" />
                            <atom:TreeViewItem Header="0-0-0-1" />
                            <atom:TreeViewItem Header="0-0-0-2" />
                        </atom:TreeViewItem>
                        <atom:TreeViewItem Header="0-0-1">
                            <atom:TreeViewItem Header="0-0-1-0" />
                            <atom:TreeViewItem Header="0-0-1-1" />
                            <atom:TreeViewItem Header="0-0-1-2" />
                        </atom:TreeViewItem>
                        <atom:TreeViewItem Header="0-0-2" />
                    </atom:TreeViewItem>
                    <atom:TreeViewItem Header="0-1">
                        <atom:TreeViewItem Header="0-1-0">
                            <atom:TreeViewItem Header="0-1-0-0" />
                            <atom:TreeViewItem Header="0-1-0-1" />
                            <atom:TreeViewItem Header="0-1-0-2" />
                        </atom:TreeViewItem>
                        <atom:TreeViewItem Header="0-1-1">
                            <atom:TreeViewItem Header="0-1-1-0" />
                            <atom:TreeViewItem Header="0-1-1-1" />
                            <atom:TreeViewItem Header="0-1-1-2" />
                        </atom:TreeViewItem>
                        <atom:TreeViewItem Header="0-0-2" />
                    </atom:TreeViewItem>
                    <atom:TreeViewItem Header="0-2">
                    </atom:TreeViewItem>
                </atom:TreeView>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TreeViewShowCaseLangResource ContextMenuTitle}"
            Description="{gallery:TreeViewShowCaseLangResource ContextMenuDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock VerticalAlignment="Center">IsSelectOnRightClick:</TextBlock>
                    <atom:ToggleSwitch Name="ContextMenuSelectOnRightClickSwitch" IsChecked="True" VerticalAlignment="Center"/>
                </StackPanel>
                <atom:TreeView Name="ContextMenuTree"
                               NodeHoverMode="Block"
                               IsDefaultExpandAll="True"
                               IsSelectOnRightClick="{Binding #ContextMenuSelectOnRightClickSwitch.IsChecked}"
                               ItemContextMenuRequest="HandleContextMenuTreeItemContextMenuRequest">
                <atom:TreeView.Resources>
                    <atom:MenuFlyout x:Key="TreeItemContextMenu" Placement="Pointer">
                        <atom:MenuItem Header="New Node" Click="HandleContextMenuNewNodeClick">
                            <atom:MenuItem.Icon>
                                <antdicons:PlusOutlined />
                            </atom:MenuItem.Icon>
                        </atom:MenuItem>
                        <atom:MenuItem Header="Rename" Click="HandleContextMenuRenameClick">
                            <atom:MenuItem.Icon>
                                <antdicons:EditOutlined />
                            </atom:MenuItem.Icon>
                        </atom:MenuItem>
                        <atom:MenuSeparator />
                        <atom:MenuItem Header="Delete" Click="HandleContextMenuDeleteClick">
                            <atom:MenuItem.Icon>
                                <antdicons:DeleteOutlined />
                            </atom:MenuItem.Icon>
                        </atom:MenuItem>
                    </atom:MenuFlyout>
                </atom:TreeView.Resources>
                <atom:TreeViewItem Header="parent 1">
                    <atom:TreeViewItem Header="parent 1-0">
                        <atom:TreeViewItem Header="leaf 1" />
                        <atom:TreeViewItem Header="leaf 2" />
                    </atom:TreeViewItem>
                    <atom:TreeViewItem Header="parent 1-1">
                        <atom:TreeViewItem Header="leaf" />
                    </atom:TreeViewItem>
                </atom:TreeViewItem>
                <atom:TreeViewItem Header="parent 2">
                    <atom:TreeViewItem Header="parent 2-0">
                        <atom:TreeViewItem Header="leaf 1" />
                        <atom:TreeViewItem Header="leaf 2" />
                    </atom:TreeViewItem>
                </atom:TreeViewItem>
            </atom:TreeView>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>