<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Cascader.CascaderShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.Cascader"
             x:DataType="vm:CascaderViewModel">
    <atom:TabControl Name="ScenarioTabs"
                     SizeType="Large"
                     SelectedIndex="0">
        <atom:TabItem Header="{gallery:CascaderShowCaseLangResource ScenarioBasic}" Tag="Basic" />
        <atom:TabItem Header="{gallery:CascaderShowCaseLangResource ScenarioMultiple}" Tag="Multiple" />
        <atom:TabItem Header="{gallery:CascaderShowCaseLangResource ScenarioAdvanced}" Tag="Advanced" />
        <atom:TabItem Header="{gallery:CascaderShowCaseLangResource ScenarioCascaderView}" Tag="CascaderView" />
    </atom:TabControl>
</UserControl>
