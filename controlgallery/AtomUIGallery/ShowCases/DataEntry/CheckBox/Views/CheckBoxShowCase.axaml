<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.CheckBox.CheckBoxShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.CheckBox"
             x:DataType="vm:CheckBoxViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCasePanel.Styles>
            <Style Selector="atom|CheckBox">
                <Setter Property="Margin" Value="0, 0, 5, 5" />
            </Style>
        </gallery:ShowCasePanel.Styles>
        <gallery:ShowCaseItem
            Title="{gallery:CheckBoxShowCaseLangResource BasicTitle}"
            Description="{gallery:CheckBoxShowCaseLangResource BasicDescription}">
            <StackPanel HorizontalAlignment="Left" Spacing="10">
                <atom:CheckBox Content="{gallery:CheckBoxShowCaseLangResource P2ContentCheckbox}" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:CheckBoxShowCaseLangResource DisabledTitle}"
            Description="{gallery:CheckBoxShowCaseLangResource DisabledDescription}">
            <StackPanel HorizontalAlignment="Left" Spacing="10" Orientation="Vertical">
                <atom:CheckBox IsChecked="False" IsEnabled="False" Content="{gallery:CheckBoxShowCaseLangResource P2ContentUnchecked}" />
                <atom:CheckBox IsChecked="{x:Null}" IsEnabled="False" Content="{gallery:CheckBoxShowCaseLangResource P2ContentIndeterminate}" />
                <atom:CheckBox IsChecked="True" IsEnabled="False" Content="{gallery:CheckBoxShowCaseLangResource P2ContentChecked}" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:CheckBoxShowCaseLangResource ControlledCheckboxTitle}"
            Description="{gallery:CheckBoxShowCaseLangResource ControlledCheckboxDescription}">
            <StackPanel HorizontalAlignment="Left" Spacing="10" Orientation="Vertical">
                <atom:CheckBox Name="ControlledCheckbox"
                    IsChecked="{Binding ControlledCheckBoxCheckedStatus}"
                               IsEnabled="{Binding ControlledCheckBoxEnabledStatus}"
                               Content="{Binding ControlledCheckBoxText}" />
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0, 10, 0, 0">
                    <atom:Button SizeType="Small" ButtonType="Primary"
                                 Name="CheckStatusBtn"
                                 Content="{Binding CheckStatusBtnText}" />
                    <atom:Button SizeType="Small" ButtonType="Primary"
                                 Name="EnableStatusBtn"
                                 Content="{Binding EnableStatusBtnText}" />
                </StackPanel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:CheckBoxShowCaseLangResource CheckboxGroupTitle}"
            Description="{gallery:CheckBoxShowCaseLangResource CheckboxGroupDescription}">
            <StackPanel HorizontalAlignment="Left" Spacing="10" Orientation="Vertical">
                <atom:CheckBoxGroup>
                    <atom:CheckBox IsChecked="True" Content="{gallery:CheckBoxShowCaseLangResource P2ContentApple}" />
                    <atom:CheckBox IsChecked="True" Content="{gallery:CheckBoxShowCaseLangResource P2ContentPear}" />
                    <atom:CheckBox IsChecked="True" Content="{gallery:CheckBoxShowCaseLangResource P2ContentOrange}" />
                </atom:CheckBoxGroup>
                <atom:CheckBoxGroup>
                    <atom:CheckBox Content="{gallery:CheckBoxShowCaseLangResource P2ContentApple}" />
                    <atom:CheckBox IsChecked="True" Content="{gallery:CheckBoxShowCaseLangResource P2ContentPear}" />
                    <atom:CheckBox Content="{gallery:CheckBoxShowCaseLangResource P2ContentOrange}" />
                </atom:CheckBoxGroup>
                <atom:CheckBoxGroup>
                    <atom:CheckBox IsChecked="True" IsEnabled="False" Content="{gallery:CheckBoxShowCaseLangResource P2ContentApple}" />
                    <atom:CheckBox IsEnabled="False" Content="{gallery:CheckBoxShowCaseLangResource P2ContentPear}" />
                    <atom:CheckBox IsEnabled="False" Content="{gallery:CheckBoxShowCaseLangResource P2ContentOrange}" />
                </atom:CheckBoxGroup>
                <atom:CheckBoxGroup Name="BasicCheckBoxGroup"/>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:CheckBoxShowCaseLangResource CheckAllTitle}"
            Description="{gallery:CheckBoxShowCaseLangResource CheckAllDescription}">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Spacing="10">
                <StackPanel>
                    <atom:CheckBox Name="CheckAllCheckbox"
                                   IsChecked="{Binding CheckedAllStatus}" Content="{gallery:CheckBoxShowCaseLangResource P2ContentCheckAll}" />
                </StackPanel>
                <WrapPanel Margin="0, 20, 0, 0">
                    <atom:CheckBox Name="AppleCheckBox"
                                   IsChecked="{Binding AppleCheckedStatus}" Content="{gallery:CheckBoxShowCaseLangResource P2ContentApple}" />
                    <atom:CheckBox Name="PearCheckBox"
                                   IsChecked="{Binding PearCheckedStatus}" Content="{gallery:CheckBoxShowCaseLangResource P2ContentPear}" />
                    <atom:CheckBox Name="OrangeCheckBox"
                                   IsChecked="{Binding OrangeCheckedStatus}" Content="{gallery:CheckBoxShowCaseLangResource P2ContentOrange}" />
                </WrapPanel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:CheckBoxShowCaseLangResource UseWithGridTitle}"
            Description="{gallery:CheckBoxShowCaseLangResource UseWithGridDescription}">
            <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto" Margin="10">
                <atom:CheckBox Grid.Row="0" Grid.Column="0" Content="{gallery:CheckBoxShowCaseLangResource P2ContentA}" />
                <atom:CheckBox Grid.Row="0" Grid.Column="1" Content="{gallery:CheckBoxShowCaseLangResource P2ContentB}" />
                <atom:CheckBox Grid.Row="0" Grid.Column="2" Content="{gallery:CheckBoxShowCaseLangResource P2ContentC}" />
                <atom:CheckBox Grid.Row="1" Grid.Column="0" Content="{gallery:CheckBoxShowCaseLangResource P2ContentD}" />
                <atom:CheckBox Grid.Row="1" Grid.Column="1" Content="{gallery:CheckBoxShowCaseLangResource P2ContentD}" />
            </Grid>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
