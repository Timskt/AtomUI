<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.CheckBox.CheckBoxShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.CheckBox"
             x:DataType="vm:CheckBoxViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCasePanel.Styles>
            <Style Selector="atom|CheckBox">
                <Setter Property="Margin" Value="0, 0, 5, 5" />
            </Style>
        </gallery:ShowCasePanel.Styles>
        <gallery:ShowCaseItem
            Title="{gallery:CheckBoxShowCaseLangResource BasicTitle}"
            Description="{gallery:CheckBoxShowCaseLangResource BasicDescription}">
            <StackPanel HorizontalAlignment="Left" Spacing="10">
                <atom:CheckBox>Checkbox</atom:CheckBox>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:CheckBoxShowCaseLangResource DisabledTitle}"
            Description="{gallery:CheckBoxShowCaseLangResource DisabledDescription}">
            <StackPanel HorizontalAlignment="Left" Spacing="10" Orientation="Vertical">
                <atom:CheckBox IsChecked="False" IsEnabled="False">UnChecked</atom:CheckBox>
                <atom:CheckBox IsChecked="{x:Null}" IsEnabled="False">Indeterminate</atom:CheckBox>
                <atom:CheckBox IsChecked="True" IsEnabled="False">Checked</atom:CheckBox>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:CheckBoxShowCaseLangResource ControlledCheckboxTitle}"
            Description="{gallery:CheckBoxShowCaseLangResource ControlledCheckboxDescription}">
            <StackPanel HorizontalAlignment="Left" Spacing="10" Orientation="Vertical">
                <atom:CheckBox Name="ControlledCheckbox"
                    IsChecked="{Binding ControlledCheckBoxCheckedStatus}"
                               IsEnabled="{Binding ControlledCheckBoxEnabledStatus}"
                               Content="{Binding ControlledCheckBoxText}" />
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0, 10, 0, 0">
                    <atom:Button SizeType="Small" ButtonType="Primary"
                                 Name="CheckStatusBtn"
                                 Content="{Binding CheckStatusBtnText}" />
                    <atom:Button SizeType="Small" ButtonType="Primary"
                                 Name="EnableStatusBtn"
                                 Content="{Binding EnableStatusBtnText}" />
                </StackPanel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:CheckBoxShowCaseLangResource CheckboxGroupTitle}"
            Description="{gallery:CheckBoxShowCaseLangResource CheckboxGroupDescription}">
            <StackPanel HorizontalAlignment="Left" Spacing="10" Orientation="Vertical">
                <atom:CheckBoxGroup>
                    <atom:CheckBox IsChecked="True">Apple</atom:CheckBox>
                    <atom:CheckBox IsChecked="True">Pear</atom:CheckBox>
                    <atom:CheckBox IsChecked="True">Orange</atom:CheckBox>
                </atom:CheckBoxGroup>
                <atom:CheckBoxGroup>
                    <atom:CheckBox>Apple</atom:CheckBox>
                    <atom:CheckBox IsChecked="True">Pear</atom:CheckBox>
                    <atom:CheckBox>Orange</atom:CheckBox>
                </atom:CheckBoxGroup>
                <atom:CheckBoxGroup>
                    <atom:CheckBox IsChecked="True" IsEnabled="False">Apple</atom:CheckBox>
                    <atom:CheckBox IsEnabled="False">Pear</atom:CheckBox>
                    <atom:CheckBox IsEnabled="False">Orange</atom:CheckBox>
                </atom:CheckBoxGroup>
                <atom:CheckBoxGroup Name="BasicCheckBoxGroup"/>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:CheckBoxShowCaseLangResource CheckAllTitle}"
            Description="{gallery:CheckBoxShowCaseLangResource CheckAllDescription}">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Spacing="10">
                <StackPanel>
                    <atom:CheckBox Name="CheckAllCheckbox"
                                   IsChecked="{Binding CheckedAllStatus}">
                        Check all
                    </atom:CheckBox>
                </StackPanel>
                <WrapPanel Margin="0, 20, 0, 0">
                    <atom:CheckBox Name="AppleCheckBox"
                                   IsChecked="{Binding AppleCheckedStatus}">
                        Apple
                    </atom:CheckBox>
                    <atom:CheckBox Name="PearCheckBox"
                                   IsChecked="{Binding PearCheckedStatus}">
                        Pear
                    </atom:CheckBox>
                    <atom:CheckBox Name="OrangeCheckBox"
                                   IsChecked="{Binding OrangeCheckedStatus}">
                        Orange
                    </atom:CheckBox>
                </WrapPanel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:CheckBoxShowCaseLangResource UseWithGridTitle}"
            Description="{gallery:CheckBoxShowCaseLangResource UseWithGridDescription}">
            <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto" Margin="10">
                <atom:CheckBox Grid.Row="0" Grid.Column="0">A</atom:CheckBox>
                <atom:CheckBox Grid.Row="0" Grid.Column="1">B</atom:CheckBox>
                <atom:CheckBox Grid.Row="0" Grid.Column="2">C</atom:CheckBox>
                <atom:CheckBox Grid.Row="1" Grid.Column="0">D</atom:CheckBox>
                <atom:CheckBox Grid.Row="1" Grid.Column="1">D</atom:CheckBox>
            </Grid>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
