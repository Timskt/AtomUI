<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.DatePicker.DatePickerShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.DatePicker"
             x:DataType="vm:DatePickerViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:DatePickerShowCaseLangResource BasicTitle}"
            Description="{gallery:DatePickerShowCaseLangResource BasicDescription}">
            <atom:DatePicker PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextSelectDate}"/>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:DatePickerShowCaseLangResource RangePickerTitle}"
            Description="{gallery:DatePickerShowCaseLangResource RangePickerDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <!-- <atom:RangeDatePicker IsShowTime="true" PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextSelectDate}" SecondaryPlaceholderText="{gallery:DatePickerShowCaseLangResource P2SecondaryPlaceholderTextEndDate}"/> -->
                <atom:RangeDatePicker IsShowTime="False" PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextSelectDate}" SecondaryPlaceholderText="{gallery:DatePickerShowCaseLangResource P2SecondaryPlaceholderTextEndDate}" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:DatePickerShowCaseLangResource NeedConfirmTitle}"
            Description="{gallery:DatePickerShowCaseLangResource NeedConfirmDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:DatePicker IsNeedConfirm="True" PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextSelectDate}" />
                <atom:RangeDatePicker IsNeedConfirm="True" IsShowTime="False" PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextSelectDate}" SecondaryPlaceholderText="{gallery:DatePickerShowCaseLangResource P2SecondaryPlaceholderTextEndDate}" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:DatePickerShowCaseLangResource ChooseTimeTitle}"
            Description="{gallery:DatePickerShowCaseLangResource ChooseTimeDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:DatePicker IsNeedConfirm="True" IsShowTime="True" PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextSelectDate}" />
                <atom:RangeDatePicker IsNeedConfirm="True" IsShowTime="True" PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextSelectDate}" SecondaryPlaceholderText="{gallery:DatePickerShowCaseLangResource P2SecondaryPlaceholderTextEndDate}" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:DatePickerShowCaseLangResource DisabledTitle}"
            Description="{gallery:DatePickerShowCaseLangResource DisabledDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:DatePicker IsNeedConfirm="True" PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextSelectDate}" SelectedDateTime="2024-01-20"
                                 IsEnabled="False" />
                <atom:DatePicker IsNeedConfirm="True" PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextSelectDate}" IsShowTime="True"
                                 SelectedDateTime="2024-01-20 12:22:23 AM" IsEnabled="False" />
                <atom:RangeDatePicker IsNeedConfirm="True"
                                      PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextSelectDate}"
                                      SecondaryPlaceholderText="{gallery:DatePickerShowCaseLangResource P2SecondaryPlaceholderTextEndDate}"
                                      RangeStartDefaultDate="2024-01-20"
                                      RangeEndDefaultDate="2024-03-20"
                                      IsEnabled="False" />
                <atom:RangeDatePicker IsNeedConfirm="True"
                                      PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextSelectDate}"
                                      SecondaryPlaceholderText="{gallery:DatePickerShowCaseLangResource P2SecondaryPlaceholderTextEndDate}"
                                      IsShowTime="True"
                                      RangeStartDefaultDate="2024-01-20 12:22:23 AM"
                                      RangeEndDefaultDate="2024-02-20 07:22:23 AM"
                                      IsEnabled="False" />
                <atom:RangeDatePicker IsNeedConfirm="True"
                                      PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextSelectDate}"
                                      SecondaryPlaceholderText="{gallery:DatePickerShowCaseLangResource P2SecondaryPlaceholderTextEndDate}"
                                      IsShowTime="True"
                                      RangeStartDefaultDate="2024-01-20 12:22:23 AM"
                                      RangeEndDefaultDate="2024-02-20 07:22:23 AM" />
                <atom:DatePicker IsNeedConfirm="True" PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextSelectDate}" SelectedDateTime="2024-01-20" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:DatePickerShowCaseLangResource ThreeSizesTitle}"
            Description="{gallery:DatePickerShowCaseLangResource ThreeSizesDescription}">

            <DockPanel Margin="0, 0, 0, 0">
                <StackPanel Orientation="Horizontal" Spacing="5" DockPanel.Dock="Top">
                    <atom:TextBlock VerticalAlignment="Center" Text="{gallery:DatePickerShowCaseLangResource P2TextExpandDirection}" />
                    <atom:OptionButtonGroup ButtonStyle="Outline" Name="PickerSizeTypeOptionGroup">
                        <atom:OptionButton Content="{gallery:DatePickerShowCaseLangResource P2ContentLarge}" />
                        <atom:OptionButton IsChecked="True" Content="{gallery:DatePickerShowCaseLangResource P2ContentDefault}" />
                        <atom:OptionButton Content="{gallery:DatePickerShowCaseLangResource P2ContentSmall}" />
                    </atom:OptionButtonGroup>
                </StackPanel>

                <StackPanel Orientation="Vertical" Margin="0, 20, 0, 0" Spacing="10">
                    <atom:DatePicker IsNeedConfirm="True" PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextSelectDate}" SelectedDateTime="2024-01-20"
                                     SizeType="{Binding PickerSizeType}" />
                    <atom:RangeDatePicker IsNeedConfirm="True"
                                          PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextSelectDate}"
                                          SecondaryPlaceholderText="{gallery:DatePickerShowCaseLangResource P2SecondaryPlaceholderTextEndDate}"
                                          IsShowTime="True"
                                          RangeStartDefaultDate="2024-01-20 12:22:23 AM"
                                          RangeEndDefaultDate="2024-02-20 07:22:23 AM"
                                          SizeType="{Binding PickerSizeType}" />
                </StackPanel>
            </DockPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:DatePickerShowCaseLangResource StatusTitle}"
            Description="{gallery:DatePickerShowCaseLangResource StatusDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <atom:DatePicker Status="Default"
                                     PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextSelectTime}" />
                    <atom:RangeDatePicker StyleVariant="Outlined"
                                          Status="Default"
                                          PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextStartDate}"
                                          SecondaryPlaceholderText="{gallery:DatePickerShowCaseLangResource P2SecondaryPlaceholderTextEndDate}"
                                          IsNeedConfirm="True"
                                          ClockIdentifier="HourClock24" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <atom:DatePicker Status="Warning"
                                     PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextSelectTime}" />
                    <atom:RangeDatePicker StyleVariant="Outlined"
                                          Status="Warning"
                                          PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextStartDate}"
                                          SecondaryPlaceholderText="{gallery:DatePickerShowCaseLangResource P2SecondaryPlaceholderTextEndDate}"
                                          IsNeedConfirm="True"
                                          ClockIdentifier="HourClock24" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <atom:DatePicker Status="Error"
                                     PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextSelectTime}" />
                    <atom:RangeDatePicker StyleVariant="Outlined"
                                          Status="Error"
                                          PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextStartDate}"
                                          SecondaryPlaceholderText="{gallery:DatePickerShowCaseLangResource P2SecondaryPlaceholderTextEndDate}"
                                          IsNeedConfirm="True"
                                          ClockIdentifier="HourClock24" />
                </StackPanel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:DatePickerShowCaseLangResource VariantsTitle}"
            Description="{gallery:DatePickerShowCaseLangResource VariantsDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <atom:DatePicker StyleVariant="Outlined"
                                     PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextOutline}" />
                    <atom:RangeDatePicker StyleVariant="Outlined"
                                          SecondaryPlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextOutline}"
                                          IsNeedConfirm="True"
                                          ClockIdentifier="HourClock24"
                                          PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextOutline}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <atom:DatePicker StyleVariant="Filled"
                                     PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextFilled}" />
                    <atom:RangeDatePicker StyleVariant="Filled"
                                          SecondaryPlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextFilled}"
                                          IsNeedConfirm="True"
                                          ClockIdentifier="HourClock24"
                                          PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextFilled}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <atom:DatePicker StyleVariant="Filled"
                                     Status="Error"
                                     PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextFilled}" />
                    <atom:RangeDatePicker StyleVariant="Filled"
                                          Status="Error"
                                          SecondaryPlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextFilled}"
                                          IsNeedConfirm="True"
                                          ClockIdentifier="HourClock24"
                                          PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextFilled}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <atom:DatePicker StyleVariant="Borderless"
                                     PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextBorderless}" />
                    <atom:RangeDatePicker StyleVariant="Borderless"
                                          SecondaryPlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextBorderless}"
                                          IsNeedConfirm="True"
                                          ClockIdentifier="HourClock24"
                                          PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextBorderless}" />
                </StackPanel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:DatePickerShowCaseLangResource PlacementTitle}"
            Description="{gallery:DatePickerShowCaseLangResource PlacementDescription}">

            <DockPanel Margin="0, 0, 0, 0">
                <StackPanel Orientation="Horizontal" Spacing="5" DockPanel.Dock="Top">
                    <atom:TextBlock VerticalAlignment="Center" Text="{gallery:DatePickerShowCaseLangResource P2TextPlacement}" />
                    <atom:OptionButtonGroup ButtonStyle="Outline" Name="PickerPlacementOptionGroup">
                        <atom:OptionButton Content="{gallery:DatePickerShowCaseLangResource P2ContentTopleft}" />
                        <atom:OptionButton Content="{gallery:DatePickerShowCaseLangResource P2ContentTopright}" />
                        <atom:OptionButton IsChecked="true" Content="{gallery:DatePickerShowCaseLangResource P2ContentBottomleft}" />
                        <atom:OptionButton Content="{gallery:DatePickerShowCaseLangResource P2ContentBottomright}" />
                    </atom:OptionButtonGroup>
                </StackPanel>

                <StackPanel Orientation="Vertical" Margin="0, 20, 0, 0" Spacing="10">
                    <atom:DatePicker IsNeedConfirm="True" PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextSelectDate}" SelectedDateTime="2024-01-20"
                                     PickerPlacement="{Binding PickerPlacement}" />
                    <atom:RangeDatePicker IsNeedConfirm="True" PlaceholderText="{gallery:DatePickerShowCaseLangResource P2PlaceholderTextSelectDate}" IsShowTime="True"
                                          RangeStartDefaultDate="2024-01-20 12:22:23 AM"
                                          RangeEndDefaultDate="2024-02-20 07:22:23 AM"
                                          PickerPlacement="{Binding PickerPlacement}" />
                </StackPanel>
            </DockPanel>
        </gallery:ShowCaseItem>

    </gallery:ShowCasePanel>
</UserControl>
