<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Form.FormBasicShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:viewModels="clr-namespace:AtomUIGallery.ShowCases.Form"
             x:DataType="viewModels:FormViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:FormShowCaseLangResource BasicUsageTitle}"
            Description="{gallery:FormShowCaseLangResource BasicUsageDescription}"
            IsOccupyEntireRow="True">
            <atom:Form LabelColInfo="8*"
                       WrapperColInfo="16*"
                       MinWidth="600"
                       HorizontalAlignment="Left"
                       Name="BasicForm">
                <atom:FormItem LabelText="Username"
                               FieldName="username"
                               IsRequired="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormStringNotEmptyValidator Message="Please input your username!" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit />
                </atom:FormItem>
                <atom:FormItem LabelText="Password"
                               FieldName="password"
                               IsRequired="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormStringNotEmptyValidator Message="Please input your password!" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit RevealPassword="False"
                                   PasswordChar="•"
                                   IsEnableRevealButton="True" />
                </atom:FormItem>
                <atom:FormItem FieldName="remember">
                    <atom:CheckBox>Remember me</atom:CheckBox>
                </atom:FormItem>
        
                <atom:FormActionsItem>
                    <atom:SubmitButton />
                </atom:FormActionsItem>
            </atom:Form>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="{gallery:FormShowCaseLangResource FormMethodsTitle}"
            Description="{gallery:FormShowCaseLangResource FormMethodsDescription}"
            IsOccupyEntireRow="True">
            <atom:Form LabelColInfo="8*"
                       WrapperColInfo="16*"
                       MinWidth="600"
                       HorizontalAlignment="Left">
                <gallery:NoteFormItem LabelText="Note"
                                      FieldName="note"
                                      IsRequired="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormStringNotEmptyValidator Message="Please enter Note" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit />
                </gallery:NoteFormItem>
                <atom:FormItem LabelText="Gender"
                               FieldName="gender"
                               IsRequired="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormNotNullValidator Message="Please enter Gender" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:Select IsAllowClear="True"
                                 PlaceholderText="Select a option and change input text above"
                                 HorizontalAlignment="Stretch">
                        <atom:SelectOption Header="male" Content="male" />
                        <atom:SelectOption Header="female" Content="female" />
                        <atom:SelectOption Header="other" Content="other" />
                    </atom:Select>
                </atom:FormItem>
                <gallery:CustomizeGenderFormItem LabelText="Customize Gender"
                                                 FieldName="customizeGender"
                                                 IsRequired="True"
                                                 IsVisible="False">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormStringNotEmptyValidator Message="Please enter Customize Gender" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit />
                </gallery:CustomizeGenderFormItem>
        
                <atom:FormActionsItem>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <atom:SubmitButton />
                        <atom:ResetButton />
                    </StackPanel>
                </atom:FormActionsItem>
            </atom:Form>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
