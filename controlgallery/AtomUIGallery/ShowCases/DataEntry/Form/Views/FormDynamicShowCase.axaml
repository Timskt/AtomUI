<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Form.FormDynamicShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:viewModels="clr-namespace:AtomUIGallery.ShowCases.Form"
             x:DataType="viewModels:FormViewModel">
    <gallery:ShowCasePanel>
        
        <gallery:ShowCaseItem
            Title="{gallery:FormShowCaseLangResource DynamicFormItemTitle}"
            Description="{gallery:FormShowCaseLangResource DynamicFormItemDescription}"
            IsOccupyEntireRow="True">
            <atom:Form LabelColInfo="8*"
                       WrapperColInfo="16*"
                       MinWidth="600"
                       HorizontalAlignment="Left"
                       Name="DynamicForm">
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextPassengers}"
                               FieldName="passengers">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseInputPassengerSNameOrDeleteThisField}" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit />
                </atom:FormItem>
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextPassengers1}"
                               FieldName="passengers1">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseInputPassengerSNameOrDeleteThisField}" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit />
                </atom:FormItem>
        
                <atom:FormActionsItem>
                    <atom:Button ButtonType="Dashed" HorizontalAlignment="Stretch" Icon="{antdicons:AntDesignIconProvider PlusOutlined}"
                                 Click="HandleAddFormItem" Content="{gallery:FormShowCaseLangResource P2ContentAddField}" />
                </atom:FormActionsItem>
                <atom:FormActionsItem>
                    <atom:Button ButtonType="Dashed" HorizontalAlignment="Stretch" Icon="{antdicons:AntDesignIconProvider PlusOutlined}"
                                 Click="HandleAddFormItemAtHead" Content="{gallery:FormShowCaseLangResource P2ContentAddFieldAtHead}" />
                </atom:FormActionsItem>
                <atom:FormActionsItem>
                    <atom:SubmitButton />
                </atom:FormActionsItem>
            </atom:Form>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
