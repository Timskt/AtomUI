<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Form.FormPresetShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:viewModels="clr-namespace:AtomUIGallery.ShowCases.Form"
             x:DataType="viewModels:FormViewModel">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://AtomUIGallery/ShowCases/DataEntry/Form/ShowCaseControls/FormThemes.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <gallery:ShowCasePanel>

        <gallery:ShowCaseItem
            Title="{gallery:FormShowCaseLangResource InlineLoginFormTitle}"
            Description="{gallery:FormShowCaseLangResource InlineLoginFormDescription}"
            IsOccupyEntireRow="True">
            <atom:Form LabelColInfo="8*"
                       WrapperColInfo="16*"
                       MinWidth="600"
                       HorizontalAlignment="Left"
                       FormLayout="Inline">
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextUsername}"
                               FieldName="username">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseInputYourUsername}" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit InnerLeftContent="{antdicons:AntDesignIconProvider UserOutlined}"
                                   PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextUsername}"
                                   Width="200"/>
                </atom:FormItem>
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextPassword}"
                               FieldName="password">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseInputYourPassword}" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit InnerLeftContent="{antdicons:AntDesignIconProvider LockOutlined}"
                                   PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextPassword}"
                                   Width="200"/>
                </atom:FormItem>
                <atom:FormActionsItem>
                    <atom:SubmitButton IsWatchValidateResult="True" Content="{gallery:FormShowCaseLangResource P2ContentLogIn}"/>
                </atom:FormActionsItem>
            </atom:Form>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="{gallery:FormShowCaseLangResource LoginFormTitle}"
            Description="{gallery:FormShowCaseLangResource LoginFormDescription}"
            IsOccupyEntireRow="True">
            <atom:Form LabelColInfo="8*"
                       WrapperColInfo="16*"
                       MinWidth="400"
                       HorizontalAlignment="Left"
                       IsHideItemLabel="True">
                <atom:FormItem FieldName="username">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseInputYourUsername}" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit InnerLeftContent="{antdicons:AntDesignIconProvider UserOutlined}"
                                   PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextUsername}"/>
                </atom:FormItem>
                <atom:FormItem FieldName="password">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseInputYourPassword}" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit InnerLeftContent="{antdicons:AntDesignIconProvider LockOutlined}"
                                   PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextPassword}"/>
                </atom:FormItem>
                <atom:FormItem FieldName="remember">
                    <atom:CheckBox IsChecked="True" Content="{gallery:FormShowCaseLangResource P2ContentRememberMe}" />
                    <atom:FormItem.Extra>
                        <atom:HyperLinkButton Content="{gallery:FormShowCaseLangResource P2ContentForgotPassword}" />
                    </atom:FormItem.Extra>
                </atom:FormItem>
                <atom:FormActionsItem>
                    <StackPanel>
                        <atom:SubmitButton Content="{gallery:FormShowCaseLangResource P2ContentLogIn}" HorizontalAlignment="Stretch"/>
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="{gallery:FormShowCaseLangResource P2TextOr}" />
                            <atom:HyperLinkTextBlock Text="{gallery:FormShowCaseLangResource P2ContentRegisterNow}" />
                        </StackPanel>
                    </StackPanel>
                </atom:FormActionsItem>
            </atom:Form>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:FormShowCaseLangResource RegistrationTitle}"
            Description="{gallery:FormShowCaseLangResource RegistrationDescription}"
            IsOccupyEntireRow="True">
            <atom:Form LabelColInfo="8*"
                       WrapperColInfo="16*"
                       MinWidth="600"
                       HorizontalAlignment="Left">
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextEmail}"
                               FieldName="email"
                               IsRequired="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseInputYourEMail}" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit />
                </atom:FormItem>
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextPassword}"
                               FieldName="password"
                               IsRequired="True"
                               IsValidateFeedbackEnabled="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseInputYourPassword}" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit RevealPassword="False"
                                   PasswordChar="•"
                                   IsEnableRevealButton="True" />
                </atom:FormItem>
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextConfirmPassword}"
                               FieldName="confirm"
                               IsRequired="True"
                               IsValidateFeedbackEnabled="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseConfirmYourPassword}" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit RevealPassword="False"
                                   PasswordChar="•"
                                   IsEnableRevealButton="True" />
                </atom:FormItem>
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextNickname}"
                               FieldName="nickname"
                               IsRequired="True"
                               Tooltip="{gallery:FormShowCaseLangResource P2TooltipWhatDoYouWantOthersToCallYou}">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseInputYourNickname}" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit />
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextHabitualResidence}"
                               FieldName="residence"
                               IsRequired="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormNotNullValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseSelectYourHabitualResidence}" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:Cascader HorizontalAlignment="Stretch" IsAllowClear="True">
                        <atom:CascaderOption Header="{gallery:FormShowCaseLangResource P2HeaderZhejiang}" Value="zhejiang">
                            <atom:CascaderOption Header="{gallery:FormShowCaseLangResource P2HeaderHangzhou}" Value="hangzhou">
                                <atom:CascaderOption Header="{gallery:FormShowCaseLangResource P2HeaderWestLake}" Value="xihu" />
                            </atom:CascaderOption>
                        </atom:CascaderOption>
                        <atom:CascaderOption Header="{gallery:FormShowCaseLangResource P2HeaderJiangsu}" Value="jiangsu">
                            <atom:CascaderOption Header="{gallery:FormShowCaseLangResource P2HeaderNanjing}" Value="nanjing">
                                <atom:CascaderOption Header="{gallery:FormShowCaseLangResource P2HeaderZhongHuaMen}" Value="zhonghuamen" />
                            </atom:CascaderOption>
                        </atom:CascaderOption>
                    </atom:Cascader>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextPhoneNumber}"
                               FieldName="phone"
                               IsRequired="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseInputYourPhoneNumber}" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <gallery:PhoneNumber/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextDonation}"
                               FieldName="donation"
                               IsRequired="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormNotNullValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseInputDonationAmount}" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <gallery:Donation/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextWebsite}"
                               FieldName="website"
                               IsRequired="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseInputWebsite}" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextWebsite}"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextIntro}"
                               FieldName="intro"
                               IsRequired="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseInputIntro}" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:TextArea IsShowCount="True" MaxLength="100"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextGender}"
                               FieldName="gender"
                               IsRequired="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormNotNullValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseSelectGender}" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:Select DefaultValues="male" HorizontalAlignment="Stretch">
                        <atom:SelectOption Header="{gallery:FormShowCaseLangResource P2HeaderMale2}" Content="male"/>
                        <atom:SelectOption Header="{gallery:FormShowCaseLangResource P2HeaderFemale2}" Content="female"/>
                        <atom:SelectOption Header="{gallery:FormShowCaseLangResource P2HeaderOther2}" Content="other"/>
                    </atom:Select>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextCaptcha}"
                               FieldName="captcha"
                               IsRequired="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseInputTheCaptchaYouGot}" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <gallery:Captcha/>
                </atom:FormItem>
        
                <atom:FormItem FieldName="agreement"
                               IsRequired="True">
                    <atom:CheckBox IsChecked="True">
                       <StackPanel Orientation="Horizontal" Spacing="5">
                           <TextBlock Text="{gallery:FormShowCaseLangResource P2TextIHaveReadThe}" />
                           <atom:HyperLinkTextBlock Text="{gallery:FormShowCaseLangResource P2ContentAgreement}" />
                       </StackPanel>
                    </atom:CheckBox>
                </atom:FormItem>
                <atom:FormActionsItem>
                    <atom:SubmitButton Content="{gallery:FormShowCaseLangResource P2ContentRegister}"/>
                </atom:FormActionsItem>
            </atom:Form>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
