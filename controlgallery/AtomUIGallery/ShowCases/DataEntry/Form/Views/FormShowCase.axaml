<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Form.FormShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:viewModels="clr-namespace:AtomUIGallery.ShowCases.Form"
             x:DataType="viewModels:FormViewModel">
    <atom:TabControl Name="ScenarioTabs"
                     SizeType="Large"
                     SelectedIndex="0">
        <atom:TabItem Header="{gallery:ShowCaseScenarioLangResource Basic}" Tag="Basic" />
        <atom:TabItem Header="{gallery:ShowCaseScenarioLangResource Layout}" Tag="Layout" />
        <atom:TabItem Header="{gallery:ShowCaseScenarioLangResource States}" Tag="States" />
        <atom:TabItem Header="{gallery:ShowCaseScenarioLangResource Validation}" Tag="Validation" />
        <atom:TabItem Header="{gallery:ShowCaseScenarioLangResource Dynamic}" Tag="Dynamic" />
        <atom:TabItem Header="{gallery:ShowCaseScenarioLangResource Presets}" Tag="Presets" />
        <atom:TabItem Header="{gallery:ShowCaseScenarioLangResource Controls}" Tag="Controls" />
    </atom:TabControl>
</UserControl>
