<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Form.FormShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:viewModels="clr-namespace:AtomUIGallery.ShowCases.Form"
             x:DataType="viewModels:FormViewModel">
    <atom:TabControl Name="ScenarioTabs"
                     SizeType="Large"
                     SelectedIndex="0">
        <atom:TabItem Header="{gallery:FormShowCaseLangResource ScenarioBasic}" Tag="Basic" />
        <atom:TabItem Header="{gallery:FormShowCaseLangResource ScenarioLayout}" Tag="Layout" />
        <atom:TabItem Header="{gallery:FormShowCaseLangResource ScenarioStates}" Tag="States" />
        <atom:TabItem Header="{gallery:FormShowCaseLangResource ScenarioValidation}" Tag="Validation" />
        <atom:TabItem Header="{gallery:FormShowCaseLangResource ScenarioDynamic}" Tag="Dynamic" />
        <atom:TabItem Header="{gallery:FormShowCaseLangResource ScenarioPresets}" Tag="Presets" />
        <atom:TabItem Header="{gallery:FormShowCaseLangResource ScenarioControls}" Tag="Controls" />
    </atom:TabControl>
</UserControl>
