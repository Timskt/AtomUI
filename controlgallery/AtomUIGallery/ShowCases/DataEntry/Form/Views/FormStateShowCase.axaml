<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Form.FormStateShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:viewModels="clr-namespace:AtomUIGallery.ShowCases.Form"
             x:DataType="viewModels:FormViewModel">
    <gallery:ShowCasePanel>
        
        <gallery:ShowCaseItem
            Title="{gallery:FormShowCaseLangResource FormLayoutTitle}"
            Description="{gallery:FormShowCaseLangResource FormLayoutDescription}"
            IsOccupyEntireRow="True">
            <StackPanel Orientation="Vertical" Spacing="5">
                <atom:CheckBox IsChecked="{Binding IsFormDisabled, Mode=TwoWay}" Content="{gallery:FormShowCaseLangResource P2ContentFormDisabled}" />
                <atom:Form LabelColInfo="8*"
                           WrapperColInfo="16*"
                           MinWidth="600"
                           HorizontalAlignment="Left"
                           IsEnabled="{Binding IsFormDisabled, Converter={x:Static BoolConverters.Not}}">
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextCheckbox}" FieldName="checkbox">
                        <atom:CheckBox Content="{gallery:FormShowCaseLangResource P2ContentCheckbox}" />
                    </atom:FormItem>
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextRadio}" FieldName="radio">
                        <atom:RadioButtonGroup>
                            <atom:RadioButton Content="{gallery:FormShowCaseLangResource P2ContentApple}" />
                            <atom:RadioButton Content="{gallery:FormShowCaseLangResource P2ContentPear}" />
                        </atom:RadioButtonGroup>
                    </atom:FormItem>
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextInput}" FieldName="input">
                        <atom:LineEdit/>
                    </atom:FormItem>
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextSelect}" FieldName="select">
                        <atom:Select HorizontalAlignment="Stretch">
                            <atom:SelectOption Header="{gallery:FormShowCaseLangResource P2HeaderDemo}" Content="demo"/>
                        </atom:Select>
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextTreeSelect}" FieldName="treeSelect">
                        <atom:TreeSelect HorizontalAlignment="Stretch">
                            <atom:TreeItemNode Header="{gallery:FormShowCaseLangResource P2HeaderLight}" Value="light">
                                <atom:TreeItemNode Header="{gallery:FormShowCaseLangResource P2HeaderBamboo}" Value="bamboo"/>
                            </atom:TreeItemNode>
                        </atom:TreeSelect>
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextCascader}" FieldName="cascader">
                        <atom:Cascader HorizontalAlignment="Stretch">
                            <atom:CascaderOption Header="{gallery:FormShowCaseLangResource P2HeaderZhejiang}" Value="zhejiang">
                                <atom:CascaderOption Header="{gallery:FormShowCaseLangResource P2HeaderHangzhou}" Value="hangzhou"/>
                            </atom:CascaderOption>
                        </atom:Cascader>
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextDatePicker}" FieldName="datePicker">
                        <atom:DatePicker PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextSelectDate}"/>
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextRangePicker}" FieldName="rangePicker">
                        <atom:RangeDatePicker PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextStartDate}"
                                              SecondaryPlaceholderText="{gallery:FormShowCaseLangResource P2SecondaryPlaceholderTextEndDate}"/>
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextInputNumber}" FieldName="inputNumber">
                        <atom:NumericUpDown Width="80"/>
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextTextArea}" FieldName="textArea">
                        <atom:TextArea Lines="4"/>
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextSwitch}" FieldName="switch">
                        <atom:ToggleSwitch/>
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextUpload}" FieldName="upload">
                        <atom:Upload Name="AvatarDemoPictureCardUpload" ListType="PictureCard">
                            <StackPanel Orientation="Vertical">
                                <Panel>
                                    <antdicons:PlusOutlined IsVisible="{Binding IsTaskRunning ,RelativeSource={RelativeSource AncestorType=atom:Upload}, Converter={x:Static BoolConverters.Not}}"
                                                            StrokeBrush="{Binding Foreground ,RelativeSource={RelativeSource AncestorType=atom:Upload}}"/>
                                    <antdicons:LoadingOutlined IsVisible="{Binding IsTaskRunning ,RelativeSource={RelativeSource AncestorType=atom:Upload}}"
                                                               StrokeBrush="{Binding Foreground ,RelativeSource={RelativeSource AncestorType=atom:Upload}}"
                                                               LoadingAnimation="Spin"/>
                                </Panel>
                                <TextBlock Margin="0, 8, 0, 0" Text="{gallery:FormShowCaseLangResource P2TextUpload}" />
                            </StackPanel>
                        </atom:Upload>
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextButton}" FieldName="button">
                        <atom:Button Content="{gallery:FormShowCaseLangResource P2ContentButton}" />
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextSlider}" FieldName="slider">
                        <atom:Slider/>
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextColorPicker}" FieldName="colorPicker">
                        <atom:ColorPicker/>
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextRate}" FieldName="rate">
                        <atom:Rate/>
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextMentions}" FieldName="mentions">
                        <atom:Mentions DefaultValue="@afc163"/>
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextTree}" FieldName="tree">
                        <atom:TreeView>
                            <atom:TreeViewItem Header="{gallery:FormShowCaseLangResource P2HeaderParentN1}" ItemKey="0-0">
                                <atom:TreeViewItem Header="{gallery:FormShowCaseLangResource P2HeaderChildN1N1}" ItemKey="0-0-0">
                                    <atom:TreeViewItem Header="{gallery:FormShowCaseLangResource P2HeaderGrandchildN1N1N1}" ItemKey="0-0-0-0"/>
                                </atom:TreeViewItem>
                                <atom:TreeViewItem Header="{gallery:FormShowCaseLangResource P2HeaderChildN1N2}" ItemKey="0-0-1"/>
                            </atom:TreeViewItem>
                            <atom:TreeViewItem Header="{gallery:FormShowCaseLangResource P2HeaderParentN2}" ItemKey="0-1">
                                <atom:TreeViewItem Header="{gallery:FormShowCaseLangResource P2HeaderChildN2N1}" ItemKey="0-1-0"/>
                            </atom:TreeViewItem>
                        </atom:TreeView>
                    </atom:FormItem>
                </atom:Form>
            </StackPanel>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="{gallery:FormShowCaseLangResource FormVariantsTitle}"
            Description="{gallery:FormShowCaseLangResource FormVariantsDescription}"
            IsOccupyEntireRow="True">
            <StackPanel Orientation="Vertical" Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FormShowCaseLangResource P2TextFormVariant}" />
                    <atom:Segmented SelectionChanged="HandleFormStyleVariantChanged">
                        <atom:SegmentedItem IsSelected="True" Tag="{x:Static atom:InputControlStyleVariant.Outlined}" Content="{gallery:FormShowCaseLangResource P2ContentOutlined}" />
                        <atom:SegmentedItem Tag="{x:Static atom:InputControlStyleVariant.Filled}" Content="{gallery:FormShowCaseLangResource P2ContentFilled}" />
                        <atom:SegmentedItem Tag="{x:Static atom:InputControlStyleVariant.Borderless}" Content="{gallery:FormShowCaseLangResource P2ContentBorderless}" />
                        <atom:SegmentedItem Tag="{x:Static atom:InputControlStyleVariant.Underlined}" Content="{gallery:FormShowCaseLangResource P2ContentUnderlined}" />
                    </atom:Segmented>
                </StackPanel>
        
                <atom:Form LabelColInfo="8*"
                           WrapperColInfo="16*"
                           MinWidth="600"
                           HorizontalAlignment="Left"
                           StyleVariant="{Binding FormStyleVariant}">
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextInput}"
                                   FieldName="input"
                                   IsRequired="True">
                        <atom:FormItem.Validators>
                            <atom:FormValidatorProvider>
                                <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseInput}" />
                            </atom:FormValidatorProvider>
                        </atom:FormItem.Validators>
                        <atom:LineEdit />
                    </atom:FormItem>
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextInputNumber}"
                                   FieldName="inputNumber"
                                   IsRequired="True">
                        <atom:FormItem.Validators>
                            <atom:FormValidatorProvider>
                                <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseInput}" />
                            </atom:FormValidatorProvider>
                        </atom:FormItem.Validators>
                        <atom:NumericUpDown Width="200" />
                    </atom:FormItem>
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextTextArea}"
                                   FieldName="textArea"
                                   IsRequired="True">
                        <atom:FormItem.Validators>
                            <atom:FormValidatorProvider>
                                <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseInput}" />
                            </atom:FormValidatorProvider>
                        </atom:FormItem.Validators>
                        <atom:TextArea Lines="4" />
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextMentions}"
                                   FieldName="mentions"
                                   IsRequired="True">
                        <atom:FormItem.Validators>
                            <atom:FormValidatorProvider>
                                <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseInput}" />
                            </atom:FormValidatorProvider>
                        </atom:FormItem.Validators>
                        <atom:Mentions />
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextSelect}"
                                   FieldName="select"
                                   IsRequired="True">
                        <atom:FormItem.Validators>
                            <atom:FormValidatorProvider>
                                <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseInput}" />
                            </atom:FormValidatorProvider>
                        </atom:FormItem.Validators>
                        <atom:Select HorizontalAlignment="Stretch" />
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextCascader}"
                                   FieldName="cascader"
                                   IsRequired="True">
                        <atom:FormItem.Validators>
                            <atom:FormValidatorProvider>
                                <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseInput}" />
                            </atom:FormValidatorProvider>
                        </atom:FormItem.Validators>
                        <atom:Cascader HorizontalAlignment="Stretch" />
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextTreeSelect}"
                                   FieldName="treeSelect"
                                   IsRequired="True">
                        <atom:FormItem.Validators>
                            <atom:FormValidatorProvider>
                                <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseInput}" />
                            </atom:FormValidatorProvider>
                        </atom:FormItem.Validators>
                        <atom:TreeSelect HorizontalAlignment="Stretch" />
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextDatePicker}"
                                   FieldName="datePicker"
                                   IsRequired="True">
                        <atom:FormItem.Validators>
                            <atom:FormValidatorProvider>
                                <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseInput}" />
                            </atom:FormValidatorProvider>
                        </atom:FormItem.Validators>
                        <atom:DatePicker PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextPleaseSelect}" />
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextRangePicker}"
                                   FieldName="rangePicker"
                                   IsRequired="True">
                        <atom:FormItem.Validators>
                            <atom:FormValidatorProvider>
                                <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseInput}" />
                            </atom:FormValidatorProvider>
                        </atom:FormItem.Validators>
                        <atom:RangeDatePicker PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextStartDate}"
                                              SecondaryPlaceholderText="{gallery:FormShowCaseLangResource P2SecondaryPlaceholderTextEndDate}" />
                    </atom:FormItem>
        
                    <atom:FormActionsItem>
                        <atom:SubmitButton />
                    </atom:FormActionsItem>
                </atom:Form>
            </StackPanel>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="{gallery:FormShowCaseLangResource RequiredStyleTitle}"
            Description="{gallery:FormShowCaseLangResource RequiredStyleDescription}"
            IsOccupyEntireRow="True">
            <StackPanel Orientation="Vertical" Spacing="20">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FormShowCaseLangResource P2TextRequiredMark}" />
                    <atom:OptionButtonGroup ButtonStyle="Outline" OptionCheckedChanged="HandleFormRequiredMarkChanged">
                        <atom:OptionButton IsChecked="True" Tag="{x:Static atom:FormRequiredMark.Default}" Content="{gallery:FormShowCaseLangResource P2ContentDefault}" />
                        <atom:OptionButton Tag="{x:Static atom:FormRequiredMark.Optional}" Content="{gallery:FormShowCaseLangResource P2ContentOptional}" />
                        <atom:OptionButton Tag="{x:Static atom:FormRequiredMark.Hidden}" Content="{gallery:FormShowCaseLangResource P2ContentHidden}" />
                        <atom:OptionButton Tag="{x:Static atom:FormRequiredMark.Customize}" Content="{gallery:FormShowCaseLangResource P2ContentCustomize}" />
                    </atom:OptionButtonGroup>
                </StackPanel>
        
                <atom:Form LabelColInfo="8*"
                           WrapperColInfo="16*"
                           HorizontalAlignment="Left"
                           MinWidth="600"
                           FormLayout="Horizontal"
                           RequiredMark="{Binding FormRequiredMark}">
                    <atom:Form.CustomRequireMark>
                        <atom:Tag TagColor="Error" Text="{gallery:FormShowCaseLangResource P2ContentRequired}" />
                    </atom:Form.CustomRequireMark>
                    <atom:Form.CustomOptionalMark>
                        <atom:Tag TagColor="Warning" Text="{gallery:FormShowCaseLangResource P2ContentOptional2}" />
                    </atom:Form.CustomOptionalMark>
                    <atom:FormItem IsRequired="True" LabelText="{gallery:FormShowCaseLangResource P2LabelTextFieldA}" FieldName="FieldA" Tooltip="{gallery:FormShowCaseLangResource P2TooltipThisIsARequiredField}">
                        <atom:LineEdit PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextInputPlaceholder}"/>
                    </atom:FormItem>
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextFieldB}" FieldName="Field B" Tooltip="{gallery:FormShowCaseLangResource P2TooltipTooltipWithCustomizeIcon}"
                                   TooltipIcon="{antdicons:AntDesignIconProvider InfoCircleOutlined}">
                        <atom:LineEdit PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextInputPlaceholder}"/>
                    </atom:FormItem>
                    <atom:FormActionsItem>
                        <atom:SubmitButton/>
                    </atom:FormActionsItem>
                </atom:Form>
            </StackPanel>
        
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="{gallery:FormShowCaseLangResource RequiredStyleTitle}"
            Description="{gallery:FormShowCaseLangResource RequiredStyleDescription}"
            IsOccupyEntireRow="True">
            <StackPanel Orientation="Vertical" Spacing="20">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FormShowCaseLangResource P2TextRequiredMark}" />
                    <atom:OptionButtonGroup ButtonStyle="Outline" OptionCheckedChanged="HandleFormSizeTypeChanged">
                        <atom:OptionButton Tag="{x:Static atom:SizeType.Small}" Content="{gallery:FormShowCaseLangResource P2ContentSmall}" />
                        <atom:OptionButton Tag="{x:Static atom:SizeType.Middle}" IsChecked="True" Content="{gallery:FormShowCaseLangResource P2ContentMiddle}" />
                        <atom:OptionButton Tag="{x:Static atom:SizeType.Large}" Content="{gallery:FormShowCaseLangResource P2ContentLarge}" />
                    </atom:OptionButtonGroup>
                </StackPanel>
        
                <atom:Form LabelColInfo="8*"
                           WrapperColInfo="16*"
                           MinWidth="600"
                           HorizontalAlignment="Left"
                           SizeType="{Binding FormSizeType}">
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextInput}"
                                   FieldName="input">
                        <atom:LineEdit />
                    </atom:FormItem>
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextInputNumber}"
                                   FieldName="inputNumber">
                        <atom:NumericUpDown Width="200" />
                    </atom:FormItem>
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextSwitch}"
                                   FieldName="switch">
                        <atom:ToggleSwitch />
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextMentions}"
                                   FieldName="mentions">
                        <atom:Mentions />
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextSelect}"
                                   FieldName="select">
                        <atom:Select HorizontalAlignment="Stretch" Mode="Multiple">
                            <atom:SelectOption Header="{gallery:FormShowCaseLangResource P2HeaderBbb}"/>
                            <atom:SelectOption Header="{gallery:FormShowCaseLangResource P2HeaderAaa}"/>
                        </atom:Select>
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextCascader}"
                                   FieldName="cascader">
                        <atom:Cascader HorizontalAlignment="Stretch" />
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextTreeSelect}"
                                   FieldName="treeSelect">
                        <atom:TreeSelect HorizontalAlignment="Stretch" />
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextDatePicker}"
                                   FieldName="datePicker">
                        <atom:DatePicker PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextPleaseSelect}" />
                    </atom:FormItem>
        
                    <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextRangePicker}"
                                   FieldName="rangePicker">
                        <atom:RangeDatePicker PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextStartDate}"
                                              SecondaryPlaceholderText="{gallery:FormShowCaseLangResource P2SecondaryPlaceholderTextEndDate}" />
                    </atom:FormItem>
        
                    <atom:FormActionsItem>
                        <atom:SubmitButton />
                    </atom:FormActionsItem>
                </atom:Form>
            </StackPanel>
        
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
