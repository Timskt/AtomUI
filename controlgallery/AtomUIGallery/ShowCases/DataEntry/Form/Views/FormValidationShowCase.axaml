<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Form.FormValidationShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:viewModels="clr-namespace:AtomUIGallery.ShowCases.Form"
             x:DataType="viewModels:FormViewModel">
    <gallery:ShowCasePanel>
        
        <gallery:ShowCaseItem
            Title="{gallery:FormShowCaseLangResource NoBlockRuleTitle}"
            Description="{gallery:FormShowCaseLangResource NoBlockRuleDescription}"
            IsOccupyEntireRow="True">
            <atom:Form LabelColInfo="8*"
                       WrapperColInfo="16*"
                       MinWidth="600"
                       HorizontalAlignment="Left"
                       Name="NoBlockRuleForm"
                       Submitted="HandleNoBlockFormSubmitted"
                       Validated="HandleNoBlockFormValidated">
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextUrl}"
                               FieldName="url"
                               IsRequired="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseEnterURL}" />
                            <atom:FormUrlValidator Message="{gallery:FormShowCaseLangResource P2MessageURLIsNotAValidUrl}" WarningOnly="True" />
                            <atom:FormStringLengthValidator Message="{gallery:FormShowCaseLangResource P2MessageURLMustBeAtLeastN6Characters}"
                                                            MinimumLength="6"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit />
                </atom:FormItem>
        
                <atom:FormActionsItem>
                   <StackPanel Orientation="Horizontal" Spacing="10">
                       <atom:SubmitButton />
                       <atom:Button ButtonType="Default" Click="HandleFillClicked" Content="{gallery:FormShowCaseLangResource P2ContentFill}" />
                   </StackPanel>
                </atom:FormActionsItem>
            </atom:Form>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="{gallery:FormShowCaseLangResource ValidateTriggerTitle}"
            Description="{gallery:FormShowCaseLangResource ValidateTriggerDescription}"
            IsOccupyEntireRow="True">
            <atom:Form LabelColInfo="8*"
                       WrapperColInfo="16*"
                       MinWidth="600"
                       HorizontalAlignment="Left"
                       IsValidateFeedbackEnabled="True">
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextFieldA}"
                               FieldName="fieldA"
                               ValidateTrigger="OnBlur">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormStringLengthValidator Message="{gallery:FormShowCaseLangResource P2MessageFieldAMustBeUpToN3Characters}"
                                                            MaximumLength="3"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextValidateRequiredOnblur}"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextFieldB}"
                               FieldName="fieldB"
                               ValidateDebounce="00:00:01">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormStringLengthValidator Message="{gallery:FormShowCaseLangResource P2MessageFieldAMustBeUpToN3Characters}"
                                                            MaximumLength="3"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextValidateRequiredDebounceAfterN1s}"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextFieldC}"
                               FieldName="fieldC"
                               ValidateStrategy="StopWhenFirstFailed">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormStringLengthValidator Message="{gallery:FormShowCaseLangResource P2MessageFieldAMustBeUpToN6Characters}"
                                                            MaximumLength="6"/>
                            <atom:FormStringLengthValidator Message="{gallery:FormShowCaseLangResource P2MessageContinueInputToExceedN6Chars}"
                                                            MaximumLength="3"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextValidateOneByOne}"/>
                </atom:FormItem>
            </atom:Form>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="{gallery:FormShowCaseLangResource ValidateOnlyTitle}"
            Description="{gallery:FormShowCaseLangResource ValidateOnlyDescription}"
            IsOccupyEntireRow="True">
            <atom:Form LabelColInfo="8*"
                       WrapperColInfo="16*"
                       MinWidth="600"
                       HorizontalAlignment="Left"
                       FormLayout="Vertical">
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextName}"
                               FieldName="name"
                               IsRequired="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseEnterName}"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit />
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextAge}"
                               FieldName="age"
                               IsRequired="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormStringNotEmptyValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseEnterAge}"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit />
                </atom:FormItem>
        
                <atom:FormActionsItem>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <atom:SubmitButton IsWatchValidateResult="True"/>
                        <atom:ResetButton />
                    </StackPanel>
                </atom:FormActionsItem>
            </atom:Form>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:FormShowCaseLangResource TimeRelatedControlsTitle}"
            Description="{gallery:FormShowCaseLangResource TimeRelatedControlsDescription}"
            IsOccupyEntireRow="True">
            <atom:Form LabelColInfo="200"
                       WrapperColInfo="16*"
                       MinWidth="600"
                       HorizontalAlignment="Left">
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextDatePicker}"
                               FieldName="datePicker"
                               IsRequired="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormNotNullValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseSelectTime}" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:DatePicker PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextSelectDate2}"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextDatePickerShowTime}"
                               FieldName="datePickerShowTime"
                               IsRequired="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormNotNullValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseSelectTime}" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:DatePicker PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextSelectDate2}" IsShowTime="True"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextRangePicker}"
                               FieldName="rangePicker"
                               IsRequired="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormNotNullValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseSelectTime}" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:RangeDatePicker PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextStartDate}"
                                          SecondaryPlaceholderText="{gallery:FormShowCaseLangResource P2SecondaryPlaceholderTextEndDate}"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextRangePickerShowTime}"
                               FieldName="rangePickerShowTime"
                               IsRequired="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormNotNullValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseSelectTime}" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:RangeDatePicker PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextStartDate}"
                                          SecondaryPlaceholderText="{gallery:FormShowCaseLangResource P2SecondaryPlaceholderTextEndDate}"
                                          IsShowTime="True"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextTimePicker}"
                               FieldName="timePicker"
                               IsRequired="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormNotNullValidator Message="{gallery:FormShowCaseLangResource P2MessagePleaseSelectTime}" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:TimePicker PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextStartTime}"/>
                </atom:FormItem>
        
                <atom:FormActionsItem>
                    <atom:SubmitButton/>
                </atom:FormActionsItem>
            </atom:Form>
        
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="{gallery:FormShowCaseLangResource CustomizedValidationTitle}"
            Description="{gallery:FormShowCaseLangResource CustomizedValidationDescription}"
            IsOccupyEntireRow="True">
            <atom:Form LabelColInfo="200"
                       WrapperColInfo="16*"
                       MinWidth="600"
                       HorizontalAlignment="Left">
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextFail}"
                               FieldName="fail"
                               Help="{gallery:FormShowCaseLangResource P2HelpShouldBeCombinationOfNumbersAndAlphabets}">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormAssertValidator AssertResult="False" />
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextUnavailableChoice}"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextWarning}"
                               FieldName="warning">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormAssertValidator AssertResult="False" WarningOnly="True"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextWarning}" InnerLeftContent="{antdicons:AntDesignIconProvider SmileOutlined}"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextValidating}"
                               FieldName="validating"
                               Help="{gallery:FormShowCaseLangResource P2HelpTheInformationIsBeingValidated}"
                               IsValidateFeedbackEnabled="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormAssertValidator AssertResult="True" Delay="00:01:00"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextIMTheContentIsBeingValidated}"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextSuccess}"
                               FieldName="success"
                               IsValidateFeedbackEnabled="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormAssertValidator AssertResult="True"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextIMTheContent}"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextWarning}"
                               FieldName="warning"
                               IsValidateFeedbackEnabled="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormAssertValidator AssertResult="False" WarningOnly="True"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextIMTheContent}"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextFail}"
                               FieldName="fail"
                               IsValidateFeedbackEnabled="True"
                               Help="{gallery:FormShowCaseLangResource P2HelpShouldBeCombinationOfNumbersAndAlphabets}">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormAssertValidator AssertResult="False"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextUnavailableChoice}"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextSuccess}"
                               FieldName="success"
                               IsValidateFeedbackEnabled="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormAssertValidator AssertResult="False"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:DatePicker PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextSelectDate}" HorizontalAlignment="Stretch"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextWarning}"
                               FieldName="warning"
                               IsValidateFeedbackEnabled="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormAssertValidator AssertResult="False" WarningOnly="True"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:TimePicker PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextSelectTime}" HorizontalAlignment="Stretch"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextFail}"
                               FieldName="fail"
                               IsValidateFeedbackEnabled="True"
                               Help="{gallery:FormShowCaseLangResource P2HelpShouldBeCombinationOfNumbersAndAlphabets}">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormAssertValidator AssertResult="False"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextUnavailableChoice}"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextSuccess}"
                               FieldName="success"
                               IsValidateFeedbackEnabled="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormAssertValidator AssertResult="True"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:DatePicker PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextSelectDate}" HorizontalAlignment="Stretch"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextWarning}"
                               FieldName="Warning"
                               IsValidateFeedbackEnabled="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormAssertValidator AssertResult="False" WarningOnly="True"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:TimePicker PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextSelectTime}" HorizontalAlignment="Stretch"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextError}"
                               FieldName="error"
                               IsValidateFeedbackEnabled="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormAssertValidator AssertResult="False"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:RangeDatePicker PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextStartDate}"
                                          SecondaryPlaceholderText="{gallery:FormShowCaseLangResource P2SecondaryPlaceholderTextEndDate}"
                                          HorizontalAlignment="Stretch"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextError}"
                               FieldName="error"
                               IsValidateFeedbackEnabled="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormAssertValidator AssertResult="False"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:Select IsAllowClear="True"
                                 PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextIMSelect}"
                                 DefaultValues="1"
                                 HorizontalAlignment="Stretch"
                                 OptionsSource="{Binding ValidationSelectOptions}" />
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextValidating}"
                               FieldName="validating"
                               IsValidateFeedbackEnabled="True"
                               Help="{gallery:FormShowCaseLangResource P2HelpSomethingBreaksTheRule}">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormAssertValidator AssertResult="False" WarningOnly="True"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:Cascader IsAllowClear="True"
                                   PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextIMSelect}"
                                   HorizontalAlignment="Stretch"
                                   IsPopupMatchSelectWidth="False"
                                   OptionsSource="{Binding ValidationCascaderOptions}" />
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextWarning}"
                               FieldName="warning"
                               IsValidateFeedbackEnabled="True"
                               Help="{gallery:FormShowCaseLangResource P2HelpNeedToBeChecked}">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormAssertValidator AssertResult="False" WarningOnly="True"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:TreeSelect IsAllowClear="True"
                                     PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextIMTreeselect}"
                                     HorizontalAlignment="Stretch"
                                     IsPopupMatchSelectWidth="False"
                                     ItemsSource="{Binding ValidationTreeNodes}" />
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextSuccess}"
                               FieldName="success"
                               IsValidateFeedbackEnabled="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormAssertValidator AssertResult="True"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:NumericUpDown IsAllowClear="True" HorizontalAlignment="Stretch"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextSuccess}"
                               FieldName="success"
                               IsValidateFeedbackEnabled="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormAssertValidator AssertResult="True"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit IsAllowClear="True" PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextWithAllowclear}"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextWarning}"
                               FieldName="warning"
                               IsValidateFeedbackEnabled="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormAssertValidator AssertResult="False" WarningOnly="True"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit RevealPassword="False"
                                   PasswordChar="•"
                                   IsEnableRevealButton="True"
                                   PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextWithInputPassword}"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextError}"
                               FieldName="error"
                               IsValidateFeedbackEnabled="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormAssertValidator AssertResult="False"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:LineEdit RevealPassword="False"
                                   PasswordChar="•"
                                   IsAllowClear="True"
                                   IsEnableRevealButton="True"
                                   PlaceholderText="{gallery:FormShowCaseLangResource P2PlaceholderTextWithInputPasswordAndAllowclear}"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextFail}"
                               FieldName="fail"
                               IsValidateFeedbackEnabled="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormAssertValidator AssertResult="False"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:Mentions/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="{gallery:FormShowCaseLangResource P2LabelTextFail}"
                               FieldName="fail"
                               Help="{gallery:FormShowCaseLangResource P2HelpShouldHaveSomething}"
                               IsValidateFeedbackEnabled="True">
                    <atom:FormItem.Validators>
                        <atom:FormValidatorProvider>
                            <atom:FormAssertValidator AssertResult="False"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:TextArea IsShowCount="True"
                                   IsAllowClear="True"/>
                </atom:FormItem>
        
                <atom:FormActionsItem>
                    <atom:SubmitButton/>
                </atom:FormActionsItem>
            </atom:Form>
        
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
