<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.LineEdit.LineEditShowCase"
             xmlns:vm="using:AtomUIGallery.ShowCases.LineEdit"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             x:DataType="vm:LineEditViewModel">
    <atom:TabControl Name="ScenarioTabs"
                     SizeType="Large"
                     SelectedIndex="0">
        <atom:TabItem Header="{gallery:LineEditShowCaseLangResource ScenarioBasic}" Tag="Basic" />
        <atom:TabItem Header="{gallery:LineEditShowCaseLangResource ScenarioState}" Tag="State" />
        <atom:TabItem Header="{gallery:LineEditShowCaseLangResource ScenarioSearch}" Tag="Search" />
        <atom:TabItem Header="{gallery:LineEditShowCaseLangResource ScenarioTextArea}" Tag="TextArea" />
    </atom:TabControl>
</UserControl>
