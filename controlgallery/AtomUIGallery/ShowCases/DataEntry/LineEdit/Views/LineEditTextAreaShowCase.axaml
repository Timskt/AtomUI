<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.LineEdit.LineEditTextAreaShowCase"
             xmlns:vm="using:AtomUIGallery.ShowCases.LineEdit"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             x:DataType="vm:LineEditViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:LineEditShowCaseLangResource TextAreaTitle}"
            Description="{gallery:LineEditShowCaseLangResource TextAreaDescription}">
            <StackPanel Orientation="Vertical" Spacing="10" Margin="0, 0, 20, 0">
                <atom:TextArea Lines="4" />
                <atom:TextArea Lines="4" PlaceholderText="{gallery:LineEditShowCaseLangResource P2PlaceholderTextMaxlengthIsN6}" MaxLength="6" />
                <atom:TextArea Lines="4" PlaceholderText="{gallery:LineEditShowCaseLangResource P2PlaceholderTextMaxlengthIsN6}" MaxLength="6" StyleVariant="Filled" />
                <atom:TextArea Lines="4" PlaceholderText="{gallery:LineEditShowCaseLangResource P2PlaceholderTextDisabled}" MaxLength="6" IsEnabled="False" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:LineEditShowCaseLangResource AutoSizeTextAreaTitle}"
            Description="{gallery:LineEditShowCaseLangResource AutoSizeTextAreaDescription}">
            <StackPanel Orientation="Vertical" Spacing="10" Margin="0, 0, 20, 0">
                <atom:TextArea PlaceholderText="{gallery:LineEditShowCaseLangResource P2PlaceholderTextAutosizeHeightBasedOnContentLines}" IsAutoSize="True" />
                <atom:TextArea PlaceholderText="{gallery:LineEditShowCaseLangResource P2PlaceholderTextAutosizeHeightWithMinimumAndMaximumNumberOf}" MinLines="3"
                               MaxLines="6" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:LineEditShowCaseLangResource CharacterCountingTitle}"
            Description="{gallery:LineEditShowCaseLangResource CharacterCountingDescription}">
            <StackPanel Orientation="Vertical" Spacing="10" Margin="0, 0, 20, 0">
                <atom:LineEdit IsShowCount="True" MaxLength="20" />
                <atom:TextArea IsShowCount="True" MaxLength="100" PlaceholderText="{gallery:LineEditShowCaseLangResource P2PlaceholderTextCanResize}" IsResizable="True" />
                <atom:TextArea IsShowCount="True" MaxLength="100" PlaceholderText="{gallery:LineEditShowCaseLangResource P2PlaceholderTextDisableResize}" Height="120"
                               IsResizable="False" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:LineEditShowCaseLangResource TextAreaStatusTitle}"
            Description="{gallery:LineEditShowCaseLangResource TextAreaStatusDescription}">
            <StackPanel Orientation="Vertical" Spacing="10" Margin="0, 0, 20, 0">
                <atom:TextArea IsShowCount="True" MaxLength="100" PlaceholderText="{gallery:LineEditShowCaseLangResource P2PlaceholderTextError}" IsResizable="True" Status="Error" />
                <atom:TextArea IsShowCount="True" MaxLength="100" PlaceholderText="{gallery:LineEditShowCaseLangResource P2PlaceholderTextWarning}" IsResizable="True" Status="Warning"/>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
