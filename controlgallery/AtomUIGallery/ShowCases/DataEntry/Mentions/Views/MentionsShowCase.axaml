<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Mentions.MentionsShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.Mentions"
             x:DataType="vm:MentionsViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:MentionsShowCaseLangResource BasicTitle}"
            Description="{gallery:MentionsShowCaseLangResource BasicDescription}">
            <atom:Mentions Name="BasicMentions"
                           HorizontalAlignment="Stretch"
                           DefaultValue="@afc163"/>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MentionsShowCaseLangResource VariantsTitle}"
            Description="{gallery:MentionsShowCaseLangResource VariantsDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Mentions HorizontalAlignment="Stretch" StyleVariant="Outlined" PlaceholderText="{gallery:MentionsShowCaseLangResource P2PlaceholderTextOutlined}"/>
                <atom:Mentions HorizontalAlignment="Stretch" StyleVariant="Filled" PlaceholderText="{gallery:MentionsShowCaseLangResource P2PlaceholderTextFilled}"/>
                <atom:Mentions HorizontalAlignment="Stretch" StyleVariant="Borderless" PlaceholderText="{gallery:MentionsShowCaseLangResource P2PlaceholderTextBorderless}"/>
                <atom:Mentions HorizontalAlignment="Stretch" StyleVariant="Underlined" PlaceholderText="{gallery:MentionsShowCaseLangResource P2PlaceholderTextUnderlined}"/>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MentionsShowCaseLangResource AsynchronousLoadingTitle}"
            Description="{gallery:MentionsShowCaseLangResource AsynchronousLoadingDescription}">
            <atom:Mentions HorizontalAlignment="Stretch" OptionsAsyncLoader="{Binding MentionOptionAsyncLoader}"/>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MentionsShowCaseLangResource CustomizeTriggerTokenTitle}"
            Description="{gallery:MentionsShowCaseLangResource CustomizeTriggerTokenDescription}">
            <atom:Mentions HorizontalAlignment="Stretch"
                           TriggerPrefix="{Binding MentionTriggers}"
                           CandidateTriggered="HandleCandidateTriggered"
                           PlaceholderText="{gallery:MentionsShowCaseLangResource P2PlaceholderTextInputToMentionPeopleToMentionTag}"/>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MentionsShowCaseLangResource DisabledOrReadOnlyTitle}"
            Description="{gallery:MentionsShowCaseLangResource DisabledOrReadOnlyDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Mentions Name="DisabledMentions"
                               HorizontalAlignment="Stretch"
                               IsEnabled="False"
                               PlaceholderText="{gallery:MentionsShowCaseLangResource P2PlaceholderTextThisIsDisabledMentions}"/>
                <atom:Mentions Name="ReadonlyMentions"
                               HorizontalAlignment="Stretch"
                               PlaceholderText="{gallery:MentionsShowCaseLangResource P2PlaceholderTextThisIsReadonlyMentions}"
                               IsReadOnly="True"/>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MentionsShowCaseLangResource PlacementTitle}"
            Description="{gallery:MentionsShowCaseLangResource PlacementDescription}">
            <atom:Mentions Name="PlacementMentions"
                           HorizontalAlignment="Stretch"
                           Placement="Top"/>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MentionsShowCaseLangResource StatusTitle}"
            Description="{gallery:MentionsShowCaseLangResource StatusDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Mentions Name="ErrorMentions"
                               HorizontalAlignment="Stretch"
                               Status="Error"
                               DefaultValue="@afc163"/>
                <atom:Mentions Name="WarningMentions"
                               HorizontalAlignment="Stretch"
                               DefaultValue="@afc163"
                               Status="Warning"/>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MentionsShowCaseLangResource AutoSizeTitle}"
            Description="{gallery:MentionsShowCaseLangResource AutoSizeDescription}">
            <atom:Mentions Name="AutoSizeMentions"
                           HorizontalAlignment="Stretch"
                           IsAutoSize="True"/>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MentionsShowCaseLangResource WithClearIconTitle}"
            Description="{gallery:MentionsShowCaseLangResource WithClearIconDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Mentions Name="ClearableMentions1"
                               HorizontalAlignment="Stretch"
                               IsAllowClear="True"/>
                <atom:Mentions HorizontalAlignment="Stretch"
                               Name="ClearableMentions2"
                               IsAllowClear="True"
                               Lines="3"/>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
