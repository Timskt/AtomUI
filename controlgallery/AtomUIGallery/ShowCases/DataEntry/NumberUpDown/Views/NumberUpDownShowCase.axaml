<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AtomUIGallery.ShowCases.NumberUpDown"
             x:Class="AtomUIGallery.ShowCases.NumberUpDown.NumberUpDownShowCase"
             x:DataType="vm:NumberUpDownViewModel"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery">
    <gallery:ShowCasePanel>
        <gallery:ShowCasePanel.Styles>
            <Style Selector="atom|NumericUpDown">
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
            </Style>
        </gallery:ShowCasePanel.Styles>
        <gallery:ShowCaseItem
            Title="{gallery:NumberUpDownShowCaseLangResource BasicUsageTitle}"
            Description="{gallery:NumberUpDownShowCaseLangResource BasicUsageDescription}">
            <atom:NumericUpDown Value="3" HorizontalAlignment="Stretch"/>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:NumberUpDownShowCaseLangResource StringModeTitle}"
            Description="{gallery:NumberUpDownShowCaseLangResource StringModeDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:NumericUpDown IsStringMode="True"
                                    StringValue="{Binding StringModeValue, Mode=TwoWay}"
                                    Increment="0.0001"
                                    Minimum="0"
                                    Maximum="100"
                                    PlaceholderText="Input weight" />
                <TextBlock Text="{Binding StringModeValue, StringFormat=Raw: {0}}"/>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:NumberUpDownShowCaseLangResource KeyboardBehaviorTitle}"
            Description="{gallery:NumberUpDownShowCaseLangResource KeyboardBehaviorDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:CheckBox Content="Keyboard enabled"
                          IsChecked="{Binding KeyboardEnabled}"/>
                <atom:NumericUpDown Value="1.2"
                                    Increment="0.1"
                                    IsKeyboardEnabled="{Binding KeyboardEnabled}"
                                    PlaceholderText="Keyboard disabled" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:NumberUpDownShowCaseLangResource MouseWheelBehaviorTitle}"
            Description="{gallery:NumberUpDownShowCaseLangResource MouseWheelBehaviorDescription}">
            <atom:NumericUpDown Value="2.5"
                                Increment="0.5"
                                PlaceholderText="Focus and scroll wheel" />
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:NumberUpDownShowCaseLangResource MinMaxTitle}"
            Description="{gallery:NumberUpDownShowCaseLangResource MinMaxDescription}">
            <atom:NumericUpDown Minimum="0"
                                Maximum="10"
                                Value="3"
                                Increment="1" />
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:NumberUpDownShowCaseLangResource DecimalStepTitle}"
            Description="{gallery:NumberUpDownShowCaseLangResource DecimalStepDescription}">
            <atom:NumericUpDown Value="1.2"
                                Increment="0.25"
                                Minimum="0"
                                Maximum="2" />
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:NumberUpDownShowCaseLangResource SizesTitle}"
            Description="{gallery:NumberUpDownShowCaseLangResource SizesDescription}">
            <StackPanel Orientation="Vertical" Spacing="10" Margin="0, 0, 20, 0">
                <atom:NumericUpDown SizeType="Large" Value="3" />
                <atom:NumericUpDown SizeType="Middle" Value="3" />
                <atom:NumericUpDown SizeType="Small" Value="3" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:NumberUpDownShowCaseLangResource VariantsTitle}"
            Description="{gallery:NumberUpDownShowCaseLangResource VariantsDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:NumericUpDown Value="3" StyleVariant="Outlined" />
                <atom:NumericUpDown Value="3" StyleVariant="Filled" />
                <atom:NumericUpDown Value="3" StyleVariant="Borderless" />
            </StackPanel>

        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:NumberUpDownShowCaseLangResource DisabledTitle}"
            Description="{gallery:NumberUpDownShowCaseLangResource DisabledDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:NumericUpDown Value="3" StyleVariant="Outlined" IsEnabled="False"/>
                <atom:NumericUpDown Value="3" StyleVariant="Filled" IsEnabled="False"/>
                <atom:NumericUpDown Value="3" StyleVariant="Borderless" IsEnabled="False"/>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:NumberUpDownShowCaseLangResource PrePostTabTitle}"
            Description="{gallery:NumberUpDownShowCaseLangResource PrePostTabDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:NumericUpDown LeftAddOn="http://" RightAddOn=".com"
                                    HorizontalAlignment="Left"
                                    Width="400"
                                    Value="3" />
                <atom:NumericUpDown RightAddOn="{antdicons:AntDesignIconProvider Kind=SettingOutlined}"
                                    HorizontalAlignment="Left"
                                    Width="400"
                                    Value="3" />
                <atom:NumericUpDown LeftAddOn="http://" InnerRightContent=".com"
                                    HorizontalAlignment="Left"
                                    Width="400"
                                    Value="3" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:NumberUpDownShowCaseLangResource WithClearIconTitle}"
            Description="{gallery:NumberUpDownShowCaseLangResource WithClearIconDescription}">
            <atom:NumericUpDown PlaceholderText="input with clear icon" Width="400" HorizontalAlignment="Left"
                                IsAllowClear="True" />
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:NumberUpDownShowCaseLangResource PrefixAndSuffixTitle}"
            Description="{gallery:NumberUpDownShowCaseLangResource PrefixAndSuffixDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:NumericUpDown PlaceholderText="Enter your value"
                                    InnerLeftContent="{antdicons:AntDesignIconProvider Kind=UserOutlined, FillBrush=#D7D7D7}"
                                    InnerRightContent="{antdicons:AntDesignIconProvider Kind=InfoCircleOutlined, FillBrush=#8C8C8C}" />
                <atom:NumericUpDown InnerLeftContent="￥" InnerRightContent="RMB" />
                <atom:NumericUpDown InnerLeftContent="￥" InnerRightContent="RMB" IsEnabled="False" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:NumberUpDownShowCaseLangResource StatusTitle}"
            Description="{gallery:NumberUpDownShowCaseLangResource StatusDescription}">
            <StackPanel Orientation="Vertical" Spacing="10" Margin="0, 0, 20, 0">
                <atom:NumericUpDown PlaceholderText="Error" Status="Error" />
                <atom:NumericUpDown PlaceholderText="Warning" Status="Warning" />
                <atom:NumericUpDown PlaceholderText="Error with prefix"
                                    InnerLeftContent="{antdicons:AntDesignIconProvider Kind=ClockCircleOutlined}" Status="Error" />
                <atom:NumericUpDown PlaceholderText="Warning with prefix"
                                    InnerLeftContent="{antdicons:AntDesignIconProvider Kind=ClockCircleOutlined}" Status="Warning" />

                <atom:NumericUpDown PlaceholderText="Error" Status="Error"
                                    InnerLeftContent="{antdicons:AntDesignIconProvider Kind=ClockCircleOutlined}"
                                    StyleVariant="Filled" />
                <atom:NumericUpDown PlaceholderText="Warning" Status="Warning"
                                    InnerLeftContent="{antdicons:AntDesignIconProvider Kind=ClockCircleOutlined}"
                                    StyleVariant="Filled" />

                <atom:NumericUpDown PlaceholderText="Error" Status="Error"
                                    InnerLeftContent="{antdicons:AntDesignIconProvider Kind=ClockCircleOutlined}"
                                    StyleVariant="Borderless" />
                <atom:NumericUpDown PlaceholderText="Warning" Status="Warning"
                                    InnerLeftContent="{antdicons:AntDesignIconProvider Kind=ClockCircleOutlined}"
                                    StyleVariant="Borderless" />
            </StackPanel>
        </gallery:ShowCaseItem>

    </gallery:ShowCasePanel>
</UserControl>
