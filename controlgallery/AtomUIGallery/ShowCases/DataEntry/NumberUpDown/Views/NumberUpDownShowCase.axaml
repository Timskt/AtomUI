<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AtomUIGallery.ShowCases.NumberUpDown"
             x:Class="AtomUIGallery.ShowCases.NumberUpDown.NumberUpDownShowCase"
             x:DataType="vm:NumberUpDownViewModel"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery">
    <atom:TabControl Name="ScenarioTabs"
                     SizeType="Large"
                     SelectedIndex="0">
        <atom:TabItem Header="{gallery:NumberUpDownShowCaseLangResource ScenarioBasic}" Tag="Basic" />
        <atom:TabItem Header="{gallery:NumberUpDownShowCaseLangResource ScenarioRange}" Tag="Range" />
        <atom:TabItem Header="{gallery:NumberUpDownShowCaseLangResource ScenarioStyle}" Tag="Style" />
        <atom:TabItem Header="{gallery:NumberUpDownShowCaseLangResource ScenarioAddon}" Tag="Addon" />
    </atom:TabControl>
</UserControl>
