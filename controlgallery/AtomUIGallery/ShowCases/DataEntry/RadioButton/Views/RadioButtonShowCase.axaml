<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.RadioButton.RadioButtonShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.RadioButton"
             x:DataType="vm:RadioButtonViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:RadioButtonShowCaseLangResource BasicTitle}"
            Description="{gallery:RadioButtonShowCaseLangResource BasicDescription}">
            <StackPanel HorizontalAlignment="Left" Spacing="10" Orientation="Horizontal">
                <atom:RadioButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentRadio}" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:RadioButtonShowCaseLangResource DisabledTitle}"
            Description="{gallery:RadioButtonShowCaseLangResource DisabledDescription}">
            <StackPanel HorizontalAlignment="Left" Orientation="Vertical">
                <StackPanel Orientation="Horizontal">
                    <atom:RadioButton x:Name="ToggleDisabledRadioUnChecked"
                                      IsEnabled="{Binding ToggleDisabledRadioUnCheckedEnabled}" Content="{gallery:RadioButtonShowCaseLangResource P2ContentRadio1}" />
                    <atom:RadioButton x:Name="ToggleDisabledRadioChecked"
                                      IsChecked="True"
                                      IsEnabled="{Binding ToggleDisabledRadioCheckedEnabled}" Content="{gallery:RadioButtonShowCaseLangResource P2ContentRadio2}" />
                </StackPanel>
                <atom:Button ButtonType="Primary"
                             x:Name="ToggleDisabledButton"
                             Margin="0, 20, 0, 0"
                             Command="{Binding ToggleDisabledCommand}" Content="{gallery:RadioButtonShowCaseLangResource P2ContentToggleDisabled}" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:RadioButtonShowCaseLangResource RadioGroupTitle}"
            Description="{gallery:RadioButtonShowCaseLangResource RadioGroupDescription}">
            <atom:RadioButtonGroup>
                <atom:RadioButton>
                    <StackPanel Spacing="5" Orientation="Vertical">
                        <antdicons:LineChartOutlined Width="18" Height="18"/>
                        <TextBlock Text="{gallery:RadioButtonShowCaseLangResource P2TextLinechart}" />
                    </StackPanel>
                </atom:RadioButton>
                <atom:RadioButton>
                    <StackPanel Spacing="5" Orientation="Vertical">
                        <antdicons:DotChartOutlined Width="18" Height="18"/>
                        <TextBlock Text="{gallery:RadioButtonShowCaseLangResource P2TextDotchart}" />
                    </StackPanel>
                </atom:RadioButton>
                <atom:RadioButton>
                    <StackPanel Spacing="5" Orientation="Vertical">
                        <antdicons:BarChartOutlined Width="18" Height="18"/>
                        <TextBlock Text="{gallery:RadioButtonShowCaseLangResource P2TextBarchart}" />
                    </StackPanel>
                </atom:RadioButton>
                <atom:RadioButton>
                    <StackPanel Spacing="5" Orientation="Vertical">
                        <antdicons:PieChartOutlined Width="18" Height="18"/>
                        <TextBlock Text="{gallery:RadioButtonShowCaseLangResource P2TextPiechart}" />
                    </StackPanel>
                </atom:RadioButton>
            </atom:RadioButtonGroup>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:RadioButtonShowCaseLangResource VerticalRadioGroupTitle}"
            Description="{gallery:RadioButtonShowCaseLangResource VerticalRadioGroupDescription}">
            <atom:RadioButtonGroup Orientation="Vertical" HorizontalAlignment="Left">
                <atom:RadioButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentOptionA}" />
                <atom:RadioButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentOptionB}" />
                <atom:RadioButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentOptionC}" />
                <atom:RadioButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentOptionD}" />
            </atom:RadioButtonGroup>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:RadioButtonShowCaseLangResource ItemsSourceRadioGroupTitle}"
            Description="{gallery:RadioButtonShowCaseLangResource ItemsSourceRadioGroupDescription}">
            <atom:RadioButtonGroup Name="RadioButtonGroup" HorizontalAlignment="Left"/>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:RadioButtonShowCaseLangResource OptionButtonTitle}"
            Description="{gallery:RadioButtonShowCaseLangResource OptionButtonDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <atom:RadioButton IsChecked="True" Content="{gallery:RadioButtonShowCaseLangResource P2ContentApple}" />
                    <atom:RadioButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentPear}" />
                    <atom:RadioButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentOrange}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <atom:RadioButton IsChecked="True" Content="{gallery:RadioButtonShowCaseLangResource P2ContentApple}" />
                    <atom:RadioButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentPear}" />
                    <atom:RadioButton IsEnabled="False" Content="{gallery:RadioButtonShowCaseLangResource P2ContentOrange}" />
                </StackPanel>
                <atom:OptionButtonGroup ButtonStyle="Solid">
                    <atom:OptionButton IsChecked="True" Content="{gallery:RadioButtonShowCaseLangResource P2ContentApple}" />
                    <atom:OptionButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentPear}" />
                    <atom:OptionButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentOrange}" />
                </atom:OptionButtonGroup>

                <atom:OptionButtonGroup ButtonStyle="Outline">
                    <atom:OptionButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentApple}" />
                    <atom:OptionButton IsChecked="True" Content="{gallery:RadioButtonShowCaseLangResource P2ContentPear}" />
                    <atom:OptionButton IsEnabled="False" Content="{gallery:RadioButtonShowCaseLangResource P2ContentOrange}" />
                </atom:OptionButtonGroup>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:RadioButtonShowCaseLangResource OptionButtonWithIconTitle}"
            Description="{gallery:RadioButtonShowCaseLangResource OptionButtonWithIconDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:OptionButtonGroup ButtonStyle="Solid">
                    <atom:OptionButton IsChecked="True" Icon="{antdicons:AntDesignIconProvider Kind=AppleOutlined}" Content="{gallery:RadioButtonShowCaseLangResource P2ContentMacos}" />
                    <atom:OptionButton Icon="{antdicons:AntDesignIconProvider Kind=LinuxOutlined}" Content="{gallery:RadioButtonShowCaseLangResource P2ContentLinux}" />
                    <atom:OptionButton Icon="{antdicons:AntDesignIconProvider Kind=WindowsOutlined}" Content="{gallery:RadioButtonShowCaseLangResource P2ContentWindows}" />
                </atom:OptionButtonGroup>

                <atom:OptionButtonGroup ButtonStyle="Outline">
                    <atom:OptionButton Icon="{antdicons:AntDesignIconProvider Kind=AppleOutlined}" Content="{gallery:RadioButtonShowCaseLangResource P2ContentMacos}" />
                    <atom:OptionButton IsChecked="True" Icon="{antdicons:AntDesignIconProvider Kind=LinuxOutlined}" Content="{gallery:RadioButtonShowCaseLangResource P2ContentLinux}" />
                    <atom:OptionButton Icon="{antdicons:AntDesignIconProvider Kind=WindowsOutlined}" Content="{gallery:RadioButtonShowCaseLangResource P2ContentWindows}" />
                </atom:OptionButtonGroup>

                <atom:OptionButtonGroup ButtonStyle="Solid" IsEnabled="False">
                    <atom:OptionButton IsChecked="True" Icon="{antdicons:AntDesignIconProvider Kind=AppleOutlined}" Content="{gallery:RadioButtonShowCaseLangResource P2ContentMacos}" />
                    <atom:OptionButton Icon="{antdicons:AntDesignIconProvider Kind=LinuxOutlined}" Content="{gallery:RadioButtonShowCaseLangResource P2ContentLinux}" />
                    <atom:OptionButton Icon="{antdicons:AntDesignIconProvider Kind=WindowsOutlined}" Content="{gallery:RadioButtonShowCaseLangResource P2ContentWindows}" />
                </atom:OptionButtonGroup>

                <atom:OptionButtonGroup ButtonStyle="Outline" IsEnabled="False">
                    <atom:OptionButton Icon="{antdicons:AntDesignIconProvider Kind=AppleOutlined}" Content="{gallery:RadioButtonShowCaseLangResource P2ContentMacos}" />
                    <atom:OptionButton IsChecked="True" Icon="{antdicons:AntDesignIconProvider Kind=LinuxOutlined}" Content="{gallery:RadioButtonShowCaseLangResource P2ContentLinux}" />
                    <atom:OptionButton Icon="{antdicons:AntDesignIconProvider Kind=WindowsOutlined}" Content="{gallery:RadioButtonShowCaseLangResource P2ContentWindows}" />
                </atom:OptionButtonGroup>
                <atom:Separator Title="{gallery:RadioButtonShowCaseLangResource P2TitleSizetype}"/>
                <atom:OptionButtonGroup ButtonStyle="Outline" SizeType="Large">
                    <atom:OptionButton Icon="{antdicons:AntDesignIconProvider Kind=AppleOutlined}" Content="{gallery:RadioButtonShowCaseLangResource P2ContentMacos}" />
                    <atom:OptionButton IsChecked="True" Icon="{antdicons:AntDesignIconProvider Kind=LinuxOutlined}" Content="{gallery:RadioButtonShowCaseLangResource P2ContentLinux}" />
                    <atom:OptionButton Icon="{antdicons:AntDesignIconProvider Kind=WindowsOutlined}" Content="{gallery:RadioButtonShowCaseLangResource P2ContentWindows}" />
                </atom:OptionButtonGroup>
                <atom:OptionButtonGroup ButtonStyle="Outline">
                    <atom:OptionButton Icon="{antdicons:AntDesignIconProvider Kind=AppleOutlined}" Content="{gallery:RadioButtonShowCaseLangResource P2ContentMacos}" />
                    <atom:OptionButton IsChecked="True" Icon="{antdicons:AntDesignIconProvider Kind=LinuxOutlined}" Content="{gallery:RadioButtonShowCaseLangResource P2ContentLinux}" />
                    <atom:OptionButton Icon="{antdicons:AntDesignIconProvider Kind=WindowsOutlined}" Content="{gallery:RadioButtonShowCaseLangResource P2ContentWindows}" />
                </atom:OptionButtonGroup>
                <atom:OptionButtonGroup ButtonStyle="Outline" SizeType="Small">
                    <atom:OptionButton Icon="{antdicons:AntDesignIconProvider Kind=AppleOutlined}" Content="{gallery:RadioButtonShowCaseLangResource P2ContentMacos}" />
                    <atom:OptionButton IsChecked="True" Icon="{antdicons:AntDesignIconProvider Kind=LinuxOutlined}" Content="{gallery:RadioButtonShowCaseLangResource P2ContentLinux}" />
                    <atom:OptionButton Icon="{antdicons:AntDesignIconProvider Kind=WindowsOutlined}" Content="{gallery:RadioButtonShowCaseLangResource P2ContentWindows}" />
                </atom:OptionButtonGroup>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:RadioButtonShowCaseLangResource OptionStyleTitle}"
            Description="{gallery:RadioButtonShowCaseLangResource OptionStyleDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:OptionButtonGroup>
                    <atom:OptionButton IsChecked="True" Content="{gallery:RadioButtonShowCaseLangResource P2ContentHangzhou}" />
                    <atom:OptionButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentShanghai}" />
                    <atom:OptionButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentBeijing}" />
                    <atom:OptionButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentChengdu}" />
                </atom:OptionButtonGroup>

                <atom:OptionButtonGroup>
                    <atom:OptionButton IsChecked="True" Content="{gallery:RadioButtonShowCaseLangResource P2ContentHangzhou}" />
                    <atom:OptionButton IsEnabled="False" Content="{gallery:RadioButtonShowCaseLangResource P2ContentShanghai}" />
                    <atom:OptionButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentBeijing}" />
                    <atom:OptionButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentChengdu}" />
                </atom:OptionButtonGroup>

                <atom:OptionButtonGroup>
                    <atom:OptionButton IsChecked="True" IsEnabled="False" Content="{gallery:RadioButtonShowCaseLangResource P2ContentHangzhou}" />
                    <atom:OptionButton IsEnabled="False" Content="{gallery:RadioButtonShowCaseLangResource P2ContentShanghai}" />
                    <atom:OptionButton IsEnabled="False" Content="{gallery:RadioButtonShowCaseLangResource P2ContentBeijing}" />
                    <atom:OptionButton IsEnabled="False" Content="{gallery:RadioButtonShowCaseLangResource P2ContentChengdu}" />
                </atom:OptionButtonGroup>

            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:RadioButtonShowCaseLangResource SolidOptionButtonTitle}"
            Description="{gallery:RadioButtonShowCaseLangResource SolidOptionButtonDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">

                <atom:OptionButtonGroup ButtonStyle="Solid">
                    <atom:OptionButton IsChecked="True" Content="{gallery:RadioButtonShowCaseLangResource P2ContentHangzhou}" />
                    <atom:OptionButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentShanghai}" />
                    <atom:OptionButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentBeijing}" />
                    <atom:OptionButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentChengdu}" />
                </atom:OptionButtonGroup>

                <atom:OptionButtonGroup ButtonStyle="Solid">
                    <atom:OptionButton IsChecked="True" Content="{gallery:RadioButtonShowCaseLangResource P2ContentHangzhou}" />
                    <atom:OptionButton IsEnabled="False" Content="{gallery:RadioButtonShowCaseLangResource P2ContentShanghai}" />
                    <atom:OptionButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentBeijing}" />
                    <atom:OptionButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentChengdu}" />
                </atom:OptionButtonGroup>

                <atom:OptionButtonGroup ButtonStyle="Solid">
                    <atom:OptionButton IsChecked="True" IsEnabled="False" Content="{gallery:RadioButtonShowCaseLangResource P2ContentHangzhou}" />
                    <atom:OptionButton IsEnabled="False" Content="{gallery:RadioButtonShowCaseLangResource P2ContentShanghai}" />
                    <atom:OptionButton IsEnabled="False" Content="{gallery:RadioButtonShowCaseLangResource P2ContentBeijing}" />
                    <atom:OptionButton IsEnabled="False" Content="{gallery:RadioButtonShowCaseLangResource P2ContentChengdu}" />
                </atom:OptionButtonGroup>

            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:RadioButtonShowCaseLangResource SizeTypeTitle}"
            Description="{gallery:RadioButtonShowCaseLangResource SizeTypeDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:OptionButtonGroup SizeType="Large">
                    <atom:OptionButton IsChecked="True" Content="{gallery:RadioButtonShowCaseLangResource P2ContentHangzhou}" />
                    <atom:OptionButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentShanghai}" />
                    <atom:OptionButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentBeijing}" />
                    <atom:OptionButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentChengdu}" />
                </atom:OptionButtonGroup>

                <atom:OptionButtonGroup SizeType="Middle">
                    <atom:OptionButton IsChecked="True" Content="{gallery:RadioButtonShowCaseLangResource P2ContentHangzhou}" />
                    <atom:OptionButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentShanghai}" />
                    <atom:OptionButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentBeijing}" />
                    <atom:OptionButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentChengdu}" />
                </atom:OptionButtonGroup>

                <atom:OptionButtonGroup SizeType="Small">
                    <atom:OptionButton IsChecked="True" Content="{gallery:RadioButtonShowCaseLangResource P2ContentHangzhou}" />
                    <atom:OptionButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentShanghai}" />
                    <atom:OptionButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentBeijing}" />
                    <atom:OptionButton Content="{gallery:RadioButtonShowCaseLangResource P2ContentChengdu}" />
                </atom:OptionButtonGroup>

            </StackPanel>
        </gallery:ShowCaseItem>

    </gallery:ShowCasePanel>
</UserControl>
