<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AtomUIGallery.ShowCases.RadioButton"
             x:Class="AtomUIGallery.ShowCases.RadioButton.RadioButtonShowCase"
             x:DataType="vm:RadioButtonViewModel"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery">
    <atom:TabControl Name="ScenarioTabs"
                     SizeType="Large"
                     SelectedIndex="0">
        <atom:TabItem Header="{gallery:RadioButtonShowCaseLangResource ScenarioBasic}" Tag="Basic" />
        <atom:TabItem Header="{gallery:RadioButtonShowCaseLangResource ScenarioGroups}" Tag="Groups" />
        <atom:TabItem Header="{gallery:RadioButtonShowCaseLangResource ScenarioOptions}" Tag="Options" />
        <atom:TabItem Header="{gallery:RadioButtonShowCaseLangResource ScenarioStyles}" Tag="Styles" />
    </atom:TabControl>
</UserControl>
