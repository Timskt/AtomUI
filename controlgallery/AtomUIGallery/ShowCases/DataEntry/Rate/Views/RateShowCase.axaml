<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Rate.RateShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.Rate"
             x:DataType="vm:RateViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:RateShowCaseLangResource BasicTitle}"
            Description="{gallery:RateShowCaseLangResource BasicDescription}">
            <atom:Rate/>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:RateShowCaseLangResource HalfStarTitle}"
            Description="{gallery:RateShowCaseLangResource HalfStarDescription}">
            <atom:Rate DefaultValue="3.5" IsAllowHalf="True"/>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:RateShowCaseLangResource ShowCopywritingTitle}"
            Description="{gallery:RateShowCaseLangResource ShowCopywritingDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Rate Name="ToolTipRate" ValueChanged="HandleValueChanged"/>
                <TextBlock Text="{Binding ActiveTooltip}"/>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:RateShowCaseLangResource ReadOnlyTitle}"
            Description="{gallery:RateShowCaseLangResource ReadOnlyDescription}">
            <atom:Rate DefaultValue="2" IsEnabled="False"/>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:RateShowCaseLangResource ClearStarTitle}"
            Description="{gallery:RateShowCaseLangResource ClearStarDescription}">
            <StackPanel Spacing="20">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <atom:Rate DefaultValue="3" IsAllowClear="True" />
                    <TextBlock Text="{gallery:RateShowCaseLangResource P2TextIsallowclearTrue}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <atom:Rate DefaultValue="3" IsAllowClear="False" />
                    <TextBlock Text="{gallery:RateShowCaseLangResource P2TextIsallowclearFalse}" />
                </StackPanel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:RateShowCaseLangResource OtherCharacterTitle}"
            Description="{gallery:RateShowCaseLangResource OtherCharacterDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Rate IsAllowHalf="True" IsAllowClear="True" Character="{antdicons:AntDesignIconProvider HeartOutlined}"/>
                <atom:Rate IsAllowHalf="True" IsAllowClear="True" Character="A"/>
                <atom:Rate IsAllowHalf="True" IsAllowClear="True" Character="秦"/>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
