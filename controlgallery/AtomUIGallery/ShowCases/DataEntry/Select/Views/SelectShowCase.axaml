<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Select.SelectShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.Select"
             xmlns:views="using:AtomUIGallery.ShowCases.Select"
             x:DataType="vm:SelectViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource BasicTitle}"
            Description="{gallery:SelectShowCaseLangResource BasicDescription}" IsOccupyEntireRow="False">
            <WrapPanel ItemSpacing="10" LineSpacing="10">
                <atom:Select Mode="Single" PlaceholderText="Please select" Width="120"
                             DefaultValues="lucy">
                    <atom:SelectOption Header="Jack" Content="jack" />
                    <atom:SelectOption Header="Lucy" Content="lucy" />
                    <atom:SelectOption Header="Yiminghe" Content="yiminghe" />
                    <atom:SelectOption Header="Disabled" IsEnabled="False" Content="disabled" />
                </atom:Select>

                <atom:Select Mode="Single" PlaceholderText="Please select" IsEnabled="False" Width="120"
                             DefaultValues="lucy">
                    <atom:SelectOption Header="Lucy" Content="lucy" />
                </atom:Select>

                <atom:Select Name="AsyncLoadSelect"
                             Mode="Single"
                             PlaceholderText="Please select"
                             Width="120"
                             DefaultValues="lucy">
                    <atom:SelectOption Header="Lucy" Content="lucy" />
                </atom:Select>

                <atom:Select Mode="Single" PlaceholderText="Please select" IsAllowClear="True" Width="120">
                    <atom:SelectOption Header="Lucy" Content="lucy" />
                </atom:Select>

                <atom:Select Name="DefaultSelectedSelect"
                             Mode="Single"
                             PlaceholderText="Please select"
                             IsAllowClear="True"
                             Width="120" />

            </WrapPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource SearchFieldTitle}"
            Description="{gallery:SelectShowCaseLangResource SearchFieldDescription}">
            <atom:Select Mode="Single" PlaceholderText="Please select" IsFilterEnabled="True">
                <atom:SelectOption Header="Jack" Content="jack" />
                <atom:SelectOption Header="Lucy" Content="lucy" />
                <atom:SelectOption Header="Tom" Content="tom" />
            </atom:Select>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource CustomSearchTitle}"
            Description="{gallery:SelectShowCaseLangResource CustomSearchDescription}">
            <atom:Select Name="CustomSearchSelect"
                         Mode="Single"
                         PlaceholderText="Select a person"
                         IsFilterEnabled="True"
                         Filter="{atom:ValueFilterProvider Contains}">
                <atom:SelectOption Header="Jack" Content="jack" />
                <atom:SelectOption Header="Lucy" Content="lucy" />
                <atom:SelectOption Header="Tom" Content="tom" />
            </atom:Select>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource MultipleSelectionTitle}"
            Description="{gallery:SelectShowCaseLangResource MultipleSelectionDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Select Name="MultiSelect1"
                             Mode="Multiple"
                             PlaceholderText="Select a person"
                             IsAllowClear="True"
                             HorizontalAlignment="Stretch"
                             IsFilterEnabled="True"
                             DefaultValues="a10, c12" />
                <atom:Select Name="MultiSelect2"
                             Mode="Multiple"
                             PlaceholderText="Select a person"
                             IsAllowClear="True"
                             HorizontalAlignment="Stretch"
                             DefaultValues="a10, c12"
                             IsEnabled="False" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource TagsTitle}"
            Description="{gallery:SelectShowCaseLangResource TagsDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Select Name="TagsModeSelect"
                             Mode="Tags"
                             PlaceholderText="Tags Mode"
                             HorizontalAlignment="Stretch"
                             IsFilterEnabled="True"
                             Filter="{atom:ValueFilterProvider Contains}" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource SizesTitle}"
            Description="{gallery:SelectShowCaseLangResource SizesDescription}">

            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:OptionButtonGroup ButtonStyle="Outline" OptionCheckedChanged="HandleSizeTypeChanged">
                    <atom:OptionButton Tag="{x:Static atom:SizeType.Large}">Large</atom:OptionButton>
                    <atom:OptionButton IsChecked="True" Tag="{x:Static atom:SizeType.Middle}">Default</atom:OptionButton>
                    <atom:OptionButton Tag="{x:Static atom:SizeType.Small}">Small</atom:OptionButton>
                </atom:OptionButtonGroup>

                <atom:Select Name="SizeSelect1"
                             Mode="Single"
                             SizeType="{Binding SelectSizeType}"
                             PlaceholderText="Select a person"
                             IsFilterEnabled="False"
                             DefaultValues="a10"
                             Width="200" />

                <atom:Select Mode="Multiple"
                             Name="SizeSelect2"
                             SizeType="{Binding SelectSizeType}"
                             PlaceholderText="Select a person"
                             IsAllowClear="True"
                             HorizontalAlignment="Stretch"
                             IsFilterEnabled="False"
                             DefaultValues="a10, c12" />
            </StackPanel>

        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource CustomDropdownOptionsTitle}"
            Description="{gallery:SelectShowCaseLangResource CustomDropdownOptionsDescription}">
            <atom:Select Mode="Multiple" PlaceholderText="Please select"
                         IsFilterEnabled="True"
                         HorizontalAlignment="Stretch"
                         IsAllowClear="True">
                <views:CustomOption Header="China" Content="china" Description="China (中国)" Emoji="🇨🇳" />
                <views:CustomOption Header="USA" Content="usa" Description="USA (美国)" Emoji="🇺🇸" />
                <views:CustomOption Header="Japan" Content="japan" Description="Japan (日本)" Emoji="🇯🇵" />
                <views:CustomOption Header="Korea" Content="korea" Description="Korea (韩国)" Emoji="🇰🇷" />
                <atom:Select.OptionTemplate>
                    <DataTemplate x:DataType="views:CustomOption">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="{Binding Emoji}" />
                            <TextBlock Text="{Binding Description}" />
                        </StackPanel>
                    </DataTemplate>
                </atom:Select.OptionTemplate>
            </atom:Select>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource OptionGroupTitle}"
            Description="{gallery:SelectShowCaseLangResource OptionGroupDescription}">
            <atom:Select Mode="Single" PlaceholderText="Please select"
                         DefaultValues="lucy"
                         Width="200"
                         IsGroupEnabled="True"
                         IsFilterEnabled="True">
                <atom:SelectOption Header="Jack" Content="jack" Group="Manager" />
                <atom:SelectOption Header="Lucy" Content="lucy" Group="Manager" />
                <atom:SelectOption Header="Chloe" Content="chloe" Group="engineer" />
                <atom:SelectOption Header="Lucas" Content="lucas" Group="engineer" />
            </atom:Select>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource VariantsTitle}"
            Description="{gallery:SelectShowCaseLangResource VariantsDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <UniformGrid Columns="2" ColumnSpacing="10">
                    <atom:Select Mode="Single"
                                 PlaceholderText="Outline"
                                 HorizontalAlignment="Stretch">
                        <atom:SelectOption Header="Jack" Content="jack" />
                        <atom:SelectOption Header="Lucy" Content="lucy" />
                        <atom:SelectOption Header="yiminghe" Content="Yiminghe" />
                    </atom:Select>
                    <atom:Select Mode="Multiple" PlaceholderText="Please select"
                                 HorizontalAlignment="Stretch"
                                 DefaultValues="lucy"
                                 IsFilterEnabled="True">
                        <atom:SelectOption Header="Jack" Content="jack" />
                        <atom:SelectOption Header="Lucy" Content="lucy" />
                        <atom:SelectOption Header="yiminghe" Content="Yiminghe" />
                    </atom:Select>
                </UniformGrid>

                <UniformGrid Columns="2" ColumnSpacing="10">
                    <atom:Select Mode="Single"
                                 PlaceholderText="Filled"
                                 HorizontalAlignment="Stretch"
                                 StyleVariant="Filled">
                        <atom:SelectOption Header="Jack" Content="jack" />
                        <atom:SelectOption Header="Lucy" Content="lucy" />
                        <atom:SelectOption Header="yiminghe" Content="Yiminghe" />
                    </atom:Select>
                    <atom:Select Mode="Multiple" PlaceholderText="Please select"
                                 HorizontalAlignment="Stretch"
                                 StyleVariant="Filled"
                                 IsFilterEnabled="True"
                                 DefaultValues="lucy">
                        <atom:SelectOption Header="Jack" Content="jack" />
                        <atom:SelectOption Header="Lucy" Content="lucy" />
                        <atom:SelectOption Header="yiminghe" Content="Yiminghe" />
                    </atom:Select>
                </UniformGrid>

                <UniformGrid Columns="2" ColumnSpacing="10">
                    <atom:Select Mode="Single"
                                 PlaceholderText="Borderless"
                                 HorizontalAlignment="Stretch"
                                 StyleVariant="Borderless">
                        <atom:SelectOption Header="Jack" Content="jack" />
                        <atom:SelectOption Header="Lucy" Content="lucy" />
                        <atom:SelectOption Header="yiminghe" Content="Yiminghe" />
                    </atom:Select>
                    <atom:Select Mode="Multiple" PlaceholderText="Please select"
                                 HorizontalAlignment="Stretch"
                                 StyleVariant="Borderless"
                                 IsFilterEnabled="True"
                                 DefaultValues="lucy">
                        <atom:SelectOption Header="Jack" Content="jack" />
                        <atom:SelectOption Header="Lucy" Content="lucy" />
                        <atom:SelectOption Header="yiminghe" Content="Yiminghe" />
                    </atom:Select>
                </UniformGrid>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource HideAlreadySelectedTitle}"
            Description="{gallery:SelectShowCaseLangResource HideAlreadySelectedDescription}">
            <atom:Select Mode="Multiple"
                         PlaceholderText="Inserted are removed"
                         IsHideSelectedOptions="True"
                         IsFilterEnabled="True"
                         HorizontalAlignment="Stretch">
                <atom:SelectOption Header="Apples" Content="Apples" />
                <atom:SelectOption Header="Nails" Content="Nails" />
                <atom:SelectOption Header="Bananas" Content="Bananas" />
                <atom:SelectOption Header="Helicopters" Content="Helicopters" />
            </atom:Select>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource StatusTitle}"
            Description="{gallery:SelectShowCaseLangResource StatusDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Select Mode="Single" HorizontalAlignment="Stretch" Status="Error" />
                <atom:Select Mode="Single" HorizontalAlignment="Stretch" Status="Warning" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource MaxCountTitle}"
            Description="{gallery:SelectShowCaseLangResource MaxCountDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Select Mode="Multiple"
                             HorizontalAlignment="Stretch"
                             PlaceholderText="Please select"
                             MaxCount="3"
                             IsShowMaxCountIndicator="True">
                    <atom:SelectOption Header="Ava Swift" Content="Ava Swift" />
                    <atom:SelectOption Header="Cole Reed" Content="Cole Reed" />
                    <atom:SelectOption Header="Mia Blake" Content="Mia Blake" />
                    <atom:SelectOption Header="Jake Stone" Content="Jake Stone" />
                    <atom:SelectOption Header="Lily Lane" Content="Lily Lane" />
                    <atom:SelectOption Header="Ryan Chase" Content="Ryan Chase" />
                    <atom:SelectOption Header="Zoe Fox" Content="Zoe Fox" />
                    <atom:SelectOption Header="Alex Grey" Content="Alex Grey" />
                    <atom:SelectOption Header="Elle Blair" Content="Elle Blair" />
                </atom:Select>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource ResponsiveMaxTagCountTitle}"
            Description="{gallery:SelectShowCaseLangResource ResponsiveMaxTagCountDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Select Name="MaxTagSelect1"
                             Mode="Multiple"
                             PlaceholderText="Select Item..."
                             HorizontalAlignment="Stretch"
                             IsFilterEnabled="True"
                             IsResponsiveTagMode="True" />

                <atom:Select Name="MaxTagSelect2"
                             Mode="Multiple"
                             PlaceholderText="Select Item..."
                             IsEnabled="False"
                             HorizontalAlignment="Stretch"
                             IsFilterEnabled="True"
                             IsResponsiveTagMode="True" />

                <atom:Select Name="MaxTagSelect3"
                             Mode="Multiple"
                             PlaceholderText="Select Item..."
                             HorizontalAlignment="Stretch"
                             IsFilterEnabled="True"
                             MaxTagCount="5" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource PrefixAndSuffixTitle}"
            Description="{gallery:SelectShowCaseLangResource PrefixAndSuffixDescription}" IsOccupyEntireRow="True">
            <StackPanel Orientation="Vertical" Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <atom:Select Mode="Single"
                                 PlaceholderText="Outline"
                                 DefaultValues="lucy"
                                 HorizontalAlignment="Stretch"
                                 Width="200"
                                 ContentLeftAddOn="User">
                        <atom:SelectOption Header="Jack" Content="jack" />
                        <atom:SelectOption Header="Lucy" Content="lucy" />
                        <atom:SelectOption Header="yiminghe" Content="Yiminghe" />
                    </atom:Select>
                    <atom:Select Mode="Single" PlaceholderText="Please select"
                                 HorizontalAlignment="Stretch"
                                 DefaultValues="lucy"
                                 IsFilterEnabled="True"
                                 Width="200"
                                 ContentRightAddOn="{antdicons:AntDesignIconProvider Kind=SmileOutlined}">
                        <atom:SelectOption Header="Jack" Content="jack" />
                        <atom:SelectOption Header="Lucy" Content="lucy" />
                        <atom:SelectOption Header="yiminghe" Content="Yiminghe" />
                    </atom:Select>

                    <atom:Select Mode="Single" PlaceholderText="Please select"
                                 HorizontalAlignment="Stretch"
                                 DefaultValues="lucy"
                                 IsFilterEnabled="True"
                                 Width="200"
                                 IsEnabled="False"
                                 ContentRightAddOn="{antdicons:AntDesignIconProvider Kind=SmileOutlined}">
                        <atom:SelectOption Header="Jack" Content="jack" />
                        <atom:SelectOption Header="Lucy" Content="lucy" />
                        <atom:SelectOption Header="yiminghe" Content="Yiminghe" />
                    </atom:Select>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <atom:Select Mode="Multiple"
                                 PlaceholderText="Outline"
                                 DefaultValues="lucy"
                                 HorizontalAlignment="Stretch"
                                 Width="200"
                                 ContentLeftAddOn="User">
                        <atom:SelectOption Header="Jack" Content="jack" />
                        <atom:SelectOption Header="Lucy" Content="lucy" />
                        <atom:SelectOption Header="yiminghe" Content="Yiminghe" />
                    </atom:Select>
                    <atom:Select Mode="Multiple" PlaceholderText="Please select"
                                 HorizontalAlignment="Stretch"
                                 DefaultValues="lucy"
                                 IsFilterEnabled="True"
                                 Width="200"
                                 ContentRightAddOn="{antdicons:AntDesignIconProvider Kind=SmileOutlined}">
                        <atom:SelectOption Header="Jack" Content="jack" />
                        <atom:SelectOption Header="Lucy" Content="lucy" />
                        <atom:SelectOption Header="yiminghe" Content="Yiminghe" />
                    </atom:Select>

                    <atom:Select Mode="Multiple" PlaceholderText="Please select"
                                 HorizontalAlignment="Stretch"
                                 DefaultValues="lucy"
                                 IsFilterEnabled="True"
                                 Width="200"
                                 IsEnabled="False"
                                 ContentRightAddOn="{antdicons:AntDesignIconProvider Kind=SmileOutlined}">
                        <atom:SelectOption Header="Jack" Content="jack" />
                        <atom:SelectOption Header="Lucy" Content="lucy" />
                        <atom:SelectOption Header="yiminghe" Content="Yiminghe" />
                    </atom:Select>
                </StackPanel>
            </StackPanel>
        </gallery:ShowCaseItem>

    </gallery:ShowCasePanel>
</UserControl>
