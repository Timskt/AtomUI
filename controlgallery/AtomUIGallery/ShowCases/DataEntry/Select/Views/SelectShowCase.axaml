<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Select.SelectShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.Select"
             xmlns:views="using:AtomUIGallery.ShowCases.Select"
             x:DataType="vm:SelectViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource BasicTitle}"
            Description="{gallery:SelectShowCaseLangResource BasicDescription}" IsOccupyEntireRow="False">
            <WrapPanel ItemSpacing="10" LineSpacing="10">
                <atom:Select Mode="Single" PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextPleaseSelect}" Width="120"
                             DefaultValues="lucy"
                             OptionsSource="{Binding BasicSelectedOptions}" />

                <atom:Select Mode="Single" PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextPleaseSelect}" IsEnabled="False" Width="120"
                             DefaultValues="lucy"
                             OptionsSource="{Binding SingleLucyOptions}" />

                <atom:Select Name="AsyncLoadSelect"
                             Mode="Single"
                             PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextPleaseSelect}"
                             Width="120"
                             DefaultValues="lucy"
                             OptionsSource="{Binding SingleLucyOptions}"
                             OptionsLoader="{Binding SelectOptionsAsyncLoader}" />

                <atom:Select Mode="Single" PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextPleaseSelect}" IsAllowClear="True" Width="120"
                             OptionsSource="{Binding SingleLucyOptions}" />

                <atom:Select Name="DefaultSelectedSelect"
                             Mode="Single"
                             PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextPleaseSelect}"
                             IsAllowClear="True"
                             Width="120"
                             OptionsSource="{Binding BasicSelectedOptions}"
                             SelectedOptions="{Binding DefaultSelectedOptions}" />

            </WrapPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource SearchFieldTitle}"
            Description="{gallery:SelectShowCaseLangResource SearchFieldDescription}">
            <atom:Select Mode="Single"
                         PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextPleaseSelect}"
                         IsFilterEnabled="True"
                         OptionsSource="{Binding SearchOptions}" />
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource CustomSearchTitle}"
            Description="{gallery:SelectShowCaseLangResource CustomSearchDescription}">
                <atom:Select Name="CustomSearchSelect"
                         Mode="Single"
                         PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextSelectAPerson}"
                         IsFilterEnabled="True"
                         Filter="{atom:ValueFilterProvider Contains}"
                         OptionsSource="{Binding SearchOptions}" />
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource MultipleSelectionTitle}"
            Description="{gallery:SelectShowCaseLangResource MultipleSelectionDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Select Name="MultiSelect1"
                             Mode="Multiple"
                             PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextSelectAPerson}"
                             IsAllowClear="True"
                             HorizontalAlignment="Stretch"
                             IsFilterEnabled="True"
                             DefaultValues="a10, c12"
                             OptionsSource="{Binding RandomOptions}" />
                <atom:Select Name="MultiSelect2"
                             Mode="Multiple"
                             PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextSelectAPerson}"
                             IsAllowClear="True"
                             HorizontalAlignment="Stretch"
                             DefaultValues="a10, c12"
                             IsEnabled="False"
                             OptionsSource="{Binding RandomOptions}" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource TagsTitle}"
            Description="{gallery:SelectShowCaseLangResource TagsDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Select Name="TagsModeSelect"
                             Mode="Tags"
                             PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextTagsMode}"
                             HorizontalAlignment="Stretch"
                             IsFilterEnabled="True"
                             Filter="{atom:ValueFilterProvider Contains}"
                             OptionsSource="{Binding RandomOptions}" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource SizesTitle}"
            Description="{gallery:SelectShowCaseLangResource SizesDescription}">

            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:OptionButtonGroup ButtonStyle="Outline" OptionCheckedChanged="HandleSizeTypeChanged">
                    <atom:OptionButton Tag="{x:Static atom:SizeType.Large}" Content="{gallery:SelectShowCaseLangResource P2ContentLarge}" />
                    <atom:OptionButton IsChecked="True" Tag="{x:Static atom:SizeType.Middle}" Content="{gallery:SelectShowCaseLangResource P2ContentDefault}" />
                    <atom:OptionButton Tag="{x:Static atom:SizeType.Small}" Content="{gallery:SelectShowCaseLangResource P2ContentSmall}" />
                </atom:OptionButtonGroup>

                <atom:Select Name="SizeSelect1"
                             Mode="Single"
                             SizeType="{Binding SelectSizeType}"
                             PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextSelectAPerson}"
                             IsFilterEnabled="False"
                             DefaultValues="a10"
                             Width="200"
                             OptionsSource="{Binding RandomOptions}" />

                <atom:Select Mode="Multiple"
                             Name="SizeSelect2"
                             SizeType="{Binding SelectSizeType}"
                             PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextSelectAPerson}"
                             IsAllowClear="True"
                             HorizontalAlignment="Stretch"
                             IsFilterEnabled="False"
                             DefaultValues="a10, c12"
                             OptionsSource="{Binding RandomOptions}" />
            </StackPanel>

        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource CustomDropdownOptionsTitle}"
            Description="{gallery:SelectShowCaseLangResource CustomDropdownOptionsDescription}">
            <atom:Select Mode="Multiple" PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextPleaseSelect}"
                         IsFilterEnabled="True"
                         HorizontalAlignment="Stretch"
                         IsAllowClear="True"
                         OptionsSource="{Binding CustomCountryOptions}">
                <atom:Select.OptionTemplate>
                    <DataTemplate x:DataType="views:CustomOption">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="{Binding Emoji}" />
                            <TextBlock Text="{Binding Description}" />
                        </StackPanel>
                    </DataTemplate>
                </atom:Select.OptionTemplate>
            </atom:Select>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource OptionGroupTitle}"
            Description="{gallery:SelectShowCaseLangResource OptionGroupDescription}">
            <atom:Select Mode="Single" PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextPleaseSelect}"
                         DefaultValues="lucy"
                         Width="200"
                         IsGroupEnabled="True"
                         IsFilterEnabled="True"
                         OptionsSource="{Binding GroupedPersonOptions}" />
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource VariantsTitle}"
            Description="{gallery:SelectShowCaseLangResource VariantsDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <UniformGrid Columns="2" ColumnSpacing="10">
                    <atom:Select Mode="Single"
                                 PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextOutline}"
                                 HorizontalAlignment="Stretch"
                                 OptionsSource="{Binding VariantOptions}" />
                    <atom:Select Mode="Multiple" PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextPleaseSelect}"
                                 HorizontalAlignment="Stretch"
                                 DefaultValues="lucy"
                                 IsFilterEnabled="True"
                                 OptionsSource="{Binding VariantOptions}" />
                </UniformGrid>

                <UniformGrid Columns="2" ColumnSpacing="10">
                    <atom:Select Mode="Single"
                                 PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextFilled}"
                                 HorizontalAlignment="Stretch"
                                 StyleVariant="Filled"
                                 OptionsSource="{Binding VariantOptions}" />
                    <atom:Select Mode="Multiple" PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextPleaseSelect}"
                                 HorizontalAlignment="Stretch"
                                 StyleVariant="Filled"
                                 IsFilterEnabled="True"
                                 DefaultValues="lucy"
                                 OptionsSource="{Binding VariantOptions}" />
                </UniformGrid>

                <UniformGrid Columns="2" ColumnSpacing="10">
                    <atom:Select Mode="Single"
                                 PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextBorderless}"
                                 HorizontalAlignment="Stretch"
                                 StyleVariant="Borderless"
                                 OptionsSource="{Binding VariantOptions}" />
                    <atom:Select Mode="Multiple" PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextPleaseSelect}"
                                 HorizontalAlignment="Stretch"
                                 StyleVariant="Borderless"
                                 IsFilterEnabled="True"
                                 DefaultValues="lucy"
                                 OptionsSource="{Binding VariantOptions}" />
                </UniformGrid>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource HideAlreadySelectedTitle}"
            Description="{gallery:SelectShowCaseLangResource HideAlreadySelectedDescription}">
            <atom:Select Mode="Multiple"
                         PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextInsertedAreRemoved}"
                         IsHideSelectedOptions="True"
                         IsFilterEnabled="True"
                         HorizontalAlignment="Stretch"
                         OptionsSource="{Binding HideSelectedOptions}" />
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource StatusTitle}"
            Description="{gallery:SelectShowCaseLangResource StatusDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Select Mode="Single" HorizontalAlignment="Stretch" Status="Error" />
                <atom:Select Mode="Single" HorizontalAlignment="Stretch" Status="Warning" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource MaxCountTitle}"
            Description="{gallery:SelectShowCaseLangResource MaxCountDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Select Mode="Multiple"
                             HorizontalAlignment="Stretch"
                             PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextPleaseSelect}"
                             MaxCount="3"
                             IsShowMaxCountIndicator="True"
                             OptionsSource="{Binding MaxCountLimitedOptions}" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource ResponsiveMaxTagCountTitle}"
            Description="{gallery:SelectShowCaseLangResource ResponsiveMaxTagCountDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Select Name="MaxTagSelect1"
                             Mode="Multiple"
                             PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextSelectItem}"
                             HorizontalAlignment="Stretch"
                             IsFilterEnabled="True"
                             IsResponsiveTagMode="True"
                             OptionsSource="{Binding MaxTagCountOptions}" />

                <atom:Select Name="MaxTagSelect2"
                             Mode="Multiple"
                             PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextSelectItem}"
                             IsEnabled="False"
                             HorizontalAlignment="Stretch"
                             IsFilterEnabled="True"
                             IsResponsiveTagMode="True"
                             OptionsSource="{Binding MaxTagCountOptions}" />

                <atom:Select Name="MaxTagSelect3"
                             Mode="Multiple"
                             PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextSelectItem}"
                             HorizontalAlignment="Stretch"
                             IsFilterEnabled="True"
                             MaxTagCount="5"
                             OptionsSource="{Binding MaxTagCountOptions}" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SelectShowCaseLangResource PrefixAndSuffixTitle}"
            Description="{gallery:SelectShowCaseLangResource PrefixAndSuffixDescription}" IsOccupyEntireRow="True">
            <StackPanel Orientation="Vertical" Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <atom:Select Mode="Single"
                                 PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextOutline}"
                                 DefaultValues="lucy"
                                 HorizontalAlignment="Stretch"
                                 Width="200"
                                 ContentLeftAddOn="{gallery:SelectShowCaseLangResource P2ContentUser}"
                                 OptionsSource="{Binding PrefixSuffixOptions}" />
                    <atom:Select Mode="Single" PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextPleaseSelect}"
                                 HorizontalAlignment="Stretch"
                                 DefaultValues="lucy"
                                 IsFilterEnabled="True"
                                 Width="200"
                                 ContentRightAddOn="{antdicons:AntDesignIconProvider Kind=SmileOutlined}"
                                 OptionsSource="{Binding PrefixSuffixOptions}" />

                    <atom:Select Mode="Single" PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextPleaseSelect}"
                                 HorizontalAlignment="Stretch"
                                 DefaultValues="lucy"
                                 IsFilterEnabled="True"
                                 Width="200"
                                 IsEnabled="False"
                                 ContentRightAddOn="{antdicons:AntDesignIconProvider Kind=SmileOutlined}"
                                 OptionsSource="{Binding PrefixSuffixOptions}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <atom:Select Mode="Multiple"
                                 PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextOutline}"
                                 DefaultValues="lucy"
                                 HorizontalAlignment="Stretch"
                                 Width="200"
                                 ContentLeftAddOn="{gallery:SelectShowCaseLangResource P2ContentUser}"
                                 OptionsSource="{Binding PrefixSuffixOptions}" />
                    <atom:Select Mode="Multiple" PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextPleaseSelect}"
                                 HorizontalAlignment="Stretch"
                                 DefaultValues="lucy"
                                 IsFilterEnabled="True"
                                 Width="200"
                                 ContentRightAddOn="{antdicons:AntDesignIconProvider Kind=SmileOutlined}"
                                 OptionsSource="{Binding PrefixSuffixOptions}" />

                    <atom:Select Mode="Multiple" PlaceholderText="{gallery:SelectShowCaseLangResource P2PlaceholderTextPleaseSelect}"
                                 HorizontalAlignment="Stretch"
                                 DefaultValues="lucy"
                                 IsFilterEnabled="True"
                                 Width="200"
                                 IsEnabled="False"
                                 ContentRightAddOn="{antdicons:AntDesignIconProvider Kind=SmileOutlined}"
                                 OptionsSource="{Binding PrefixSuffixOptions}" />
                </StackPanel>
            </StackPanel>
        </gallery:ShowCaseItem>

    </gallery:ShowCasePanel>
</UserControl>
