<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Select.SelectShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.Select"
             x:DataType="vm:SelectViewModel">
    <atom:TabControl Name="ScenarioTabs"
                     SizeType="Large"
                     SelectedIndex="0">
        <atom:TabItem Header="{gallery:SelectShowCaseLangResource ScenarioBasic}" Tag="Basic" />
        <atom:TabItem Header="{gallery:SelectShowCaseLangResource ScenarioOptions}" Tag="Options" />
        <atom:TabItem Header="{gallery:SelectShowCaseLangResource ScenarioAppearance}" Tag="Appearance" />
    </atom:TabControl>
</UserControl>
