<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AtomUIGallery.ShowCases.TimePicker"
             x:Class="AtomUIGallery.ShowCases.TimePicker.TimePickerShowCase"
             x:DataType="vm:TimePickerViewModel"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery">

    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:TimePickerShowCaseLangResource BasicTitle}"
            Description="{gallery:TimePickerShowCaseLangResource BasicDescription}">
            <atom:TimePicker PlaceholderText="Select time" IsNeedConfirm="False" IsShowNow="True" />
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TimePickerShowCaseLangResource HourFormatsTitle}"
            Description="{gallery:TimePickerShowCaseLangResource HourFormatsDescription}">
            <atom:TimePicker PlaceholderText="Select time" IsNeedConfirm="True" IsShowNow="True"
                             ClockIdentifier="HourClock24" />
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TimePickerShowCaseLangResource ThreeSizesTitle}"
            Description="{gallery:TimePickerShowCaseLangResource ThreeSizesDescription}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <atom:TimePicker PlaceholderText="Select time" SizeType="Large" DefaultTime="12:08:23" />
                <atom:TimePicker PlaceholderText="Select time" SizeType="Middle" DefaultTime="12:08:23" />
                <atom:TimePicker PlaceholderText="Select time" SizeType="Small" DefaultTime="12:08:23" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TimePickerShowCaseLangResource DisabledTitle}"
            Description="{gallery:TimePickerShowCaseLangResource DisabledDescription}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <atom:TimePicker PlaceholderText="Select time" IsEnabled="False" DefaultTime="12:08:23" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TimePickerShowCaseLangResource IntervalOptionTitle}"
            Description="{gallery:TimePickerShowCaseLangResource IntervalOptionDescription}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <atom:TimePicker PlaceholderText="Select time"
                                 DefaultTime="12:08:23"
                                 MinuteIncrement="15"
                                 SecondIncrement="10" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TimePickerShowCaseLangResource TwelveHoursTitle}"
            Description="{gallery:TimePickerShowCaseLangResource TwelveHoursDescription}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <atom:TimePicker PlaceholderText="Select time"
                                 DefaultTime="12:08:23"
                                 ClockIdentifier="HourClock12" />
                <atom:TimePicker PlaceholderText="Select time"
                                 DefaultTime="12:08:23"
                                 ClockIdentifier="HourClock24" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TimePickerShowCaseLangResource VariantsTitle}"
            Description="{gallery:TimePickerShowCaseLangResource VariantsDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <atom:TimePicker PlaceholderText="Outline"
                                     StyleVariant="Outlined" />
                    <atom:RangeTimePicker StyleVariant="Outlined"
                                          PlaceholderText="Outline" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <atom:TimePicker PlaceholderText="Filled"
                                     StyleVariant="Filled" />
                    <atom:RangeTimePicker StyleVariant="Filled"
                                          PlaceholderText="Filled" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <atom:TimePicker PlaceholderText="Borderless"
                                     StyleVariant="Borderless" />
                    <atom:RangeTimePicker StyleVariant="Borderless"
                                          PlaceholderText="Borderless" />
                </StackPanel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TimePickerShowCaseLangResource StatusTitle}"
            Description="{gallery:TimePickerShowCaseLangResource StatusDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <atom:TimePicker Status="Default"
                                     PlaceholderText="Select time" />
                    <atom:RangeTimePicker StyleVariant="Outlined"
                                          Status="Default"
                                          PlaceholderText="Start time"
                                          SecondaryPlaceholderText="End time"
                                          IsNeedConfirm="True"
                                          ClockIdentifier="HourClock24" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <atom:TimePicker Status="Warning"
                                     PlaceholderText="Select time" />
                    <atom:RangeTimePicker StyleVariant="Outlined"
                                          Status="Warning"
                                          PlaceholderText="Start time"
                                          SecondaryPlaceholderText="End time"
                                          IsNeedConfirm="True"
                                          ClockIdentifier="HourClock24" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <atom:TimePicker Status="Error"
                                     PlaceholderText="Select time" />
                    <atom:RangeTimePicker StyleVariant="Outlined"
                                          Status="Error"
                                          PlaceholderText="Start time"
                                          SecondaryPlaceholderText="End time"
                                          IsNeedConfirm="True"
                                          ClockIdentifier="HourClock24" />
                </StackPanel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TimePickerShowCaseLangResource TimeRangePickerTitle}"
            Description="{gallery:TimePickerShowCaseLangResource TimeRangePickerDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:RangeTimePicker Status="Default"
                                      PlaceholderText="Start time"
                                      SecondaryPlaceholderText="End time"
                                      RangeStartDefaultTime="10:09:20"
                                      RangeEndDefaultTime="12:12:20" />
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
