<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.ToggleSwitch.ToggleSwitchShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:showCase="clr-namespace:AtomUIGallery.ShowCases.ToggleSwitch"
             xmlns:vm="using:AtomUIGallery.ShowCases.ToggleSwitch"
             x:DataType="vm:ToggleSwitchViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:ToggleSwitchShowCaseLangResource BasicTitle}"
            Description="{gallery:ToggleSwitchShowCaseLangResource BasicDescription}">
            <StackPanel HorizontalAlignment="Left" Spacing="10" Orientation="Horizontal">
                <atom:ToggleSwitch />
            </StackPanel>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="{gallery:ToggleSwitchShowCaseLangResource DisabledTitle}"
            Description="{gallery:ToggleSwitchShowCaseLangResource DisabledDescription}">
            <StackPanel HorizontalAlignment="Left" Spacing="10" Orientation="Vertical">
                <atom:ToggleSwitch x:Name="ToggleDisabledSwitch" />
                <atom:Button ButtonType="Primary"
                             Command="{Binding $parent[showCase:ToggleSwitchShowCase].ToggleSwitchCommand}" Content="{gallery:ToggleSwitchShowCaseLangResource P2ContentToggleDisabled}" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ToggleSwitchShowCaseLangResource TextAndIconTitle}"
            Description="{gallery:ToggleSwitchShowCaseLangResource TextAndIconDescription}">
            <StackPanel HorizontalAlignment="Left" Spacing="10" Orientation="Vertical">
                <atom:ToggleSwitch
                    OnContent="{gallery:ToggleSwitchShowCaseLangResource P2OnContentOn}"
                    OffContent="{gallery:ToggleSwitchShowCaseLangResource P2OffContentOff}"
                    IsChecked="True" />
                <atom:ToggleSwitch
                    OnContent="{gallery:ToggleSwitchShowCaseLangResource P2OnContentText}"
                    OffContent="{gallery:ToggleSwitchShowCaseLangResource P2OffContentText}" />
                <atom:ToggleSwitch
                    OnContent="{antdicons:AntDesignIconProvider Kind=TwitterOutlined}"
                    OffContent="{antdicons:AntDesignIconProvider Kind=WechatOutlined}"/>
                <atom:ToggleSwitch
                    SizeType="Small"
                    OnContent="{antdicons:AntDesignIconProvider Kind=CheckOutlined}"
                    OffContent="{antdicons:AntDesignIconProvider Kind=WechatOutlined}"/>
                <atom:ToggleSwitch SizeType="Small">
                    <atom:ToggleSwitch.OnContent>
                        <antdicons:CheckOutlined/>
                    </atom:ToggleSwitch.OnContent>
                    <atom:ToggleSwitch.OffContent>
                        <antdicons:CloseOutlined/>
                    </atom:ToggleSwitch.OffContent>
                </atom:ToggleSwitch>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ToggleSwitchShowCaseLangResource TwoSizesTitle}"
            Description="{gallery:ToggleSwitchShowCaseLangResource TwoSizesDescription}">
            <StackPanel HorizontalAlignment="Left" Spacing="10" Orientation="Vertical">
                <atom:ToggleSwitch />
                <atom:ToggleSwitch SizeType="Small" />
            </StackPanel>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="{gallery:ToggleSwitchShowCaseLangResource LoadingTitle}"
            Description="{gallery:ToggleSwitchShowCaseLangResource LoadingDescription}">
            <StackPanel HorizontalAlignment="Left" Spacing="10" Orientation="Vertical">
                <atom:ToggleSwitch IsLoading="True" IsChecked="true" x:Name="ToggleSwitchDefault" />
                <atom:ToggleSwitch SizeType="Small" IsLoading="True" x:Name="ToggleSwitchSmall" />
                <atom:Button ButtonType="Primary"
                             Command="{Binding $parent[showCase:ToggleSwitchShowCase].ToggleLoadingStatus}" Content="{gallery:ToggleSwitchShowCaseLangResource P2ContentToggleLoading}" />
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>