        <!-- </gallery:ShowCaseItem> -->

        <gallery:ShowCaseItem
            Title="{gallery:TransferShowCaseLangResource TreeTransferTitle}"
            IsOccupyEntireRow="True"
            Description="{gallery:TransferShowCaseLangResource TreeTransferDescription}">
            <StackPanel Spacing="20">
                <atom:TreeTransfer Name="TreeTransfer"
                                   IsStretchView="True"
                                   IsOneWay="{Binding TreeTransferIsOneWay}">
                    <atom:TreeTransfer.SourceView>
                        <atom:TransferTreeView IsDefaultExpandAll="True" />
                    </atom:TreeTransfer.SourceView>
                </atom:TreeTransfer>
                <atom:ToggleSwitch IsChecked="{Binding TreeTransferIsOneWay, Mode=TwoWay}"
                                   OnContent="ony way"
                                   OffContent="ony way" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TransferShowCaseLangResource StatusTitle}"
            IsOccupyEntireRow="True"
            Description="{gallery:TransferShowCaseLangResource StatusDescription}">
            <StackPanel Spacing="20">
                <atom:ListTransfer Status="Error"/>
                <atom:ListTransfer Status="Warning"/>
            </StackPanel>
        </gallery:ShowCaseItem>

    </gallery:ShowCasePanel>
</UserControl>
