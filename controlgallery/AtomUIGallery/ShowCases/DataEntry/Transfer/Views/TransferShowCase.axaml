        <!--                         <atom:DataGridTemplateColumn Header="Tag"> -->
        <!--                             <atom:DataGridTemplateColumn.CellTemplate> -->
        <!--                                 <DataTemplate> -->
        <!--                                     <atom:Tag TagText="{Binding Tag}" TagColor="cyan" /> -->
        <!--                                 </DataTemplate> -->
        <!--                             </atom:DataGridTemplateColumn.CellTemplate> -->
        <!--                         </atom:DataGridTemplateColumn> -->
        <!--                         <atom:DataGridTextColumn Header="Description" Binding="{Binding Description}" /> -->
        <!--                     </atom:TransferDataGridView.Columns> -->
        <!--                 </atom:TransferDataGridView> -->
        <!--             </atom:Transfer.SourcePanel> -->
        <!--             <atom:Transfer.TargetPanel> -->
        <!--                 <atom:TransferDataGridView> -->
        <!--                     <atom:TransferDataGridView.Columns> -->
        <!-- -->
