<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Transfer.TransferShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:viewModels="clr-namespace:AtomUIGallery.ShowCases.Transfer"
             x:DataType="viewModels:TransferViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:TransferShowCaseLangResource BasicTitle}"
            IsOccupyEntireRow="True"
            Description="{gallery:TransferShowCaseLangResource BasicDescription}">
            <atom:ListTransfer Name="BasicListTransfer"
                               SourceTitle="Source"
                               TargetTitle="Target"/>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TransferShowCaseLangResource OneWayTitle}"
            IsOccupyEntireRow="True"
            Description="{gallery:TransferShowCaseLangResource OneWayDescription}">
            <StackPanel Spacing="20">
                <atom:ListTransfer Name="OneWayTransferList"
                                   SourceTitle="Source"
                                   TargetTitle="Target"
                                   IsOneWay="True"
                                   IsEnabled="{Binding OneWayTransferEnabled}" />
                <atom:ToggleSwitch IsChecked="{Binding OneWayTransferEnabled, Mode=TwoWay}"
                                   OnContent="disable"
                                   OffContent="enable" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TransferShowCaseLangResource SearchTitle}"
            IsOccupyEntireRow="True"
            Description="{gallery:TransferShowCaseLangResource SearchDescription}">
            <StackPanel Spacing="20">
                <atom:ListTransfer Name="SearchTransferList"
                                   IsFilterEnabled="True"
                                   FilterPlaceholderText="Search here"
                                   FilterValueSelector="{Binding TransferFilterValueSelector}" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TransferShowCaseLangResource AdvancedTitle}"
            IsOccupyEntireRow="True"
            Description="{gallery:TransferShowCaseLangResource AdvancedDescription}">
            <atom:ListTransfer ToTargetButtonText="to right"
                               ToSourceButtonText="to left"
                               ListWidth="300"
                               Name="AdvanceTransfer">
                <atom:ListTransfer.SourceViewFooter>
                    <atom:Button SizeType="Small" Click="ReloadAdvancedTransferItems">Left button reload</atom:Button>
                </atom:ListTransfer.SourceViewFooter>
                <atom:ListTransfer.TargetViewFooter>
                    <atom:Button SizeType="Small" Click="ReloadAdvancedTransferItems">Right button reload</atom:Button>
                </atom:ListTransfer.TargetViewFooter>
                <atom:ListTransfer.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:SearchCaseItemData">
                        <TextBlock TextTrimming="CharacterEllipsis">
                            <Run Text="{Binding Content}" />
                            <Run Text="-" />
                            <Run Text="{Binding Description}" />
                        </TextBlock>
                    </DataTemplate>
                </atom:ListTransfer.ItemTemplate>
            </atom:ListTransfer>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TransferShowCaseLangResource PaginationTitle}"
            IsOccupyEntireRow="True"
            Description="{gallery:TransferShowCaseLangResource PaginationDescription}">
            <StackPanel Spacing="20">
                <atom:ListTransfer Name="PaginationTransferList"
                                   IsOneWay="{Binding PaginationIsOneWay}"
                                   PageSize="10"
                                   ListHeight="370" />
                <atom:ToggleSwitch IsChecked="{Binding PaginationIsOneWay, Mode=TwoWay}"
                                   OnContent="ony way"
                                   OffContent="ony way" />
            </StackPanel>
        </gallery:ShowCaseItem>

