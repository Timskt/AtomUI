<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Transfer.TransferShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:viewModels="clr-namespace:AtomUIGallery.ShowCases.Transfer"
             x:DataType="viewModels:TransferViewModel">
    <atom:TabControl Name="ScenarioTabs"
                     SizeType="Large"
                     SelectedIndex="0">
        <atom:TabItem Header="{gallery:TransferShowCaseLangResource ScenarioBasic}" Tag="Basic" />
        <atom:TabItem Header="{gallery:TransferShowCaseLangResource ScenarioAdvanced}" Tag="Advanced" />
        <atom:TabItem Header="{gallery:TransferShowCaseLangResource ScenarioTreeStatus}" Tag="TreeStatus" />
    </atom:TabControl>
</UserControl>
