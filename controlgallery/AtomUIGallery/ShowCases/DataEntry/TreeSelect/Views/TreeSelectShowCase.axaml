<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.TreeSelect.TreeSelectShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.TreeSelect"
             x:DataType="vm:TreeSelectViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:TreeSelectShowCaseLangResource BasicTitle}"
            Description="{gallery:TreeSelectShowCaseLangResource BasicDescription}">
            <atom:TreeSelect Name="BasicTreeSelect"
                             HorizontalAlignment="Stretch"
                             IsDefaultExpandAll="True"
                             IsAllowClear="True"
                             IsFilterEnabled="True"
                             PlaceholderText="Please select" />
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TreeSelectShowCaseLangResource MultipleSelectionTitle}"
            Description="{gallery:TreeSelectShowCaseLangResource MultipleSelectionDescription}">
            <atom:TreeSelect Name="MultiSelectionTreeSelect"
                             HorizontalAlignment="Stretch"
                             IsDefaultExpandAll="True"
                             IsAllowClear="True"
                             IsFilterEnabled="True"
                             IsMultiple="True"
                             PlaceholderText="Please select" />
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TreeSelectShowCaseLangResource GenerateFromTreeDataTitle}"
            Description="{gallery:TreeSelectShowCaseLangResource GenerateFromTreeDataDescription}">
            <atom:TreeSelect Name="ItemsSourceTreeSelect"
                             HorizontalAlignment="Stretch"
                             IsDefaultExpandAll="True"
                             IsAllowClear="True"
                             IsFilterEnabled="True"
                             PlaceholderText="Please select" />
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TreeSelectShowCaseLangResource CheckableTitle}"
            Description="{gallery:TreeSelectShowCaseLangResource CheckableDescription}">
            <atom:TreeSelect Name="CheckableTreeSelect"
                             HorizontalAlignment="Stretch"
                             IsDefaultExpandAll="True"
                             IsAllowClear="True"
                             IsFilterEnabled="True"
                             IsTreeCheckable="True"
                             PlaceholderText="Please select"
                             ShowCheckedStrategy="ShowParent" />
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TreeSelectShowCaseLangResource AsynchronousLoadingTitle}"
            Description="{gallery:TreeSelectShowCaseLangResource AsynchronousLoadingDescription}">
            <atom:TreeSelect Name="AsyncLoadTreeSelect"
                             HorizontalAlignment="Stretch"
                             IsAllowClear="True"
                             PlaceholderText="Please select" />
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TreeSelectShowCaseLangResource PlacementTitle}"
            Description="{gallery:TreeSelectShowCaseLangResource PlacementDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:TextBlock VerticalAlignment="Center">Placement:</atom:TextBlock>
                <atom:OptionButtonGroup ButtonStyle="Outline" Name="PlacementOptionGroup"
                                        OptionCheckedChanged="HandlePlacementOptionCheckedChanged">
                    <atom:OptionButton IsChecked="True">TopLeft</atom:OptionButton>
                    <atom:OptionButton>TopRight</atom:OptionButton>
                    <atom:OptionButton>BottomLeft</atom:OptionButton>
                    <atom:OptionButton>BottomRight</atom:OptionButton>
                </atom:OptionButtonGroup>
                <atom:TreeSelect Name="PlacementTreeSelect"
                                 IsAllowClear="True"
                                 PlaceholderText="Please select"
                                 IsDefaultExpandAll="True"
                                 IsFilterEnabled="True"
                                 IsPopupMatchSelectWidth="False" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TreeSelectShowCaseLangResource ShowTreeLineTitle}"
            Description="{gallery:TreeSelectShowCaseLangResource ShowTreeLineDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:ToggleSwitch OnContent="ShowIcon" OffContent="ShowIcon" Name="ShowIconSwitch" />
                <atom:ToggleSwitch OnContent="TreeLine" OffContent="TreeLine" IsChecked="True"
                                   Name="ShowTreeLineSwitch" />
                <atom:ToggleSwitch OnContent="ShowLeafIcon" OffContent="ShowLeafIcon" Name="ShowLeafIconSwitch" />
                <atom:TreeSelect Name="ShowTreeLineTreeSelect"
                                 HorizontalAlignment="Stretch"
                                 IsAllowClear="True"
                                 PlaceholderText="Please select"
                                 IsShowIcon="{Binding #ShowIconSwitch.IsChecked}"
                                 IsShowLeafIcon="{Binding #ShowLeafIconSwitch.IsChecked}"
                                 IsShowLine="{Binding #ShowTreeLineSwitch.IsChecked}"
                                 IsSwitcherRotation="{Binding #ShowTreeLineSwitch.IsChecked, Converter={x:Static BoolConverters.Not}}" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TreeSelectShowCaseLangResource VariantsTitle}"
            Description="{gallery:TreeSelectShowCaseLangResource VariantsDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:TreeSelect HorizontalAlignment="Stretch"
                                 IsAllowClear="True"
                                 PlaceholderText="Please select"
                                 StyleVariant="Borderless" />
                <atom:TreeSelect HorizontalAlignment="Stretch"
                                 IsAllowClear="True"
                                 PlaceholderText="Please select"
                                 StyleVariant="Filled" />
                <atom:TreeSelect HorizontalAlignment="Stretch"
                                 IsAllowClear="True"
                                 PlaceholderText="Please select"
                                 StyleVariant="Outlined" />
                <atom:TreeSelect HorizontalAlignment="Stretch"
                                 IsAllowClear="True"
                                 PlaceholderText="Please select"
                                 StyleVariant="Underlined" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TreeSelectShowCaseLangResource StatusTitle}"
            Description="{gallery:TreeSelectShowCaseLangResource StatusDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:TreeSelect HorizontalAlignment="Stretch"
                                 IsAllowClear="True"
                                 PlaceholderText="Please select"
                                 Status="Error" />
                <atom:TreeSelect HorizontalAlignment="Stretch"
                                 IsAllowClear="True"
                                 PlaceholderText="Please select"
                                 Status="Warning" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TreeSelectShowCaseLangResource PrefixAndSuffixTitle}"
            Description="{gallery:TreeSelectShowCaseLangResource PrefixAndSuffixDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:TreeSelect Name="LeftAddTreeSelect"
                                 HorizontalAlignment="Stretch"
                                 IsAllowClear="True"
                                 PlaceholderText="Please select"
                                 IsDefaultExpandAll="True"
                                 LeftAddOn="Prefix"
                                 IsFilterEnabled="True" />
                <atom:TreeSelect Name="ContentLeftAddTreeSelect"
                                 HorizontalAlignment="Stretch"
                                 IsAllowClear="True"
                                 PlaceholderText="Please select"
                                 IsDefaultExpandAll="True"
                                 ContentLeftAddOn="Prefix"
                                 IsFilterEnabled="True" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:TreeSelectShowCaseLangResource MaxCountTitle}"
            Description="{gallery:TreeSelectShowCaseLangResource MaxCountDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:TreeSelect Name="MaxSelectedTreeSelect"
                                 HorizontalAlignment="Stretch"
                                 IsDefaultExpandAll="True"
                                 IsMultiple="True"
                                 IsAllowClear="True"
                                 IsFilterEnabled="True"
                                 PlaceholderText="Please select"
                                 IsShowMaxCountIndicator="True"
                                 MaxCount="3" />
                <atom:TreeSelect Name="MaxCheckedTreeSelect"
                                 HorizontalAlignment="Stretch"
                                 IsDefaultExpandAll="True"
                                 IsMultiple="True"
                                 IsTreeCheckable="True"
                                 IsAllowClear="True"
                                 IsFilterEnabled="True"
                                 PlaceholderText="Please select"
                                 IsShowMaxCountIndicator="True"
                                 MaxCount="3" />
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
