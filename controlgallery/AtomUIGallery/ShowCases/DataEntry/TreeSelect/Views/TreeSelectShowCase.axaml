<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.TreeSelect.TreeSelectShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.TreeSelect"
             x:DataType="vm:TreeSelectViewModel">
    <atom:TabControl Name="ScenarioTabs"
                     SizeType="Large"
                     SelectedIndex="0">
        <atom:TabItem Header="{gallery:TreeSelectShowCaseLangResource ScenarioBasic}" Tag="Basic" />
        <atom:TabItem Header="{gallery:TreeSelectShowCaseLangResource ScenarioBehavior}" Tag="Behavior" />
        <atom:TabItem Header="{gallery:TreeSelectShowCaseLangResource ScenarioAppearance}" Tag="Appearance" />
    </atom:TabControl>
</UserControl>
