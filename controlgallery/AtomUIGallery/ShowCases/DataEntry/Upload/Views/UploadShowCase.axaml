<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Upload.UploadShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:viewModels="using:AtomUIGallery.ShowCases.Upload"
             x:DataType="viewModels:UploadViewModel">
    <atom:TabControl Name="ScenarioTabs"
                     SizeType="Large"
                     SelectedIndex="0">
        <atom:TabItem Header="{gallery:UploadShowCaseLangResource ScenarioBasic}" Tag="Basic" />
        <atom:TabItem Header="{gallery:UploadShowCaseLangResource ScenarioPictures}" Tag="Pictures" />
        <atom:TabItem Header="{gallery:UploadShowCaseLangResource ScenarioConstraints}" Tag="Constraints" />
    </atom:TabControl>
</UserControl>
