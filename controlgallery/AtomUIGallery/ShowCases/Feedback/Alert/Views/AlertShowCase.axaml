<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Alert.AlertShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.Alert"
             x:DataType="vm:AlertViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:AlertShowCaseLangResource BasicTitle}"
            Description="{gallery:AlertShowCaseLangResource BasicDescription}">
            <StackPanel Orientation="Vertical">
                <atom:Alert Type="Success" Message="{gallery:AlertShowCaseLangResource P2ContentSuccessText}" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:AlertShowCaseLangResource MoreTypesTitle}"
            Description="{gallery:AlertShowCaseLangResource MoreTypesDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Alert Type="Success" Message="{gallery:AlertShowCaseLangResource P2ContentSuccessText}" />
                <atom:Alert Type="Info" Message="{gallery:AlertShowCaseLangResource P2ContentInfoText}" />
                <atom:Alert Type="Warning" Message="{gallery:AlertShowCaseLangResource P2ContentWarningText}" />
                <atom:Alert Type="Error" Message="{gallery:AlertShowCaseLangResource P2ContentErrorText}" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:AlertShowCaseLangResource ClosableTitle}"
            Description="{gallery:AlertShowCaseLangResource ClosableDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Alert Type="Warning" IsClosable="True" Message="{gallery:AlertShowCaseLangResource P2ContentWarningTextWarningTextWarningTextWarningText}" />
                <atom:Alert Type="Error" IsClosable="True"
                            Description="{gallery:AlertShowCaseLangResource P2DescriptionErrorDescriptionErrorDescriptionErrorDescriptionErrorDesc}" Message="{gallery:AlertShowCaseLangResource P2ContentErrorText}" />
                <atom:Alert Type="Error" IsClosable="True"
                            Description="{gallery:AlertShowCaseLangResource P2DescriptionErrorDescriptionErrorDescriptionErrorDescriptionErrorDesc}"
                            CloseIcon="{antdicons:AntDesignIconProvider CloseSquareFilled}" Message="{gallery:AlertShowCaseLangResource P2ContentErrorText}" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:AlertShowCaseLangResource DescriptionTitle}"
            Description="{gallery:AlertShowCaseLangResource DescriptionDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Alert Type="Success"
                            Message="{gallery:AlertShowCaseLangResource P2MessageSuccessText}"
                            Description="{gallery:AlertShowCaseLangResource P2DescriptionSuccessDescriptionSuccessDescriptionSuccessDescription}" />
                <atom:Alert Type="Info"
                            Message="{gallery:AlertShowCaseLangResource P2MessageInfoText}"
                            Description="{gallery:AlertShowCaseLangResource P2DescriptionInfoDescriptionInfoDescriptionInfoDescriptionInfoDescript}" />
                <atom:Alert Type="Warning"
                            Message="{gallery:AlertShowCaseLangResource P2MessageWarningText}"
                            Description="{gallery:AlertShowCaseLangResource P2DescriptionWarningDescriptionWarningDescriptionWarningDescriptionWar}" />
                <atom:Alert Type="Error"
                            Message="{gallery:AlertShowCaseLangResource P2MessageErrorText}"
                            Description="{gallery:AlertShowCaseLangResource P2DescriptionErrorDescriptionErrorDescriptionErrorDescriptionErrorDesc2}" />
            </StackPanel>
        </gallery:ShowCaseItem>


        <gallery:ShowCaseItem
            Title="{gallery:AlertShowCaseLangResource IconTitle}"
            Description="{gallery:AlertShowCaseLangResource IconDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Alert Type="Success"
                            Message="{gallery:AlertShowCaseLangResource P2MessageSuccessTips}"
                            IsShowIcon="True" />
                <atom:Alert Type="Info"
                            Message="{gallery:AlertShowCaseLangResource P2MessageInformationalNotes}"
                            IsShowIcon="True" />
                <atom:Alert Type="Warning"
                            Message="{gallery:AlertShowCaseLangResource P2MessageWarning}"
                            IsShowIcon="True"
                            IsClosable="True" />
                <atom:Alert Type="Error"
                            Message="{gallery:AlertShowCaseLangResource P2MessageError}"
                            IsShowIcon="True" />

                <atom:Alert Type="Success"
                            Message="{gallery:AlertShowCaseLangResource P2MessageSuccessTips}"
                            IsShowIcon="True"
                            Description="{gallery:AlertShowCaseLangResource P2DescriptionDetailedDescriptionAndAdviceAboutSuccessfulCopywriting}" />
                <atom:Alert Type="Info"
                            Message="{gallery:AlertShowCaseLangResource P2MessageInformationalNotes}"
                            IsShowIcon="True"
                            Description="{gallery:AlertShowCaseLangResource P2DescriptionAdditionalDescriptionAndInformationAboutCopywriting}" />
                <atom:Alert Type="Warning"
                            Message="{gallery:AlertShowCaseLangResource P2MessageWarning}"
                            IsClosable="True"
                            IsShowIcon="True"
                            Description="{gallery:AlertShowCaseLangResource P2DescriptionThisIsAWarningNoticeAboutCopywriting}" />
                <atom:Alert Type="Error"
                            Message="{gallery:AlertShowCaseLangResource P2MessageError}"
                            IsShowIcon="True"
                            Description="{gallery:AlertShowCaseLangResource P2DescriptionThisIsAnErrorMessageAboutCopywriting}" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:AlertShowCaseLangResource CustomActionTitle}"
            Description="{gallery:AlertShowCaseLangResource CustomActionDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Alert Message="{gallery:AlertShowCaseLangResource P2MessageSuccessTips}" Type="Success"
                            IsShowIcon="True"
                            IsClosable="true">
                    <atom:Alert.ExtraAction>
                        <atom:Button ButtonType="Text" SizeType="Small" Content="{gallery:AlertShowCaseLangResource P2ContentUndo}" />
                    </atom:Alert.ExtraAction></atom:Alert>

                <atom:Alert Message="{gallery:AlertShowCaseLangResource P2MessageErrorText}" Type="Error"
                            IsShowIcon="True"
                            Description="{gallery:AlertShowCaseLangResource P2DescriptionErrorDescriptionErrorDescriptionErrorDescriptionErrorDesc2}">
                    <atom:Alert.ExtraAction>
                        <atom:Button ButtonType="Default" SizeType="Small" IsDanger="True" Content="{gallery:AlertShowCaseLangResource P2ContentDetail}" />
                    </atom:Alert.ExtraAction></atom:Alert>

                <atom:Alert Message="{gallery:AlertShowCaseLangResource P2MessageWarningText}" Type="Warning"
                            IsClosable="true">
                    <atom:Alert.ExtraAction>
                        <atom:Button ButtonType="Text" SizeType="Small" Content="{gallery:AlertShowCaseLangResource P2ContentDone}" />
                    </atom:Alert.ExtraAction></atom:Alert>

                <atom:Alert Message="{gallery:AlertShowCaseLangResource P2MessageInfoText}" Type="Info"
                            IsShowIcon="False"
                            IsClosable="true"
                            Description="{gallery:AlertShowCaseLangResource P2DescriptionInfoDescriptionInfoDescriptionInfoDescriptionInfoDescript}">
                    <atom:Alert.ExtraAction>
                        <StackPanel Orientation="Vertical" Spacing="5">
                            <atom:Button ButtonType="Primary" SizeType="Small" Content="{gallery:AlertShowCaseLangResource P2ContentAccept}" />
                            <atom:Button SizeType="Small" IsDanger="True" IsGhost="True" Content="{gallery:AlertShowCaseLangResource P2ContentDecline}" />
                        </StackPanel>
                    </atom:Alert.ExtraAction></atom:Alert>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:AlertShowCaseLangResource LoopBannerTitle}"
            Description="{gallery:AlertShowCaseLangResource LoopBannerDescription}">
            <atom:Alert Type="Warning" IsShowIcon="True" IsMessageMarqueeEnabled="True" Message="{gallery:AlertShowCaseLangResource P2ContentICanBeAReactComponentMultipleReact}" />
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
