<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Message.MessageShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:MessageShowCaseLangResource BasicTitle}"
            Description="{gallery:MessageShowCaseLangResource BasicDescription}">
            <atom:Button ButtonType="Primary" Click="ShowSimpleMessage">
                Display normal message
            </atom:Button>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MessageShowCaseLangResource OtherTypesTitle}"
            Description="{gallery:MessageShowCaseLangResource OtherTypesDescription}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <atom:Button ButtonType="Default" Click="ShowSuccessMessage">
                    Success
                </atom:Button>
                <atom:Button ButtonType="Default" Click="ShowInfoMessage">
                    Info
                </atom:Button>
                <atom:Button ButtonType="Default" Click="ShowWarningMessage">
                    Warning
                </atom:Button>
                <atom:Button ButtonType="Default" Click="ShowErrorMessage">
                    Error
                </atom:Button>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:MessageShowCaseLangResource LoadingIndicatorTitle}"
                              Description="{gallery:MessageShowCaseLangResource LoadingIndicatorDescription}">
            <atom:Button ButtonType="Default" Click="ShowLoadingMessage">
                Display a loading indicator
            </atom:Button>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MessageShowCaseLangResource CallbackTitle}"
            Description="{gallery:MessageShowCaseLangResource CallbackDescription}">
            <atom:Button ButtonType="Default" Click="ShowSequentialMessage">
                Display a loading indicator
            </atom:Button>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
