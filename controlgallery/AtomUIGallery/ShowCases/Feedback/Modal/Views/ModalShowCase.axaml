<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Modal.ModalShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:viewModels="clr-namespace:AtomUIGallery.ShowCases.Modal"
             x:DataType="viewModels:ModalViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:ModalShowCaseLangResource BasicTitle}"
            Description="{gallery:ModalShowCaseLangResource BasicDescription}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Panel>
                    <atom:Button ButtonType="Primary" Name="BasicOpenModalButton" Content="{gallery:ModalShowCaseLangResource P2ContentOpenModalOverlay}" />
                    <atom:Dialog PlacementTarget="BasicOpenModalButton"
                                 IsOpen="{Binding IsBasicModalOpened, Mode=TwoWay}"
                                 Title="{gallery:ModalShowCaseLangResource P2TitleBasicModal}"
                                 IsModal="False"
                                 IsResizable="False"
                                 IsDragMovable="True"
                                 IsMaximizable="False"
                                 StandardButtons="Cancel,Ok"
                                 DefaultStandardButton="Ok"
                                 HorizontalStartupLocation="Center"
                                 VerticalOffset="30%"
                                 HostMinWidth="300">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeContents}" />
                            <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeContents}" />
                            <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeContents}" />
                        </StackPanel>
                    </atom:Dialog>
                </Panel>
                <Panel>
                    <atom:Button ButtonType="Primary" Name="BasicWindowOpenModalButton" Content="{gallery:ModalShowCaseLangResource P2ContentOpenModalWindow}" />
                    <atom:Dialog PlacementTarget="BasicWindowOpenModalButton"
                                 IsOpen="{Binding IsBasicWindowModalOpened, Mode=TwoWay}"
                                 Title="{gallery:ModalShowCaseLangResource P2TitleBasicWindowModal}"
                                 IsModal="True"
                                 IsResizable="True"
                                 IsClosable="True"
                                 IsDragMovable="True"
                                 IsMaximizable="False"
                                 DialogHostType="Window"
                                 HorizontalStartupLocation="Center"
                                 VerticalOffset="30%"
                                 StandardButtons="Yes"
                                 DefaultStandardButton="Yes"
                                 HostMinWidth="300">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeContents}" />
                            <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeContents}" />
                            <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeContents}" />
                        </StackPanel>
                    </atom:Dialog>
                </Panel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ModalShowCaseLangResource AsynchronouslyCloseTitle}"
            Description="{gallery:ModalShowCaseLangResource AsynchronouslyCloseDescription}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Panel>
                    <atom:Button ButtonType="Primary" Name="AsyncDialogOpenModalButton" Content="{gallery:ModalShowCaseLangResource P2ContentOpenModalWithAsyncLogic}" />
                    <atom:Dialog PlacementTarget="AsyncDialogOpenModalButton"
                                 IsOpen="{Binding IsAsyncDialogOpened, Mode=TwoWay}"
                                 Title="{gallery:ModalShowCaseLangResource P2TitleAsynchronouslyCloseModal}"
                                 IsModal="True"
                                 IsDragMovable="True"
                                 IsResizable="False"
                                 IsMaximizable="False"
                                 StandardButtons="Ok, Cancel"
                                 HorizontalStartupLocation="Center"
                                 VerticalStartupLocation="Center"
                                 DefaultStandardButton="Ok"
                                 ButtonClicked="HandleAsyncDialogButtonClicked"
                                 HostMinWidth="400">
                        <StackPanel>
                            <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextContentOfTheModal}" />
                        </StackPanel>
                    </atom:Dialog>
                </Panel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ModalShowCaseLangResource MessageBoxStyleTitle}"
            Description="{gallery:ModalShowCaseLangResource MessageBoxStyleDescription}">

            <StackPanel Orientation="Vertical" Spacing="20">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBlock VerticalAlignment="Center" Text="{gallery:ModalShowCaseLangResource P2TextNativeWindow}" />
                    <atom:ToggleSwitch Name="StyleCaseHostTypeSwitch" />
                </StackPanel>
                <atom:Separator Title="{gallery:ModalShowCaseLangResource P2TitleNormal}"/>
                <WrapPanel Orientation="Horizontal" ItemSpacing="10" LineSpacing="10">
                    <Panel>
                        <atom:MessageBox PlacementTarget="ConfirmMsgBoxBtn"
                                         Title="{gallery:ModalShowCaseLangResource P2TitleDoYouWantToDeleteTheseItems}"
                                         IsOpen="{Binding IsConfirmMsgBoxOpened, Mode=TwoWay}"
                                         Style="Confirm"
                                         DialogHostType="{Binding MessageBoxStyleCaseHostType}">
                            <StackPanel Orientation="Vertical" Spacing="5">
                                <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeDescriptions}" />
                            </StackPanel>
                        </atom:MessageBox>
                        <atom:Button Name="ConfirmMsgBoxBtn" Content="{gallery:ModalShowCaseLangResource P2ContentConfirm}" />
                    </Panel>
                    <Panel>
                        <atom:MessageBox PlacementTarget="InformationMsgBoxBtn"
                                         Title="{gallery:ModalShowCaseLangResource P2TitleThisIsANotificationMessage}"
                                         IsOpen="{Binding IsInformationMsgBoxOpened, Mode=TwoWay}"
                                         Style="Information"
                                         DialogHostType="{Binding MessageBoxStyleCaseHostType}">
                            <StackPanel Orientation="Vertical" Spacing="5">
                                <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeMessagesSomeMessages}" />
                                <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeMessagesSomeMessages}" />
                            </StackPanel>
                        </atom:MessageBox>
                        <atom:Button Name="InformationMsgBoxBtn" Content="{gallery:ModalShowCaseLangResource P2ContentInformation}" />
                    </Panel>
                    <Panel>
                        <atom:MessageBox PlacementTarget="SuccessMsgBoxBtn"
                                         Title="{gallery:ModalShowCaseLangResource P2TitleOperationSuccessful}"
                                         Style="Success"
                                         DialogHostType="{Binding MessageBoxStyleCaseHostType}"
                                         IsOpen="{Binding IsSuccessMsgBoxOpened, Mode=TwoWay}">
                            <StackPanel Orientation="Vertical" Spacing="5">
                                <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeMessagesSomeMessages}" />
                                <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeMessagesSomeMessages}" />
                            </StackPanel>
                        </atom:MessageBox>
                        <atom:Button Name="SuccessMsgBoxBtn" Content="{gallery:ModalShowCaseLangResource P2ContentSuccess}" />
                    </Panel>
                    <Panel>
                        <atom:MessageBox PlacementTarget="ErrorMsgBoxBtn"
                                         Title="{gallery:ModalShowCaseLangResource P2TitleThisIsAnErrorMessage}"
                                         Style="Error"
                                         DialogHostType="{Binding MessageBoxStyleCaseHostType}"
                                         IsOpen="{Binding IsErrorMsgBoxOpened, Mode=TwoWay}">
                            <StackPanel Orientation="Vertical" Spacing="5">
                                <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeMessagesSomeMessages}" />
                                <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeMessagesSomeMessages}" />
                            </StackPanel>
                        </atom:MessageBox>
                        <atom:Button Name="ErrorMsgBoxBtn" Content="{gallery:ModalShowCaseLangResource P2ContentError}" />
                    </Panel>
                    <Panel>
                        <atom:MessageBox PlacementTarget="WarningMsgBoxBtn"
                                         Title="{gallery:ModalShowCaseLangResource P2TitleThisIsAWarningMessage}"
                                         Style="Warning"
                                         DialogHostType="{Binding MessageBoxStyleCaseHostType}"
                                         IsOpen="{Binding IsWarningMsgBoxOpened, Mode=TwoWay}">
                            <StackPanel Orientation="Vertical" Spacing="5">
                                <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeMessagesSomeMessages}" />
                                <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeMessagesSomeMessages}" />
                            </StackPanel>
                        </atom:MessageBox>
                        <atom:Button Name="WarningMsgBoxBtn" Content="{gallery:ModalShowCaseLangResource P2ContentWarning}" />
                    </Panel>
                </WrapPanel>

                <atom:Separator Title="{gallery:ModalShowCaseLangResource P2TitleStaticApi}" />
                <WrapPanel Orientation="Horizontal" ItemSpacing="10" LineSpacing="10">
                    <atom:Button Click="HandleCreateConfirmMessageBox" Content="{gallery:ModalShowCaseLangResource P2ContentConfirm}" />
                    <atom:Button Click="HandleCreateInformationMessageBox" Content="{gallery:ModalShowCaseLangResource P2ContentInformation}" />
                    <atom:Button Click="HandleCreateSuccessMessageBox" Content="{gallery:ModalShowCaseLangResource P2ContentSuccess}" />
                    <atom:Button Click="HandleCreateErrorMessageBox" Content="{gallery:ModalShowCaseLangResource P2ContentError}" />
                    <atom:Button Click="HandleCreateWarningMessageBox" Content="{gallery:ModalShowCaseLangResource P2ContentWarning}" />
                </WrapPanel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ModalShowCaseLangResource LoadingTitle}"
            Description="{gallery:ModalShowCaseLangResource LoadingDescription}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Panel>
                    <atom:Button ButtonType="Primary" Name="LoadingDialogOpenModalButton" Content="{gallery:ModalShowCaseLangResource P2ContentOpenModal}" />
                    <atom:Dialog PlacementTarget="LoadingDialogOpenModalButton"
                                 IsOpen="{Binding IsLoadingMsgBoxOpened, Mode=TwoWay}"
                                 Title="{gallery:ModalShowCaseLangResource P2TitleLoadingModal}"
                                 IsModal="True"
                                 IsLoading="True"
                                 IsDragMovable="True"
                                 IsResizable="False"
                                 IsMaximizable="False"
                                 StandardButtons="Reload"
                                 HorizontalStartupLocation="Center"
                                 VerticalStartupLocation="Center"
                                 DefaultStandardButton="Reload"
                                 Opened="HandleLoadingDialogOpened"
                                 ButtonClicked="HandleLoadingDialogButtonClicked"
                                 HostMinWidth="400">
                        <StackPanel>
                            <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeContents}" />
                            <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeContents}" />
                            <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeContents}" />
                        </StackPanel>
                    </atom:Dialog>
                </Panel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ModalShowCaseLangResource CustomFooterButtonsTitle}"
            Description="{gallery:ModalShowCaseLangResource CustomFooterButtonsDescription}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Panel>
                    <atom:Button ButtonType="Primary" Name="CustomFooterDialogOpenButton" Content="{gallery:ModalShowCaseLangResource P2ContentOpenModal}" />
                    <atom:Dialog PlacementTarget="CustomFooterDialogOpenButton"
                                 IsOpen="{Binding IsCustomFooterDialogOpened, Mode=TwoWay}"
                                 Title="{gallery:ModalShowCaseLangResource P2TitleTitle}"
                                 IsModal="True"
                                 DialogHostType="Window"
                                 StandardButtons="Ok, Cancel"
                                 HorizontalStartupLocation="Center"
                                 VerticalStartupLocation="Center"
                                 DefaultStandardButton="Ok"
                                 HostMinWidth="400">
                        <atom:Dialog.CustomButtons>
                            <atom:DialogButton Role="ActionRole" Content="{gallery:ModalShowCaseLangResource P2ContentCustomButton}" />
                        </atom:Dialog.CustomButtons>
                        <StackPanel Spacing="5">
                            <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeContents}" />
                            <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeContents}" />
                            <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeContents}" />
                            <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeContents}" />
                            <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeContents}" />
                        </StackPanel>
                    </atom:Dialog>
                </Panel>

                <Panel>
                    <atom:Button ButtonType="Primary" Name="CustomFooterMsgBoxOpenButton" Content="{gallery:ModalShowCaseLangResource P2ContentOpenModal}" />
                    <atom:MessageBox PlacementTarget="CustomFooterMsgBoxOpenButton"
                                     IsOpen="{Binding IsCustomFooterMsgBoxOpened, Mode=TwoWay}"
                                     Title="{gallery:ModalShowCaseLangResource P2TitleConfirm}"
                                     IsModal="True"
                                     Style="Confirm"
                                     HostMinWidth="400">
                        <atom:MessageBox.CustomButtons>
                            <atom:DialogButton Role="ActionRole" Content="{gallery:ModalShowCaseLangResource P2ContentCustomButton}" />
                        </atom:MessageBox.CustomButtons>
                        <StackPanel Spacing="5">
                            <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextBlaBla}" />
                        </StackPanel>
                    </atom:MessageBox>
                </Panel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ModalShowCaseLangResource OpenDraggableModalTitle}"
            Description="{gallery:ModalShowCaseLangResource OpenDraggableModalDescription}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Panel>
                    <atom:Button ButtonType="Primary" Name="DraggableDialogOpenButton" Content="{gallery:ModalShowCaseLangResource P2ContentOpenModal}" />
                    <atom:Dialog PlacementTarget="DraggableDialogOpenButton"
                                 IsOpen="{Binding IsDraggableMsgBoxOpened, Mode=TwoWay}"
                                 Title="{gallery:ModalShowCaseLangResource P2TitleDraggableModal}"
                                 IsModal="True"
                                 IsDragMovable="True"
                                 StandardButtons="Ok, Cancel"
                                 HorizontalStartupLocation="Center"
                                 VerticalStartupLocation="Center"
                                 DefaultStandardButton="Ok"
                                 HostWidth="400">
                        <StackPanel Spacing="10">
                            <TextBlock TextWrapping="Wrap" Text="{gallery:ModalShowCaseLangResource P2TextJustDonTLearnPhysicsAtSchoolAnd}" />
                            <TextBlock TextWrapping="Wrap" Text="{gallery:ModalShowCaseLangResource P2TextDayBeforeYesterdayISawARabbitAnd}" />
                        </StackPanel>
                    </atom:Dialog>
                </Panel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ModalShowCaseLangResource ManualUpdateDestroyTitle}"
            Description="{gallery:ModalShowCaseLangResource ManualUpdateDestroyDescription}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Panel>
                    <atom:Button Name="DelayedCloseMsgBoxOpenButton" Content="{gallery:ModalShowCaseLangResource P2ContentOpenModalToCloseInN5s}" />
                    <atom:MessageBox PlacementTarget="DelayedCloseMsgBoxOpenButton"
                                     IsOpen="{Binding IsDelayedCloseMsgBoxOpened, Mode=TwoWay}"
                                     Title="{gallery:ModalShowCaseLangResource P2TitleThisIsANotificationMessage}"
                                     IsModal="True"
                                     IsDragMovable="False"
                                     IsCenterOnStartup="True"
                                     Style="Success"
                                     Opened="HandleDelayedCloseMsgBoxOpened"
                                     HostWidth="400">
                        <StackPanel Spacing="10">
                            <TextBlock TextWrapping="Wrap">
                                <Run Text="{gallery:ModalShowCaseLangResource P2RunThisModalWillBeDestroyedAfter}" />
                                <Run Text="{Binding CountdownSeconds}" />
                                <Run Text="{gallery:ModalShowCaseLangResource P2RunSecond}" />
                            </TextBlock>
                        </StackPanel>
                    </atom:MessageBox>
                </Panel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ModalShowCaseLangResource CustomizeFooterButtonPropsTitle}"
            Description="{gallery:ModalShowCaseLangResource CustomizeFooterButtonPropsDescription}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Panel>
                    <atom:Button ButtonType="Primary" Name="ConfigureButtonsDialogOpenButton" Content="{gallery:ModalShowCaseLangResource P2ContentOpenModalWithCustomizedButtonProps}" />
                    <atom:Dialog Name="ConfigureButtonPropertiesDialog"
                                 PlacementTarget="ConfigureButtonsDialogOpenButton"
                                 IsOpen="{Binding IsConfigureButtonsDialogOpened, Mode=TwoWay}"
                                 Title="{gallery:ModalShowCaseLangResource P2TitleBasicModal}"
                                 IsModal="True"
                                 IsDragMovable="True"
                                 StandardButtons="Ok, Cancel"
                                 HorizontalStartupLocation="Center"
                                 VerticalStartupLocation="Center"
                                 DefaultStandardButton="Ok"
                                 HostWidth="400">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeContents}" />
                            <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeContents}" />
                            <TextBlock Text="{gallery:ModalShowCaseLangResource P2TextSomeContents}" />
                        </StackPanel>
                    </atom:Dialog>
                </Panel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ModalShowCaseLangResource StaticDialogApiTitle}"
            Description="{gallery:ModalShowCaseLangResource StaticDialogApiDescription}">
            <WrapPanel Orientation="Horizontal" ItemSpacing="10" LineSpacing="10">
                <atom:Button Name="OpenOverlayDialogAPIButton" ButtonType="Primary" Click="HandleOpenOverlayDialogButtonClick" Content="{gallery:ModalShowCaseLangResource P2ContentOpenOverlayDialog}" />

                <atom:Button ButtonType="Primary" Click="HandleOpenWindowDialogButtonClick" Content="{gallery:ModalShowCaseLangResource P2ContentOpenWindowDialog}" />

                <atom:Button ButtonType="Primary" Click="HandleOpenCustomViewDialogButtonClick" Content="{gallery:ModalShowCaseLangResource P2ContentOpenCustomviewDialog}" />
            </WrapPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
