<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Notification.NotificationShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem Title="{gallery:NotificationShowCaseLangResource BasicTitle}" Description="{gallery:NotificationShowCaseLangResource BasicDescription}">
            <atom:Button ButtonType="Primary" Click="ShowSimpleNotification" Content="{gallery:NotificationShowCaseLangResource P2ContentShowNotification}" />
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:NotificationShowCaseLangResource DurationTitle}"
                                      Description="{gallery:NotificationShowCaseLangResource DurationDescription}">
            <atom:Button ButtonType="Primary" Click="ShowNeverCloseNotification" Content="{gallery:NotificationShowCaseLangResource P2ContentOpenTheNotificationBox}" />
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:NotificationShowCaseLangResource WithIconTitle}"
                                      Description="{gallery:NotificationShowCaseLangResource WithIconDescription}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <atom:Button ButtonType="Default" Click="ShowSuccessNotification" Content="{gallery:NotificationShowCaseLangResource P2ContentSuccess}" />
                <atom:Button ButtonType="Default" Click="ShowInfoNotification" Content="{gallery:NotificationShowCaseLangResource P2ContentInfo}" />
                <atom:Button ButtonType="Default" Click="ShowWarningNotification" Content="{gallery:NotificationShowCaseLangResource P2ContentWarning}" />
                <atom:Button ButtonType="Default" Click="ShowErrorNotification" Content="{gallery:NotificationShowCaseLangResource P2ContentError}" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:NotificationShowCaseLangResource PlacementTitle}"
                                      Description="{gallery:NotificationShowCaseLangResource PlacementDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <atom:Button ButtonType="Primary" Click="ShowTopNotification" Content="{gallery:NotificationShowCaseLangResource P2ContentTop}" />
                    <atom:Button ButtonType="Primary" Click="ShowBottomNotification" Content="{gallery:NotificationShowCaseLangResource P2ContentBottom}" />
                </StackPanel>
                <atom:Separator />
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <atom:Button ButtonType="Primary" Click="ShowTopLeftNotification" Content="{gallery:NotificationShowCaseLangResource P2ContentTopleft}" />
                    <atom:Button ButtonType="Primary" Click="ShowTopRightNotification" Content="{gallery:NotificationShowCaseLangResource P2ContentTopright}" />
                </StackPanel>
                <atom:Separator />
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <atom:Button ButtonType="Primary" Click="ShowBottomLeftNotification" Content="{gallery:NotificationShowCaseLangResource P2ContentBottomleft}" />
                    <atom:Button ButtonType="Primary" Click="ShowBottomRightNotification" Content="{gallery:NotificationShowCaseLangResource P2ContentBottomright}" />
                </StackPanel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:NotificationShowCaseLangResource CustomizedIconTitle}"
                                      Description="{gallery:NotificationShowCaseLangResource CustomizedIconDescription}">
            <atom:Button ButtonType="Primary" Click="ShowCustomIconNotification" Content="{gallery:NotificationShowCaseLangResource P2ContentOpenTheNotificationBox}" />
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:NotificationShowCaseLangResource ProgressTitle}"
                                      Description="{gallery:NotificationShowCaseLangResource ProgressDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:OptionButtonGroup Name="HoverOptionGroup" ButtonStyle="Outline">
                    <atom:OptionButton IsChecked="True" Content="{gallery:NotificationShowCaseLangResource P2ContentPauseOnHover}" />
                    <atom:OptionButton Content="{gallery:NotificationShowCaseLangResource P2ContentDonTPauseOnHover}" />
                </atom:OptionButtonGroup>
                <atom:Button ButtonType="Primary" Click="ShowProgressNotification" Content="{gallery:NotificationShowCaseLangResource P2ContentShowNotification}" />
            </StackPanel>

        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
