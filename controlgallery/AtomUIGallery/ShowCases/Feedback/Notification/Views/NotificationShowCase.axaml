<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Notification.NotificationShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem Title="{gallery:NotificationShowCaseLangResource BasicTitle}" Description="{gallery:NotificationShowCaseLangResource BasicDescription}">
            <atom:Button ButtonType="Primary" Click="ShowSimpleNotification">
                Show Notification
            </atom:Button>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:NotificationShowCaseLangResource DurationTitle}"
                                      Description="{gallery:NotificationShowCaseLangResource DurationDescription}">
            <atom:Button ButtonType="Primary" Click="ShowNeverCloseNotification">
                Open the notification box
            </atom:Button>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:NotificationShowCaseLangResource WithIconTitle}"
                                      Description="{gallery:NotificationShowCaseLangResource WithIconDescription}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <atom:Button ButtonType="Default" Click="ShowSuccessNotification">
                    Success
                </atom:Button>
                <atom:Button ButtonType="Default" Click="ShowInfoNotification">
                    Info
                </atom:Button>
                <atom:Button ButtonType="Default" Click="ShowWarningNotification">
                    Warning
                </atom:Button>
                <atom:Button ButtonType="Default" Click="ShowErrorNotification">
                    Error
                </atom:Button>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:NotificationShowCaseLangResource PlacementTitle}"
                                      Description="{gallery:NotificationShowCaseLangResource PlacementDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <atom:Button ButtonType="Primary" Click="ShowTopNotification">
                        Top
                    </atom:Button>
                    <atom:Button ButtonType="Primary" Click="ShowBottomNotification">
                        Bottom
                    </atom:Button>
                </StackPanel>
                <atom:Separator />
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <atom:Button ButtonType="Primary" Click="ShowTopLeftNotification">
                        TopLeft
                    </atom:Button>
                    <atom:Button ButtonType="Primary" Click="ShowTopRightNotification">
                        TopRight
                    </atom:Button>
                </StackPanel>
                <atom:Separator />
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <atom:Button ButtonType="Primary" Click="ShowBottomLeftNotification">
                        BottomLeft
                    </atom:Button>
                    <atom:Button ButtonType="Primary" Click="ShowBottomRightNotification">
                        BottomRight
                    </atom:Button>
                </StackPanel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:NotificationShowCaseLangResource CustomizedIconTitle}"
                                      Description="{gallery:NotificationShowCaseLangResource CustomizedIconDescription}">
            <atom:Button ButtonType="Primary" Click="ShowCustomIconNotification">
                Open the notification box
            </atom:Button>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:NotificationShowCaseLangResource ProgressTitle}"
                                      Description="{gallery:NotificationShowCaseLangResource ProgressDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:OptionButtonGroup Name="HoverOptionGroup" ButtonStyle="Outline">
                    <atom:OptionButton IsChecked="True">Pause on hover</atom:OptionButton>
                    <atom:OptionButton>Don&apos;t pause on hover</atom:OptionButton>
                </atom:OptionButtonGroup>
                <atom:Button ButtonType="Primary" Click="ShowProgressNotification">
                    Show Notification
                </atom:Button>
            </StackPanel>

        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
