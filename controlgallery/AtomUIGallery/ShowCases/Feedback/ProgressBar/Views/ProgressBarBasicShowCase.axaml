<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.ProgressBar.ProgressBarBasicShowCase"
             xmlns:vm="using:AtomUIGallery.ShowCases.ProgressBar"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             x:DataType="vm:ProgressBarViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCasePanel.Styles>
            <Style Selector="atom|CircleProgress">
                <Setter Property="Margin" Value="5" />
            </Style>
            <Style Selector="atom|DashboardProgress">
                <Setter Property="Margin" Value="5" />
            </Style>
            <Style Selector="#CircleWithStep atom|StepsProgressBar">
                <Setter Property="Margin" Value="5" />
            </Style>
        </gallery:ShowCasePanel.Styles>
        <gallery:ShowCaseItem
            Title="{gallery:ProgressBarShowCaseLangResource ProgressBarTitle}"
            Description="{gallery:ProgressBarShowCaseLangResource ProgressBarDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:ProgressBar Value="30" Minimum="0" Maximum="100" />
                <atom:ProgressBar Value="50" Minimum="0" Maximum="100" />
                <atom:ProgressBar Value="70" Minimum="0" Maximum="100" Status="Exception" />
                <atom:ProgressBar Value="100" Minimum="0" Maximum="100" />
                <atom:ProgressBar Value="50" Minimum="0" Maximum="100" IsProgressInfoVisible="False" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ProgressBarShowCaseLangResource CircularProgressBarTitle}"
            Description="{gallery:ProgressBarShowCaseLangResource CircularProgressBarDescription}">
            <WrapPanel Orientation="Horizontal">
                <atom:CircleProgress Value="75" Minimum="0" Maximum="100" />
                <atom:CircleProgress Value="70" Minimum="0" Maximum="100" Status="Exception" />
                <atom:CircleProgress Value="100" Minimum="0" Maximum="100" />
            </WrapPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ProgressBarShowCaseLangResource MiniSizeTitle}"
            Description="{gallery:ProgressBarShowCaseLangResource MiniSizeDescription}">
            <WrapPanel Orientation="Horizontal" Width="180" HorizontalAlignment="Left">
                <atom:ProgressBar Value="30" Minimum="0" Maximum="100" SizeType="Middle" />
                <atom:ProgressBar Value="50" Minimum="0" Maximum="100" SizeType="Middle" />
                <atom:ProgressBar Value="70" Minimum="0" Maximum="100" Status="Exception" SizeType="Middle" />
                <atom:ProgressBar Value="100" Minimum="0" Maximum="100" SizeType="Middle" />
                <atom:ProgressBar Value="50" Minimum="0" Maximum="100" IsProgressInfoVisible="False" SizeType="Middle" />
            </WrapPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ProgressBarShowCaseLangResource SmallerCircularProgressBarTitle}"
            Description="{gallery:ProgressBarShowCaseLangResource SmallerCircularProgressBarDescription}">
            <WrapPanel Orientation="Horizontal">
                <atom:CircleProgress Value="75" Minimum="0" Maximum="100" SizeType="Middle" />
                <atom:CircleProgress Value="70" Minimum="0" Maximum="100" Status="Exception" SizeType="Middle" />
                <atom:CircleProgress Value="100" Minimum="0" Maximum="100" SizeType="Middle" />
            </WrapPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ProgressBarShowCaseLangResource DynamicTitle}"
            Description="{gallery:ProgressBarShowCaseLangResource DynamicDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:ProgressBar Value="{Binding ProgressValue}" Minimum="0" Maximum="100" IsProgressInfoVisible="False" />
                <atom:CircleProgress Value="{Binding ProgressValue}" Minimum="0" Maximum="100" />
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <atom:Button SizeType="Small" Command="{Binding SubProgressValue}" Content="{gallery:ProgressBarShowCaseLangResource P2ContentSub}" />
                    <atom:Button SizeType="Small" Command="{Binding AddProgressValue}" Content="{gallery:ProgressBarShowCaseLangResource P2ContentAdd}" />
                </StackPanel>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
