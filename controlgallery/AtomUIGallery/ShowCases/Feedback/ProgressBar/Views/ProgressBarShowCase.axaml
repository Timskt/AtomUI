<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.ProgressBar.ProgressBarShowCase"
             xmlns:vm="using:AtomUIGallery.ShowCases.ProgressBar"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             x:DataType="vm:ProgressBarViewModel">
    <atom:TabControl Name="ScenarioTabs"
                     SizeType="Large"
                     SelectedIndex="0">
        <atom:TabItem Header="{gallery:ProgressBarShowCaseLangResource ScenarioBasic}" Tag="Basic" />
        <atom:TabItem Header="{gallery:ProgressBarShowCaseLangResource ScenarioAdvanced}" Tag="Advanced" />
        <atom:TabItem Header="{gallery:ProgressBarShowCaseLangResource ScenarioLayout}" Tag="Layout" />
    </atom:TabControl>
</UserControl>
