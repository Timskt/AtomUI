<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Result.ResultShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.Result"
             x:DataType="vm:ResultViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:ResultShowCaseLangResource SuccessTitle}"
            Description="{gallery:ResultShowCaseLangResource SuccessDescription}"
            IsOccupyEntireRow="True">
            <atom:Result Status="Success"
                         Header="Successfully Purchased Cloud Server ECS!"
                         SubHeader="Order number: 2017182818828182881 Cloud server configuration takes 1-5 minutes, please wait.">
                <atom:Result.Extra>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <atom:Button ButtonType="Primary">Go Console</atom:Button>
                        <atom:Button>Buy Again</atom:Button>
                    </StackPanel>
                </atom:Result.Extra>
            </atom:Result>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ResultShowCaseLangResource InfoTitle}"
            Description="{gallery:ResultShowCaseLangResource InfoDescription}"
            IsOccupyEntireRow="True">
            <atom:Result Status="Info"
                         Header="Your operation has been executed.">
                <atom:Result.Extra>
                    <atom:Button ButtonType="Primary">Go Console</atom:Button>
                </atom:Result.Extra>
            </atom:Result>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ResultShowCaseLangResource WarningTitle}"
            Description="{gallery:ResultShowCaseLangResource WarningDescription}"
            IsOccupyEntireRow="True">
            <atom:Result Status="Warning"
                         Header="There are some problems with your operation.">
                <atom:Result.Extra>
                    <atom:Button ButtonType="Primary">Go Console</atom:Button>
                </atom:Result.Extra>
            </atom:Result>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ResultShowCaseLangResource ForbiddenTitle}"
            Description="{gallery:ResultShowCaseLangResource ForbiddenDescription}"
            IsOccupyEntireRow="True">
            <atom:Result Status="ErrorCode403"
                         Header="403"
                         SubHeader="Sorry, you are not authorized to access this page.">
                <atom:Result.Extra>
                    <atom:Button ButtonType="Primary">Back Home</atom:Button>
                </atom:Result.Extra>
            </atom:Result>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ResultShowCaseLangResource NotFoundTitle}"
            Description="{gallery:ResultShowCaseLangResource NotFoundDescription}"
            IsOccupyEntireRow="True">
            <atom:Result Status="ErrorCode404"
                         Header="404"
                         SubHeader="Sorry, the page you visited does not exist.">
                <atom:Result.Extra>
                    <atom:Button ButtonType="Primary">Back Home</atom:Button>
                </atom:Result.Extra>
            </atom:Result>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ResultShowCaseLangResource ServerErrorTitle}"
            Description="{gallery:ResultShowCaseLangResource ServerErrorDescription}"
            IsOccupyEntireRow="True">
            <atom:Result Status="ErrorCode500"
                         Header="500"
                         SubHeader="Sorry, something went wrong.">
                <atom:Result.Extra>
                    <atom:Button ButtonType="Primary">Back Home</atom:Button>
                </atom:Result.Extra>
            </atom:Result>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ResultShowCaseLangResource ErrorTitle}"
            Description="{gallery:ResultShowCaseLangResource ErrorDescription}"
            IsOccupyEntireRow="True">
            <atom:Result Status="Error"
                         Header="Submission Failed"
                         SubHeader="Please check and modify the following information before resubmitting.">
                <atom:Result.Extra>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <atom:Button ButtonType="Primary">Go Console</atom:Button>
                        <atom:Button>Buy Again</atom:Button>
                    </StackPanel>
                </atom:Result.Extra>
                <StackPanel Spacing="8">
                    <TextBlock FontWeight="Bold" FontSize="16">
                        The content you submitted has the following error:
                    </TextBlock>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <antdicons:CloseCircleOutlined Foreground="{atom:SharedTokenResource ColorError}"/>
                        <TextBlock>Your account has been frozen. </TextBlock>
                        <TextBlock Foreground="{atom:SharedTokenResource ColorPrimary}">Thaw immediately ></TextBlock>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <antdicons:CloseCircleOutlined Foreground="{atom:SharedTokenResource ColorError}"/>
                        <TextBlock>Your account is not yet eligible to apply. </TextBlock>
                        <TextBlock Foreground="{atom:SharedTokenResource ColorPrimary}">Apply Unlock ></TextBlock>
                    </StackPanel>
                </StackPanel>
            </atom:Result>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ResultShowCaseLangResource CustomIconTitle}"
            Description="{gallery:ResultShowCaseLangResource CustomIconDescription}"
            IsOccupyEntireRow="True">
            <atom:Result Status="Info"
                         Icon="{antdicons:AntDesignIconProvider SmileOutlined}"
                         Header="Great, we have done all the operations!">
                <atom:Result.Extra>
                    <atom:Button ButtonType="Primary">Next</atom:Button>
                </atom:Result.Extra>
            </atom:Result>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
