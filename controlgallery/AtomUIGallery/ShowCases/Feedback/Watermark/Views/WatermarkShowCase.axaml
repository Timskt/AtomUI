<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Watermark.WatermarkShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery">
    <gallery:ShowCasePanel>

        <gallery:ShowCaseItem Title="{gallery:WatermarkShowCaseLangResource BasicTitle}" Description="{gallery:WatermarkShowCaseLangResource BasicDescription}">
            <Border Height="300" HorizontalAlignment="Stretch" atom:Watermark.Glyph="{atom:TextGlyph 'AtomUI'}" />
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:WatermarkShowCaseLangResource MultiLineTitle}"
                                      Description="{gallery:WatermarkShowCaseLangResource MultiLineDescription}">
            <Border Height="200"
                    HorizontalAlignment="Stretch">
                <atom:Watermark.Glyph>
                    <atom:TextGlyph Text="{gallery:WatermarkShowCaseLangResource P2WatermarkMultiLineText}"
                                    FontSize="18"
                                    Foreground="Gray" />
                </atom:Watermark.Glyph>
            </Border>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:WatermarkShowCaseLangResource ImageWatermarkTitle}"
                                      Description="{gallery:WatermarkShowCaseLangResource ImageWatermarkDescription}">
            <Border Height="400">
                <atom:Watermark.Glyph>
                    <atom:ImageGlyph Source="/Assets/ATOMUI-LOGO.png" />
                </atom:Watermark.Glyph>
            </Border>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:WatermarkShowCaseLangResource CustomConfigurationTitle}"
                                      Description="{gallery:WatermarkShowCaseLangResource CustomConfigurationDescription}">
            <StackPanel atom:Watermark.Glyph="{atom:TextGlyph 'AtomUI'}">
                <atom:TextBlock TextWrapping="Wrap"
                                Text="{gallery:WatermarkShowCaseLangResource P2TextNaturalInteractionDescription}" />
                <Image Source="/Assets/watermark-sample.png" />
            </StackPanel>
        </gallery:ShowCaseItem>

    </gallery:ShowCasePanel>
</UserControl>
