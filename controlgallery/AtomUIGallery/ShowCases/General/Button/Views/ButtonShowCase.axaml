<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Button.ButtonShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:viewModels="clr-namespace:AtomUIGallery.ShowCases.Button"
             x:DataType="viewModels:ButtonViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCasePanel.Styles>
            <Style Selector="atom|Button">
                <Setter Property="Margin" Value="5" />
            </Style>
        </gallery:ShowCasePanel.Styles>
        <gallery:ShowCaseItem
            Title="{gallery:ButtonShowCaseLangResource TypeTitle}"
            Description="{gallery:ButtonShowCaseLangResource TypeDescription}">
            <WrapPanel HorizontalAlignment="Left" Orientation="Horizontal">
                <atom:Button ButtonType="Primary" Content="{gallery:ButtonShowCaseLangResource P2ContentPrimaryButton}" />
                <atom:Button Content="{gallery:ButtonShowCaseLangResource P2ContentDefaultButton}" />
                <atom:Button ButtonType="Dashed" Content="{gallery:ButtonShowCaseLangResource P2ContentDashed}" />
                <atom:Button ButtonType="Text" Content="{gallery:ButtonShowCaseLangResource P2ContentTextButton}" />
                <atom:Button ButtonType="Link" Content="{gallery:ButtonShowCaseLangResource P2ContentLinkButton}" />
            </WrapPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ButtonShowCaseLangResource ButtonShapeTitle}"
            Description="{gallery:ButtonShowCaseLangResource ButtonShapeDescription}">
            <StackPanel Orientation="Vertical">
                <WrapPanel HorizontalAlignment="Left" Orientation="Horizontal" Margin="0, 0, 0, 20">
                    <atom:Button ButtonType="Primary" Content="{gallery:ButtonShowCaseLangResource P2ContentPrimary}" />
                    <atom:Button Content="{gallery:ButtonShowCaseLangResource P2ContentDefault}" />

                    <atom:Button ButtonType="Text" Content="{gallery:ButtonShowCaseLangResource P2ContentText}" />
                    <atom:Button ButtonType="Link" Content="{gallery:ButtonShowCaseLangResource P2ContentLink}" />
                </WrapPanel>
                <WrapPanel HorizontalAlignment="Left" Orientation="Horizontal" Margin="0, 0, 0, 20">
                    <atom:Button ButtonType="Primary" Shape="Round" Content="{gallery:ButtonShowCaseLangResource P2ContentPrimary}" />
                    <atom:Button Shape="Round" Content="{gallery:ButtonShowCaseLangResource P2ContentDefault}" />
                    <atom:Button ButtonType="Text" Shape="Round" Content="{gallery:ButtonShowCaseLangResource P2ContentText}" />
                    <atom:Button ButtonType="Link" Shape="Round" Content="{gallery:ButtonShowCaseLangResource P2ContentLink}" />
                </WrapPanel>
                <StackPanel HorizontalAlignment="Left" Spacing="10" Orientation="Horizontal" Margin="0, 0, 0, 20">
                    <atom:Button ButtonType="Primary" Shape="Circle" Content="{gallery:ButtonShowCaseLangResource P2ContentAa}" />
                    <atom:Button Shape="Circle" Content="{gallery:ButtonShowCaseLangResource P2ContentAa}" />
                    <atom:Button ButtonType="Text" Shape="Circle" Content="{gallery:ButtonShowCaseLangResource P2ContentAa}" />
                    <atom:Button ButtonType="Link" Shape="Circle" Content="{gallery:ButtonShowCaseLangResource P2ContentAa}" />
                </StackPanel>
            </StackPanel>

        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ButtonShowCaseLangResource SizeTitle}"
            Description="{gallery:ButtonShowCaseLangResource SizeDescription}">
            <DockPanel Margin="0, 0, 0, 0">
                <StackPanel Orientation="Horizontal" Spacing="5" DockPanel.Dock="Top">
                    <atom:TextBlock VerticalAlignment="Center" Text="{gallery:ButtonShowCaseLangResource P2TextExpandDirection}" />
                    <atom:OptionButtonGroup ButtonStyle="Outline"
                                            OptionCheckedChanged="HandleButtonSizeTypeOptionCheckedChanged">
                        <atom:OptionButton IsChecked="True" Content="{gallery:ButtonShowCaseLangResource P2ContentLarge}" />
                        <atom:OptionButton Content="{gallery:ButtonShowCaseLangResource P2ContentDefault}" />
                        <atom:OptionButton Content="{gallery:ButtonShowCaseLangResource P2ContentSmall}" />
                    </atom:OptionButtonGroup>
                </StackPanel>

                <StackPanel Orientation="Vertical" Margin="0, 20, 0, 0" Spacing="10">
                    <WrapPanel>
                        <atom:Button ButtonType="Primary" SizeType="{Binding ButtonSizeType}" Content="{gallery:ButtonShowCaseLangResource P2ContentPrimary}" />
                        <atom:Button ButtonType="Dashed" SizeType="{Binding ButtonSizeType}" Content="{gallery:ButtonShowCaseLangResource P2ContentDashed}" />
                        <atom:Button ButtonType="Default" SizeType="{Binding ButtonSizeType}" Content="{gallery:ButtonShowCaseLangResource P2ContentDefault}" />
                        <atom:Button ButtonType="Link" SizeType="{Binding ButtonSizeType}" Content="{gallery:ButtonShowCaseLangResource P2ContentLink}" />
                    </WrapPanel>
                    <WrapPanel>
                        <atom:Button ButtonType="Primary" Shape="Default"
                                     Icon="{antdicons:AntDesignIconProvider Kind=DownloadOutlined}"
                                     SizeType="{Binding ButtonSizeType}" />
                        <atom:Button ButtonType="Dashed" Shape="Default"
                                     Icon="{antdicons:AntDesignIconProvider Kind=DownloadOutlined}"
                                     SizeType="{Binding ButtonSizeType}" />
                        <atom:Button ButtonType="Primary" Shape="Circle"
                                     Icon="{antdicons:AntDesignIconProvider Kind=DownloadOutlined}"
                                     SizeType="{Binding ButtonSizeType}" />
                        <atom:Button ButtonType="Primary" Shape="Round"
                                     Icon="{antdicons:AntDesignIconProvider Kind=DownloadOutlined}"
                                     SizeType="{Binding ButtonSizeType}" />
                        <atom:Button ButtonType="Primary" Shape="Round"
                                     Icon="{antdicons:AntDesignIconProvider Kind=DownloadOutlined}"
                                     SizeType="{Binding ButtonSizeType}" Content="{gallery:ButtonShowCaseLangResource P2ContentDownload}" />
                        <atom:Button ButtonType="Primary" Shape="Default"
                                     Icon="{antdicons:AntDesignIconProvider Kind=DownloadOutlined}"
                                     SizeType="{Binding ButtonSizeType}" Content="{gallery:ButtonShowCaseLangResource P2ContentDownload}" />
                    </WrapPanel>
                </StackPanel>
            </DockPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ButtonShowCaseLangResource IconTitle}"
            Description="{gallery:ButtonShowCaseLangResource IconDescription}">
            <StackPanel Orientation="Vertical">
                <WrapPanel HorizontalAlignment="Left" Orientation="Horizontal">
                    <atom:Button ButtonType="Primary" Shape="Circle"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" />
                    <atom:Button ButtonType="Primary" Shape="Round"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentSearch}" />

                    <atom:Button ButtonType="Default" Shape="Circle"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" />
                    <atom:Button ButtonType="Default" Shape="Round"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentSearch}" />

                    <atom:Button ButtonType="Text" Shape="Default"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentSearch}" />

                    <atom:Button ButtonType="Link" Shape="Default"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentSearch}" />

                    <atom:Button ButtonType="Dashed" Shape="Circle"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" />
                    <atom:Button ButtonType="Link" Shape="Default"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentSearch}" />

                </WrapPanel>
                <WrapPanel HorizontalAlignment="Left" Orientation="Horizontal">
                    <atom:Button ButtonType="Primary" IsDanger="True"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentSearch}" />

                    <atom:Button ButtonType="Default" Shape="Round" IsDanger="True"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentSearch}" />

                    <atom:Button ButtonType="Text" Shape="Default" IsDanger="True"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentSearch}" />

                    <atom:Button ButtonType="Link" Shape="Default" IsDanger="True"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentSearch}" />

                    <atom:Button ButtonType="Dashed" Shape="Circle" IsDanger="True"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" />
                    <atom:Button ButtonType="Dashed" Shape="Default" IsDanger="True"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentSearch}" />
                </WrapPanel>
            </StackPanel>

        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ButtonShowCaseLangResource LoadingTitle}"
            Description="{gallery:ButtonShowCaseLangResource LoadingDescription}">
            <StackPanel HorizontalAlignment="Stretch" Orientation="Vertical" Margin="10">
                <atom:Button ButtonType="Primary"
                             Click="HandleLoadingBtnClick"
                             Icon="{antdicons:AntDesignIconProvider Kind=PoweroffOutlined}" />
                <WrapPanel>
                    <atom:Button ButtonType="Primary" IsLoading="True" Content="{gallery:ButtonShowCaseLangResource P2ContentLoading}" />
                    <atom:Button ButtonType="Primary" SizeType="Small" IsLoading="True" Content="{gallery:ButtonShowCaseLangResource P2ContentLoading}" />
                    <atom:Button ButtonType="Primary" IsLoading="True"
                                 Icon="{antdicons:AntDesignIconProvider Kind=PoweroffOutlined}" />
                </WrapPanel>
                <WrapPanel>
                    <atom:Button ButtonType="Primary" Click="HandleLoadingBtnClick" Content="{gallery:ButtonShowCaseLangResource P2ContentClickMe}" />
                    <atom:Button ButtonType="Primary"
                                 Click="HandleLoadingBtnClick"
                                 Icon="{antdicons:AntDesignIconProvider Kind=PoweroffOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentClickMe}" />
                    <atom:Button ButtonType="Primary"
                                 Click="HandleLoadingBtnClick"
                                 Icon="{antdicons:AntDesignIconProvider Kind=PoweroffOutlined}" />
                </WrapPanel>

            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ButtonShowCaseLangResource BlockButtonTitle}"
            Description="{gallery:ButtonShowCaseLangResource BlockButtonDescription}">
            <StackPanel HorizontalAlignment="Stretch" Orientation="Vertical" Margin="10">
                <atom:Button ButtonType="Primary" HorizontalAlignment="Stretch" Content="{gallery:ButtonShowCaseLangResource P2ContentPrimary}" />
                <atom:Button ButtonType="Default" HorizontalAlignment="Stretch" Content="{gallery:ButtonShowCaseLangResource P2ContentDefault}" />
                <atom:Button ButtonType="Dashed" HorizontalAlignment="Stretch" Content="{gallery:ButtonShowCaseLangResource P2ContentDashed}" />
                <atom:Button ButtonType="Text" HorizontalAlignment="Stretch" Content="{gallery:ButtonShowCaseLangResource P2ContentText}" />
                <atom:Button ButtonType="Link" HorizontalAlignment="Stretch" Content="{gallery:ButtonShowCaseLangResource P2ContentLink}" />
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ButtonShowCaseLangResource DangerButtonsTitle}"
            Description="{gallery:ButtonShowCaseLangResource DangerButtonsDescription}">
            <WrapPanel HorizontalAlignment="Stretch" Orientation="Horizontal">
                <atom:Button ButtonType="Primary" IsDanger="True" Content="{gallery:ButtonShowCaseLangResource P2ContentPrimary}" />
                <atom:Button ButtonType="Default" IsDanger="True" Content="{gallery:ButtonShowCaseLangResource P2ContentDefault}" />
                <atom:Button ButtonType="Dashed" IsDanger="True" Content="{gallery:ButtonShowCaseLangResource P2ContentDashed}" />
                <atom:Button ButtonType="Text" IsDanger="True" Content="{gallery:ButtonShowCaseLangResource P2ContentText}" />
                <atom:Button ButtonType="Link" IsDanger="True" Content="{gallery:ButtonShowCaseLangResource P2ContentLink}" />
            </WrapPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ButtonShowCaseLangResource GhostButtonTitle}"
            Description="{gallery:ButtonShowCaseLangResource GhostButtonDescription}">
            <Border Background="rgb(190, 200, 200)"
                    Margin="10"
                    Padding="10">
                <StackPanel Orientation="Vertical">
                    <WrapPanel HorizontalAlignment="Stretch" Orientation="Horizontal">
                        <atom:Button ButtonType="Primary" IsGhost="True" Content="{gallery:ButtonShowCaseLangResource P2ContentPrimary}" />
                        <atom:Button ButtonType="Default" IsGhost="True" Content="{gallery:ButtonShowCaseLangResource P2ContentDefault}" />
                        <atom:Button ButtonType="Dashed" IsGhost="True" Content="{gallery:ButtonShowCaseLangResource P2ContentDashed}" />
                        <atom:Button ButtonType="Text" IsGhost="True" Content="{gallery:ButtonShowCaseLangResource P2ContentText}" />
                        <atom:Button ButtonType="Link" IsGhost="True" Content="{gallery:ButtonShowCaseLangResource P2ContentLink}" />
                        <atom:Button ButtonType="Primary" IsDanger="True" IsGhost="True" Content="{gallery:ButtonShowCaseLangResource P2ContentDanger}" />
                    </WrapPanel>
                    <WrapPanel HorizontalAlignment="Stretch" Orientation="Horizontal">
                        <atom:Button ButtonType="Primary" IsGhost="True"
                                     Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentPrimary}" />
                        <atom:Button ButtonType="Default" IsGhost="True"
                                     Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentDefault}" />
                        <atom:Button ButtonType="Text" IsGhost="True"
                                     Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentText}" />
                        <atom:Button ButtonType="Link" IsGhost="True"
                                     Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentLink}" />
                        <atom:Button ButtonType="Primary" IsDanger="True" IsGhost="True"
                                     Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentDanger}" />
                    </WrapPanel>
                </StackPanel>
            </Border>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ButtonShowCaseLangResource DisabledTitle}"
            Description="{gallery:ButtonShowCaseLangResource DisabledDescription}">
            <WrapPanel HorizontalAlignment="Stretch" Orientation="Vertical">
                <StackPanel Orientation="Horizontal">
                    <atom:Button ButtonType="Primary" Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentPrimary}" />
                    <atom:Button ButtonType="Primary" IsEnabled="False"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentPrimaryDisabled}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <atom:Button ButtonType="Default" Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentDefault}" />
                    <atom:Button ButtonType="Default" IsEnabled="False" Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentDefaultDisabled}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <atom:Button ButtonType="Dashed" Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentDashed}" />
                    <atom:Button ButtonType="Dashed" IsEnabled="False"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentDashedDisabled}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <atom:Button ButtonType="Text" Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentText}" />
                    <atom:Button ButtonType="Text" IsEnabled="False"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentTextDisabled}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <atom:Button ButtonType="Link" Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentLink}" />
                    <atom:Button ButtonType="Link" IsEnabled="False"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentLinkDisabled}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <atom:Button ButtonType="Primary" IsDanger="True"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentDangerPrimary}" />
                    <atom:Button ButtonType="Primary" IsDanger="True" IsEnabled="False"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentDangerPrimaryDisabled}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <atom:Button ButtonType="Default" IsDanger="True"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentDangerDefault}" />
                    <atom:Button ButtonType="Default" IsDanger="True" IsEnabled="False"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentDangerDefaultDisabled}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <atom:Button ButtonType="Text" IsDanger="True"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentDangerText}" />
                    <atom:Button ButtonType="Text" IsDanger="True" IsEnabled="False"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentDangerTextDisabled}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <atom:Button ButtonType="Link" IsDanger="True"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentDangerLink}" />
                    <atom:Button ButtonType="Link" IsDanger="True" IsEnabled="False"
                                 Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentDangerLinkDisabled}" />
                </StackPanel>

                <Border Background="rgb(190, 200, 200)">
                    <StackPanel Orientation="Horizontal">
                        <atom:Button IsGhost="True" Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentGhost}" />
                        <atom:Button IsGhost="True" IsEnabled="False"
                                     Icon="{antdicons:AntDesignIconProvider Kind=SearchOutlined}" Content="{gallery:ButtonShowCaseLangResource P2ContentGhostDisabled}" />
                    </StackPanel>
                </Border>

            </WrapPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
