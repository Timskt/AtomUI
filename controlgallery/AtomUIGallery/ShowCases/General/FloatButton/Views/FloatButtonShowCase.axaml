<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.FloatButton.FloatButtonShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.FloatButton"
             x:DataType="vm:FloatButtonViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:FloatButtonShowCaseLangResource BasicTitle}"
            Description="{gallery:FloatButtonShowCaseLangResource BasicDescription}">
            <atom:ScrollViewer Height="300">
                <Border Background="White">
                    <Panel Height="500">
                        <atom:FloatButtonHost />
                    </Panel>
                </Border>
            </atom:ScrollViewer>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="{gallery:FloatButtonShowCaseLangResource TypeTitle}"
            Description="{gallery:FloatButtonShowCaseLangResource TypeDescription}">
            <atom:ScrollViewer Height="300">
                <Border Background="White">
                    <Panel Height="500">
                        <atom:FloatButtonHost ButtonType="Default"
                                              Icon="{antdicons:AntDesignIconProvider QuestionCircleOutlined}"
                                              FloatOffsetX="80" />
                        <atom:FloatButtonHost ButtonType="Primary"
                                              Icon="{antdicons:AntDesignIconProvider QuestionCircleOutlined}" />
                    </Panel>
                </Border>
            </atom:ScrollViewer>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="{gallery:FloatButtonShowCaseLangResource ShapeTitle}"
            Description="{gallery:FloatButtonShowCaseLangResource ShapeDescription}">
            <atom:ScrollViewer Height="300">
                <Border Background="White">
                    <Panel Height="500">
                        <atom:FloatButtonHost ButtonType="Primary"
                                              Shape="Circle"
                                              Icon="{antdicons:AntDesignIconProvider CustomerServiceOutlined}"
                                              FloatOffsetX="80" />
                        <atom:FloatButtonHost ButtonType="Primary"
                                              Shape="Square"
                                              Icon="{antdicons:AntDesignIconProvider CustomerServiceOutlined}" />
                    </Panel>
                </Border>
            </atom:ScrollViewer>
        
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="{gallery:FloatButtonShowCaseLangResource TooltipTitle}"
            Description="{gallery:FloatButtonShowCaseLangResource TooltipDescription}">
            <atom:ScrollViewer Height="300">
                <Border Background="White">
                    <Panel Height="500">
                        <atom:FloatButtonHost FloatOffsetX="80"
                                              Tooltip="{gallery:FloatButtonShowCaseLangResource P2TooltipSinceN5N25N0}" TooltipColor="blue" />
                        <atom:FloatButtonHost Tooltip="{gallery:FloatButtonShowCaseLangResource P2TooltipDocuments}" />
                    </Panel>
                </Border>
            </atom:ScrollViewer>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="{gallery:FloatButtonShowCaseLangResource DescriptionTitle}"
            Description="{gallery:FloatButtonShowCaseLangResource DescriptionDescription}">
            <atom:ScrollViewer Height="300">
                <Border Background="White">
                    <Panel Height="500">
                        <atom:FloatButtonHost Shape="Square"
                                              Icon="{antdicons:AntDesignIconProvider FileTextOutlined}" Margin="0"
                                              FloatOffsetX="145"
                                              Description="{gallery:FloatButtonShowCaseLangResource P2DescriptionHelpInfo}" />
                        <atom:FloatButtonHost Shape="Square"
                                              FloatOffsetX="80"
                                              Description="{gallery:FloatButtonShowCaseLangResource P2DescriptionHelpInfo}" />
                        <atom:FloatButtonHost Shape="Square"
                                              Icon="{antdicons:AntDesignIconProvider FileTextOutlined}"
                                              Description="{gallery:FloatButtonShowCaseLangResource P2DescriptionHelpInfo}" />
                    </Panel>
                </Border>
            </atom:ScrollViewer>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="{gallery:FloatButtonShowCaseLangResource GroupTitle}"
            Description="{gallery:FloatButtonShowCaseLangResource GroupDescription}">
        
            <atom:ScrollViewer Height="300">
                <Border Background="White">
                    <Panel Height="500">
                        <atom:FloatButtonGroupHost Shape="Square" FloatOffsetX="80">
                            <atom:FloatButton Icon="{antdicons:AntDesignIconProvider QuestionCircleOutlined}" />
                            <atom:FloatButton />
                            <atom:FloatButton Icon="{antdicons:AntDesignIconProvider SyncOutlined}" />
                            <atom:BackTopFloatButton />
                        </atom:FloatButtonGroupHost>
                        <atom:FloatButtonGroupHost Shape="Circle">
                            <atom:FloatButton Icon="{antdicons:AntDesignIconProvider QuestionCircleOutlined}" />
                            <atom:FloatButton />
                            <atom:FloatButton Icon="{antdicons:AntDesignIconProvider SyncOutlined}" />
                            <atom:BackTopFloatButton />
                        </atom:FloatButtonGroupHost>
                    </Panel>
                </Border>
            </atom:ScrollViewer>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="{gallery:FloatButtonShowCaseLangResource MenuModeTitle}"
            Description="{gallery:FloatButtonShowCaseLangResource MenuModeDescription}">
            <atom:ScrollViewer Height="300">
                <Border Background="White">
                    <Panel Height="500">
                        <atom:FloatButtonGroupHost Shape="Circle"
                                                   Trigger="Hover"
                                                   Icon="{antdicons:AntDesignIconProvider CustomerServiceOutlined}"
                                                   ButtonType="Primary"
                                                   FloatOffsetX="80">
                            <atom:FloatButton />
                            <atom:FloatButton Icon="{antdicons:AntDesignIconProvider CommentOutlined}" />
                        </atom:FloatButtonGroupHost>
        
                        <atom:FloatButtonGroupHost Shape="Circle"
                                                   Trigger="Click"
                                                   Icon="{antdicons:AntDesignIconProvider CustomerServiceOutlined}"
                                                   ButtonType="Primary">
                            <atom:FloatButton />
                            <atom:FloatButton Icon="{antdicons:AntDesignIconProvider CommentOutlined}" />
                        </atom:FloatButtonGroupHost>
                    </Panel>
                </Border>
            </atom:ScrollViewer>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="{gallery:FloatButtonShowCaseLangResource ControlledModeTitle}"
            Description="{gallery:FloatButtonShowCaseLangResource ControlledModeDescription}">
            <StackPanel Spacing="10">
                <atom:ToggleSwitch HorizontalContentAlignment="Left"
                                   VerticalAlignment="Top"
                                   IsChecked="{Binding IsOpened, Mode=TwoWay}" />
                <atom:ScrollViewer Height="300">
                    <Border Background="White">
                        <Panel Height="500">
                            <atom:FloatButtonGroupHost Shape="Square"
                                                       FloatOffsetX="80"
                                                       Trigger="Hover"
                                                       Icon="{antdicons:AntDesignIconProvider CustomerServiceOutlined}"
                                                       IsOpen="{Binding IsOpened}">
                                <atom:FloatButton Icon="{antdicons:AntDesignIconProvider WechatOutlined}" />
                                <atom:FloatButton Icon="{antdicons:AntDesignIconProvider QqOutlined}" />
                                <atom:FloatButton Icon="{antdicons:AntDesignIconProvider TwitterOutlined}" />
                            </atom:FloatButtonGroupHost>
        
                            <atom:FloatButtonGroupHost Shape="Circle"
                                                       Trigger="Click"
                                                       Icon="{antdicons:AntDesignIconProvider CustomerServiceOutlined}"
                                                       IsOpen="{Binding IsOpened}">
                                <atom:FloatButton Icon="{antdicons:AntDesignIconProvider WechatOutlined}" />
                                <atom:FloatButton Icon="{antdicons:AntDesignIconProvider QqOutlined}" />
                                <atom:FloatButton Icon="{antdicons:AntDesignIconProvider TwitterOutlined}" />
                            </atom:FloatButtonGroupHost>
                        </Panel>
                    </Border>
                </atom:ScrollViewer>
        
            </StackPanel>
        
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="{gallery:FloatButtonShowCaseLangResource PlacementTitle}"
            IsOccupyEntireRow="True"
            Description="{gallery:FloatButtonShowCaseLangResource PlacementDescription}">
            <atom:ScrollViewer Height="400">
                <Border Background="White">
                    <Panel Height="600">
                        <atom:FloatButtonGroupHost Shape="Circle"
                                                   Trigger="Click"
                                                   Placement="Center"
                                                   MenuPlacement="Top"
                                                   FloatOffsetY="-60"
                                                   Icon="{antdicons:AntDesignIconProvider UpOutlined}">
                            <atom:FloatButton Icon="{antdicons:AntDesignIconProvider WechatOutlined}" />
                            <atom:FloatButton Icon="{antdicons:AntDesignIconProvider QqOutlined}" />
                        </atom:FloatButtonGroupHost>
                        <atom:FloatButtonGroupHost Shape="Circle"
                                                   Trigger="Click"
                                                   Placement="Center"
                                                   MenuPlacement="Left"
                                                   FloatOffsetX="-60"
                                                   Icon="{antdicons:AntDesignIconProvider LeftOutlined}">
                            <atom:FloatButton Icon="{antdicons:AntDesignIconProvider WechatOutlined}" />
                            <atom:FloatButton Icon="{antdicons:AntDesignIconProvider QqOutlined}" />
                        </atom:FloatButtonGroupHost>
                        <atom:FloatButtonGroupHost Shape="Circle"
                                                   Trigger="Click"
                                                   Icon="{antdicons:AntDesignIconProvider DownOutlined}"
                                                   Placement="Center"
                                                   MenuPlacement="Bottom"
                                                   FloatOffsetY="60">
                            <atom:FloatButton Icon="{antdicons:AntDesignIconProvider WechatOutlined}" />
                            <atom:FloatButton Icon="{antdicons:AntDesignIconProvider QqOutlined}" />
                        </atom:FloatButtonGroupHost>
                        <atom:FloatButtonGroupHost Shape="Circle"
                                                   Trigger="Click"
                                                   Icon="{antdicons:AntDesignIconProvider RightOutlined}"
                                                   Placement="Center"
                                                   FloatOffsetX="60"
                                                   MenuPlacement="Right">
                            <atom:FloatButton Icon="{antdicons:AntDesignIconProvider WechatOutlined}" />
                            <atom:FloatButton Icon="{antdicons:AntDesignIconProvider QqOutlined}" />
                        </atom:FloatButtonGroupHost>
                    </Panel>
                </Border>
            </atom:ScrollViewer>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="{gallery:FloatButtonShowCaseLangResource BadgeTitle}"
            Description="{gallery:FloatButtonShowCaseLangResource BadgeDescription}">
            <atom:ScrollViewer Height="300">
                <Border Background="White">
                    <Panel Height="500">
                        <atom:FloatButtonHost FloatOffsetX="145" IsBadgeEnabled="True" IsDotBadge="True" />
                        <atom:FloatButtonGroupHost Shape="Circle"
                                                   Icon="{antdicons:AntDesignIconProvider CustomerServiceOutlined}"
                                                   ButtonType="Primary"
                                                   FloatOffsetX="80">
                            <atom:FloatButton IsBadgeEnabled="True" IsDotBadge="False" BadgeCount="5" BadgeColor="blue" />
                            <atom:FloatButton Icon="{antdicons:AntDesignIconProvider CommentOutlined}"
                                              IsBadgeEnabled="True" IsDotBadge="False" BadgeCount="5" />
                        </atom:FloatButtonGroupHost>
        
                        <atom:FloatButtonGroupHost Shape="Circle"
                                                   Icon="{antdicons:AntDesignIconProvider CustomerServiceOutlined}"
                                                   ButtonType="Primary">
                            <atom:FloatButton IsBadgeEnabled="True" IsDotBadge="False" BadgeCount="12" />
                            <atom:FloatButton Icon="{antdicons:AntDesignIconProvider CommentOutlined}"
                                              IsBadgeEnabled="True" IsDotBadge="False" BadgeCount="123" />
                            <atom:FloatButton Icon="{antdicons:AntDesignIconProvider ToTopOutlined}"
                                              IsBadgeEnabled="True" IsDotBadge="False" BadgeCount="1230"
                                              BadgeOverflowCount="" />
                        </atom:FloatButtonGroupHost>
                    </Panel>
                </Border>
            </atom:ScrollViewer>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="{gallery:FloatButtonShowCaseLangResource BackTopTitle}"
            Description="{gallery:FloatButtonShowCaseLangResource BackTopDescription}">
            <atom:ScrollViewer Height="300">
                <Border Background="White">
                    <Panel Height="1000">
                        <StackPanel>
                            <TextBlock Text="{gallery:FloatButtonShowCaseLangResource P2TextScrollToBottom}" />
                            <TextBlock Text="{gallery:FloatButtonShowCaseLangResource P2TextScrollToBottom}" />
                            <TextBlock Text="{gallery:FloatButtonShowCaseLangResource P2TextScrollToBottom}" />
                            <TextBlock Text="{gallery:FloatButtonShowCaseLangResource P2TextScrollToBottom}" />
                            <TextBlock Text="{gallery:FloatButtonShowCaseLangResource P2TextScrollToBottom}" />
                            <TextBlock Text="{gallery:FloatButtonShowCaseLangResource P2TextScrollToBottom}" />
                            <TextBlock Text="{gallery:FloatButtonShowCaseLangResource P2TextScrollToBottom}" />
                            <TextBlock Text="{gallery:FloatButtonShowCaseLangResource P2TextScrollToBottom}" />
                        </StackPanel>
                        <atom:BackTopFloatButtonHost ButtonType="Default" />
                    </Panel>
                </Border>
            </atom:ScrollViewer>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
