<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Icon.IconShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery">
    <atom:TabControl>
        <atom:TabItem Header="{gallery:IconShowCaseLangResource P2HeaderOutlined}">
            <gallery:IconGallery IconThemeType="Outlined" />
        </atom:TabItem>
        <atom:TabItem Header="{gallery:IconShowCaseLangResource P2HeaderFilled}">
            <gallery:IconGallery IconThemeType="Filled" />
        </atom:TabItem>
        <atom:TabItem Header="{gallery:IconShowCaseLangResource P2HeaderTwoTone}">
            <gallery:IconGallery IconThemeType="TwoTone" />
        </atom:TabItem>
    </atom:TabControl>
</UserControl>
