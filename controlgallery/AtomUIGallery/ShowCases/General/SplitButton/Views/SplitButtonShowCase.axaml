<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.SplitButton.SplitButtonShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:viewModels="clr-namespace:AtomUIGallery.ShowCases.SplitButton"
             x:DataType="viewModels:SplitButtonViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:SplitButtonShowCaseLangResource BasicTitle}"
            Description="{gallery:SplitButtonShowCaseLangResource BasicDescription}">
            <atom:SplitButton TriggerType="Hover"
                              Content="{gallery:SplitButtonShowCaseLangResource P2ContentHoverMe}">
                <atom:SplitButton.Flyout>
                    <atom:MenuFlyout>
                        <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCut}" InputGesture="Ctrl+X"
                                       Icon="{antdicons:AntDesignIconProvider Kind=ScissorOutlined}" />
                        <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCopy}" InputGesture="Ctrl+C"
                                       Icon="{antdicons:AntDesignIconProvider Kind=CopyOutlined}" />
                        <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderDelete}" InputGesture="Ctrl+D"
                                       Icon="{antdicons:AntDesignIconProvider Kind=DeleteOutlined}" />
                    </atom:MenuFlyout>
                </atom:SplitButton.Flyout>
            </atom:SplitButton>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SplitButtonShowCaseLangResource SizeTitle}"
            Description="{gallery:SplitButtonShowCaseLangResource SizeDescription}">
            <gallery:ShowCaseItem.Styles>
                <Style Selector="atom|SplitButton">
                    <Setter Property="Margin" Value="5" />
                    <Setter Property="VerticalAlignment" Value="Bottom" />
                </Style>
            </gallery:ShowCaseItem.Styles>
            <StackPanel Orientation="Vertical" Spacing="10">
                <WrapPanel>
                    <atom:SplitButton SizeType="Large"
                                      Content="{gallery:SplitButtonShowCaseLangResource P2ContentLarge}">
                        <atom:SplitButton.Flyout>
                            <atom:MenuFlyout>
                                <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCut}" InputGesture="Ctrl+X"
                                               Icon="{antdicons:AntDesignIconProvider Kind=ScissorOutlined}" />
                                <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCopy}" InputGesture="Ctrl+C"
                                               Icon="{antdicons:AntDesignIconProvider Kind=CopyOutlined}" />
                                <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderDelete}" InputGesture="Ctrl+D"
                                               Icon="{antdicons:AntDesignIconProvider Kind=DeleteOutlined}" />
                            </atom:MenuFlyout>
                        </atom:SplitButton.Flyout>
                    </atom:SplitButton>
                    <atom:SplitButton SizeType="Middle"
                                      Content="{gallery:SplitButtonShowCaseLangResource P2ContentMiddle}">
                        <atom:SplitButton.Flyout>
                            <atom:MenuFlyout>
                                <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCut}" InputGesture="Ctrl+X"
                                               Icon="{antdicons:AntDesignIconProvider Kind=ScissorOutlined}" />
                                <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCopy}" InputGesture="Ctrl+C"
                                               Icon="{antdicons:AntDesignIconProvider Kind=CopyOutlined}" />
                                <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderDelete}" InputGesture="Ctrl+D"
                                               Icon="{antdicons:AntDesignIconProvider Kind=DeleteOutlined}" />
                            </atom:MenuFlyout>
                        </atom:SplitButton.Flyout>
                    </atom:SplitButton>
                    <atom:SplitButton SizeType="Small"
                                      Content="{gallery:SplitButtonShowCaseLangResource P2ContentSmall}">
                        <atom:SplitButton.Flyout>
                            <atom:MenuFlyout>
                                <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCut}" InputGesture="Ctrl+X"
                                               Icon="{antdicons:AntDesignIconProvider Kind=ScissorOutlined}" />
                                <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCopy}" InputGesture="Ctrl+C"
                                               Icon="{antdicons:AntDesignIconProvider Kind=CopyOutlined}" />
                                <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderDelete}" InputGesture="Ctrl+D"
                                               Icon="{antdicons:AntDesignIconProvider Kind=DeleteOutlined}" />
                            </atom:MenuFlyout>
                        </atom:SplitButton.Flyout>
                    </atom:SplitButton>
                </WrapPanel>
                <WrapPanel>
                    <atom:SplitButton SizeType="Large"
                                      IsPrimaryButtonType="True"
                                      Content="{gallery:SplitButtonShowCaseLangResource P2ContentLarge}">
                        <atom:SplitButton.Flyout>
                            <atom:MenuFlyout>
                                <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCut}" InputGesture="Ctrl+X"
                                               Icon="{antdicons:AntDesignIconProvider Kind=ScissorOutlined}" />
                                <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCopy}" InputGesture="Ctrl+C"
                                               Icon="{antdicons:AntDesignIconProvider Kind=CopyOutlined}" />
                                <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderDelete}" InputGesture="Ctrl+D"
                                               Icon="{antdicons:AntDesignIconProvider Kind=DeleteOutlined}" />
                            </atom:MenuFlyout>
                        </atom:SplitButton.Flyout>
                    </atom:SplitButton>
                    <atom:SplitButton SizeType="Middle"
                                      IsPrimaryButtonType="True"
                                      Content="{gallery:SplitButtonShowCaseLangResource P2ContentMiddle}">
                        <atom:SplitButton.Flyout>
                            <atom:MenuFlyout>
                                <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCut}" InputGesture="Ctrl+X"
                                               Icon="{antdicons:AntDesignIconProvider Kind=ScissorOutlined}" />
                                <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCopy}" InputGesture="Ctrl+C"
                                               Icon="{antdicons:AntDesignIconProvider Kind=CopyOutlined}" />
                                <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderDelete}" InputGesture="Ctrl+D"
                                               Icon="{antdicons:AntDesignIconProvider Kind=DeleteOutlined}" />
                            </atom:MenuFlyout>
                        </atom:SplitButton.Flyout>
                    </atom:SplitButton>
                    <atom:SplitButton SizeType="Small"
                                      IsPrimaryButtonType="True"
                                      Content="{gallery:SplitButtonShowCaseLangResource P2ContentSmall}">
                        <atom:SplitButton.Flyout>
                            <atom:MenuFlyout>
                                <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCut}" InputGesture="Ctrl+X"
                                               Icon="{antdicons:AntDesignIconProvider Kind=ScissorOutlined}" />
                                <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCopy}" InputGesture="Ctrl+C"
                                               Icon="{antdicons:AntDesignIconProvider Kind=CopyOutlined}" />
                                <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderDelete}" InputGesture="Ctrl+D"
                                               Icon="{antdicons:AntDesignIconProvider Kind=DeleteOutlined}" />
                            </atom:MenuFlyout>
                        </atom:SplitButton.Flyout>
                    </atom:SplitButton>
                </WrapPanel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SplitButtonShowCaseLangResource DangerButtonsTitle}"
            Description="{gallery:SplitButtonShowCaseLangResource DangerButtonsDescription}">
            <gallery:ShowCaseItem.Styles>
                <Style Selector="atom|SplitButton">
                    <Setter Property="Margin" Value="5" />
                    <Setter Property="VerticalAlignment" Value="Bottom" />
                </Style>
            </gallery:ShowCaseItem.Styles>
            <WrapPanel HorizontalAlignment="Stretch" Orientation="Horizontal">
                <atom:SplitButton IsDanger="True"
                                  Content="{gallery:SplitButtonShowCaseLangResource P2ContentDefault}">
                    <atom:SplitButton.Flyout>
                        <atom:MenuFlyout>
                            <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCut}" InputGesture="Ctrl+X"
                                           Icon="{antdicons:AntDesignIconProvider Kind=ScissorOutlined}" />
                            <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCopy}" InputGesture="Ctrl+C"
                                           Icon="{antdicons:AntDesignIconProvider Kind=CopyOutlined}" />
                            <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderDelete}" InputGesture="Ctrl+D"
                                           Icon="{antdicons:AntDesignIconProvider Kind=DeleteOutlined}" />
                        </atom:MenuFlyout>
                    </atom:SplitButton.Flyout>
                </atom:SplitButton>

                <atom:SplitButton IsDanger="True"
                                  IsPrimaryButtonType="True"
                                  Content="{gallery:SplitButtonShowCaseLangResource P2ContentPrimary}">
                    <atom:SplitButton.Flyout>
                        <atom:MenuFlyout>
                            <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCut}" InputGesture="Ctrl+X"
                                           Icon="{antdicons:AntDesignIconProvider Kind=ScissorOutlined}" />
                            <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCopy}" InputGesture="Ctrl+C"
                                           Icon="{antdicons:AntDesignIconProvider Kind=CopyOutlined}" />
                            <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderDelete}" InputGesture="Ctrl+D"
                                           Icon="{antdicons:AntDesignIconProvider Kind=DeleteOutlined}" />
                        </atom:MenuFlyout>
                    </atom:SplitButton.Flyout>
                </atom:SplitButton>
            </WrapPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SplitButtonShowCaseLangResource CustomIconTitle}"
            Description="{gallery:SplitButtonShowCaseLangResource CustomIconDescription}">
            <gallery:ShowCaseItem.Styles>
                <Style Selector="atom|SplitButton">
                    <Setter Property="Margin" Value="5" />
                    <Setter Property="VerticalAlignment" Value="Bottom" />
                </Style>
            </gallery:ShowCaseItem.Styles>
            <WrapPanel HorizontalAlignment="Stretch" Orientation="Horizontal">
                <atom:SplitButton Content="{gallery:SplitButtonShowCaseLangResource P2ContentDefault}">
                    <atom:SplitButton.Flyout>
                        <atom:MenuFlyout>
                            <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCut}" InputGesture="Ctrl+X"
                                           Icon="{antdicons:AntDesignIconProvider Kind=ScissorOutlined}" />
                            <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCopy}" InputGesture="Ctrl+C"
                                           Icon="{antdicons:AntDesignIconProvider Kind=CopyOutlined}" />
                            <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderDelete}" InputGesture="Ctrl+D"
                                           Icon="{antdicons:AntDesignIconProvider Kind=DeleteOutlined}" />
                        </atom:MenuFlyout>
                    </atom:SplitButton.Flyout>
                </atom:SplitButton>

                <atom:SplitButton OpenIndicator="{antdicons:AntDesignIconProvider Kind=UserOutlined}"
                                  Content="{gallery:SplitButtonShowCaseLangResource P2ContentPrimary}">
                    <atom:SplitButton.Flyout>
                        <atom:MenuFlyout>
                            <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCut}" InputGesture="Ctrl+X"
                                           Icon="{antdicons:AntDesignIconProvider Kind=ScissorOutlined}" />
                            <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCopy}" InputGesture="Ctrl+C"
                                           Icon="{antdicons:AntDesignIconProvider Kind=CopyOutlined}" />
                            <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderDelete}" InputGesture="Ctrl+D"
                                           Icon="{antdicons:AntDesignIconProvider Kind=DeleteOutlined}" />
                        </atom:MenuFlyout>
                    </atom:SplitButton.Flyout>
                </atom:SplitButton>
            </WrapPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:SplitButtonShowCaseLangResource FlyoutTriggerTypeTitle}"
            Description="{gallery:SplitButtonShowCaseLangResource FlyoutTriggerTypeDescription}">
            <gallery:ShowCaseItem.Styles>
                <Style Selector="atom|SplitButton">
                    <Setter Property="Margin" Value="5" />
                    <Setter Property="VerticalAlignment" Value="Bottom" />
                </Style>
            </gallery:ShowCaseItem.Styles>
            <WrapPanel HorizontalAlignment="Stretch" Orientation="Horizontal">
                <atom:SplitButton TriggerType="Hover"
                                  Content="{gallery:SplitButtonShowCaseLangResource P2ContentHoverMe}">
                    <atom:SplitButton.Flyout>
                        <atom:MenuFlyout>
                            <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCut}" InputGesture="Ctrl+X"
                                           Icon="{antdicons:AntDesignIconProvider Kind=ScissorOutlined}" />
                            <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCopy}" InputGesture="Ctrl+C"
                                           Icon="{antdicons:AntDesignIconProvider Kind=CopyOutlined}" />
                            <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderDelete}" InputGesture="Ctrl+D"
                                           Icon="{antdicons:AntDesignIconProvider Kind=DeleteOutlined}" />
                        </atom:MenuFlyout>
                    </atom:SplitButton.Flyout>
                </atom:SplitButton>

                <atom:SplitButton OpenIndicator="{antdicons:AntDesignIconProvider Kind=UserOutlined}"
                                  TriggerType="Click"
                                  Content="{gallery:SplitButtonShowCaseLangResource P2ContentClickMe}">
                    <atom:SplitButton.Flyout>
                        <atom:MenuFlyout>
                            <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCut}" InputGesture="Ctrl+X"
                                           Icon="{antdicons:AntDesignIconProvider Kind=ScissorOutlined}" />
                            <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderCopy}" InputGesture="Ctrl+C"
                                           Icon="{antdicons:AntDesignIconProvider Kind=CopyOutlined}" />
                            <atom:MenuItem Header="{gallery:SplitButtonShowCaseLangResource P2HeaderDelete}" InputGesture="Ctrl+D"
                                           Icon="{antdicons:AntDesignIconProvider Kind=DeleteOutlined}" />
                        </atom:MenuFlyout>
                    </atom:SplitButton.Flyout>
                </atom:SplitButton>
            </WrapPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
