<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.FlexPanel.FlexPanelShowCase"
             xmlns:vm="using:AtomUIGallery.ShowCases.FlexPanel"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             x:DataType="vm:FlexPanelViewModel">

    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem Title="{gallery:FlexPanelShowCaseLangResource BasicLayoutTitle}" Description="{gallery:FlexPanelShowCaseLangResource BasicLayoutDescription}" IsOccupyEntireRow="True">
            <StackPanel Margin="20" Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="20">
                    <atom:RadioButton x:Name="DirectionHorizontal" IsChecked="True" Content="{gallery:FlexPanelShowCaseLangResource P2ContentHorizontal}" />
                    <atom:RadioButton x:Name="DirectionVertical" Content="{gallery:FlexPanelShowCaseLangResource P2ContentVertical}" />
                </StackPanel>

                <Border BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="6" Padding="12"
                        HorizontalAlignment="Stretch">
                    <atom:FlexPanel x:Name="BasicFlexPanel"
                                    Direction="Row"
                                    AlignItems="Stretch"
                                    HorizontalAlignment="Stretch">
                        <Border x:Name="BasicItem1" Background="#4F7CF5" Height="60" MinWidth="80" />
                        <Border x:Name="BasicItem2" Background="#1F5BFF" Height="60" MinWidth="80" />
                        <Border x:Name="BasicItem3" Background="#4F7CF5" Height="60" MinWidth="80" />
                        <Border x:Name="BasicItem4" Background="#1F5BFF" Height="60" MinWidth="80" />
                    </atom:FlexPanel>
                </Border>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:FlexPanelShowCaseLangResource AlignmentTitle}" Description="{gallery:FlexPanelShowCaseLangResource AlignmentDescription}" IsOccupyEntireRow="True">
            <StackPanel Margin="20" Spacing="12">
                <atom:TextBlock FontWeight="Bold" Text="{gallery:FlexPanelShowCaseLangResource P2TextSelectJustify}" />
                <atom:Segmented x:Name="JustifySegmented">
                    <atom:SegmentedItem IsSelected="True" Content="{gallery:FlexPanelShowCaseLangResource P2ContentFlexStart}" />
                    <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentCenter}" />
                    <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentFlexEnd}" />
                    <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentSpaceBetween}" />
                    <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentSpaceAround}" />
                    <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentSpaceEvenly}" />
                </atom:Segmented>

                <atom:TextBlock FontWeight="Bold" Text="{gallery:FlexPanelShowCaseLangResource P2TextSelectAlign}" />
                <atom:Segmented x:Name="AlignSegmented">
                    <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentFlexStart}" />
                    <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentCenter}" />
                    <atom:SegmentedItem IsSelected="True" Content="{gallery:FlexPanelShowCaseLangResource P2ContentFlexEnd}" />
                    <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentStretch}" />
                </atom:Segmented>

                <Border BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="6"  Height="120">
                    <atom:FlexPanel x:Name="AlignFlexPanel"
                                    Direction="Row"
                                    JustifyContent="FlexStart"
                                    AlignItems="FlexEnd">
                        <atom:Button ButtonType="Primary" Content="{gallery:FlexPanelShowCaseLangResource P2ContentPrimary}" />
                        <atom:Button ButtonType="Primary" Content="{gallery:FlexPanelShowCaseLangResource P2ContentPrimary}" />
                        <atom:Button ButtonType="Primary" Content="{gallery:FlexPanelShowCaseLangResource P2ContentPrimary}" />
                        <atom:Button ButtonType="Primary" Content="{gallery:FlexPanelShowCaseLangResource P2ContentPrimary}" />
                    </atom:FlexPanel>
                </Border>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:FlexPanelShowCaseLangResource GapTitle}" Description="{gallery:FlexPanelShowCaseLangResource GapDescription}" IsOccupyEntireRow="True">
            <StackPanel Margin="20" Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="20">
                    <atom:RadioButton x:Name="GapSmall" IsChecked="True" GroupName="GapMode" Content="{gallery:FlexPanelShowCaseLangResource P2ContentSmall}" />
                    <atom:RadioButton x:Name="GapMiddle" GroupName="GapMode" Content="{gallery:FlexPanelShowCaseLangResource P2ContentMiddle}" />
                    <atom:RadioButton x:Name="GapLarge" GroupName="GapMode" Content="{gallery:FlexPanelShowCaseLangResource P2ContentLarge}" />
                    <atom:RadioButton x:Name="GapCustomize" GroupName="GapMode" Content="{gallery:FlexPanelShowCaseLangResource P2ContentCustomize}" />
                </StackPanel>

                <StackPanel x:Name="GapCustomPanel" Orientation="Horizontal" Spacing="8" IsVisible="False">
                    <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextCustomGap}" />
                    <Slider x:Name="GapValueSlider"
                                 Width="200"
                                 Minimum="0"
                                 Maximum="100"
                                 TickFrequency="4"
                                 Value="12" />
                </StackPanel>

                <atom:FlexPanel x:Name="GapFlexPanel" Direction="Row" ColumnSpacing="8" RowSpacing="8">
                    <atom:Button ButtonType="Primary" Content="{gallery:FlexPanelShowCaseLangResource P2ContentPrimary}" />
                    <atom:Button ButtonType="Default" Content="{gallery:FlexPanelShowCaseLangResource P2ContentDefault}" />
                    <atom:Button ButtonType="Dashed" Content="{gallery:FlexPanelShowCaseLangResource P2ContentDashed}" />
                    <atom:Button ButtonType="Link" Content="{gallery:FlexPanelShowCaseLangResource P2ContentLink}" />
                </atom:FlexPanel>
            </StackPanel>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem Title="{gallery:FlexPanelShowCaseLangResource AlignSelfTitle}" Description="{gallery:FlexPanelShowCaseLangResource AlignSelfDescription}" IsOccupyEntireRow="True">
            <StackPanel Margin="20" Spacing="12">
                <atom:Segmented x:Name="AlignSelfSegmented">
                    <atom:SegmentedItem IsSelected="True" Content="{gallery:FlexPanelShowCaseLangResource P2ContentFlexStart}" />
                    <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentCenter}" />
                    <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentFlexEnd}" />
                    <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentStretch}" />
                </atom:Segmented>

                <Border BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="6" Padding="12" Height="140">
                    <atom:FlexPanel x:Name="AlignSelfFlexPanel" Direction="Row" ColumnSpacing="8" AlignItems="FlexStart">
                        <Border Background="#4F7CF5" Height="50" Width="80" CornerRadius="4" />
                        <Border x:Name="AlignSelfTarget" Background="#1F5BFF" Height="70" Width="80" CornerRadius="4">
                            <atom:TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextItemA}" />
                        </Border>
                        <Border Background="#4F7CF5" Height="60" Width="80" CornerRadius="4" />
                    </atom:FlexPanel>
                </Border>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:FlexPanelShowCaseLangResource AutoWrapTitle}" Description="{gallery:FlexPanelShowCaseLangResource AutoWrapDescription}" IsOccupyEntireRow="True">
            <StackPanel Margin="20" Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="20">
                    <atom:RadioButton x:Name="WrapEnabled" IsChecked="True" GroupName="WrapMode" Content="{gallery:FlexPanelShowCaseLangResource P2ContentWrap}" />
                    <atom:RadioButton x:Name="WrapDisabled" GroupName="WrapMode" Content="{gallery:FlexPanelShowCaseLangResource P2ContentNowrap}" />
                </StackPanel>
                <Border BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="6" Padding="12">
                    <atom:ScrollViewer x:Name="WrapScrollViewer"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Disabled">
                        <atom:FlexPanel x:Name="WrapFlexPanel"
                                        Direction="Row"
                                        Wrap="Wrap"
                                        ColumnSpacing="8"
                                        RowSpacing="8"
                                        JustifyContent="FlexStart">
                            <atom:Button ButtonType="Primary" Content="{gallery:FlexPanelShowCaseLangResource P2ContentButton}" />
                            <atom:Button ButtonType="Primary" Content="{gallery:FlexPanelShowCaseLangResource P2ContentButton}" />
                            <atom:Button ButtonType="Primary" Content="{gallery:FlexPanelShowCaseLangResource P2ContentButton}" />
                            <atom:Button ButtonType="Primary" Content="{gallery:FlexPanelShowCaseLangResource P2ContentButton}" />
                            <atom:Button ButtonType="Primary" Content="{gallery:FlexPanelShowCaseLangResource P2ContentButton}" />
                            <atom:Button ButtonType="Primary" Content="{gallery:FlexPanelShowCaseLangResource P2ContentButton}" />
                            <atom:Button ButtonType="Primary" Content="{gallery:FlexPanelShowCaseLangResource P2ContentButton}" />
                            <atom:Button ButtonType="Primary" Content="{gallery:FlexPanelShowCaseLangResource P2ContentButton}" />
                            <atom:Button ButtonType="Primary" Content="{gallery:FlexPanelShowCaseLangResource P2ContentButton}" />
                            <atom:Button ButtonType="Primary" Content="{gallery:FlexPanelShowCaseLangResource P2ContentButton}" />
                            <atom:Button ButtonType="Primary" Content="{gallery:FlexPanelShowCaseLangResource P2ContentButton}" />
                            <atom:Button ButtonType="Primary" Content="{gallery:FlexPanelShowCaseLangResource P2ContentButton}" />
                            <atom:Button ButtonType="Primary" Content="{gallery:FlexPanelShowCaseLangResource P2ContentButton}" />
                            <atom:Button ButtonType="Primary" Content="{gallery:FlexPanelShowCaseLangResource P2ContentButton}" />
                            <atom:Button ButtonType="Primary" Content="{gallery:FlexPanelShowCaseLangResource P2ContentButton}" />
                        </atom:FlexPanel>
                    </atom:ScrollViewer>
                </Border>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:FlexPanelShowCaseLangResource OrderTitle}" Description="{gallery:FlexPanelShowCaseLangResource OrderDescription}" IsOccupyEntireRow="True">
            <StackPanel Margin="20" Spacing="12">
                <atom:Segmented x:Name="OrderSegmented">
                    <atom:SegmentedItem IsSelected="True" Content="{gallery:FlexPanelShowCaseLangResource P2ContentDefault2}" />
                    <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentReverse}" />
                    <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentCustom}" />
                </atom:Segmented>

                <Border BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="6" Padding="12">
                    <atom:FlexPanel Direction="Row" ColumnSpacing="8">
                        <Border x:Name="OrderItemA" Background="#4F7CF5" Width="80" Height="50" CornerRadius="4">
                            <atom:TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextA}" />
                        </Border>
                        <Border x:Name="OrderItemB" Background="#1F5BFF" Width="80" Height="50" CornerRadius="4">
                            <atom:TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextB}" />
                        </Border>
                        <Border x:Name="OrderItemC" Background="#4F7CF5" Width="80" Height="50" CornerRadius="4">
                            <atom:TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextC}" />
                        </Border>
                        <Border x:Name="OrderItemD" Background="#1F5BFF" Width="80" Height="50" CornerRadius="4">
                            <atom:TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextD}" />
                        </Border>
                    </atom:FlexPanel>
                </Border>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:FlexPanelShowCaseLangResource BasisTitle}" Description="{gallery:FlexPanelShowCaseLangResource BasisDescription}" IsOccupyEntireRow="True">
            <StackPanel Margin="20" Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <atom:Segmented x:Name="BasisKindSegmented">
                        <atom:SegmentedItem IsSelected="True" Content="{gallery:FlexPanelShowCaseLangResource P2ContentAuto}" />
                        <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentAbsolute}" />
                        <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentRelative}" />
                    </atom:Segmented>

                    <StackPanel x:Name="BasisValuePanel" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextValue}" />
                        <atom:NumericUpDown x:Name="BasisValueInput"
                                            Width="120"
                                            Minimum="0"
                                            Maximum="600"
                                            Increment="1"
                                            FormatString="0"
                                            Value="120" />
                        <atom:TextBlock x:Name="BasisValueUnit" VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextPx}" />
                    </StackPanel>

                    <StackPanel x:Name="BasisPercentPanel" Orientation="Horizontal" Spacing="8"
                                VerticalAlignment="Center" IsVisible="False">
                        <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextPercent}" />
                        <Slider x:Name="BasisValueSlider"
                                     Width="160"
                                     Minimum="0"
                                     Maximum="100"
                                     TickFrequency="10"
                                     Value="100" />
                        <atom:TextBlock x:Name="BasisPercentText" VerticalAlignment="Center" Text="100%" />
                    </StackPanel>
                </StackPanel>

                <Border BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="6" Padding="12">
                    <atom:FlexPanel x:Name="BasisFlexPanel" Direction="Row" ColumnSpacing="8">
                        <Border x:Name="BasisItem"  Background="#4F7CF5" Height="50" MinWidth="60" CornerRadius="4">
                            <atom:TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextItemA}" />
                        </Border>
                        <Border x:Name="BasisGrowItem1" Background="#1F5BFF" Height="50" atom:Flex.Grow="1" CornerRadius="4">
                            <atom:TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextGrow}" />
                        </Border>
                        <Border x:Name="BasisGrowItem2" Background="#4F7CF5" Height="50" atom:Flex.Grow="1" CornerRadius="4">
                            <atom:TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextGrow}" />
                        </Border>
                    </atom:FlexPanel>
                </Border>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:FlexPanelShowCaseLangResource FlexGrowTitle}" Description="{gallery:FlexPanelShowCaseLangResource FlexGrowDescription}" IsOccupyEntireRow="True">
            <StackPanel Margin="20" Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextItemA2}" />
                    <atom:NumericUpDown x:Name="GrowInputA"
                                        Width="80"
                                        Minimum="0"
                                        Maximum="5"
                                        Increment="1"
                                        FormatString="0"
                                        Value="1" />
                    <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextItemB2}" />
                    <atom:NumericUpDown x:Name="GrowInputB"
                                        Width="80"
                                        Minimum="0"
                                        Maximum="5"
                                        Increment="1"
                                        FormatString="0"
                                        Value="2" />
                </StackPanel>

                <Border BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="6" Padding="12">
                    <atom:FlexPanel x:Name="GrowFlexPanel" Direction="Row" ColumnSpacing="8">
                        <Border x:Name="GrowItemA" Background="#4F7CF5" Height="50" MinWidth="60" CornerRadius="4" >
                            <atom:TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextItemA}" />
                        </Border>
                        <Border x:Name="GrowItemB" Background="#1F5BFF" Height="50" MinWidth="60" CornerRadius="4" >
                            <atom:TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextItemB}" />
                        </Border>
                        <Border x:Name="GrowItemC" Background="#4F7CF5" Height="50" MinWidth="60" CornerRadius="4" />
                    </atom:FlexPanel>
                </Border>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:FlexPanelShowCaseLangResource FlexShrinkTitle}" Description="{gallery:FlexPanelShowCaseLangResource FlexShrinkDescription}" IsOccupyEntireRow="True">
            <StackPanel Margin="20" Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextContainerWidth}" />
                    <Slider x:Name="ShrinkWidthSlider"
                                 Width="200"
                                 Minimum="180"
                                 Maximum="360"
                                 TickFrequency="10"
                                 Value="260" />
                    <atom:TextBlock x:Name="ShrinkWidthText" VerticalAlignment="Center" Text="260px" />
                </StackPanel>

                <Border BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="6" Padding="12">
                    <Border x:Name="ShrinkContainer"
                            Width="260"
                            HorizontalAlignment="Left"
                            BorderBrush="#DADADA"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8">
                        <atom:FlexPanel x:Name="ShrinkFlexPanel" Direction="Row" ColumnSpacing="8">
                            <Border Background="#4F7CF5"
                                    Height="50"
                                    CornerRadius="4"
                                    atom:Flex.Basis="200"
                                    atom:Flex.Shrink="1">
                                <atom:TextBlock HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="White"
                                                Text="{gallery:FlexPanelShowCaseLangResource P2TextBasisN200}" />
                            </Border>
                            <Border Background="#1F5BFF"
                                    Height="50"
                                    CornerRadius="4"
                                    atom:Flex.Basis="100"
                                    atom:Flex.Shrink="1">
                                <atom:TextBlock HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="White"
                                                Text="{gallery:FlexPanelShowCaseLangResource P2TextBasisN100}" />
                            </Border>
                        </atom:FlexPanel>
                    </Border>
                </Border>
            </StackPanel>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem Title="{gallery:FlexPanelShowCaseLangResource CombinationTitle}" Description="{gallery:FlexPanelShowCaseLangResource CombinationDescription}" IsOccupyEntireRow="True">
            <StackPanel Margin="20" Spacing="16">
                <Border BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="8" Padding="16">
                    <atom:FlexPanel Direction="Row" ColumnSpacing="16" AlignItems="Center">
                        <Border Width="260" Height="160" CornerRadius="6" ClipToBounds="True" atom:Flex.Shrink="0">
                            <Image Source="/Assets/CardShowCase/Cover1.png" Stretch="UniformToFill" />
                        </Border>
                        <atom:FlexPanel Direction="Column"
                                        Wrap="Wrap"
                                        RowSpacing="12"
                                        AlignItems="FlexStart"
                                        MinWidth="0"
                                        atom:Flex.Grow="1">
                            <atom:TextBlock FontSize="20"
                                            FontWeight="Bold"
                                            TextWrapping="Wrap"
                                            Text="{gallery:FlexPanelShowCaseLangResource P2TextAtomuiIsAnEnterpriseClassUiDesignLanguage}" />
                            <atom:Button ButtonType="Primary"
                                         Width="120"
                                         atom:Flex.AlignSelf="FlexEnd" Content="{gallery:FlexPanelShowCaseLangResource P2ContentGetStarted}" />
                        </atom:FlexPanel>
                    </atom:FlexPanel>
                </Border>
            </StackPanel>
        </gallery:ShowCaseItem>
        
                <gallery:ShowCaseItem Title="{gallery:FlexPanelShowCaseLangResource PlaygroundTitle}" Description="{gallery:FlexPanelShowCaseLangResource PlaygroundDescription}" IsOccupyEntireRow="True">
            <StackPanel Margin="20" Spacing="16">
                <StackPanel Spacing="12">
                    <atom:TextBlock FontWeight="Bold" Text="{gallery:FlexPanelShowCaseLangResource P2TextPanel}" />

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextDirection}" />
                        <atom:Segmented x:Name="PlaygroundDirectionSegmented">
                            <atom:SegmentedItem IsSelected="True" Content="{gallery:FlexPanelShowCaseLangResource P2ContentRow}" />
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentColumn}" />
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentRowReverse}" />
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentColumnReverse}" />
                        </atom:Segmented>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextWrap}" />
                        <atom:Segmented x:Name="PlaygroundWrapSegmented">
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentNowrap}" />
                            <atom:SegmentedItem IsSelected="True" Content="{gallery:FlexPanelShowCaseLangResource P2ContentWrap}" />
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentWrapReverse}" />
                        </atom:Segmented>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextJustify}" />
                        <atom:Segmented x:Name="PlaygroundJustifySegmented">
                            <atom:SegmentedItem IsSelected="True" Content="{gallery:FlexPanelShowCaseLangResource P2ContentFlexStart}" />
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentCenter}" />
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentFlexEnd}" />
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentSpaceBetween}" />
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentSpaceAround}" />
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentSpaceEvenly}" />
                        </atom:Segmented>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextAlignItems}" />
                        <atom:Segmented x:Name="PlaygroundAlignItemsSegmented">
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentFlexStart}" />
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentCenter}" />
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentFlexEnd}" />
                            <atom:SegmentedItem IsSelected="True" Content="{gallery:FlexPanelShowCaseLangResource P2ContentStretch}" />
                        </atom:Segmented>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextAlignContent}" />
                        <atom:Segmented x:Name="PlaygroundAlignContentSegmented">
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentFlexStart}" />
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentCenter}" />
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentFlexEnd}" />
                            <atom:SegmentedItem IsSelected="True" Content="{gallery:FlexPanelShowCaseLangResource P2ContentStretch}" />
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentSpaceBetween}" />
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentSpaceAround}" />
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentSpaceEvenly}" />
                        </atom:Segmented>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextColumnGap}" />
                        <Slider x:Name="PlaygroundColumnSpacingSlider"
                                     Width="140"
                                     Minimum="0"
                                     Maximum="60"
                                     TickFrequency="2"
                                     Value="8" />
                        <atom:TextBlock x:Name="PlaygroundColumnSpacingText" VerticalAlignment="Center" Text="8px" />
                        <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextRowGap}" />
                        <Slider x:Name="PlaygroundRowSpacingSlider"
                                     Width="140"
                                     Minimum="0"
                                     Maximum="60"
                                     TickFrequency="2"
                                     Value="8" />
                        <atom:TextBlock x:Name="PlaygroundRowSpacingText" VerticalAlignment="Center" Text="8px" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextWidth}" />
                        <Slider x:Name="PlaygroundWidthSlider"
                                     Width="200"
                                     Minimum="200"
                                     Maximum="1000"
                                     TickFrequency="20"
                                     Value="320" />
                        <atom:TextBlock x:Name="PlaygroundWidthText" VerticalAlignment="Center" Text="320px" />
                        <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextHeight}" />
                        <Slider x:Name="PlaygroundHeightSlider"
                                     Width="160"
                                     Minimum="120"
                                     Maximum="600"
                                     TickFrequency="20"
                                     Value="200" />
                        <atom:TextBlock x:Name="PlaygroundHeightText" VerticalAlignment="Center" Text="200px" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="12">
                    <atom:TextBlock FontWeight="Bold" Text="{gallery:FlexPanelShowCaseLangResource P2TextItem}" />

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextSelect}" />
                        <atom:Segmented x:Name="PlaygroundItemSegmented">
                            <atom:SegmentedItem IsSelected="True" Content="{gallery:FlexPanelShowCaseLangResource P2ContentA}" />
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentB}" />
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentC}" />
                        </atom:Segmented>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextAlignSelf}" />
                        <atom:Segmented x:Name="PlaygroundAlignSelfSegmented">
                            <atom:SegmentedItem IsSelected="True" Content="{gallery:FlexPanelShowCaseLangResource P2ContentAuto}" />
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentFlexStart}" />
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentCenter}" />
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentFlexEnd}" />
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentStretch}" />
                        </atom:Segmented>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextBasis}" />
                        <atom:Segmented x:Name="PlaygroundBasisKindSegmented">
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentAuto}" />
                            <atom:SegmentedItem IsSelected="True" Content="{gallery:FlexPanelShowCaseLangResource P2ContentAbsolute}" />
                            <atom:SegmentedItem Content="{gallery:FlexPanelShowCaseLangResource P2ContentRelative}" />
                        </atom:Segmented>

                        <StackPanel x:Name="PlaygroundBasisValuePanel" Orientation="Horizontal" Spacing="8">
                            <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextValue}" />
                            <atom:NumericUpDown x:Name="PlaygroundBasisValueInput"
                                                Width="100"
                                                Minimum="0"
                                                Maximum="600"
                                                Increment="1"
                                                FormatString="0"
                                                Value="160" />
                            <atom:TextBlock x:Name="PlaygroundBasisValueUnit" VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextPx}" />
                        </StackPanel>

                        <StackPanel x:Name="PlaygroundBasisPercentPanel" Orientation="Horizontal" Spacing="8"
                                    IsVisible="False">
                            <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextPercent}" />
                            <Slider x:Name="PlaygroundBasisValueSlider"
                                         Width="140"
                                         Minimum="0"
                                         Maximum="100"
                                         TickFrequency="10"
                                         Value="50" />
                            <atom:TextBlock x:Name="PlaygroundBasisPercentText" VerticalAlignment="Center" Text="50%" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextGrow2}" />
                        <atom:NumericUpDown x:Name="PlaygroundGrowInput"
                                            Width="70"
                                            Minimum="0"
                                            Maximum="5"
                                            Increment="1"
                                            FormatString="0"
                                            Value="1" />
                        <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextShrink}" />
                        <atom:NumericUpDown x:Name="PlaygroundShrinkInput"
                                            Width="70"
                                            Minimum="0"
                                            Maximum="5"
                                            Increment="1"
                                            FormatString="0"
                                            Value="1" />
                        <atom:TextBlock VerticalAlignment="Center" Text="{gallery:FlexPanelShowCaseLangResource P2TextOrder}" />
                        <atom:NumericUpDown x:Name="PlaygroundOrderInput"
                                            Width="70"
                                            Minimum="-5"
                                            Maximum="5"
                                            Increment="1"
                                            FormatString="0"
                                            Value="0" />
                    </StackPanel>
                </StackPanel>

                <Border BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="6" Padding="12">
                    <Border x:Name="PlaygroundContainer"
                            Width="320"
                            Height="200"
                            HorizontalAlignment="Left"
                            BorderBrush="#DADADA"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8">
                        <atom:FlexPanel x:Name="PlaygroundFlexPanel"
                                        Direction="Row"
                                        Wrap="Wrap"
                                        ColumnSpacing="8"
                                        RowSpacing="8"
                                        JustifyContent="FlexStart"
                                        AlignItems="Stretch"
                                        AlignContent="Stretch">
                            <Border x:Name="PlaygroundItemA"
                                    Background="#4F7CF5"
                                    MinHeight="50"
                                    MinWidth="60"
                                    CornerRadius="4"
                                    atom:Flex.Basis="160"
                                    atom:Flex.Grow="1"
                                    atom:Flex.Shrink="1">
                                <atom:TextBlock HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="White"
                                                Text="{gallery:FlexPanelShowCaseLangResource P2TextA}" />
                            </Border>
                            <Border x:Name="PlaygroundItemB"
                                    Background="#1F5BFF"
                                    MinHeight="50"
                                    MinWidth="60"
                                    CornerRadius="4"
                                    atom:Flex.Basis="100"
                                    atom:Flex.Grow="1"
                                    atom:Flex.Shrink="1">
                                <atom:TextBlock HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="White"
                                                Text="{gallery:FlexPanelShowCaseLangResource P2TextB}" />
                            </Border>
                            <Border x:Name="PlaygroundItemC"
                                    Background="#4F7CF5"
                                    MinHeight="50"
                                    MinWidth="60"
                                    CornerRadius="4"
                                    atom:Flex.Basis="80"
                                    atom:Flex.Grow="0"
                                    atom:Flex.Shrink="1">
                                <atom:TextBlock HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="White"
                                                Text="{gallery:FlexPanelShowCaseLangResource P2TextC}" />
                            </Border>
                        </atom:FlexPanel>
                    </Border>
                </Border>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
