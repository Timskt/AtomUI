<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.FlexPanel.FlexPanelShowCase"
             xmlns:vm="using:AtomUIGallery.ShowCases.FlexPanel"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             x:DataType="vm:FlexPanelViewModel">
    <atom:TabControl Name="ScenarioTabs"
                     SizeType="Large"
                     SelectedIndex="0">
        <atom:TabItem Header="{gallery:FlexPanelShowCaseLangResource ScenarioBasic}" Tag="Basic" />
        <atom:TabItem Header="{gallery:FlexPanelShowCaseLangResource ScenarioAlignment}" Tag="Alignment" />
        <atom:TabItem Header="{gallery:FlexPanelShowCaseLangResource ScenarioItem}" Tag="Item" />
        <atom:TabItem Header="{gallery:FlexPanelShowCaseLangResource ScenarioCombination}" Tag="Combination" />
        <atom:TabItem Header="{gallery:FlexPanelShowCaseLangResource ScenarioPlayground}" Tag="Playground" />
    </atom:TabControl>
</UserControl>
