<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Grid.GridShowCase"
             xmlns:vm="using:AtomUIGallery.ShowCases.Grid"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             x:DataType="vm:GridViewModel">
    <atom:TabControl Name="ScenarioTabs"
                     SizeType="Large"
                     SelectedIndex="0">
        <atom:TabItem Header="{gallery:GridShowCaseLangResource ScenarioBasic}" Tag="Basic" />
        <atom:TabItem Header="{gallery:GridShowCaseLangResource ScenarioSpacing}" Tag="Spacing" />
        <atom:TabItem Header="{gallery:GridShowCaseLangResource ScenarioAlignment}" Tag="Alignment" />
        <atom:TabItem Header="{gallery:GridShowCaseLangResource ScenarioOrder}" Tag="Order" />
        <atom:TabItem Header="{gallery:GridShowCaseLangResource ScenarioColInfo}" Tag="ColInfo" />
    </atom:TabControl>
</UserControl>
