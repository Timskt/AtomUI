<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Grid.GridShowCase"
             xmlns:vm="using:AtomUIGallery.ShowCases.Grid"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             x:DataType="vm:GridViewModel">
    <UserControl.Styles>
        <Style Selector="Border.grid-cell">
            <Setter Property="Height" Value="48" />
            <Setter Property="Background" Value="#1677FF" />
        </Style>
        <Style Selector="Border.grid-cell.alt">
            <Setter Property="Background" Value="#4096FF" />
        </Style>
        <Style Selector="Border.grid-row-surface">
            <Setter Property="Background" Value="#F5F5F5" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style Selector="TextBlock.grid-cell-text">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBlock.grid-section-title">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,8,0,4" />
        </Style>
    </UserControl.Styles>

    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem Title="{gallery:GridShowCaseLangResource BasicGridTitle}" Description="{gallery:GridShowCaseLangResource BasicGridDescription}" IsOccupyEntireRow="True">
            <StackPanel Margin="20" Spacing="12">
                <atom:Row Gutter="16,16">
                    <atom:Col Span="24">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextCol}" />
                        </Border>
                    </atom:Col>
                </atom:Row>
                <atom:Row Gutter="16,16">
                    <atom:Col Span="12">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN12}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="12">
                        <Border Classes="grid-cell alt">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN12}" />
                        </Border>
                    </atom:Col>
                </atom:Row>
                <atom:Row Gutter="16,16">
                    <atom:Col Span="8">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN8}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="8">
                        <Border Classes="grid-cell alt">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN8}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="8">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN8}" />
                        </Border>
                    </atom:Col>
                </atom:Row>
                <atom:Row Gutter="16,16">
                    <atom:Col Span="6">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="6">
                        <Border Classes="grid-cell alt">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="6">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="6">
                        <Border Classes="grid-cell alt">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6}" />
                        </Border>
                    </atom:Col>
                </atom:Row>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:GridShowCaseLangResource GutterTitle}" Description="{gallery:GridShowCaseLangResource GutterDescription}" IsOccupyEntireRow="True">
            <StackPanel Margin="20" Spacing="12">
                <TextBlock Classes="grid-section-title" Text="{gallery:GridShowCaseLangResource P2TextHorizontal}" />
                <atom:Row Gutter="16,16">
                    <atom:Col Span="6">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="6">
                        <Border Classes="grid-cell alt">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="6">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="6">
                        <Border Classes="grid-cell alt">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6}" />
                        </Border>
                    </atom:Col>
                </atom:Row>

                <TextBlock Classes="grid-section-title" Text="{gallery:GridShowCaseLangResource P2TextResponsive}" />
                <atom:Row Gutter="16,16">
                    <atom:Col Xs="24" Sm="12" Md="16" Lg="6" Xl="6">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Xs="24" Sm="12" Md="16" Lg="6" Xl="6">
                        <Border Classes="grid-cell alt">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Xs="24" Sm="12" Md="16" Lg="6" Xl="6">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Xs="24" Sm="12" Md="16" Lg="6" Xl="6">
                        <Border Classes="grid-cell alt">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6}" />
                        </Border>
                    </atom:Col>
                </atom:Row>

                <TextBlock Classes="grid-section-title" Text="{gallery:GridShowCaseLangResource P2TextVertical}" />
                <atom:Row Gutter="16,24" IsWrapped="True">
                    <atom:Col Span="6">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="6">
                        <Border Classes="grid-cell alt">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="6">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="6">
                        <Border Classes="grid-cell alt">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="6">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="6">
                        <Border Classes="grid-cell alt">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="6">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="6">
                        <Border Classes="grid-cell alt">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6}" />
                        </Border>
                    </atom:Col>
                </atom:Row>

                <TextBlock Classes="grid-section-title" Text="{gallery:GridShowCaseLangResource P2TextGutterString}" />
                <atom:Row Gutter="16">
                    <atom:Col Span="6">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="6">
                        <Border Classes="grid-cell alt">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="6">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="6">
                        <Border Classes="grid-cell alt">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6}" />
                        </Border>
                    </atom:Col>
                </atom:Row>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:GridShowCaseLangResource OffsetTitle}" Description="{gallery:GridShowCaseLangResource OffsetDescription}" IsOccupyEntireRow="True">
            <StackPanel Margin="20" Spacing="12">
                <atom:Row Gutter="16,16">
                    <atom:Col Span="8">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN8}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="8" Offset="8">
                        <Border Classes="grid-cell alt">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN8ColOffsetN8}" />
                        </Border>
                    </atom:Col>
                </atom:Row>
                <atom:Row Gutter="16,16">
                    <atom:Col Span="6" Offset="6">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6ColOffsetN6}" />
                        </Border>
                    </atom:Col>
                </atom:Row>
                <atom:Row Gutter="16,16">
                    <atom:Col Span="12" Offset="6">
                        <Border Classes="grid-cell alt">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN12ColOffsetN6}" />
                        </Border>
                    </atom:Col>
                </atom:Row>
                <atom:Row Gutter="16,16">
                    <atom:Col Span="6" Offset="18">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6ColOffsetN18}" />
                        </Border>
                    </atom:Col>
                </atom:Row>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:GridShowCaseLangResource PushPullTitle}" Description="{gallery:GridShowCaseLangResource PushPullDescription}" IsOccupyEntireRow="True">
            <StackPanel Margin="20" Spacing="12">
                <atom:Row Gutter="16,16">
                    <atom:Col Span="18" Push="6">
                        <Border Classes="grid-cell alt">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN18ColPushN6}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="6" Pull="18">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN6ColPullN18}" />
                        </Border>
                    </atom:Col>
                </atom:Row>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:GridShowCaseLangResource JustifyTitle}" Description="{gallery:GridShowCaseLangResource JustifyDescription}" IsOccupyEntireRow="True">
            <StackPanel Margin="20" Spacing="12">
                <TextBlock Classes="grid-section-title" Text="{gallery:GridShowCaseLangResource P2TextSubElementAlignLeft}" />
                <Border Classes="grid-row-surface">
                    <atom:Row Gutter="16,16" Justify="start">
                        <atom:Col Span="4">
                            <Border Classes="grid-cell">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell alt">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell alt">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                    </atom:Row>
                </Border>

                <TextBlock Classes="grid-section-title" Text="{gallery:GridShowCaseLangResource P2TextSubElementAlignCenter}" />
                <Border Classes="grid-row-surface">
                    <atom:Row Gutter="16,16" Justify="center">
                        <atom:Col Span="4">
                            <Border Classes="grid-cell">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell alt">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell alt">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                    </atom:Row>
                </Border>

                <TextBlock Classes="grid-section-title" Text="{gallery:GridShowCaseLangResource P2TextSubElementAlignEnd}" />
                <Border Classes="grid-row-surface">
                    <atom:Row Gutter="16,16" Justify="end">
                        <atom:Col Span="4">
                            <Border Classes="grid-cell">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell alt">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell alt">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                    </atom:Row>
                </Border>

                <TextBlock Classes="grid-section-title" Text="{gallery:GridShowCaseLangResource P2TextSubElementAlignBetween}" />
                <Border Classes="grid-row-surface">
                    <atom:Row Gutter="16,16" Justify="SpaceBetween">
                        <atom:Col Span="4">
                            <Border Classes="grid-cell">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell alt">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell alt">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                    </atom:Row>
                </Border>

                <TextBlock Classes="grid-section-title" Text="{gallery:GridShowCaseLangResource P2TextSubElementAlignAround}" />
                <Border Classes="grid-row-surface">
                    <atom:Row Gutter="16,16" Justify="SpaceAround">
                        <atom:Col Span="4">
                            <Border Classes="grid-cell">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell alt">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell alt">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                    </atom:Row>
                </Border>

                <TextBlock Classes="grid-section-title" Text="{gallery:GridShowCaseLangResource P2TextSubElementAlignEvenly}" />
                <Border Classes="grid-row-surface">
                    <atom:Row Gutter="16,16" Justify="SpaceEvenly">
                        <atom:Col Span="4">
                            <Border Classes="grid-cell">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell alt">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell alt">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                    </atom:Row>
                </Border>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:GridShowCaseLangResource AlignTitle}" Description="{gallery:GridShowCaseLangResource AlignDescription}" IsOccupyEntireRow="True">
            <StackPanel Margin="20" Spacing="12">
                <TextBlock Classes="grid-section-title" Text="{gallery:GridShowCaseLangResource P2TextAlignTop}" />
                <Border Classes="grid-row-surface">
                    <atom:Row Gutter="16,16" Justify="center" Align="top">
                        <atom:Col Span="4">
                            <Border Classes="grid-cell" Height="72">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell alt" Height="48">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell" Height="64">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell alt" Height="56">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                    </atom:Row>
                </Border>

                <TextBlock Classes="grid-section-title" Text="{gallery:GridShowCaseLangResource P2TextAlignMiddle}" />
                <Border Classes="grid-row-surface">
                    <atom:Row Gutter="16,16" Justify="center" Align="middle">
                        <atom:Col Span="4">
                            <Border Classes="grid-cell" Height="72">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell alt" Height="48">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell" Height="64">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell alt" Height="56">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                    </atom:Row>
                </Border>

                <TextBlock Classes="grid-section-title" Text="{gallery:GridShowCaseLangResource P2TextAlignBottom}" />
                <Border Classes="grid-row-surface">
                    <atom:Row Gutter="16,16" Justify="center" Align="bottom">
                        <atom:Col Span="4">
                            <Border Classes="grid-cell" Height="72">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell alt" Height="48">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell" Height="64">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                        <atom:Col Span="4">
                            <Border Classes="grid-cell alt" Height="56">
                                <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4}" />
                            </Border>
                        </atom:Col>
                    </atom:Row>
                </Border>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:GridShowCaseLangResource OrderTitle}" Description="{gallery:GridShowCaseLangResource OrderDescription}" IsOccupyEntireRow="True">
            <StackPanel Margin="20" Spacing="12">
                <TextBlock Classes="grid-section-title" Text="{gallery:GridShowCaseLangResource P2TextNormal}" />
                <atom:Row Gutter="16,16">
                    <atom:Col Span="6" Order="1">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextN4ColOrderN1}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="6" Order="2">
                        <Border Classes="grid-cell alt">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextN3ColOrderN2}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="6" Order="3">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextN2ColOrderN3}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="6" Order="4">
                        <Border Classes="grid-cell alt">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextN1ColOrderN4}" />
                        </Border>
                    </atom:Col>
                </atom:Row>

                <TextBlock Classes="grid-section-title" Text="{gallery:GridShowCaseLangResource P2TextResponsive}" />
                <atom:Row Gutter="16,16">
                    <atom:Col Span="6" Order="1" Sm="{atom:ColInfo Order=2}">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextN3ColOrderResponsive}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="6" Order="2" Sm="{atom:ColInfo Order=1}">
                        <Border Classes="grid-cell alt">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextN4ColOrderResponsive}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="6" Order="3" Sm="{atom:ColInfo Order=4}">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextN2ColOrderResponsive}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="6" Order="4" Sm="{atom:ColInfo Order=3}">
                        <Border Classes="grid-cell alt">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextN1ColOrderResponsive}" />
                        </Border>
                    </atom:Col>
                </atom:Row>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:GridShowCaseLangResource ColInfoTitle}" Description="{gallery:GridShowCaseLangResource ColInfoDescription}" IsOccupyEntireRow="True">
            <StackPanel Margin="20" Spacing="12">
                <StackPanel.Resources>
                    <atom:ColInfo x:Key="MdCol1" Span="12" Order="2" />
                    <atom:ColInfo x:Key="MdCol2" Span="12" Order="1" />
                    <atom:ColInfo x:Key="MdCol3" Span="12" Order="4" />
                    <atom:ColInfo x:Key="MdCol4" Span="12" Order="3" />
                    <atom:ColInfo x:Key="LgCol1" Span="6" Order="1" />
                    <atom:ColInfo x:Key="LgCol2" Span="6" Order="2" />
                    <atom:ColInfo x:Key="LgCol3" Span="6" Order="3" />
                    <atom:ColInfo x:Key="LgCol4" Span="6" Order="4" />
                </StackPanel.Resources>
                <TextBlock Classes="grid-section-title" Text="{gallery:GridShowCaseLangResource P2TextBaseMdLgOverrides}" />
                <atom:Row Gutter="16,16">
                    <atom:Col Span="24">
                        <atom:Col.Md>
                            <atom:ColInfo Span="12" Order="2" />
                        </atom:Col.Md>
                        <atom:Col.Lg>
                            <atom:ColInfo Span="6" Order="1" />
                        </atom:Col.Lg>
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN1WithColinfo}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="24">
                        <atom:Col.Md>
                            <atom:ColInfo Span="12" Order="1" />
                        </atom:Col.Md>
                        <atom:Col.Lg>
                            <atom:ColInfo Span="6" Order="2" />
                        </atom:Col.Lg>
                        <Border Classes="grid-cell alt">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN2WithColinfo}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="24">
                        <atom:Col.Md>
                            <atom:ColInfo Span="12" Order="3" />
                        </atom:Col.Md>
                        <atom:Col.Lg>
                            <atom:ColInfo Span="6" Order="3" />
                        </atom:Col.Lg>
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN3WithColinfo}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="24">
                        <atom:Col.Md>
                            <atom:ColInfo Span="12" Order="4" />
                        </atom:Col.Md>
                        <atom:Col.Lg>
                            <atom:ColInfo Span="6" Order="4" />
                        </atom:Col.Lg>
                        <Border Classes="grid-cell alt">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextColN4WithColinfo}" />
                        </Border>
                    </atom:Col>
                </atom:Row>
                <TextBlock Classes="grid-section-title" Text="{gallery:GridShowCaseLangResource P2TextSharedResources}" />
                <atom:Row Gutter="16,16">
                    <atom:Col Span="24" Md="{StaticResource MdCol1}" Lg="{StaticResource LgCol1}">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextResColN1}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="24" Md="{StaticResource MdCol2}" Lg="{StaticResource LgCol2}">
                        <Border Classes="grid-cell alt">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextResColN2}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="24" Md="{StaticResource MdCol3}" Lg="{StaticResource LgCol3}">
                        <Border Classes="grid-cell">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextResColN3}" />
                        </Border>
                    </atom:Col>
                    <atom:Col Span="24" Md="{StaticResource MdCol4}" Lg="{StaticResource LgCol4}">
                        <Border Classes="grid-cell alt">
                            <TextBlock Classes="grid-cell-text" Text="{gallery:GridShowCaseLangResource P2TextResColN4}" />
                        </Border>
                    </atom:Col>
                </atom:Row>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
