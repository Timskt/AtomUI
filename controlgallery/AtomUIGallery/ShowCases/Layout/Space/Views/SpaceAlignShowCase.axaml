<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Space.SpaceAlignShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:viewModels="clr-namespace:AtomUIGallery.ShowCases.Space"
             x:DataType="viewModels:SpaceViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCasePanel.Styles>
            <Style Selector="Border.align-box">
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="#1677FF" />
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="Padding" Value="{atom:SharedTokenResource PaddingXXS}" />
            </Style>
            <Style Selector="Border.align-block-item">
                <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgLayout}" />
                <Setter Property="Padding" Value="{atom:SharedTokenResource PaddingXXS}" />
                <Setter Property="Height" Value="70" />
                <Setter Property="Width" Value="50" />
            </Style>
        </gallery:ShowCasePanel.Styles>
        
        <gallery:ShowCaseItem Title="{gallery:SpaceShowCaseLangResource AlignTitle}"
                              Description="{gallery:SpaceShowCaseLangResource AlignDescription}"
                              IsOccupyEntireRow="True">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Border Classes="align-box">
                    <atom:Space ItemsAlignment="Start" Orientation="Horizontal">
                        <atom:TextBlock Text="{gallery:SpaceShowCaseLangResource P2TextCenter}" />
                        <atom:Button ButtonType="Primary" Content="{gallery:SpaceShowCaseLangResource P2ContentPrimary}" />
                        <Border Classes="align-block-item">
                            <atom:TextBlock VerticalAlignment="Center" Text="{gallery:SpaceShowCaseLangResource P2TextBlock}" />
                        </Border>
                    </atom:Space>
                </Border>
        
                <Border Classes="align-box">
                    <atom:Space ItemsAlignment="Center" Orientation="Horizontal">
                        <atom:TextBlock Text="{gallery:SpaceShowCaseLangResource P2TextCenter}" />
                        <atom:Button ButtonType="Primary" Content="{gallery:SpaceShowCaseLangResource P2ContentPrimary}" />
                        <Border Classes="align-block-item">
                            <atom:TextBlock VerticalAlignment="Center" Text="{gallery:SpaceShowCaseLangResource P2TextBlock}" />
                        </Border>
                    </atom:Space>
                </Border>
        
                <Border Classes="align-box">
                    <atom:Space ItemsAlignment="End" Orientation="Horizontal">
                        <atom:TextBlock Text="{gallery:SpaceShowCaseLangResource P2TextCenter}" />
                        <atom:Button ButtonType="Primary" Content="{gallery:SpaceShowCaseLangResource P2ContentPrimary}" />
                        <Border Classes="align-block-item">
                            <atom:TextBlock VerticalAlignment="Center" Text="{gallery:SpaceShowCaseLangResource P2TextBlock}" />
                        </Border>
                    </atom:Space>
                </Border>
            </StackPanel>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem Title="{gallery:SpaceShowCaseLangResource WrapTitle}"
                              Description="{gallery:SpaceShowCaseLangResource WrapDescription}"
                              IsOccupyEntireRow="True">
            <atom:Space Orientation="Horizontal" ItemSpacing="8" LineSpacing="16">
                <atom:Button Content="{gallery:SpaceShowCaseLangResource P2ContentButton}" />
                <atom:Button Content="{gallery:SpaceShowCaseLangResource P2ContentButton}" />
                <atom:Button Content="{gallery:SpaceShowCaseLangResource P2ContentButton}" />
                <atom:Button Content="{gallery:SpaceShowCaseLangResource P2ContentButton}" />
                <atom:Button Content="{gallery:SpaceShowCaseLangResource P2ContentButton}" />
                <atom:Button Content="{gallery:SpaceShowCaseLangResource P2ContentButton}" />
                <atom:Button Content="{gallery:SpaceShowCaseLangResource P2ContentButton}" />
                <atom:Button Content="{gallery:SpaceShowCaseLangResource P2ContentButton}" />
                <atom:Button Content="{gallery:SpaceShowCaseLangResource P2ContentButton}" />
                <atom:Button Content="{gallery:SpaceShowCaseLangResource P2ContentButton}" />
                <atom:Button Content="{gallery:SpaceShowCaseLangResource P2ContentButton}" />
                <atom:Button Content="{gallery:SpaceShowCaseLangResource P2ContentButton}" />
                <atom:Button Content="{gallery:SpaceShowCaseLangResource P2ContentButton}" />
                <atom:Button Content="{gallery:SpaceShowCaseLangResource P2ContentButton}" />
                <atom:Button Content="{gallery:SpaceShowCaseLangResource P2ContentButton}" />
            </atom:Space>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem Title="{gallery:SpaceShowCaseLangResource SplitTitle}"
                              Description="{gallery:SpaceShowCaseLangResource SplitDescription}"
                              IsOccupyEntireRow="True">
            <atom:Space Orientation="Horizontal" ItemsAlignment="Center">
                <atom:Space.SplitTemplate>
                    <Template>
                        <atom:Separator Orientation="Vertical"/>
                    </Template>
                </atom:Space.SplitTemplate>
                <atom:HyperLinkTextBlock Text="{gallery:SpaceShowCaseLangResource P2ContentLink}" />
                <atom:HyperLinkTextBlock Text="{gallery:SpaceShowCaseLangResource P2ContentLink}" />
                <atom:HyperLinkTextBlock Text="{gallery:SpaceShowCaseLangResource P2ContentLink}" />
            </atom:Space>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
