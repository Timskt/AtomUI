<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Space.SpaceBasicShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:viewModels="clr-namespace:AtomUIGallery.ShowCases.Space"
             x:DataType="viewModels:SpaceViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem Description="{gallery:SpaceShowCaseLangResource BasicDescription}"
                              Title="{gallery:SpaceShowCaseLangResource BasicTitle}" IsOccupyEntireRow="True">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <atom:TextBlock VerticalAlignment="Center" Text="{gallery:SpaceShowCaseLangResource P2TextSpace}" />
                <atom:Space>
                    <atom:Button ButtonType="Primary" Content="{gallery:SpaceShowCaseLangResource P2ContentButton}" />
                    <atom:Button Icon="{antdicons:AntDesignIconProvider UploadOutlined}" Content="{gallery:SpaceShowCaseLangResource P2ContentClickToUpload}" />
                    <atom:PopupConfirm
                        Title="{gallery:SpaceShowCaseLangResource P2TitleDeleteTheTask}"
                        ConfirmContent="{gallery:SpaceShowCaseLangResource P2ConfirmContentAreYouSureToDeleteThisTask}"
                        OkText="{gallery:SpaceShowCaseLangResource P2OkTextOk}"
                        CancelText="{gallery:SpaceShowCaseLangResource P2CancelTextCancel}"
                        Placement="Top"
                        IsArrowVisible="True">
                        <atom:Button ButtonType="Default" IsDanger="True" Content="{gallery:SpaceShowCaseLangResource P2ContentConfirm}" />
                    </atom:PopupConfirm>
                </atom:Space>
            </StackPanel>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem Description="{gallery:SpaceShowCaseLangResource VerticalSpaceDescription}"
                              Title="{gallery:SpaceShowCaseLangResource VerticalSpaceTitle}" IsOccupyEntireRow="True">
            <atom:Space Orientation="Vertical" HorizontalAlignment="Stretch" Height="300">
                <atom:Card Header="{gallery:SpaceShowCaseLangResource P2HeaderCard}" SizeType="Middle" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Vertical" Spacing="10">
                        <atom:TextBlock Text="{gallery:SpaceShowCaseLangResource P2TextCardContent}" />
                        <atom:TextBlock Text="{gallery:SpaceShowCaseLangResource P2TextCardContent}" />
                    </StackPanel>
                </atom:Card>
        
                <atom:Card Header="{gallery:SpaceShowCaseLangResource P2HeaderCard}" SizeType="Middle" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Vertical" Spacing="10">
                        <atom:TextBlock Text="{gallery:SpaceShowCaseLangResource P2TextCardContent}" />
                        <atom:TextBlock Text="{gallery:SpaceShowCaseLangResource P2TextCardContent}" />
                    </StackPanel>
                </atom:Card>
        
                <atom:Card Header="{gallery:SpaceShowCaseLangResource P2HeaderCard}" SizeType="Middle" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Vertical" Spacing="10">
                        <atom:TextBlock Text="{gallery:SpaceShowCaseLangResource P2TextCardContent}" />
                        <atom:TextBlock Text="{gallery:SpaceShowCaseLangResource P2TextCardContent}" />
                    </StackPanel>
                </atom:Card>
            </atom:Space>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
