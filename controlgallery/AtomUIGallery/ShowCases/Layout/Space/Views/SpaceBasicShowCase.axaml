<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Space.SpaceBasicShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:viewModels="clr-namespace:AtomUIGallery.ShowCases.Space"
             x:DataType="viewModels:SpaceViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem Description="{gallery:SpaceShowCaseLangResource BasicDescription}"
                              Title="{gallery:SpaceShowCaseLangResource BasicTitle}" IsOccupyEntireRow="True">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <atom:TextBlock VerticalAlignment="Center">Space:</atom:TextBlock>
                <atom:Space>
                    <atom:Button ButtonType="Primary">Button</atom:Button>
                    <atom:Button Icon="{antdicons:AntDesignIconProvider UploadOutlined}">Click to Upload</atom:Button>
                    <atom:PopupConfirm
                        Title="Delete the task"
                        ConfirmContent="Are you sure to delete this task?"
                        OkText="Ok"
                        CancelText="Cancel"
                        Placement="Top"
                        IsArrowVisible="True">
                        <atom:Button ButtonType="Default" IsDanger="True">Confirm</atom:Button>
                    </atom:PopupConfirm>
                </atom:Space>
            </StackPanel>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem Description="{gallery:SpaceShowCaseLangResource VerticalSpaceDescription}"
                              Title="{gallery:SpaceShowCaseLangResource VerticalSpaceTitle}" IsOccupyEntireRow="True">
            <atom:Space Orientation="Vertical" HorizontalAlignment="Stretch" Height="300">
                <atom:Card Header="Card" SizeType="Middle" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Vertical" Spacing="10">
                        <atom:TextBlock>Card content</atom:TextBlock>
                        <atom:TextBlock>Card content</atom:TextBlock>
                    </StackPanel>
                </atom:Card>
        
                <atom:Card Header="Card" SizeType="Middle" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Vertical" Spacing="10">
                        <atom:TextBlock>Card content</atom:TextBlock>
                        <atom:TextBlock>Card content</atom:TextBlock>
                    </StackPanel>
                </atom:Card>
        
                <atom:Card Header="Card" SizeType="Middle" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Vertical" Spacing="10">
                        <atom:TextBlock>Card content</atom:TextBlock>
                        <atom:TextBlock>Card content</atom:TextBlock>
                    </StackPanel>
                </atom:Card>
            </atom:Space>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
