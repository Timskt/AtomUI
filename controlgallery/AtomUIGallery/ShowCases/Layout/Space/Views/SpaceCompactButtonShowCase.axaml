<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Space.SpaceCompactButtonShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:viewModels="clr-namespace:AtomUIGallery.ShowCases.Space"
             x:DataType="viewModels:SpaceViewModel">
    <gallery:ShowCasePanel>

        <gallery:ShowCaseItem Title="{gallery:SpaceShowCaseLangResource CompactButtonTitle}"
                              Description="{gallery:SpaceShowCaseLangResource CompactButtonDescription}"
                              IsOccupyEntireRow="True">
            <StackPanel Spacing="10">
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:Button Icon="{antdicons:AntDesignIconProvider LikeOutlined}" atom:ToolTip.Tip="{gallery:SpaceShowCaseLangResource P2ToolTipTipLike}"/>
                    <atom:Button Icon="{antdicons:AntDesignIconProvider CommentOutlined}" atom:ToolTip.Tip="{gallery:SpaceShowCaseLangResource P2ToolTipTipComment}"/>
                    <atom:Button Icon="{antdicons:AntDesignIconProvider StarOutlined}" atom:ToolTip.Tip="{gallery:SpaceShowCaseLangResource P2ToolTipTipStar}"/>
                    <atom:Button Icon="{antdicons:AntDesignIconProvider HeartOutlined}" atom:ToolTip.Tip="{gallery:SpaceShowCaseLangResource P2ToolTipTipHeart}"/>
                    <atom:Button Icon="{antdicons:AntDesignIconProvider ShareAltOutlined}" atom:ToolTip.Tip="{gallery:SpaceShowCaseLangResource P2ToolTipTipShare}"/>
                    <atom:Button Icon="{antdicons:AntDesignIconProvider DownloadOutlined}" atom:ToolTip.Tip="{gallery:SpaceShowCaseLangResource P2ToolTipTipDownload}"/>
                    <atom:DropdownButton TriggerType="Click"
                                         Placement="BottomEdgeAlignedRight"
                                         IsShowOpenIndicator="False"
                                         Icon="{antdicons:AntDesignIconProvider EllipsisOutlined}">
                        <atom:DropdownButton.DropdownFlyout>
                            <atom:MenuFlyout>
                                <atom:MenuItem Header="{gallery:SpaceShowCaseLangResource P2HeaderReport}"
                                               Icon="{antdicons:AntDesignIconProvider Kind=WarningOutlined}" />
                                <atom:MenuItem Header="{gallery:SpaceShowCaseLangResource P2HeaderMail}"
                                               Icon="{antdicons:AntDesignIconProvider Kind=MailOutlined}" />
                                <atom:MenuItem Header="{gallery:SpaceShowCaseLangResource P2HeaderMobile}"
                                               Icon="{antdicons:AntDesignIconProvider Kind=MobileOutlined}" />
                            </atom:MenuFlyout>
                        </atom:DropdownButton.DropdownFlyout>
                    </atom:DropdownButton>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:Button ButtonType="Primary" Content="{gallery:SpaceShowCaseLangResource P2ContentButtonN1}" />
                    <atom:Button ButtonType="Primary" Content="{gallery:SpaceShowCaseLangResource P2ContentButtonN2}" />
                    <atom:Button ButtonType="Primary" Content="{gallery:SpaceShowCaseLangResource P2ContentButtonN3}" />
                    <atom:Button ButtonType="Primary" Content="{gallery:SpaceShowCaseLangResource P2ContentButtonN4}" />
                    <atom:Button Icon="{antdicons:AntDesignIconProvider DownloadOutlined}" IsEnabled="False" atom:ToolTip.Tip="{gallery:SpaceShowCaseLangResource P2ToolTipTipTooltip}"/>
                    <atom:Button Icon="{antdicons:AntDesignIconProvider DownloadOutlined}" atom:ToolTip.Tip="{gallery:SpaceShowCaseLangResource P2ToolTipTipTooltip}"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:Button ButtonType="Default" Content="{gallery:SpaceShowCaseLangResource P2ContentButtonN1}" />
                    <atom:Button ButtonType="Default" Content="{gallery:SpaceShowCaseLangResource P2ContentButtonN2}" />
                    <atom:Button ButtonType="Default" Content="{gallery:SpaceShowCaseLangResource P2ContentButtonN3}" />
                    <atom:Button Icon="{antdicons:AntDesignIconProvider DownloadOutlined}" IsEnabled="False" atom:ToolTip.Tip="{gallery:SpaceShowCaseLangResource P2ToolTipTipTooltip}"/>
                    <atom:Button Icon="{antdicons:AntDesignIconProvider DownloadOutlined}" atom:ToolTip.Tip="{gallery:SpaceShowCaseLangResource P2ToolTipTipTooltip}"/>
                    <atom:Button ButtonType="Primary" Content="{gallery:SpaceShowCaseLangResource P2ContentButtonN4}" />
                    <atom:DropdownButton TriggerType="Click"
                                         Placement="BottomEdgeAlignedRight"
                                         IsShowOpenIndicator="False"
                                         ButtonType="Primary"
                                         Icon="{antdicons:AntDesignIconProvider EllipsisOutlined}">
                        <atom:DropdownButton.DropdownFlyout>
                            <atom:MenuFlyout>
                                <atom:MenuItem Header="{gallery:SpaceShowCaseLangResource P2HeaderN1stItem}"/>
                                <atom:MenuItem Header="{gallery:SpaceShowCaseLangResource P2HeaderN2ndItem}"/>
                                <atom:MenuItem Header="{gallery:SpaceShowCaseLangResource P2HeaderN3rdItem}"/>
                            </atom:MenuFlyout>
                        </atom:DropdownButton.DropdownFlyout>
                    </atom:DropdownButton>
                </atom:CompactSpace>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:SpaceShowCaseLangResource VerticalCompactTitle}"
                              Description="{gallery:SpaceShowCaseLangResource VerticalCompactDescription}"
                              IsOccupyEntireRow="True">
            <StackPanel Spacing="10" Orientation="Horizontal">
                <atom:CompactSpace Orientation="Vertical">
                    <atom:Button ButtonType="Default" Content="{gallery:SpaceShowCaseLangResource P2ContentButtonN1}" />
                    <atom:Button ButtonType="Default" Content="{gallery:SpaceShowCaseLangResource P2ContentButtonN2}" />
                    <atom:Button ButtonType="Default" Content="{gallery:SpaceShowCaseLangResource P2ContentButtonN3}" />
                </atom:CompactSpace>
                
                <atom:CompactSpace Orientation="Vertical">
                    <atom:Button ButtonType="Dashed" Content="{gallery:SpaceShowCaseLangResource P2ContentButtonN1}" />
                    <atom:Button ButtonType="Dashed" Content="{gallery:SpaceShowCaseLangResource P2ContentButtonN2}" />
                    <atom:Button ButtonType="Dashed" Content="{gallery:SpaceShowCaseLangResource P2ContentButtonN3}" />
                </atom:CompactSpace>
                
                <atom:CompactSpace Orientation="Vertical">
                    <atom:Button ButtonType="Primary" Content="{gallery:SpaceShowCaseLangResource P2ContentButtonN1}" />
                    <atom:Button ButtonType="Primary" Content="{gallery:SpaceShowCaseLangResource P2ContentButtonN2}" />
                    <atom:Button ButtonType="Primary" Content="{gallery:SpaceShowCaseLangResource P2ContentButtonN3}" />
                </atom:CompactSpace>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
