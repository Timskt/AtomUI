<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Space.SpaceCompactFormShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:viewModels="clr-namespace:AtomUIGallery.ShowCases.Space"
             x:DataType="viewModels:SpaceViewModel">
    <gallery:ShowCasePanel>
        
        <gallery:ShowCaseItem Title="{gallery:SpaceShowCaseLangResource CompactFormTitle}"
                              Description="{gallery:SpaceShowCaseLangResource CompactFormDescription}"
                              IsOccupyEntireRow="True">
            <StackPanel Spacing="10">
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:LineEdit Text="0571" atom:CompactSpace.ItemSize="2*"/>
                    <atom:LineEdit Text="26888888" atom:CompactSpace.ItemSize="3*"/>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="5*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch" SizeType="Small">
                    <atom:LineEdit Text="https://atomui.net" atom:CompactSpace.ItemSize="4*"/>
                    <atom:Button ButtonType="Primary" Content="{gallery:SpaceShowCaseLangResource P2ContentSubmit}" />
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="5*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:LineEdit Text="https://atomui.net" atom:CompactSpace.ItemSize="4*"/>
                    <atom:Button ButtonType="Primary" Content="{gallery:SpaceShowCaseLangResource P2ContentSubmit}" />
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="5*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:LineEdit Text="git@github.com:AtomUI/AtomUI.git" atom:CompactSpace.ItemSize="4*"/>
                    <atom:Button Icon="{antdicons:AntDesignIconProvider CopyOutlined}" atom:ToolTip.Tip="{gallery:SpaceShowCaseLangResource P2ToolTipTipCopyGitUrl}"/>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="5*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:Select IsAllowClear="True" DefaultValues="Zhejiang">
                        <atom:SelectOption Header="{gallery:SpaceShowCaseLangResource P2HeaderZhejiang}" Content="Zhejiang" />
                        <atom:SelectOption Header="{gallery:SpaceShowCaseLangResource P2HeaderJiangsu}" Content="Jiangsu" />
                    </atom:Select>
                    <atom:LineEdit Text="{gallery:SpaceShowCaseLangResource P2TextXihuDistrictHangzhou}" atom:CompactSpace.ItemSize="4*"/>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="4*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:Select  IsAllowClear="True" DefaultValues="Zhejiang" Mode="Multiple" atom:CompactSpace.ItemSize="4*">
                        <atom:SelectOption Header="{gallery:SpaceShowCaseLangResource P2HeaderZhejiang}" Content="Zhejiang" />
                        <atom:SelectOption Header="{gallery:SpaceShowCaseLangResource P2HeaderJiangsu}" Content="Jiangsu" />
                    </atom:Select>
                    <atom:LineEdit Text="{gallery:SpaceShowCaseLangResource P2TextXihuDistrictHangzhou}" atom:CompactSpace.ItemSize="4*"/>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="4*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:SearchEdit Text="0571" atom:CompactSpace.ItemSize="3*"/>
                    <atom:SearchEdit Text="26888888" atom:CompactSpace.ItemSize="5*"/>
                    <atom:SearchEdit Text="{gallery:SpaceShowCaseLangResource P2TextN1}" atom:CompactSpace.ItemSize="2*"/>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="4*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:Select DefaultValues="Option1">
                        <atom:SelectOption Header="{gallery:SpaceShowCaseLangResource P2HeaderOption1}" Content="Option1" />
                        <atom:SelectOption Header="{gallery:SpaceShowCaseLangResource P2HeaderOption2}" Content="Option2" />
                    </atom:Select>
                    <atom:LineEdit Text="{gallery:SpaceShowCaseLangResource P2TextInputContent}" atom:CompactSpace.ItemSize="5*"/>
                    <atom:NumericUpDown Value="12" atom:CompactSpace.ItemSize="80"/>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="5*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:LineEdit Text="{gallery:SpaceShowCaseLangResource P2TextInputContent}" atom:CompactSpace.ItemSize="5*"/>
                    <atom:DatePicker atom:CompactSpace.ItemSize="5*"/>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="5*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:RangeDatePicker atom:CompactSpace.ItemSize="7*"/>
                    <atom:LineEdit Text="{gallery:SpaceShowCaseLangResource P2TextInputContent}" atom:CompactSpace.ItemSize="3*"/>
                    <atom:Button ButtonType="Primary" Content="{gallery:SpaceShowCaseLangResource P2Content查询}" />
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="5*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:Select DefaultValues="Option1-1">
                        <atom:SelectOption Header="{gallery:SpaceShowCaseLangResource P2HeaderOption1N1}" Content="Option1-1" />
                        <atom:SelectOption Header="{gallery:SpaceShowCaseLangResource P2HeaderOption2N1}" Content="Option2-1" />
                    </atom:Select>
                    <atom:Select DefaultValues="Option2-1">
                        <atom:SelectOption Header="{gallery:SpaceShowCaseLangResource P2HeaderOption2N1}" Content="Option2-1" />
                        <atom:SelectOption Header="{gallery:SpaceShowCaseLangResource P2HeaderOption2N2}" Content="Option2-2" />
                    </atom:Select>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="5*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:Select DefaultValues="1">
                        <atom:SelectOption Header="{gallery:SpaceShowCaseLangResource P2HeaderBetween}" Content="1" />
                        <atom:SelectOption Header="{gallery:SpaceShowCaseLangResource P2HeaderExcept}" Content="2" />
                    </atom:Select>
                    <atom:LineEdit atom:CompactSpace.ItemSize="100" PlaceholderText="{gallery:SpaceShowCaseLangResource P2PlaceholderTextMinimum}"/>
                    <atom:LineEdit PlaceholderText="{gallery:SpaceShowCaseLangResource P2PlaceholderTextText}" IsEnabled="False"/>
                    <atom:LineEdit atom:CompactSpace.ItemSize="100" PlaceholderText="{gallery:SpaceShowCaseLangResource P2PlaceholderTextMaximum}"/>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="5*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:Select DefaultValues="Sign Up">
                        <atom:SelectOption Header="{gallery:SpaceShowCaseLangResource P2HeaderSignUp}" Content="Sign Up" />
                        <atom:SelectOption Header="{gallery:SpaceShowCaseLangResource P2HeaderSignIn}" Content="Sign In" />
                    </atom:Select>
                    <atom:AutoComplete PlaceholderText="{gallery:SpaceShowCaseLangResource P2PlaceholderTextEmail}">
                        <atom:AutoCompleteOption Header="{gallery:SpaceShowCaseLangResource P2HeaderTextN1}" Content="text 1"/>
                        <atom:AutoCompleteOption Header="{gallery:SpaceShowCaseLangResource P2HeaderTextN2}" Content="text 2"/>
                    </atom:AutoComplete>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="5*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:TimePicker atom:CompactSpace.ItemSize="7*" PlaceholderText="{gallery:SpaceShowCaseLangResource P2PlaceholderTextSelectTime}"/>
                    <atom:Cascader atom:CompactSpace.ItemSize="7*" PlaceholderText="{gallery:SpaceShowCaseLangResource P2PlaceholderTextSelectAddress}">
                        <atom:CascaderOption Header="{gallery:SpaceShowCaseLangResource P2HeaderZhejiang}" Value="zhejiang">
                            <atom:CascaderOption Header="{gallery:SpaceShowCaseLangResource P2HeaderHangzhou}" Value="hangzhou">
                                <atom:CascaderOption Header="{gallery:SpaceShowCaseLangResource P2HeaderWestLake}" Value="xihu" />
                                <atom:CascaderOption Header="{gallery:SpaceShowCaseLangResource P2HeaderLingyinShi}" Value="lingyinshi" />
                            </atom:CascaderOption>
                        </atom:CascaderOption>
                        <atom:CascaderOption Header="{gallery:SpaceShowCaseLangResource P2HeaderJiangsu}" Value="jiangsu">
                            <atom:CascaderOption Header="{gallery:SpaceShowCaseLangResource P2HeaderNanjing}" Value="nanjing">
                                <atom:CascaderOption Header="{gallery:SpaceShowCaseLangResource P2HeaderZhongHuaMen}" Value="zhonghuamen" />
                            </atom:CascaderOption>
                        </atom:CascaderOption>
                    </atom:Cascader>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="5*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:RangeTimePicker PlaceholderText="{gallery:SpaceShowCaseLangResource P2PlaceholderTextStartTime}" SecondaryPlaceholderText="{gallery:SpaceShowCaseLangResource P2SecondaryPlaceholderTextEndTime}" />
                    <atom:TreeSelect atom:CompactSpace.ItemSize="7*"
                                     IsAllowClear="True"
                                     IsFilterEnabled="True"
                                     IsDefaultExpandAll="True"
                                     PlaceholderText="{gallery:SpaceShowCaseLangResource P2PlaceholderTextPleaseSelect}">
                        <atom:TreeItemNode Header="{gallery:SpaceShowCaseLangResource P2HeaderParentN1}" Value="parent 1">
                            <atom:TreeItemNode Header="{gallery:SpaceShowCaseLangResource P2HeaderParentN1N0}" Value="parent 1-0">
                                <atom:TreeItemNode Header="{gallery:SpaceShowCaseLangResource P2HeaderLeaf1}" Value="leaf1"/>
                                <atom:TreeItemNode Header="{gallery:SpaceShowCaseLangResource P2HeaderLeaf2}" Value="leaf2"/>
                            </atom:TreeItemNode>
                            <atom:TreeItemNode Header="{gallery:SpaceShowCaseLangResource P2HeaderParentN1N1}" Value="parent 1-1">
                                <atom:TreeItemNode Header="{gallery:SpaceShowCaseLangResource P2HeaderLeaf3}" Value="leaf3"/>
                            </atom:TreeItemNode>
                        </atom:TreeItemNode>
                    </atom:TreeSelect>
                    <atom:Button ButtonType="Primary" Content="{gallery:SpaceShowCaseLangResource P2ContentSubmit}" />
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="5*" />
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:LineEdit PlaceholderText="{gallery:SpaceShowCaseLangResource P2PlaceholderTextInputHere}"/>
                    <atom:CompactSpaceAddOn Content="$"/>
                    <atom:NumericUpDown PlaceholderText="{gallery:SpaceShowCaseLangResource P2PlaceholderTextAnotherInput}" atom:CompactSpace.ItemSize="1*"/>
                    <atom:NumericUpDown PlaceholderText="{gallery:SpaceShowCaseLangResource P2PlaceholderTextAnotherInput}" atom:CompactSpace.ItemSize="1*"/>
                    <atom:CompactSpaceAddOn Content="$"/>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="*" />
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:LineEdit PlaceholderText="{gallery:SpaceShowCaseLangResource P2PlaceholderTextInputHere}"/>
                    <atom:ColorPicker DefaultValue="#1677ff"/>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="*" />
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:Button ButtonType="Primary" Content="{gallery:SpaceShowCaseLangResource P2ContentButton}" />
                    <atom:LineEdit PlaceholderText="{gallery:SpaceShowCaseLangResource P2PlaceholderTextInputHere}"/>
                    <atom:CompactSpaceAddOn Content="$"/>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="*" />
                </atom:CompactSpace>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
