<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Space.SpaceCompactFormShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:viewModels="clr-namespace:AtomUIGallery.ShowCases.Space"
             x:DataType="viewModels:SpaceViewModel">
    <gallery:ShowCasePanel>
        
        <gallery:ShowCaseItem Title="{gallery:SpaceShowCaseLangResource CompactFormTitle}"
                              Description="{gallery:SpaceShowCaseLangResource CompactFormDescription}"
                              IsOccupyEntireRow="True">
            <StackPanel Spacing="10">
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:LineEdit Text="0571" atom:CompactSpace.ItemSize="2*"/>
                    <atom:LineEdit Text="26888888" atom:CompactSpace.ItemSize="3*"/>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="5*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch" SizeType="Small">
                    <atom:LineEdit Text="https://atomui.net" atom:CompactSpace.ItemSize="4*"/>
                    <atom:Button ButtonType="Primary">Submit</atom:Button>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="5*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:LineEdit Text="https://atomui.net" atom:CompactSpace.ItemSize="4*"/>
                    <atom:Button ButtonType="Primary">Submit</atom:Button>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="5*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:LineEdit Text="git@github.com:AtomUI/AtomUI.git" atom:CompactSpace.ItemSize="4*"/>
                    <atom:Button Icon="{antdicons:AntDesignIconProvider CopyOutlined}" atom:ToolTip.Tip="copy git url"/>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="5*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:Select IsAllowClear="True" DefaultValues="Zhejiang">
                        <atom:SelectOption Header="Zhejiang" Content="Zhejiang" />
                        <atom:SelectOption Header="Jiangsu" Content="Jiangsu" />
                    </atom:Select>
                    <atom:LineEdit Text="Xihu District, Hangzhou" atom:CompactSpace.ItemSize="4*"/>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="4*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:Select  IsAllowClear="True" DefaultValues="Zhejiang" Mode="Multiple" atom:CompactSpace.ItemSize="4*">
                        <atom:SelectOption Header="Zhejiang" Content="Zhejiang" />
                        <atom:SelectOption Header="Jiangsu" Content="Jiangsu" />
                    </atom:Select>
                    <atom:LineEdit Text="Xihu District, Hangzhou" atom:CompactSpace.ItemSize="4*"/>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="4*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:SearchEdit Text="0571" atom:CompactSpace.ItemSize="3*"/>
                    <atom:SearchEdit Text="26888888" atom:CompactSpace.ItemSize="5*"/>
                    <atom:SearchEdit Text="+1" atom:CompactSpace.ItemSize="2*"/>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="4*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:Select DefaultValues="Option1">
                        <atom:SelectOption Header="Option1" Content="Option1" />
                        <atom:SelectOption Header="Option2" Content="Option2" />
                    </atom:Select>
                    <atom:LineEdit Text="input content" atom:CompactSpace.ItemSize="5*"/>
                    <atom:NumericUpDown Value="12" atom:CompactSpace.ItemSize="80"/>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="5*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:LineEdit Text="input content" atom:CompactSpace.ItemSize="5*"/>
                    <atom:DatePicker atom:CompactSpace.ItemSize="5*"/>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="5*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:RangeDatePicker atom:CompactSpace.ItemSize="7*"/>
                    <atom:LineEdit Text="input content" atom:CompactSpace.ItemSize="3*"/>
                    <atom:Button ButtonType="Primary">查询</atom:Button>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="5*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:Select DefaultValues="Option1-1">
                        <atom:SelectOption Header="Option1-1" Content="Option1-1" />
                        <atom:SelectOption Header="Option2-1" Content="Option2-1" />
                    </atom:Select>
                    <atom:Select DefaultValues="Option2-1">
                        <atom:SelectOption Header="Option2-1" Content="Option2-1" />
                        <atom:SelectOption Header="Option2-2" Content="Option2-2" />
                    </atom:Select>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="5*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:Select DefaultValues="1">
                        <atom:SelectOption Header="Between" Content="1" />
                        <atom:SelectOption Header="Except" Content="2" />
                    </atom:Select>
                    <atom:LineEdit atom:CompactSpace.ItemSize="100" PlaceholderText="Minimum"/>
                    <atom:LineEdit PlaceholderText="~" IsEnabled="False"/>
                    <atom:LineEdit atom:CompactSpace.ItemSize="100" PlaceholderText="Maximum"/>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="5*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:Select DefaultValues="Sign Up">
                        <atom:SelectOption Header="Sign Up" Content="Sign Up" />
                        <atom:SelectOption Header="Sign In" Content="Sign In" />
                    </atom:Select>
                    <atom:AutoComplete PlaceholderText="Email">
                        <atom:AutoCompleteOption Header="text 1" Content="text 1"/>
                        <atom:AutoCompleteOption Header="text 2" Content="text 2"/>
                    </atom:AutoComplete>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="5*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:TimePicker atom:CompactSpace.ItemSize="7*" PlaceholderText="Select Time"/>
                    <atom:Cascader atom:CompactSpace.ItemSize="7*" PlaceholderText="Select Address">
                        <atom:CascaderOption Header="Zhejiang" Value="zhejiang">
                            <atom:CascaderOption Header="Hangzhou" Value="hangzhou">
                                <atom:CascaderOption Header="West Lake" Value="xihu" />
                                <atom:CascaderOption Header="Lingyin shi" Value="lingyinshi" />
                            </atom:CascaderOption>
                        </atom:CascaderOption>
                        <atom:CascaderOption Header="Jiangsu" Value="jiangsu">
                            <atom:CascaderOption Header="Nanjing" Value="nanjing">
                                <atom:CascaderOption Header="Zhong Hua Men" Value="zhonghuamen" />
                            </atom:CascaderOption>
                        </atom:CascaderOption>
                    </atom:Cascader>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="5*"/>
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:RangeTimePicker PlaceholderText="Start time" SecondaryPlaceholderText="End time" />
                    <atom:TreeSelect atom:CompactSpace.ItemSize="7*"
                                     IsAllowClear="True"
                                     IsFilterEnabled="True"
                                     IsDefaultExpandAll="True"
                                     PlaceholderText="Please select">
                        <atom:TreeItemNode Header="parent 1" Value="parent 1">
                            <atom:TreeItemNode Header="parent 1-0" Value="parent 1-0">
                                <atom:TreeItemNode Header="leaf1" Value="leaf1"/>
                                <atom:TreeItemNode Header="leaf2" Value="leaf2"/>
                            </atom:TreeItemNode>
                            <atom:TreeItemNode Header="parent 1-1" Value="parent 1-1">
                                <atom:TreeItemNode Header="leaf3" Value="leaf3"/>
                            </atom:TreeItemNode>
                        </atom:TreeItemNode>
                    </atom:TreeSelect>
                    <atom:Button ButtonType="Primary">Submit</atom:Button>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="5*" />
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:LineEdit PlaceholderText="input here"/>
                    <atom:CompactSpaceAddOn Content="$"/>
                    <atom:NumericUpDown PlaceholderText="another input" atom:CompactSpace.ItemSize="1*"/>
                    <atom:NumericUpDown PlaceholderText="another input" atom:CompactSpace.ItemSize="1*"/>
                    <atom:CompactSpaceAddOn Content="$"/>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="*" />
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:LineEdit PlaceholderText="input here"/>
                    <atom:ColorPicker DefaultValue="#1677ff"/>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="*" />
                </atom:CompactSpace>
        
                <atom:CompactSpace Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <atom:Button ButtonType="Primary">Button</atom:Button>
                    <atom:LineEdit PlaceholderText="input here"/>
                    <atom:CompactSpaceAddOn Content="$"/>
                    <atom:CompactSpaceFiller atom:CompactSpace.ItemSize="*" />
                </atom:CompactSpace>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
