<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Splitter.SplitterShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
           >
    <UserControl.Styles>
        <Style Selector="Border.splitter-surface">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgContainer}" />
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorBorderSecondary}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BoxShadow" Value="0 0 10 0 #1A000000" />
        </Style>
        <Style Selector="Border.splitter-panel">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgContainer}" />
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorBorder}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <Style Selector="Border.splitter-panel.alt">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorFillAlter}" />
        </Style>
        <Style Selector="TextBlock.splitter-label">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorTextDescription}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Styles>

    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem Title="{gallery:SplitterShowCaseLangResource BasicTitle}" Description="{gallery:SplitterShowCaseLangResource BasicDescription}" IsOccupyEntireRow="True">
            <Border Classes="splitter-surface">
                <atom:Splitter Orientation="Vertical" Height="220">
                    <Border Classes="splitter-panel" atom:Splitter.Size="30%">
                        <TextBlock Classes="splitter-label" Text="{gallery:SplitterShowCaseLangResource P2TextFirst}" />
                    </Border>
                    <Border Classes="splitter-panel" atom:Splitter.DefaultSize="100" atom:Splitter.MinSize="60">
                        <TextBlock Classes="splitter-label" Text="{gallery:SplitterShowCaseLangResource P2TextSecond}" />
                    </Border>
                </atom:Splitter>
            </Border>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:SplitterShowCaseLangResource HorizontalTitle}" Description="{gallery:SplitterShowCaseLangResource HorizontalDescription}" IsOccupyEntireRow="True">
            <Border Classes="splitter-surface">
                <atom:Splitter Orientation="Horizontal" Height="220">
                    <Border Classes="splitter-panel" atom:Splitter.Size="40%">
                        <TextBlock Classes="splitter-label" Text="{gallery:SplitterShowCaseLangResource P2TextTop}" />
                    </Border>
                    <Border Classes="splitter-panel alt">
                        <TextBlock Classes="splitter-label" Text="{gallery:SplitterShowCaseLangResource P2TextBottom}" />
                    </Border>
                </atom:Splitter>
            </Border>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:SplitterShowCaseLangResource CompositeTitle}" Description="{gallery:SplitterShowCaseLangResource CompositeDescription}" IsOccupyEntireRow="True">
            <Border Classes="splitter-surface">
                <atom:Splitter Orientation="Vertical" Height="260">
                    <Border Classes="splitter-panel" atom:Splitter.Size="40%">
                        <TextBlock Classes="splitter-label" Text="{gallery:SplitterShowCaseLangResource P2TextLeft}" />
                    </Border>
                    <atom:Splitter Orientation="Horizontal">
                        <Border Classes="splitter-panel">
                            <TextBlock Classes="splitter-label" Text="{gallery:SplitterShowCaseLangResource P2TextTop}" />
                        </Border>
                        <Border Classes="splitter-panel alt">
                            <TextBlock Classes="splitter-label" Text="{gallery:SplitterShowCaseLangResource P2TextBottom}" />
                        </Border>
                    </atom:Splitter>
                </atom:Splitter>
            </Border>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:SplitterShowCaseLangResource ResizableDisabledTitle}" Description="{gallery:SplitterShowCaseLangResource ResizableDisabledDescription}" IsOccupyEntireRow="True">
            <Border Classes="splitter-surface">
                <atom:Splitter Orientation="Vertical" Height="220">
                    <Border Classes="splitter-panel" atom:Splitter.Size="35%">
                        <TextBlock Classes="splitter-label" Text="{gallery:SplitterShowCaseLangResource P2TextResizable}" />
                    </Border>
                    <Border Classes="splitter-panel alt" atom:Splitter.DefaultSize="120" atom:Splitter.IsResizable="False">
                        <TextBlock Classes="splitter-label" Text="{gallery:SplitterShowCaseLangResource P2TextNotResizable}" />
                    </Border>
                    <Border Classes="splitter-panel" atom:Splitter.DefaultSize="120">
                        <TextBlock Classes="splitter-label" Text="{gallery:SplitterShowCaseLangResource P2TextResizable}" />
                    </Border>
                </atom:Splitter>
            </Border>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:SplitterShowCaseLangResource ShowCollapsibleIconTitle}"
                              Description="{gallery:SplitterShowCaseLangResource ShowCollapsibleIconDescription}"
                              IsOccupyEntireRow="True">
            <Border Classes="splitter-surface" Padding="16">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center" Text="{gallery:SplitterShowCaseLangResource P2TextShowcollapsibleicon}" />
                        <atom:RadioButton GroupName="ShowCollapsibleIconMode"
                                          Tag="Hover"
                                          IsCheckedChanged="HandleShowCollapsibleIconChanged" Content="{gallery:SplitterShowCaseLangResource P2ContentHover}" />
                        <atom:RadioButton GroupName="ShowCollapsibleIconMode"
                                          Tag="True"
                                          IsChecked="True"
                                          IsCheckedChanged="HandleShowCollapsibleIconChanged" Content="{gallery:SplitterShowCaseLangResource P2ContentTrue}" />
                        <atom:RadioButton GroupName="ShowCollapsibleIconMode"
                                          Tag="False"
                                          IsCheckedChanged="HandleShowCollapsibleIconChanged" Content="{gallery:SplitterShowCaseLangResource P2ContentFalse}" />
                    </StackPanel>
                    <atom:Splitter Orientation="Vertical" Height="220">
                        <Border Classes="splitter-panel"
                                x:Name="ShowCollapsiblePanelFirst"
                                atom:Splitter.DefaultSize="33%">
                            <TextBlock Classes="splitter-label" Text="{gallery:SplitterShowCaseLangResource P2TextFirst}" />
                        </Border>
                        <Border Classes="splitter-panel alt" x:Name="ShowCollapsiblePanelSecond"
                                atom:Splitter.DefaultSize="34%">
                            <TextBlock Classes="splitter-label" Text="{gallery:SplitterShowCaseLangResource P2TextSecond}" />
                        </Border>
                        <Border Classes="splitter-panel"
                                x:Name="ShowCollapsiblePanelThird">
                            <TextBlock Classes="splitter-label" Text="{gallery:SplitterShowCaseLangResource P2TextThird}" />
                        </Border>
                    </atom:Splitter>
                </StackPanel>
            </Border>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:SplitterShowCaseLangResource MultiPanelsTitle}" Description="{gallery:SplitterShowCaseLangResource MultiPanelsDescription}" IsOccupyEntireRow="True">
            <Border Classes="splitter-surface">
                <atom:Splitter Orientation="Vertical" Height="240">
                    <Border Classes="splitter-panel" atom:Splitter.Size="20%">
                        <TextBlock Classes="splitter-label" Text="{gallery:SplitterShowCaseLangResource P2TextA}" />
                    </Border>
                    <Border Classes="splitter-panel alt" atom:Splitter.Size="20%">
                        <TextBlock Classes="splitter-label" Text="{gallery:SplitterShowCaseLangResource P2TextB}" />
                    </Border>
                    <Border Classes="splitter-panel">
                        <TextBlock Classes="splitter-label" Text="{gallery:SplitterShowCaseLangResource P2TextC}" />
                    </Border>
                    <Border Classes="splitter-panel alt">
                        <TextBlock Classes="splitter-label" Text="{gallery:SplitterShowCaseLangResource P2TextD}" />
                    </Border>
                </atom:Splitter>
            </Border>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="{gallery:SplitterShowCaseLangResource LazyTitle}"
                              Description="{gallery:SplitterShowCaseLangResource LazyDescription}"
                              IsOccupyEntireRow="True">
            <Border Classes="splitter-surface" Padding="16">
                <StackPanel Spacing="12">
                    <atom:Splitter Orientation="Vertical" Height="140" IsLazy="True">
                        <Border Classes="splitter-panel" atom:Splitter.Size="50%">
                            <TextBlock Classes="splitter-label" Text="{gallery:SplitterShowCaseLangResource P2TextFirst}" />
                        </Border>
                        <Border Classes="splitter-panel alt">
                            <TextBlock Classes="splitter-label" Text="{gallery:SplitterShowCaseLangResource P2TextSecond}" />
                        </Border>
                    </atom:Splitter>
                    <atom:Splitter Orientation="Horizontal" Height="140" IsLazy="True">
                        <Border Classes="splitter-panel" atom:Splitter.Size="50%">
                            <TextBlock Classes="splitter-label" Text="{gallery:SplitterShowCaseLangResource P2TextFirst}" />
                        </Border>
                        <Border Classes="splitter-panel alt">
                            <TextBlock Classes="splitter-label" Text="{gallery:SplitterShowCaseLangResource P2TextSecond}" />
                        </Border>
                    </atom:Splitter>
                </StackPanel>
            </Border>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
