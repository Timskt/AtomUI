<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.ButtonSpinner.ButtonSpinnerShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:ButtonSpinnerShowCaseLangResource BasicTitle}"
            Description="{gallery:ButtonSpinnerShowCaseLangResource BasicDescription}">
            <atom:ButtonSpinner>
                <atom:TextBlock
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Text="{gallery:ButtonSpinnerShowCaseLangResource P2Text床前明月光}" />
            </atom:ButtonSpinner>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ButtonSpinnerShowCaseLangResource ThreeSizesTitle}"
            Description="{gallery:ButtonSpinnerShowCaseLangResource ThreeSizesDescription}">
            <StackPanel Orientation="Vertical" Spacing="10" Margin="0, 0, 20, 0">
                <atom:ButtonSpinner SizeType="Large">
                    <atom:TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{gallery:ButtonSpinnerShowCaseLangResource P2Text床前明月光}" />
                </atom:ButtonSpinner>
                <atom:ButtonSpinner SizeType="Middle">
                    <atom:TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{gallery:ButtonSpinnerShowCaseLangResource P2Text床前明月光}" />
                </atom:ButtonSpinner>
                <atom:ButtonSpinner SizeType="Small">
                    <atom:TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{gallery:ButtonSpinnerShowCaseLangResource P2Text床前明月光}" />
                </atom:ButtonSpinner>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ButtonSpinnerShowCaseLangResource VariantsTitle}"
            Description="{gallery:ButtonSpinnerShowCaseLangResource VariantsDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:ButtonSpinner StyleVariant="Outlined">
                    <atom:TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{gallery:ButtonSpinnerShowCaseLangResource P2Text床前明月光}" />
                </atom:ButtonSpinner>
                <atom:ButtonSpinner StyleVariant="Filled">
                    <atom:TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{gallery:ButtonSpinnerShowCaseLangResource P2Text床前明月光}" />
                </atom:ButtonSpinner>
                <atom:ButtonSpinner StyleVariant="Borderless">
                    <atom:TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{gallery:ButtonSpinnerShowCaseLangResource P2Text床前明月光}" />
                </atom:ButtonSpinner>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ButtonSpinnerShowCaseLangResource DisabledTitle}"
            Description="{gallery:ButtonSpinnerShowCaseLangResource DisabledDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:ButtonSpinner StyleVariant="Outlined" IsEnabled="False">
                    <atom:TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{gallery:ButtonSpinnerShowCaseLangResource P2Text床前明月光}" />
                </atom:ButtonSpinner>
                <atom:ButtonSpinner StyleVariant="Filled" IsEnabled="False">
                    <atom:TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{gallery:ButtonSpinnerShowCaseLangResource P2Text床前明月光}" />
                </atom:ButtonSpinner>
                <atom:ButtonSpinner StyleVariant="Borderless" IsEnabled="False">
                    <atom:TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{gallery:ButtonSpinnerShowCaseLangResource P2Text床前明月光}" />
                </atom:ButtonSpinner>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ButtonSpinnerShowCaseLangResource PrePostTabTitle}"
            Description="{gallery:ButtonSpinnerShowCaseLangResource PrePostTabDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:ButtonSpinner
                    LeftAddOn="http://"
                    RightAddOn=".com"
                    Width="400"
                    HorizontalAlignment="Left">
                    <atom:TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{gallery:ButtonSpinnerShowCaseLangResource P2Text床前明月光}" />
                </atom:ButtonSpinner>

                <atom:ButtonSpinner
                    RightAddOn="{antdicons:AntDesignIconProvider Kind=SettingOutlined}"
                    Width="400"
                    HorizontalAlignment="Left">
                    <atom:TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{gallery:ButtonSpinnerShowCaseLangResource P2Text床前明月光}" />
                </atom:ButtonSpinner>

                <atom:ButtonSpinner
                    LeftAddOn="http://"
                    Width="400"
                    HorizontalAlignment="Left"
                    InnerRightContent=".com">
                    <atom:TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{gallery:ButtonSpinnerShowCaseLangResource P2Text床前明月光}" />
                </atom:ButtonSpinner>

            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ButtonSpinnerShowCaseLangResource PrefixSuffixTitle}"
            Description="{gallery:ButtonSpinnerShowCaseLangResource PrefixSuffixDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">

                <atom:ButtonSpinner
                    InnerLeftContent="{antdicons:AntDesignIconProvider Kind=UserOutlined, FillBrush=#D7D7D7}"
                    InnerRightContent="{antdicons:AntDesignIconProvider Kind=InfoCircleOutlined, FillBrush=#8C8C8C}"
                    Width="400"
                    HorizontalAlignment="Left">
                    <atom:TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{gallery:ButtonSpinnerShowCaseLangResource P2Text床前明月光}" />
                </atom:ButtonSpinner>

                <atom:ButtonSpinner
                    InnerLeftContent="￥"
                    InnerRightContent="RMB"
                    Width="400"
                    HorizontalAlignment="Left">
                    <atom:TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{gallery:ButtonSpinnerShowCaseLangResource P2Text床前明月光}" />
                </atom:ButtonSpinner>

                <atom:ButtonSpinner
                    InnerLeftContent="￥" InnerRightContent="RMB" IsEnabled="False"
                    Width="400"
                    HorizontalAlignment="Left">
                    <atom:TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{gallery:ButtonSpinnerShowCaseLangResource P2Text床前明月光}" />
                </atom:ButtonSpinner>

            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ButtonSpinnerShowCaseLangResource StatusTitle}"
            Description="{gallery:ButtonSpinnerShowCaseLangResource StatusDescription}">
            <StackPanel Orientation="Vertical" Spacing="10" Margin="0, 0, 20, 0">
                <atom:ButtonSpinner
                    Status="Error"
                    Width="400"
                    HorizontalAlignment="Left">
                    <atom:TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{gallery:ButtonSpinnerShowCaseLangResource P2Text床前明月光}" />
                </atom:ButtonSpinner>
                <atom:ButtonSpinner
                    Status="Warning"
                    Width="400"
                    HorizontalAlignment="Left">
                    <atom:TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{gallery:ButtonSpinnerShowCaseLangResource P2Text床前明月光}" />
                </atom:ButtonSpinner>

                <atom:ButtonSpinner
                    Status="Error"
                    Width="400"
                    InnerLeftContent="{antdicons:AntDesignIconProvider Kind=ClockCircleOutlined}"
                    HorizontalAlignment="Left">
                    <atom:TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{gallery:ButtonSpinnerShowCaseLangResource P2Text床前明月光}" />
                </atom:ButtonSpinner>

                <atom:ButtonSpinner
                    Status="Warning"
                    Width="400"
                    InnerLeftContent="{antdicons:AntDesignIconProvider Kind=ClockCircleOutlined}"
                    HorizontalAlignment="Left">
                    <atom:TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{gallery:ButtonSpinnerShowCaseLangResource P2Text床前明月光}" />
                </atom:ButtonSpinner>

                <atom:ButtonSpinner
                    Status="Error"
                    Width="400"
                    InnerLeftContent="{antdicons:AntDesignIconProvider Kind=ClockCircleOutlined}"
                    HorizontalAlignment="Left"
                    StyleVariant="Filled">
                    <atom:TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{gallery:ButtonSpinnerShowCaseLangResource P2Text床前明月光}" />
                </atom:ButtonSpinner>

                <atom:ButtonSpinner
                    Status="Warning"
                    Width="400"
                    InnerLeftContent="{antdicons:AntDesignIconProvider Kind=ClockCircleOutlined}"
                    HorizontalAlignment="Left"
                    StyleVariant="Filled">
                    <atom:TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{gallery:ButtonSpinnerShowCaseLangResource P2Text床前明月光}" />
                </atom:ButtonSpinner>

                <atom:ButtonSpinner
                    Status="Error"
                    Width="400"
                    InnerLeftContent="{antdicons:AntDesignIconProvider Kind=ClockCircleOutlined}"
                    HorizontalAlignment="Left"
                    StyleVariant="Borderless">
                    <atom:TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{gallery:ButtonSpinnerShowCaseLangResource P2Text床前明月光}" />
                </atom:ButtonSpinner>

                <atom:ButtonSpinner
                    Status="Warning"
                    Width="400"
                    InnerLeftContent="{antdicons:AntDesignIconProvider Kind=ClockCircleOutlined, FillBrush=Red}"
                    HorizontalAlignment="Left"
                    StyleVariant="Borderless">
                    <atom:TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{gallery:ButtonSpinnerShowCaseLangResource P2Text床前明月光}" />
                </atom:ButtonSpinner>

            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
