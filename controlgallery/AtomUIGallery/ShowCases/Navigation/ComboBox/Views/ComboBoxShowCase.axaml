<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.ComboBox.ComboBoxShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.ComboBox"
             x:DataType="vm:ComboBoxViewModel"
             x:CompileBindings="True">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:ComboBoxShowCaseLangResource BasicTitle}"
            Description="{gallery:ComboBoxShowCaseLangResource BasicDescription}">
            <atom:ComboBox PlaceholderText="{gallery:ComboBoxShowCaseLangResource P2PlaceholderTextPleaseSelect}" Width="300">
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
            </atom:ComboBox>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ComboBoxShowCaseLangResource ItemsSourceTitle}"
            Description="{gallery:ComboBoxShowCaseLangResource ItemsSourceDescription}">
            <atom:ComboBox Name="TplComboBox"
                           PlaceholderText="{gallery:ComboBoxShowCaseLangResource P2PlaceholderTextPleaseSelect}" Width="300"
                           ItemsSource="{Binding ComboBoxItems}">
                <atom:ComboBox.ItemTemplate>
                    <DataTemplate>
                        <atom:TextBlock Text="{Binding Text}" VerticalAlignment="Center"/>
                    </DataTemplate>
                </atom:ComboBox.ItemTemplate>
            </atom:ComboBox>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ComboBoxShowCaseLangResource DisabledTitle}"
            Description="{gallery:ComboBoxShowCaseLangResource DisabledDescription}">
            <atom:ComboBox PlaceholderText="{gallery:ComboBoxShowCaseLangResource P2PlaceholderTextPleaseSelect}" Width="300" IsEnabled="False">
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
            </atom:ComboBox>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ComboBoxShowCaseLangResource ThreeSizesTitle}"
            Description="{gallery:ComboBoxShowCaseLangResource ThreeSizesDescription}">
            <StackPanel Orientation="Vertical" Spacing="10" Margin="0, 0, 20, 0">
                <atom:ComboBox SizeType="Large" PlaceholderText="{gallery:ComboBoxShowCaseLangResource P2PlaceholderTextPleaseSelect}">
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                </atom:ComboBox>
                <atom:ComboBox SizeType="Middle" PlaceholderText="{gallery:ComboBoxShowCaseLangResource P2PlaceholderTextPleaseSelect}">
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                </atom:ComboBox>
                <atom:ComboBox SizeType="Small" PlaceholderText="{gallery:ComboBoxShowCaseLangResource P2PlaceholderTextPleaseSelect}">
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                </atom:ComboBox>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ComboBoxShowCaseLangResource VariantsTitle}"
            Description="{gallery:ComboBoxShowCaseLangResource VariantsDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:ComboBox StyleVariant="Outlined" PlaceholderText="{gallery:ComboBoxShowCaseLangResource P2PlaceholderTextPleaseSelect}" Width="300">
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                </atom:ComboBox>

                <atom:ComboBox StyleVariant="Filled" PlaceholderText="{gallery:ComboBoxShowCaseLangResource P2PlaceholderTextPleaseSelect}" Width="300">
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                </atom:ComboBox>

                <atom:ComboBox StyleVariant="Borderless" PlaceholderText="{gallery:ComboBoxShowCaseLangResource P2PlaceholderTextPleaseSelect}" Width="300">
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                </atom:ComboBox>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ComboBoxShowCaseLangResource PrePostTabTitle}"
            Description="{gallery:ComboBoxShowCaseLangResource PrePostTabDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:ComboBox PlaceholderText="{gallery:ComboBoxShowCaseLangResource P2PlaceholderTextPleaseSelect}" Width="300"
                               LeftAddOn="http://"
                               RightAddOn=".com">
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                </atom:ComboBox>

                <atom:ComboBox PlaceholderText="{gallery:ComboBoxShowCaseLangResource P2PlaceholderTextPleaseSelect}" Width="300"
                               RightAddOn="{antdicons:AntDesignIconProvider Kind=SettingOutlined}">
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                </atom:ComboBox>

                <atom:ComboBox PlaceholderText="{gallery:ComboBoxShowCaseLangResource P2PlaceholderTextPleaseSelect}" Width="300"
                               LeftAddOn="http://"
                               ContentRightAddOn=".com">
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                </atom:ComboBox>

            </StackPanel>
        </gallery:ShowCaseItem>


        <gallery:ShowCaseItem
            Title="{gallery:ComboBoxShowCaseLangResource PrefixSuffixTitle}"
            Description="{gallery:ComboBoxShowCaseLangResource PrefixSuffixDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:ComboBox PlaceholderText="{gallery:ComboBoxShowCaseLangResource P2PlaceholderTextPleaseSelect}" Width="300"
                               ContentLeftAddOn="{antdicons:AntDesignIconProvider Kind=UserOutlined, FillBrush=#D7D7D7}"
                               ContentRightAddOn="{antdicons:AntDesignIconProvider Kind=InfoCircleOutlined, FillBrush=#8C8C8C}">
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                </atom:ComboBox>

                <atom:ComboBox PlaceholderText="{gallery:ComboBoxShowCaseLangResource P2PlaceholderTextPleaseSelect}" Width="300"
                               ContentLeftAddOn="￥"
                               ContentRightAddOn="RMB">
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                </atom:ComboBox>

                <atom:ComboBox PlaceholderText="{gallery:ComboBoxShowCaseLangResource P2PlaceholderTextPleaseSelect}" Width="300"
                               ContentLeftAddOn="￥"
                               ContentRightAddOn="RMB" IsEnabled="False">
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                </atom:ComboBox>

            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:ComboBoxShowCaseLangResource StatusTitle}"
            Description="{gallery:ComboBoxShowCaseLangResource StatusDescription}">
            <StackPanel Orientation="Vertical" Spacing="10" Margin="0, 0, 20, 0">
                <atom:ComboBox PlaceholderText="{gallery:ComboBoxShowCaseLangResource P2PlaceholderTextPleaseSelect}" Width="300"
                               Status="Error">
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                </atom:ComboBox>

                <atom:ComboBox PlaceholderText="{gallery:ComboBoxShowCaseLangResource P2PlaceholderTextPleaseSelect}" Width="300"
                               Status="Warning">
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                </atom:ComboBox>

                <atom:ComboBox PlaceholderText="{gallery:ComboBoxShowCaseLangResource P2PlaceholderTextPleaseSelect}" Width="300"
                               Status="Error"
                               ContentLeftAddOn="{antdicons:AntDesignIconProvider Kind=ClockCircleOutlined}">
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                </atom:ComboBox>

                <atom:ComboBox PlaceholderText="{gallery:ComboBoxShowCaseLangResource P2PlaceholderTextPleaseSelect}" Width="300"
                               Status="Warning"
                               ContentLeftAddOn="{antdicons:AntDesignIconProvider Kind=ClockCircleOutlined}">
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                </atom:ComboBox>

                <atom:ComboBox PlaceholderText="{gallery:ComboBoxShowCaseLangResource P2PlaceholderTextPleaseSelect}" Width="300"
                               Status="Error"
                               StyleVariant="Filled"
                               ContentLeftAddOn="{antdicons:AntDesignIconProvider Kind=ClockCircleOutlined}">
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                </atom:ComboBox>

                <atom:ComboBox PlaceholderText="{gallery:ComboBoxShowCaseLangResource P2PlaceholderTextPleaseSelect}" Width="300"
                               Status="Warning"
                               StyleVariant="Filled"
                               ContentLeftAddOn="{antdicons:AntDesignIconProvider Kind=ClockCircleOutlined}">
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                </atom:ComboBox>

                <atom:ComboBox PlaceholderText="{gallery:ComboBoxShowCaseLangResource P2PlaceholderTextPleaseSelect}" Width="300"
                               Status="Error"
                               StyleVariant="Borderless"
                               ContentLeftAddOn="{antdicons:AntDesignIconProvider Kind=ClockCircleOutlined}">
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                </atom:ComboBox>

                <atom:ComboBox PlaceholderText="{gallery:ComboBoxShowCaseLangResource P2PlaceholderTextPleaseSelect}" Width="300"
                               Status="Warning"
                               StyleVariant="Borderless"
                               ContentLeftAddOn="{antdicons:AntDesignIconProvider Kind=ClockCircleOutlined}">
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine1}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine2}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine3}" />
                    <atom:ComboBoxItem Content="{gallery:ComboBoxShowCaseLangResource P2ContentPoemLine4}" />
                </atom:ComboBox>

            </StackPanel>
        </gallery:ShowCaseItem>

    </gallery:ShowCasePanel>
</UserControl>
