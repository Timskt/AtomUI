<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Menu.MenuContextShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:viewModels="clr-namespace:AtomUIGallery.ShowCases.Menu"
             x:DataType="viewModels:MenuViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:MenuShowCaseLangResource ContextMenuTitle}"
            Description="{gallery:MenuShowCaseLangResource ContextMenuDescription}">
            <gallery:ShowCaseItem.Styles>
                <Style Selector="Border#ContextMenuContainer">
                    <Setter Property="BorderBrush" Value="Gray" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="CornerRadius" Value="6" />
                    <Setter Property="Padding" Value="10" />
                    <Setter Property="Margin" Value="10" />
                </Style>
            </gallery:ShowCaseItem.Styles>
            <Border Name="ContextMenuContainer">
                <Border.ContextMenu>
                    <atom:ContextMenu>
                        <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderCut}" InputGesture="Ctrl+X"
                                       Icon="{antdicons:AntDesignIconProvider Kind=ScissorOutlined}" />
                        <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderCopy}" InputGesture="Ctrl+C" Icon="{antdicons:AntDesignIconProvider Kind=CopyOutlined}" />
                        <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderDelete}" InputGesture="Ctrl+D"
                                       Icon="{antdicons:AntDesignIconProvider Kind=DeleteOutlined}" />
                        <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderPaste}">
                            <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderPaste}" InputGesture="Ctrl+P"
                                           Icon="{antdicons:AntDesignIconProvider Kind=FileDoneOutlined}" />
                            <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderPasteFromHistory}" InputGesture="Ctrl+Shift+V" />
                        </atom:MenuItem>
                    </atom:ContextMenu>
                </Border.ContextMenu>
                <atom:TextBlock Text="{gallery:MenuShowCaseLangResource P2TextRightClickToShowContextMenu}" />
            </Border>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MenuShowCaseLangResource ContextMenuItemsSourceTitle}"
            Description="{gallery:MenuShowCaseLangResource ContextMenuItemsSourceDescription}">
            <gallery:ShowCaseItem.Styles>
                <Style Selector="Border#ItemSourcesContextMenuContainer">
                    <Setter Property="BorderBrush" Value="Gray" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="CornerRadius" Value="6" />
                    <Setter Property="Padding" Value="10" />
                    <Setter Property="Margin" Value="10" />
                </Style>
            </gallery:ShowCaseItem.Styles>
            <Border Name="ItemSourcesContextMenuContainer">
                <Border.ContextMenu>
                    <atom:ContextMenu Name="BasicContextMenu">
                        <atom:ContextMenu.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="atom:IMenuItemData">
                                <atom:TextBlock Text="{Binding Header}" />
                            </TreeDataTemplate>
                        </atom:ContextMenu.ItemTemplate>
                    </atom:ContextMenu>
                </Border.ContextMenu>
                <atom:TextBlock Text="{gallery:MenuShowCaseLangResource P2TextRightClickToShowContextMenu}" />
            </Border>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MenuShowCaseLangResource MenuFlyoutTitle}"
            Description="{gallery:MenuShowCaseLangResource MenuFlyoutDescription}">
            <gallery:ShowCaseItem.Styles>
                <Style Selector="Border.ContextFlyoutContainer">
                    <Setter Property="BorderBrush" Value="Gray" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="CornerRadius" Value="6" />
                    <Setter Property="Padding" Value="10" />
                    <Setter Property="Margin" Value="10" />
                </Style>
            </gallery:ShowCaseItem.Styles>

            <StackPanel>
                <atom:Separator Title="{gallery:MenuShowCaseLangResource P2TitleNormal}" />
                <Border Classes="ContextFlyoutContainer">
                    <Border.ContextFlyout>
                        <atom:MenuFlyout IsMotionEnabled="True">
                            <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderCut}" InputGesture="Ctrl+X"
                                           Icon="{antdicons:AntDesignIconProvider Kind=ScissorOutlined}" />
                            <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderCopy}" InputGesture="Ctrl+C" Icon="{antdicons:AntDesignIconProvider Kind=CopyOutlined}" />
                            <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderDelete}" InputGesture="Ctrl+D"
                                           Icon="{antdicons:AntDesignIconProvider Kind=DeleteOutlined}" />
                            <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderPaste}">
                                <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderPaste}" InputGesture="Ctrl+P"
                                               Icon="{antdicons:AntDesignIconProvider Kind=FileDoneOutlined}" />
                                <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderPasteFromHistory}" InputGesture="Ctrl+Shift+V" />
                            </atom:MenuItem>
                        </atom:MenuFlyout>
                    </Border.ContextFlyout>
                    <atom:TextBlock Text="{gallery:MenuShowCaseLangResource P2TextRightClickToShowContextFlyout}" />
                </Border>

                <atom:Separator Title="{gallery:MenuShowCaseLangResource P2TitleGeneratedByTemplate}" />
                <Border Classes="ContextFlyoutContainer">
                    <Border.ContextFlyout>
                        <atom:MenuFlyout IsMotionEnabled="True"
                                         ItemsSource="{Binding MenuFlyoutItems}">
                            <atom:MenuFlyout.ItemTemplate>
                                <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="atom:IMenuItemData">
                                    <atom:TextBlock Text="{Binding Header}" />
                                </TreeDataTemplate>
                            </atom:MenuFlyout.ItemTemplate>
                        </atom:MenuFlyout>
                    </Border.ContextFlyout>
                    <atom:TextBlock Text="{gallery:MenuShowCaseLangResource P2TextRightClickToShowContextFlyout}" />
                </Border>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
