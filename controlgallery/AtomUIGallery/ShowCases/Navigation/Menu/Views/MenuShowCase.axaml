<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Menu.MenuShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:viewModels="clr-namespace:AtomUIGallery.ShowCases.Menu"
             x:DataType="viewModels:MenuViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:MenuShowCaseLangResource BasicTitle}"
            Description="{gallery:MenuShowCaseLangResource BasicDescription}">
            <atom:Menu>
                <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderFile}">
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderNewTextFile}" InputGesture="Ctrl+N" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderNewFile}" InputGesture="Ctrl+Alt+N" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderNewWindow}" InputGesture="Ctrl+Shift+N" />
                </atom:MenuItem>
                <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderEdit}">
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderUndo}" InputGesture="Ctrl+Shift+Z" />
                    <atom:MenuSeparator />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderCut}" InputGesture="Ctrl+X" />
                </atom:MenuItem>
                <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderDisabledItem}" IsEnabled="False" />
            </atom:Menu>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MenuShowCaseLangResource MenuItemItemsSourceTitle}"
            Description="{gallery:MenuShowCaseLangResource MenuItemItemsSourceDescription}">
            <atom:Menu Name="BasicItemsSourceMenu">
                <atom:Menu.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}"
                                      x:DataType="atom:IMenuItemData">
                        <atom:TextBlock Text="{Binding Header}" />
                    </TreeDataTemplate>
                </atom:Menu.ItemTemplate>
            </atom:Menu>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MenuShowCaseLangResource InlineNavMenuItemsSourceTitle}"
            Description="{gallery:MenuShowCaseLangResource InlineNavMenuItemsSourceDescription}">
            <atom:NavMenu Mode="Inline" Name="InlineModeMenu">
                <atom:NavMenu.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}"
                                      x:DataType="atom:INavMenuNode">
                        <atom:TextBlock Text="{Binding Header}" />
                    </TreeDataTemplate>
                </atom:NavMenu.ItemTemplate>
            </atom:NavMenu>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MenuShowCaseLangResource IconAndSubmenuTitle}"
            Description="{gallery:MenuShowCaseLangResource IconAndSubmenuDescription}">
            <atom:Menu>
                <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderFile}">
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderNewTextFile}" InputGesture="Ctrl+N" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderNewFile}" InputGesture="Ctrl+Alt+N" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderNewWindow}" InputGesture="Ctrl+Shift+N" />
                    <atom:MenuSeparator />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderSave}" InputGesture="Ctrl+S" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderSaveAs}" InputGesture="Ctrl+Shift+S" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderSaveAll}" InputGesture="Ctrl+K" />
                    <atom:MenuSeparator />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderExit}" />
                </atom:MenuItem>
                <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderEdit}">
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderUndo}" InputGesture="Ctrl+Shift+Z" />
                    <atom:MenuSeparator />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderCut}" InputGesture="Ctrl+X" Icon="{antdicons:AntDesignIconProvider Kind=ScissorOutlined}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderCopy}" InputGesture="Ctrl+C" Icon="{antdicons:AntDesignIconProvider Kind=CopyOutlined}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderDelete}" InputGesture="Ctrl+D" Icon="{antdicons:AntDesignIconProvider Kind=DeleteOutlined}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderPaste}">
                        <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderPaste}" InputGesture="Ctrl+P"
                                       Icon="{antdicons:AntDesignIconProvider Kind=FileDoneOutlined}" />
                        <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderPasteFromHistory}" InputGesture="Ctrl+Shift+V" />
                    </atom:MenuItem>
                </atom:MenuItem>
            </atom:Menu>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MenuShowCaseLangResource ToggleTypeTitle}"
            Description="{gallery:MenuShowCaseLangResource ToggleTypeDescription}">
            <atom:Menu>
                <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuA}">
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderNewTextFile}" InputGesture="Ctrl+N" ToggleType="Radio" GroupName="Group1" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderNewFile}" InputGesture="Ctrl+Alt+N" ToggleType="Radio" GroupName="Group1" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderNewWindow}" InputGesture="Ctrl+Shift+N" ToggleType="Radio"
                                   GroupName="Group1" />
                    <atom:MenuSeparator />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderSave}" InputGesture="Ctrl+S" ToggleType="CheckBox" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderSaveAs}" InputGesture="Ctrl+Shift+S" ToggleType="CheckBox"
                                   Icon="{antdicons:AntDesignIconProvider Kind=GithubOutlined}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderSaveAll}" InputGesture="Ctrl+K" ToggleType="CheckBox"
                                   Icon="{antdicons:AntDesignIconProvider Kind=CheckOutlined}" />
                    <atom:MenuSeparator />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderExit}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderDisabled}" IsEnabled="False" Icon="{antdicons:AntDesignIconProvider Kind=DeleteOutlined}" />
                </atom:MenuItem>
            </atom:Menu>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MenuShowCaseLangResource ScrollableTitle}"
            Description="{gallery:MenuShowCaseLangResource ScrollableDescription}">
            <atom:Menu>
                <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenu}">
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                    <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderMenuItem}" />
                </atom:MenuItem>
            </atom:Menu>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MenuShowCaseLangResource ContextMenuTitle}"
            Description="{gallery:MenuShowCaseLangResource ContextMenuDescription}">
            <gallery:ShowCaseItem.Styles>
                <Style Selector="Border#ContextMenuContainer">
                    <Setter Property="BorderBrush" Value="Gray" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="CornerRadius" Value="6" />
                    <Setter Property="Padding" Value="10" />
                    <Setter Property="Margin" Value="10" />
                </Style>
            </gallery:ShowCaseItem.Styles>
            <Border Name="ContextMenuContainer">
                <Border.ContextMenu>
                    <atom:ContextMenu>
                        <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderCut}" InputGesture="Ctrl+X"
                                       Icon="{antdicons:AntDesignIconProvider Kind=ScissorOutlined}" />
                        <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderCopy}" InputGesture="Ctrl+C" Icon="{antdicons:AntDesignIconProvider Kind=CopyOutlined}" />
                        <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderDelete}" InputGesture="Ctrl+D"
                                       Icon="{antdicons:AntDesignIconProvider Kind=DeleteOutlined}" />
                        <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderPaste}">
                            <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderPaste}" InputGesture="Ctrl+P"
                                           Icon="{antdicons:AntDesignIconProvider Kind=FileDoneOutlined}" />
                            <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderPasteFromHistory}" InputGesture="Ctrl+Shift+V" />
                        </atom:MenuItem>
                    </atom:ContextMenu>
                </Border.ContextMenu>
                <atom:TextBlock Text="{gallery:MenuShowCaseLangResource P2TextRightClickToShowContextMenu}" />
            </Border>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MenuShowCaseLangResource ContextMenuItemsSourceTitle}"
            Description="{gallery:MenuShowCaseLangResource ContextMenuItemsSourceDescription}">
            <gallery:ShowCaseItem.Styles>
                <Style Selector="Border#ItemSourcesContextMenuContainer">
                    <Setter Property="BorderBrush" Value="Gray" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="CornerRadius" Value="6" />
                    <Setter Property="Padding" Value="10" />
                    <Setter Property="Margin" Value="10" />
                </Style>
            </gallery:ShowCaseItem.Styles>
            <Border Name="ItemSourcesContextMenuContainer">
                <Border.ContextMenu>
                    <atom:ContextMenu Name="BasicContextMenu">
                        <atom:ContextMenu.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="atom:IMenuItemData">
                                <atom:TextBlock Text="{Binding Header}" />
                            </TreeDataTemplate>
                        </atom:ContextMenu.ItemTemplate>
                    </atom:ContextMenu>
                </Border.ContextMenu>
                <atom:TextBlock Text="{gallery:MenuShowCaseLangResource P2TextRightClickToShowContextMenu}" />
            </Border>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MenuShowCaseLangResource MenuFlyoutTitle}"
            Description="{gallery:MenuShowCaseLangResource MenuFlyoutDescription}">
            <gallery:ShowCaseItem.Styles>
                <Style Selector="Border.ContextFlyoutContainer">
                    <Setter Property="BorderBrush" Value="Gray" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="CornerRadius" Value="6" />
                    <Setter Property="Padding" Value="10" />
                    <Setter Property="Margin" Value="10" />
                </Style>
            </gallery:ShowCaseItem.Styles>

            <StackPanel>
                <atom:Separator Title="{gallery:MenuShowCaseLangResource P2TitleNormal}" />
                <Border Classes="ContextFlyoutContainer">
                    <Border.ContextFlyout>
                        <atom:MenuFlyout IsMotionEnabled="True">
                            <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderCut}" InputGesture="Ctrl+X"
                                           Icon="{antdicons:AntDesignIconProvider Kind=ScissorOutlined}" />
                            <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderCopy}" InputGesture="Ctrl+C" Icon="{antdicons:AntDesignIconProvider Kind=CopyOutlined}" />
                            <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderDelete}" InputGesture="Ctrl+D"
                                           Icon="{antdicons:AntDesignIconProvider Kind=DeleteOutlined}" />
                            <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderPaste}">
                                <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderPaste}" InputGesture="Ctrl+P"
                                               Icon="{antdicons:AntDesignIconProvider Kind=FileDoneOutlined}" />
                                <atom:MenuItem Header="{gallery:MenuShowCaseLangResource P2HeaderPasteFromHistory}" InputGesture="Ctrl+Shift+V" />
                            </atom:MenuItem>
                        </atom:MenuFlyout>
                    </Border.ContextFlyout>
                    <atom:TextBlock Text="{gallery:MenuShowCaseLangResource P2TextRightClickToShowContextFlyout}" />
                </Border>

                <atom:Separator Title="{gallery:MenuShowCaseLangResource P2TitleGeneratedByTemplate}" />
                <Border Classes="ContextFlyoutContainer">
                    <Border.ContextFlyout>
                        <atom:MenuFlyout IsMotionEnabled="True"
                                         ItemsSource="{Binding MenuFlyoutItems}">
                            <atom:MenuFlyout.ItemTemplate>
                                <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="atom:IMenuItemData">
                                    <atom:TextBlock Text="{Binding Header}" />
                                </TreeDataTemplate>
                            </atom:MenuFlyout.ItemTemplate>
                        </atom:MenuFlyout>
                    </Border.ContextFlyout>
                    <atom:TextBlock Text="{gallery:MenuShowCaseLangResource P2TextRightClickToShowContextFlyout}" />
                </Border>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MenuShowCaseLangResource VerticalNavMenuTitle}"
            Description="{gallery:MenuShowCaseLangResource VerticalNavMenuDescription}">
            <atom:NavMenu Mode="Vertical" Width="300" Margin="0, 0, 0, 20">
                <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderNavigationOne}" Icon="{antdicons:AntDesignIconProvider Kind=MailOutlined}" />
                <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderNavigationTwo}" Icon="{antdicons:AntDesignIconProvider Kind=AppstoreOutlined}"
                                  IsEnabled="False" />
                <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderNavigationThreeSubmenu}" Icon="{antdicons:AntDesignIconProvider Kind=SettingOutlined}">
                    <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderItemN1}">
                        <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderOptionN1}" />
                        <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderOptionN2}" />
                    </atom:NavMenuNode>

                    <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderItemN2}">
                        <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderOptionN3}" />
                        <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderOptionN4}" />
                    </atom:NavMenuNode>
                </atom:NavMenuNode>
                <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderNavigationFour}" />
            </atom:NavMenu>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MenuShowCaseLangResource InlineMenuTitle}"
            Description="{gallery:MenuShowCaseLangResource InlineMenuDescription}">
            <atom:NavMenu Mode="Inline" Width="300" Margin="0, 0, 0, 20">
                <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderNavigationOne}" Icon="{antdicons:AntDesignIconProvider Kind=MailOutlined}" />
                <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderNavigationTwo}" Icon="{antdicons:AntDesignIconProvider Kind=AppstoreOutlined}"
                                  IsEnabled="False" />
                <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderNavigationThreeSubmenu}" Icon="{antdicons:AntDesignIconProvider Kind=SettingOutlined}">
                    <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderItemN1}">
                        <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderOptionN1}" />
                        <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderOptionN2}" />
                    </atom:NavMenuNode>

                    <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderItemN2}">
                        <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderOptionN3}" />
                        <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderOptionN4}" />
                    </atom:NavMenuNode>
                </atom:NavMenuNode>
                <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderNavigationFour}" />
            </atom:NavMenu>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MenuShowCaseLangResource TopNavigationTitle}"
            Description="{gallery:MenuShowCaseLangResource TopNavigationDescription}"
            IsOccupyEntireRow="True">
            <StackPanel>
                <atom:NavMenu Mode="Horizontal">
                    <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderNavigationOne}" Icon="{antdicons:AntDesignIconProvider Kind=MailOutlined}" />
                    <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderNavigationTwo}" Icon="{antdicons:AntDesignIconProvider Kind=AppstoreOutlined}"
                                      IsEnabled="False" />
                    <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderNavigationThreeSubmenu}"
                                      Icon="{antdicons:AntDesignIconProvider Kind=SettingOutlined}">
                        <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderItemN1}">
                            <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderOptionN1}" />
                            <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderOptionN2}" />
                        </atom:NavMenuNode>

                        <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderItemN2}">
                            <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderOptionN3}" />
                            <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderOptionN4}" />
                        </atom:NavMenuNode>
                    </atom:NavMenuNode>
                    <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderNavigationFour}" />
                </atom:NavMenu>
                <atom:Separator />
                <atom:NavMenu IsDarkStyle="True" Mode="Horizontal">
                    <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderNavigationOne}" Icon="{antdicons:AntDesignIconProvider Kind=MailOutlined}" />
                    <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderNavigationTwo}" Icon="{antdicons:AntDesignIconProvider Kind=AppstoreOutlined}"
                                      IsEnabled="False" />
                    <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderNavigationThreeSubmenu}"
                                      Icon="{antdicons:AntDesignIconProvider Kind=SettingOutlined}">
                        <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderItemN1}">
                            <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderOptionN1}" />
                            <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderOptionN2}" />
                        </atom:NavMenuNode>

                        <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderItemN2}">
                            <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderOptionN3}" />
                            <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderOptionN4}" />
                        </atom:NavMenuNode>
                    </atom:NavMenuNode>
                    <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderNavigationFour}" />
                </atom:NavMenu>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MenuShowCaseLangResource SwitchMenuTypeTitle}"
            Description="{gallery:MenuShowCaseLangResource SwitchMenuTypeDescription}">
            <StackPanel Orientation="Vertical" Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <atom:ToggleSwitch Name="ChangeModeSwitch" />
                    <atom:TextBlock Text="{gallery:MenuShowCaseLangResource P2TextChangeMode}" />
                    <atom:ToggleSwitch Margin="10, 0, 0, 0" Name="ChangeStyleSwitch" />
                    <atom:TextBlock Text="{gallery:MenuShowCaseLangResource P2TextChangeStyle}" />
                </StackPanel>
                <atom:NavMenu Mode="{Binding Mode}" Width="300"
                              Margin="0, 0, 0, 20"
                              IsDarkStyle="{Binding IsDark}">
                    <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderNavigationOne}" Icon="{antdicons:AntDesignIconProvider Kind=MailOutlined}" />
                    <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderNavigationTwo}" Icon="{antdicons:AntDesignIconProvider Kind=AppstoreOutlined}"
                                      IsEnabled="False" />
                    <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderNavigationThreeSubmenu}"
                                      Icon="{antdicons:AntDesignIconProvider Kind=SettingOutlined}">
                        <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderItemN1}">
                            <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderOptionN1}" />
                            <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderOptionN2}" />
                        </atom:NavMenuNode>

                        <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderItemN2}">
                            <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderOptionN3}" />
                            <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderOptionN4}" />
                        </atom:NavMenuNode>
                    </atom:NavMenuNode>
                    <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderNavigationFour}" />
                </atom:NavMenu>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MenuShowCaseLangResource DefaultOpenedPathsTitle}"
            Description="{gallery:MenuShowCaseLangResource DefaultOpenedPathsDescription}">
            <atom:NavMenu Mode="Inline" Margin="0, 0, 0, 20"
                          DefaultOpenPaths="{Binding DefaultOpenPaths}"
                          DefaultSelectedPath="{Binding DefaultSelectedPath}">
                <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderNavigationOne}" Icon="{antdicons:AntDesignIconProvider Kind=MailOutlined}" ItemKey="1" />
                <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderNavigationTwo}" Icon="{antdicons:AntDesignIconProvider Kind=AppstoreOutlined}"
                                  IsEnabled="False"
                                  ItemKey="2" />
                <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderNavigationThreeSubmenu}" Icon="{antdicons:AntDesignIconProvider Kind=SettingOutlined}"
                                  ItemKey="3">
                    <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderItemN1}" ItemKey="SubGroup1">
                        <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderOptionN1}" ItemKey="Option1" />
                        <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderOptionN2}" ItemKey="Option2" />
                    </atom:NavMenuNode>

                    <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderItemN2}" ItemKey="SubGroup2">
                        <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderOptionN3}" ItemKey="Option3" />
                        <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderOptionN4}" ItemKey="Option4" />
                    </atom:NavMenuNode>
                </atom:NavMenuNode>
                <atom:NavMenuNode Header="{gallery:MenuShowCaseLangResource P2HeaderNavigationFour}" ItemKey="4" />
            </atom:NavMenu>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:MenuShowCaseLangResource NavMenuItemItemsSourceTitle}"
            Description="{gallery:MenuShowCaseLangResource NavMenuItemItemsSourceDescription}">
            <atom:NavMenu Name="ItemsSourceDemoNavMenu"
                          Mode="Inline"
                          SelectedItem="{Binding DefaultSelectedNode}"
                          DefaultSelectedPath="{Binding DefaultSelectedPath}" />
        </gallery:ShowCaseItem>

    </gallery:ShowCasePanel>
</UserControl>
