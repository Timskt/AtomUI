<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Menu.MenuShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:viewModels="clr-namespace:AtomUIGallery.ShowCases.Menu"
             x:DataType="viewModels:MenuViewModel">
    <atom:TabControl Name="ScenarioTabs"
                     SizeType="Large"
                     SelectedIndex="0">
        <atom:TabItem Header="{gallery:MenuShowCaseLangResource ScenarioBasic}" Tag="Basic" />
        <atom:TabItem Header="{gallery:MenuShowCaseLangResource ScenarioFeatures}" Tag="Features" />
        <atom:TabItem Header="{gallery:MenuShowCaseLangResource ScenarioItemsSource}" Tag="ItemsSource" />
        <atom:TabItem Header="{gallery:MenuShowCaseLangResource ScenarioContext}" Tag="Context" />
        <atom:TabItem Header="{gallery:MenuShowCaseLangResource ScenarioNavMenu}" Tag="NavMenu" />
    </atom:TabControl>
</UserControl>
