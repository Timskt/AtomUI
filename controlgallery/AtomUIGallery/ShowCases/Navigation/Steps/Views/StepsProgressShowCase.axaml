<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Steps.StepsProgressShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.Steps"
             x:DataType="vm:StepsViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:StepsShowCaseLangResource StepsWithProgressTitle}"
            Description="{gallery:StepsShowCaseLangResource StepsWithProgressDescription}"
            IsOccupyEntireRow="True"
            MinHeight="200">
            <StackPanel Orientation="Vertical" Spacing="20">
                <atom:Steps CurrentStep="1" ProgressValue="60" IsShowItemProgress="True">
                    <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderFinished}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}" />
                    <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderInProgress}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}" SubHeader="{gallery:StepsShowCaseLangResource P2SubHeaderLeftTime}" />
                    <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderWaiting}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}" />
                </atom:Steps>
                <atom:Separator/>
                <atom:Steps CurrentStep="1" ProgressValue="30" IsShowItemProgress="True" SizeType="Small">
                    <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderFinished}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}" />
                    <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderInProgress}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}" SubHeader="{gallery:StepsShowCaseLangResource P2SubHeaderLeftTime}" />
                    <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderWaiting}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}" />
                </atom:Steps>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:StepsShowCaseLangResource LabelPlacementTitle}"
            Description="{gallery:StepsShowCaseLangResource LabelPlacementDescription}"
            IsOccupyEntireRow="True"
            MinHeight="200">
            <StackPanel Orientation="Vertical" Spacing="20">
                <atom:Steps CurrentStep="1" LabelPlacement="Vertical">
                    <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderFinished}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}" />
                    <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderInProgress}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}" SubHeader="{gallery:StepsShowCaseLangResource P2SubHeaderLeftTime}" />
                    <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderWaiting}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}" />
                </atom:Steps>
                <atom:Separator />
                <atom:Steps CurrentStep="1" LabelPlacement="Vertical" ProgressValue="45" IsShowItemProgress="True">
                    <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderFinished}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}" />
                    <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderInProgress}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}" SubHeader="{gallery:StepsShowCaseLangResource P2SubHeaderLeftTime}" />
                    <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderWaiting}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}" />
                </atom:Steps>
                <atom:Separator />
                <atom:Steps CurrentStep="1" LabelPlacement="Vertical" ProgressValue="45" IsShowItemProgress="True" SizeType="Small">
                    <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderFinished}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}" />
                    <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderInProgress}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}" SubHeader="{gallery:StepsShowCaseLangResource P2SubHeaderLeftTime}" />
                    <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderWaiting}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}" />
                </atom:Steps>
                <atom:Separator />
                <atom:Steps CurrentStep="1" Style="Navigation" IsItemClickable="True" ProgressValue="45" IsShowItemProgress="True" LabelPlacement="Vertical">
                    <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderStepN1}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}"/>
                    <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderStepN2}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}"/>
                    <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderStepN3}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}"/>
                    <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderStepN4}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}"/>
                </atom:Steps>
                <atom:Separator />
                <atom:Steps CurrentStep="1" Style="Navigation" IsItemClickable="True" ProgressValue="67" IsShowItemProgress="True" LabelPlacement="Vertical" SizeType="Small">
                    <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderStepN1}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}"/>
                    <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderStepN2}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}"/>
                    <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderStepN3}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}"/>
                    <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderStepN4}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}"/>
                </atom:Steps>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
