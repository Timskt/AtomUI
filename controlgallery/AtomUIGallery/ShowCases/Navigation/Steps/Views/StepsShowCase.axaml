<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Steps.StepsShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.Steps"
             x:DataType="vm:StepsViewModel">
    <atom:TabControl Name="ScenarioTabs"
                     SizeType="Large"
                     SelectedIndex="0">
        <atom:TabItem Header="{gallery:StepsShowCaseLangResource ScenarioBasic}" Tag="Basic" />
        <atom:TabItem Header="{gallery:StepsShowCaseLangResource ScenarioInteractive}" Tag="Interactive" />
        <atom:TabItem Header="{gallery:StepsShowCaseLangResource ScenarioVertical}" Tag="Vertical" />
        <atom:TabItem Header="{gallery:StepsShowCaseLangResource ScenarioDotClickable}" Tag="DotClickable" />
        <atom:TabItem Header="{gallery:StepsShowCaseLangResource ScenarioNavigation}" Tag="Navigation" />
        <atom:TabItem Header="{gallery:StepsShowCaseLangResource ScenarioProgress}" Tag="Progress" />
        <atom:TabItem Header="{gallery:StepsShowCaseLangResource ScenarioInline}" Tag="Inline" />
    </atom:TabControl>
</UserControl>
