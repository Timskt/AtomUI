<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Steps.StepsVerticalShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.Steps"
             x:DataType="vm:StepsViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="{gallery:StepsShowCaseLangResource VerticalTitle}"
            Description="{gallery:StepsShowCaseLangResource VerticalDescription}"
            IsOccupyEntireRow="True"
            MinHeight="200">
            <atom:Steps CurrentStep="1" Orientation="Vertical">
                <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderFinished}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}" />
                <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderInProgress}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}" SubHeader="{gallery:StepsShowCaseLangResource P2SubHeaderLeftTime}" />
                <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderWaiting}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}" />
            </atom:Steps>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:StepsShowCaseLangResource VerticalMiniVersionTitle}"
            Description="{gallery:StepsShowCaseLangResource VerticalMiniVersionDescription}"
            IsOccupyEntireRow="True"
            MinHeight="200">
            <atom:Steps CurrentStep="1" Orientation="Vertical" SizeType="Small">
                <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderFinished}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}" />
                <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderInProgress}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}" SubHeader="{gallery:StepsShowCaseLangResource P2SubHeaderLeftTime}" />
                <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderWaiting}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}" />
            </atom:Steps>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="{gallery:StepsShowCaseLangResource ErrorStatusTitle}"
            Description="{gallery:StepsShowCaseLangResource ErrorStatusDescription}"
            IsOccupyEntireRow="True"
            MinHeight="200">
            <atom:Steps CurrentStep="1" CurrentStepStatus="Error">
                <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderFinished}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}" />
                <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderInProgress}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}" SubHeader="{gallery:StepsShowCaseLangResource P2SubHeaderLeftTime}" />
                <atom:StepsItem Header="{gallery:StepsShowCaseLangResource P2HeaderWaiting}" Description="{gallery:StepsShowCaseLangResource P2DescriptionThisIsADescription}" />
            </atom:Steps>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
