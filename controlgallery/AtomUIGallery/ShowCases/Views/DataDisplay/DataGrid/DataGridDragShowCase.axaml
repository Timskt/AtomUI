<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Views.DataGridDragShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:vm="using:AtomUIGallery.ShowCases.ViewModels">
    <gallery:ShowCasePanel>

        <gallery:ShowCaseItem Title="Drag Column sorting"
                              Description="Drag the Header to sort the columns."
                              IsOccupyEntireRow="True">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Separator Title="Normal" TitlePosition="Left"
                                FontWeight="Bold" />
                <atom:DataGrid x:Name="DragColumnDataGrid1"
                               CanUserReorderColumns="True"
                               x:DataType="vm:DragColumnDataType">
                    <atom:DataGrid.Columns>
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Gender" Binding="{Binding Gender}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Email" Binding="{Binding Email}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Name" Binding="{Binding Name}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Address" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn Header="Age" Binding="{Binding Age}" />
                    </atom:DataGrid.Columns>
                </atom:DataGrid>

                <atom:Separator Title="Many columns" TitlePosition="Left" Margin="0, 20, 0, 0"
                                FontWeight="Bold" />
                <atom:DataGrid x:Name="DragColumnDataGrid2"
                               CanUserReorderColumns="True"
                               x:DataType="vm:DragColumnDataType">
                    <atom:DataGrid.Columns>
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Gender" Binding="{Binding Gender}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Email" Binding="{Binding Email}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Name" Binding="{Binding Name}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Address" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Age" Binding="{Binding Age}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Column1" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Column2" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Column3" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Column4" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Column5" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Column6" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Column7" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Column8" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Column9" Binding="{Binding Address}" />
                    </atom:DataGrid.Columns>
                </atom:DataGrid>

                <atom:Separator Title="Drag reorder with frozen columns" TitlePosition="Left" Margin="0, 20, 0, 0"
                                FontWeight="Bold" />
                <atom:DataGrid x:Name="DragColumnDataGrid3"
                               CanUserReorderColumns="True"
                               LeftFrozenColumnCount="2"
                               RightFrozenColumnCount="2"
                               x:DataType="vm:DragColumnDataType">
                    <atom:DataGrid.Columns>
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Gender" Binding="{Binding Gender}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Email" Binding="{Binding Email}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Name" Binding="{Binding Name}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Address" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Age" Binding="{Binding Age}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Column1" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Column2" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Column3" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Column4" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Column5" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Column6" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Column7" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Column8" Binding="{Binding Address}" />
                        <atom:DataGridTextColumn CanUserReorder="True" Header="Column9" Binding="{Binding Address}" />
                    </atom:DataGrid.Columns>
                </atom:DataGrid>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem Title="Drag sorting with handler"
                              Description="You can drag the row indicator column to sort the rows."
                              IsOccupyEntireRow="True">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Separator Title="Normal" TitlePosition="Left"
                                FontWeight="Bold" />
                <atom:DataGrid x:Name="DragRowDataGrid1"
                               CanUserReorderRows="True"
                               x:DataType="vm:DataGridBaseInfo">
                    <atom:DataGrid.Columns>
                        <atom:DataGridRowReorderColumn />
                        <atom:DataGridTextColumn Header="Name" Binding="{Binding Name}" />
                        <atom:DataGridTextColumn Header="Address" Binding="{Binding Name}" />
                        <atom:DataGridTextColumn Header="Age" Binding="{Binding Address}" />
                    </atom:DataGrid.Columns>
                </atom:DataGrid>

                <atom:Separator Title="Normal" TitlePosition="Left"
                                FontWeight="Bold"
                                Margin="0, 20, 0, 0" />
                <atom:DataGrid x:Name="DragRowDataGrid2"
                               CanUserReorderRows="True"
                               Height="400"
                               x:DataType="vm:DataGridBaseInfo">
                    <atom:DataGrid.Columns>
                        <atom:DataGridRowReorderColumn />
                        <atom:DataGridTextColumn Header="Name" Binding="{Binding Name}" />
                        <atom:DataGridTextColumn Header="Address" Binding="{Binding Name}" />
                        <atom:DataGridTextColumn Header="Age" Binding="{Binding Address}" />
                    </atom:DataGrid.Columns>
                </atom:DataGrid>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
