<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Views.DataGridShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:vm="using:AtomUIGallery.ShowCases.ViewModels"
             x:DataType="vm:DataGridViewModel">
    <atom:TabControl Name="ScenarioTabs"
                     SizeType="Large"
                     SelectedIndex="0">
        <atom:TabItem Header="Basic" Tag="Basic" />
        <atom:TabItem Header="Interaction" Tag="Interaction" />
        <atom:TabItem Header="Filtering" Tag="Filtering" />
        <atom:TabItem Header="Structure" Tag="Structure" />
        <atom:TabItem Header="Fixed" Tag="Fixed" />
        <atom:TabItem Header="Drag" Tag="Drag" />
        <atom:TabItem Header="Editing" Tag="Editing" />
        <atom:TabItem Header="Paging" Tag="Paging" />
    </atom:TabControl>
</UserControl>
