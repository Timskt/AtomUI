<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Views.TagShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:gallery="https://atomui.net/oss-controls/gallery">
    <gallery:ShowCasePanel>
        <gallery:ShowCasePanel.Styles>
            <Style Selector="atom|AbstractTag">
                <Setter Property="Margin" Value="5" />
            </Style>
        </gallery:ShowCasePanel.Styles>
        <gallery:ShowCaseItem
            Title="Basic"
            Description="Usage of basic Tag, and it could be IsClosable and customize close button by set closeIcon property,will display default close button when closeIcon is setting to true. IsClosable Tag supports onClose events.">
            <WrapPanel HorizontalAlignment="Left" Orientation="Horizontal">
                <atom:AbstractTag>Tag 1</atom:AbstractTag>
                <atom:AbstractTag>Link</atom:AbstractTag>
                <atom:AbstractTag IsClosable="true">Prevent Default</atom:AbstractTag>
                <atom:AbstractTag IsClosable="True"
                          CloseIcon="{antdicons:AntDesignIconProvider Kind=CloseCircleOutlined}">
                    Tag 2
                </atom:AbstractTag>
            </WrapPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="Colorful Tag"
            Description="We preset a series of colorful tag styles for use in different situations. You can also set it to a hex color string for custom color.">
            <StackPanel Orientation="Vertical">
                <atom:TextBlock FontWeight="Bold" FontSize="14" Margin="0, 0, 0, 10">Presets</atom:TextBlock>
                <WrapPanel HorizontalAlignment="Left">
                    <atom:AbstractTag TagColor="magenta">magenta</atom:AbstractTag>
                    <atom:AbstractTag TagColor="red">red</atom:AbstractTag>
                    <atom:AbstractTag TagColor="volcano">volcano</atom:AbstractTag>
                    <atom:AbstractTag TagColor="orange">orange</atom:AbstractTag>
                    <atom:AbstractTag TagColor="gold">gold</atom:AbstractTag>
                    <atom:AbstractTag TagColor="lime">lime</atom:AbstractTag>
                    <atom:AbstractTag TagColor="green">green</atom:AbstractTag>
                    <atom:AbstractTag TagColor="cyan">cyan</atom:AbstractTag>
                    <atom:AbstractTag TagColor="blue">blue</atom:AbstractTag>
                    <atom:AbstractTag TagColor="geekblue">geekblue</atom:AbstractTag>
                    <atom:AbstractTag TagColor="purple">purple</atom:AbstractTag>
                </WrapPanel>

                <atom:TextBlock FontWeight="Bold" FontSize="14" Margin="0, 20, 0, 10">Custom</atom:TextBlock>
                <WrapPanel HorizontalAlignment="Left">
                    <atom:AbstractTag TagColor="#f50">#f50</atom:AbstractTag>
                    <atom:AbstractTag TagColor="#2db7f5" IsClosable="True">#2db7f5</atom:AbstractTag>
                    <atom:AbstractTag TagColor="#87d068">#87d068</atom:AbstractTag>
                    <atom:AbstractTag TagColor="#108ee9">#108ee9</atom:AbstractTag>
                </WrapPanel>
            </StackPanel>

        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="Status Tag"
            Description="We preset five different colors, you can set color property such as success,processing,error,default and warning to indicate specific status.">
            <StackPanel Orientation="Vertical">
                <atom:TextBlock FontWeight="Bold" FontSize="14" Margin="0, 0, 0, 10">Without icon</atom:TextBlock>
                <WrapPanel HorizontalAlignment="Left">
                    <atom:AbstractTag TagColor="success">success</atom:AbstractTag>
                    <atom:AbstractTag TagColor="info">processing</atom:AbstractTag>
                    <atom:AbstractTag TagColor="error">error</atom:AbstractTag>
                    <atom:AbstractTag TagColor="warning">warning</atom:AbstractTag>
                    <atom:AbstractTag TagColor="default">default</atom:AbstractTag>
                </WrapPanel>

                <atom:TextBlock FontWeight="Bold" FontSize="14" Margin="0, 20, 0, 10">Custom</atom:TextBlock>
                <WrapPanel HorizontalAlignment="Left">
                    <atom:AbstractTag TagColor="success"
                              Icon="{antdicons:AntDesignIconProvider Kind=CheckCircleOutlined}">
                        success
                    </atom:AbstractTag>
                    <atom:AbstractTag TagColor="info"
                              Icon="{antdicons:AntDesignIconProvider Kind=SyncOutlined}">
                        processing
                    </atom:AbstractTag>
                    <atom:AbstractTag TagColor="error"
                              Icon="{antdicons:AntDesignIconProvider Kind=CloseCircleOutlined}">
                        error
                    </atom:AbstractTag>
                    <atom:AbstractTag TagColor="warning"
                              Icon="{antdicons:AntDesignIconProvider Kind=ExclamationCircleOutlined}">
                        warning
                    </atom:AbstractTag>
                    <atom:AbstractTag TagColor="default"
                              Icon="{antdicons:AntDesignIconProvider Kind=ClockCircleOutlined}">
                        default
                    </atom:AbstractTag>
                    <atom:AbstractTag TagColor="default"
                              Icon="{antdicons:AntDesignIconProvider Kind=MinusCircleOutlined}">
                        default
                    </atom:AbstractTag>
                </WrapPanel>
            </StackPanel>

        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="Icon"
            Description="Tag components can contain an Icon. This is done by setting the icon property or placing an Icon component within the Tag.
If you want specific control over the positioning and placement of the Icon, then that should be done by placing the Icon component within the Tag rather than using the icon property.">
            <WrapPanel HorizontalAlignment="Left" Orientation="Horizontal">
                <atom:AbstractTag TagColor="#55acee"
                          Icon="{antdicons:AntDesignIconProvider Kind=TwitterOutlined}">
                    Twitter
                </atom:AbstractTag>
                <atom:AbstractTag TagColor="#cd201f"
                          Icon="{antdicons:AntDesignIconProvider Kind=YoutubeOutlined}">
                    Youtube
                </atom:AbstractTag>
                <atom:AbstractTag TagColor="#3b5999"
                          Icon="{antdicons:AntDesignIconProvider Kind=FacebookOutlined}">
                    Facebook
                </atom:AbstractTag>
                <atom:AbstractTag TagColor="#55acee"
                          Icon="{antdicons:AntDesignIconProvider Kind=LinkedinOutlined}">
                    Linkedin
                </atom:AbstractTag>
                <atom:AbstractTag TagColor="#55acee">
                    <atom:AbstractTag.Icon>
                        <PathIcon Data="M240-200h120v-240h240v240h120v-360L480-740 240-560v360Zm-80 80v-480l320-240 320 240v480H520v-240h-80v240H160Zm320-350Z"/>
                    </atom:AbstractTag.Icon>
                    Material icon
                </atom:AbstractTag>
            </WrapPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="borderless"
            Description="borderless">
            <StackPanel Orientation="Vertical">
                <WrapPanel HorizontalAlignment="Left">
                    <atom:AbstractTag Bordered="False">Tag1</atom:AbstractTag>
                    <atom:AbstractTag Bordered="False">Tag2</atom:AbstractTag>
                    <atom:AbstractTag Bordered="False" IsClosable="True">Tag3</atom:AbstractTag>
                    <atom:AbstractTag Bordered="False" IsClosable="True">Tag4</atom:AbstractTag>
                </WrapPanel>

                <atom:Separator FontWeight="Bold" FontSize="14" Margin="0, 20, 0, 20" />
                <WrapPanel HorizontalAlignment="Left">
                    <atom:AbstractTag TagColor="magenta" Bordered="False">magenta</atom:AbstractTag>
                    <atom:AbstractTag TagColor="red" Bordered="False">red</atom:AbstractTag>
                    <atom:AbstractTag TagColor="volcano" Bordered="False">volcano</atom:AbstractTag>
                    <atom:AbstractTag TagColor="orange" Bordered="False">orange</atom:AbstractTag>
                    <atom:AbstractTag TagColor="gold" Bordered="False">gold</atom:AbstractTag>
                    <atom:AbstractTag TagColor="lime" Bordered="False">lime</atom:AbstractTag>
                    <atom:AbstractTag TagColor="green" Bordered="False">green</atom:AbstractTag>
                    <atom:AbstractTag TagColor="cyan" Bordered="False">cyan</atom:AbstractTag>
                    <atom:AbstractTag TagColor="blue" Bordered="False">blue</atom:AbstractTag>
                    <atom:AbstractTag TagColor="geekblue" Bordered="False">geekblue</atom:AbstractTag>
                    <atom:AbstractTag TagColor="purple" Bordered="False">purple</atom:AbstractTag>

                    <atom:AbstractTag TagColor="success" Bordered="False">success</atom:AbstractTag>
                    <atom:AbstractTag TagColor="info" Bordered="False">processing</atom:AbstractTag>
                    <atom:AbstractTag TagColor="error" Bordered="False">error</atom:AbstractTag>
                    <atom:AbstractTag TagColor="warning" Bordered="False">warning</atom:AbstractTag>
                </WrapPanel>
            </StackPanel>

        </gallery:ShowCaseItem>

    </gallery:ShowCasePanel>
</UserControl>