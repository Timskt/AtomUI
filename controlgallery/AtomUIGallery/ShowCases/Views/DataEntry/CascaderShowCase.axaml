<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Views.CascaderShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:viewModels="clr-namespace:AtomUIGallery.ShowCases.ViewModels"
             xmlns:gallery="https://atomui.net/oss-controls/gallery">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="Basic"
            Description="Cascade selection box for selecting province/city/district.">
            <atom:Cascader
                Name="BasicCascader"
                PlaceholderText="Please select"
                IsAllowClear="True">
                <atom:Cascader.OptionTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}"
                                      x:DataType="atom:ICascaderOption">
                        <atom:TextBlock Text="{Binding Header}" />
                    </TreeDataTemplate>
                </atom:Cascader.OptionTemplate>
            </atom:Cascader>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="Default value"
            Description="Specifies default value by an array.">
            <atom:Cascader
                Name="DefaultValueCascader"
                PlaceholderText="Please select"
                IsAllowClear="True">
                <atom:Cascader.OptionTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}"
                                      x:DataType="atom:ICascaderOption">
                        <atom:TextBlock Text="{Binding Header}" />
                    </TreeDataTemplate>
                </atom:Cascader.OptionTemplate>
            </atom:Cascader>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="Hover"
            Description="Hover to expand sub menu, click to select option.">
            <atom:Cascader
                Name="HoverCascader"
                PlaceholderText="Please select"
                IsAllowClear="True"
                ExpandTrigger="Hover">
                <atom:Cascader.OptionTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}"
                                      x:DataType="atom:ICascaderOption">
                        <atom:TextBlock Text="{Binding Header}" />
                    </TreeDataTemplate>
                </atom:Cascader.OptionTemplate>
            </atom:Cascader>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="Disabled option"
            Description="Disable option by specifying the disabled property in options.">
            <atom:Cascader
                Name="DisabledCascader"
                PlaceholderText="Please select"
                IsAllowClear="True">
                <atom:Cascader.OptionTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}"
                                      x:DataType="atom:ICascaderOption">
                        <atom:TextBlock Text="{Binding Header}" />
                    </TreeDataTemplate>
                </atom:Cascader.OptionTemplate>
            </atom:Cascader>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="Change on select"
            Description="Allows the selection of only parent options.">
            <atom:Cascader
                Name="SelectParentCascader"
                PlaceholderText="Please select"
                IsAllowClear="True"
                IsAllowSelectParent="True">
                <atom:Cascader.OptionTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}"
                                      x:DataType="atom:ICascaderOption">
                        <atom:TextBlock Text="{Binding Header}" />
                    </TreeDataTemplate>
                </atom:Cascader.OptionTemplate>
            </atom:Cascader>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="Multiple"
            Description="Select multiple options. Disable the checkbox by adding the disableCheckbox property and selecting a specific item. The style of the disable can be modified by the className.">
            <atom:Cascader
                Name="MultiSelectCascader"
                PlaceholderText="Please select"
                HorizontalAlignment="Stretch"
                ShowCheckedStrategy="ShowParent"
                IsAllowClear="True"
                IsMultiple="True">
                <atom:Cascader.OptionTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}"
                                      x:DataType="atom:ICascaderOption">
                        <atom:TextBlock Text="{Binding Header}" />
                    </TreeDataTemplate>
                </atom:Cascader.OptionTemplate>
            </atom:Cascader>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="ShowCheckedStrategy"
            Description="Shows a selected item in a box using showCheckedStrategy.">
            <StackPanel Spacing="15">
                <atom:Separator Title="ShowCheckedStrategy=All"/>
                <atom:Cascader
                    Name="CheckStrategyAllCascader"
                    PlaceholderText="Please select"
                    HorizontalAlignment="Stretch"
                    ShowCheckedStrategy="All"
                    IsAllowClear="True"
                    IsResponsiveTagMode="True"
                    IsMultiple="True">
                    <atom:Cascader.OptionTemplate>
                        <TreeDataTemplate ItemsSource="{Binding Children}"
                                          x:DataType="atom:ICascaderOption">
                            <atom:TextBlock Text="{Binding Header}" />
                        </TreeDataTemplate>
                    </atom:Cascader.OptionTemplate>
                </atom:Cascader>
                <atom:Separator Title="ShowCheckedStrategy=ShowParent"/>
                <atom:Cascader
                    Name="CheckStrategyShowParentCascader"
                    PlaceholderText="Please select"
                    HorizontalAlignment="Stretch"
                    ShowCheckedStrategy="ShowParent"
                    IsAllowClear="True"
                    IsResponsiveTagMode="True"
                    IsMultiple="True">
                    <atom:Cascader.OptionTemplate>
                        <TreeDataTemplate ItemsSource="{Binding Children}"
                                          x:DataType="atom:ICascaderOption">
                            <atom:TextBlock Text="{Binding Header}" />
                        </TreeDataTemplate>
                    </atom:Cascader.OptionTemplate>
                </atom:Cascader>
            </StackPanel>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="Search"
            Description="Search and select options directly.">
            <atom:Cascader
                Name="SearchCascader"
                PlaceholderText="Please select"
                IsAllowClear="True"
                IsFilterEnabled="True">
                <atom:Cascader.OptionTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}"
                                      x:DataType="atom:ICascaderOption">
                        <atom:TextBlock Text="{Binding Header}" />
                    </TreeDataTemplate>
                </atom:Cascader.OptionTemplate>
            </atom:Cascader>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="Load Options Lazily"
            Description="Load options lazily with loadData.">
            <atom:Cascader
                Name="AsyncLoadCascader"
                x:DataType="viewModels:CascaderViewModel"
                PlaceholderText="Please select"
                IsAllowClear="True">
                <atom:Cascader.OptionTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}"
                                      x:DataType="atom:ICascaderOption">
                        <atom:TextBlock Text="{Binding Header}" />
                    </TreeDataTemplate>
                </atom:Cascader.OptionTemplate>
            </atom:Cascader>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="Prefix and Suffix"
            Description="Use prefix to customize the prefix content, use suffixIcon to customize the selection box suffix icon, and use expandIcon to customize the current item expand icon.">
            <StackPanel Spacing="10">
                <atom:Cascader
                    Name="PrefixAndSuffixCascader1"
                    PlaceholderText="Please select"
                    IsAllowClear="True"
                    SuffixIcon="{antdicons:AntDesignIconProvider SmileOutlined}">
                    <atom:Cascader.OptionTemplate>
                        <TreeDataTemplate ItemsSource="{Binding Children}"
                                          x:DataType="atom:ICascaderOption">
                            <atom:TextBlock Text="{Binding Header}" />
                        </TreeDataTemplate>
                    </atom:Cascader.OptionTemplate>
                </atom:Cascader>
        
                <atom:Cascader
                    Name="PrefixAndSuffixCascader2"
                    PlaceholderText="Please select"
                    IsAllowClear="True">
                    <atom:Cascader.ExpandIcon>
                        <atom:IconTemplate>
                            <antdicons:SmileOutlined/>
                        </atom:IconTemplate>
                    </atom:Cascader.ExpandIcon>
                    <atom:Cascader.OptionTemplate>
                        <TreeDataTemplate ItemsSource="{Binding Children}"
                                          x:DataType="atom:ICascaderOption">
                            <atom:TextBlock Text="{Binding Header}" />
                        </TreeDataTemplate>
                    </atom:Cascader.OptionTemplate>
                </atom:Cascader>
        
                <atom:Cascader
                    Name="PrefixAndSuffixCascader3"
                    PlaceholderText="Please select"
                    IsAllowClear="True">
                    <atom:Cascader.ContentLeftAddOn>
                        <antdicons:SmileOutlined/>
                    </atom:Cascader.ContentLeftAddOn>
                    <atom:Cascader.OptionTemplate>
                        <TreeDataTemplate ItemsSource="{Binding Children}"
                                          x:DataType="atom:ICascaderOption">
                            <atom:TextBlock Text="{Binding Header}" />
                        </TreeDataTemplate>
                    </atom:Cascader.OptionTemplate>
                </atom:Cascader>
            </StackPanel>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="Variants"
            Description="Variants of Cascader, there are four variants: outlined filled borderless and underlined.">
            <StackPanel Spacing="15">
                <atom:Cascader
                    x:DataType="viewModels:CascaderViewModel"
                    PlaceholderText="Please select"
                    IsAllowClear="True"
                    StyleVariant="Borderless">
                    <atom:Cascader.OptionTemplate>
                        <TreeDataTemplate ItemsSource="{Binding Children}"
                                          x:DataType="atom:ICascaderOption">
                            <atom:TextBlock Text="{Binding Header}" />
                        </TreeDataTemplate>
                    </atom:Cascader.OptionTemplate>
                </atom:Cascader>
        
                <atom:Cascader
                    x:DataType="viewModels:CascaderViewModel"
                    PlaceholderText="Please select"
                    IsAllowClear="True"
                    StyleVariant="Filled">
                    <atom:Cascader.OptionTemplate>
                        <TreeDataTemplate ItemsSource="{Binding Children}"
                                          x:DataType="atom:ICascaderOption">
                            <atom:TextBlock Text="{Binding Header}" />
                        </TreeDataTemplate>
                    </atom:Cascader.OptionTemplate>
                </atom:Cascader>
        
                <atom:Cascader
                    x:DataType="viewModels:CascaderViewModel"
                    PlaceholderText="Please select"
                    IsAllowClear="True"
                    StyleVariant="Outlined">
                    <atom:Cascader.OptionTemplate>
                        <TreeDataTemplate ItemsSource="{Binding Children}"
                                          x:DataType="atom:ICascaderOption">
                            <atom:TextBlock Text="{Binding Header}" />
                        </TreeDataTemplate>
                    </atom:Cascader.OptionTemplate>
                </atom:Cascader>
        
                <atom:Cascader
                    x:DataType="viewModels:CascaderViewModel"
                    PlaceholderText="Please select"
                    IsAllowClear="True"
                    StyleVariant="Underlined">
                    <atom:Cascader.OptionTemplate>
                        <TreeDataTemplate ItemsSource="{Binding Children}"
                                          x:DataType="atom:ICascaderOption">
                            <atom:TextBlock Text="{Binding Header}" />
                        </TreeDataTemplate>
                    </atom:Cascader.OptionTemplate>
                </atom:Cascader>
            </StackPanel>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="Placement"
            Description="You can manually specify the position of the popup via placement.">
        
            <StackPanel Orientation="Vertical" Spacing="20">
                <atom:TextBlock VerticalAlignment="Center">Placement:</atom:TextBlock>
                <atom:OptionButtonGroup ButtonStyle="Outline" OptionCheckedChanged="HandlePlacementOptionCheckedChanged">
                    <atom:OptionButton IsChecked="True">TopLeft</atom:OptionButton>
                    <atom:OptionButton>TopRight</atom:OptionButton>
                    <atom:OptionButton>BottomLeft</atom:OptionButton>
                    <atom:OptionButton>BottomRight</atom:OptionButton>
                </atom:OptionButtonGroup>
                <atom:Cascader
                    Name="PlacementCascader"
                    x:DataType="viewModels:CascaderViewModel"
                    PlaceholderText="Please select"
                    IsAllowClear="True"
                    Placement="{Binding Placement}">
                    <atom:Cascader.OptionTemplate>
                        <TreeDataTemplate ItemsSource="{Binding Children}"
                                          x:DataType="atom:ICascaderOption">
                            <atom:TextBlock Text="{Binding Header}" />
                        </TreeDataTemplate>
                    </atom:Cascader.OptionTemplate>
                </atom:Cascader>
            </StackPanel>
        
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="Status"
            Description="Add status to Cascader with status, which could be error or warning.">
            <StackPanel Spacing="15">
                <atom:Cascader
                    x:DataType="viewModels:CascaderViewModel"
                    PlaceholderText="Please select"
                    IsAllowClear="True"
                    Status="Error">
                    <atom:Cascader.OptionTemplate>
                        <TreeDataTemplate ItemsSource="{Binding Children}"
                                          x:DataType="atom:ICascaderOption">
                            <atom:TextBlock Text="{Binding Header}" />
                        </TreeDataTemplate>
                    </atom:Cascader.OptionTemplate>
                </atom:Cascader>
        
                <atom:Cascader
                    x:DataType="viewModels:CascaderViewModel"
                    PlaceholderText="Please select"
                    IsAllowClear="True"
                    Status="Warning">
                    <atom:Cascader.OptionTemplate>
                        <TreeDataTemplate ItemsSource="{Binding Children}"
                                          x:DataType="atom:ICascaderOption">
                            <atom:TextBlock Text="{Binding Header}" />
                        </TreeDataTemplate>
                    </atom:Cascader.OptionTemplate>
                </atom:Cascader>
        
            </StackPanel>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="Size"
            Description="Cascade selection box of different sizes.">
            <StackPanel Spacing="15">
                <atom:Cascader
                    Name="SizeCascader1"
                    x:DataType="viewModels:CascaderViewModel"
                    PlaceholderText="Please select"
                    OptionsSource="{Binding SizeCascaderNodes}"
                    IsAllowClear="True"
                    SizeType="Large">
                    <atom:Cascader.OptionTemplate>
                        <TreeDataTemplate ItemsSource="{Binding Children}"
                                          x:DataType="atom:ICascaderOption">
                            <atom:TextBlock Text="{Binding Header}" />
                        </TreeDataTemplate>
                    </atom:Cascader.OptionTemplate>
                </atom:Cascader>
        
                <atom:Cascader
                    Name="SizeCascader2"
                    x:DataType="viewModels:CascaderViewModel"
                    PlaceholderText="Please select"
                    IsAllowClear="True"
                    OptionsSource="{Binding SizeCascaderNodes}"
                    SizeType="Middle">
                    <atom:Cascader.OptionTemplate>
                        <TreeDataTemplate ItemsSource="{Binding Children}"
                                          x:DataType="atom:ICascaderOption">
                            <atom:TextBlock Text="{Binding Header}" />
                        </TreeDataTemplate>
                    </atom:Cascader.OptionTemplate>
                </atom:Cascader>
        
                <atom:Cascader
                    Name="SizeCascader3"
                    x:DataType="viewModels:CascaderViewModel"
                    PlaceholderText="Please select"
                    IsAllowClear="True"
                    OptionsSource="{Binding SizeCascaderNodes}"
                    SizeType="Small">
                    <atom:Cascader.OptionTemplate>
                        <TreeDataTemplate ItemsSource="{Binding Children}"
                                          x:DataType="atom:ICascaderOption">
                            <atom:TextBlock Text="{Binding Header}" />
                        </TreeDataTemplate>
                    </atom:Cascader.OptionTemplate>
                </atom:Cascader>
        
            </StackPanel>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="Basic CascaderView"
            Description="The most basic usage.">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:CascaderView>
                    <atom:CascaderOption Header="Zhejiang" Value="zhejiang">
                        <atom:CascaderOption Header="Hangzhou" Value="hangzhou">
                            <atom:CascaderOption Header="West Lake" Value="xihu" />
                            <atom:CascaderOption Header="Lingyin shi" Value="lingyinshi" />
                        </atom:CascaderOption>
                    </atom:CascaderOption>
                    <atom:CascaderOption Header="Jiangsu" Value="jiangsu">
                        <atom:CascaderOption Header="Nanjing" Value="nanjing">
                            <atom:CascaderOption Header="Zhong Hua Men" Value="zhonghuamen" />
                        </atom:CascaderOption>
                    </atom:CascaderOption>
                </atom:CascaderView>
        
                <atom:CascaderView IsCheckable="True">
                    <atom:CascaderOption Header="Zhejiang" Value="zhejiang">
                        <atom:CascaderOption Header="Hangzhou" Value="hangzhou">
                            <atom:CascaderOption Header="West Lake" Value="xihu" />
                            <atom:CascaderOption Header="Lingyin shi" Value="lingyinshi" />
                        </atom:CascaderOption>
                    </atom:CascaderOption>
                    <atom:CascaderOption Header="Jiangsu" Value="jiangsu">
                        <atom:CascaderOption Header="Nanjing" Value="nanjing">
                            <atom:CascaderOption Header="Zhong Hua Men" Value="zhonghuamen" />
                        </atom:CascaderOption>
                    </atom:CascaderOption>
                </atom:CascaderView>
        
                <atom:CascaderView />
            </StackPanel>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="Generate by template"
            Description="You can use the Template mechanism to generate tree nodes">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:CascaderView
                    Name="BasicCascaderView">
                    <atom:CascaderView.OptionTemplate>
                        <TreeDataTemplate ItemsSource="{Binding Children}"
                                          x:DataType="atom:ICascaderOption">
                            <atom:TextBlock Text="{Binding Header}" />
                        </TreeDataTemplate>
                    </atom:CascaderView.OptionTemplate>
                </atom:CascaderView>
        
                <atom:CascaderView
                    Name="BasicCheckableCascaderView"
                    IsCheckable="True">
                    <atom:CascaderView.OptionTemplate>
                        <TreeDataTemplate x:DataType="atom:ICascaderOption"
                                          ItemsSource="{Binding Children}">
                            <atom:TextBlock Text="{Binding Header}" />
                        </TreeDataTemplate>
                    </atom:CascaderView.OptionTemplate>
                </atom:CascaderView>
            </StackPanel>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="Load Options Lazily"
            Description="Load options lazily with loadData.">
            <atom:CascaderView Name="AsyncLoadCascaderView">
                <atom:CascaderView.OptionTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}"
                                      x:DataType="atom:ICascaderOption">
                        <atom:TextBlock Text="{Binding Header}" />
                    </TreeDataTemplate>
                </atom:CascaderView.OptionTemplate>
            </atom:CascaderView>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="Searchable"
            Description="Searchable CascaderView.">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:SearchEdit PlaceholderText="Search"
                                 SearchButtonClick="HandleFilterCascaderViewClicked" />
                <atom:CascaderView Name="SearchCascaderView">
                    <atom:CascaderOption Header="Zhejiang" Value="zhejiang">
                        <atom:CascaderOption Header="Hangzhou" Value="hangzhou">
                            <atom:CascaderOption Header="West Lake" Value="xihu" />
                            <atom:CascaderOption Header="Lingyin shi" Value="lingyinshi" />
                            <atom:CascaderOption Header="XiSha" Value="xisha" IsEnabled="False" />
                        </atom:CascaderOption>
                    </atom:CascaderOption>
                    <atom:CascaderOption Header="Jiangsu" Value="jiangsu">
                        <atom:CascaderOption Header="Nanjing" Value="nanjing">
                            <atom:CascaderOption Header="Zhong Hua Men" Value="zhonghuamen" />
                        </atom:CascaderOption>
                    </atom:CascaderOption>
                </atom:CascaderView>
            </StackPanel>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="Searchable"
            Description="Searchable CascaderView with ItemsSource.">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:SearchEdit PlaceholderText="Search"
                                 SearchButtonClick="HandleFilterCascaderViewItemsSourceClicked" />
                <atom:CascaderView Name="SearchCascaderViewItemsSource">
                    <atom:CascaderView.OptionTemplate>
                        <TreeDataTemplate ItemsSource="{Binding Children}"
                                          x:DataType="atom:ICascaderOption">
                            <atom:TextBlock Text="{Binding Header}" />
                        </TreeDataTemplate>
                    </atom:CascaderView.OptionTemplate>
                </atom:CascaderView>
            </StackPanel>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="Default expanded"
            Description="You can set the default expansion path..">
            <StackPanel Spacing="10">
                <atom:CascaderView DefaultExpandedPath="{Binding DefaultExpandPath}">
                    <atom:CascaderOption Header="Zhejiang" ItemKey="zhejiang">
                        <atom:CascaderOption Header="Hangzhou" ItemKey="hangzhou">
                            <atom:CascaderOption Header="West Lake" ItemKey="xihu" />
                            <atom:CascaderOption Header="Lingyin shi" ItemKey="lingyinshi" />
                            <atom:CascaderOption Header="XiSha" ItemKey="xisha" IsEnabled="False" />
                        </atom:CascaderOption>
                    </atom:CascaderOption>
                    <atom:CascaderOption Header="Jiangsu" ItemKey="jiangsu">
                        <atom:CascaderOption Header="Nanjing" ItemKey="nanjing">
                            <atom:CascaderOption Header="Zhong Hua Men" ItemKey="zhonghuamen" />
                        </atom:CascaderOption>
                    </atom:CascaderOption>
                </atom:CascaderView>
                <atom:Separator Title="By template"/>
                <atom:CascaderView Name="DefaultExpandCascaderView">
                    <atom:CascaderView.OptionTemplate>
                        <TreeDataTemplate ItemsSource="{Binding Children}"
                                          x:DataType="atom:ICascaderOption">
                            <atom:TextBlock Text="{Binding Header}" />
                        </TreeDataTemplate>
                    </atom:CascaderView.OptionTemplate>
                </atom:CascaderView>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>