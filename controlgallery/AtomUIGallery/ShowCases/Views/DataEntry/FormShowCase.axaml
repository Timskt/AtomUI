                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:Select IsAllowClear="True" PlaceholderText="I'm Select" DefaultValues="1" HorizontalAlignment="Stretch">
                        <atom:SelectOption Header="Option 1" Value="1"/>
                        <atom:SelectOption Header="Option 2" Value="2"/>
                        <atom:SelectOption Header="Option 3" Value="3"/>
                    </atom:Select>
                </atom:FormItem>
        
                <atom:FormItem LabelText="Validating"
                               FieldName="validating"
                               IsValidateFeedbackEnabled="True"
