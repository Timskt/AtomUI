<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Views.FormShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:viewModels="clr-namespace:AtomUIGallery.ShowCases.ViewModels"
             x:DataType="viewModels:FormViewModel">
    <atom:TabControl Name="ScenarioTabs"
                     SizeType="Large"
                     SelectedIndex="0">
        <atom:TabItem Header="Basic" Tag="Basic" />
        <atom:TabItem Header="Layout" Tag="Layout" />
        <atom:TabItem Header="States" Tag="States" />
        <atom:TabItem Header="Validation" Tag="Validation" />
        <atom:TabItem Header="Dynamic" Tag="Dynamic" />
        <atom:TabItem Header="Presets" Tag="Presets" />
        <atom:TabItem Header="Controls" Tag="Controls" />
    </atom:TabControl>
</UserControl>
