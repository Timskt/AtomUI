                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:TimePicker PlaceholderText="Select time" HorizontalAlignment="Stretch"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="Error"
                               FieldName="error"
                               IsValidateFeedbackEnabled="True">
                    <atom:FormItem.Validators>
