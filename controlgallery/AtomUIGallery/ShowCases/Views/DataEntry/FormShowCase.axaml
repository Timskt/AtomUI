                            <atom:FormAssertValidator AssertResult="True"/>
                        </atom:FormValidatorProvider>
                    </atom:FormItem.Validators>
                    <atom:DatePicker PlaceholderText="Select date" HorizontalAlignment="Stretch"/>
                </atom:FormItem>
        
                <atom:FormItem LabelText="Warning"
