<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Views.MentionsShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="Basic"
            Description="The simplest use.">
            <atom:Mentions Name="BasicMentions"
                           HorizontalAlignment="Stretch"
                           DefaultValue="@afc163"/>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="Variants"
            Description="Variants of Mentions, there are four variants: outlined filled borderless and underlined.">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Mentions HorizontalAlignment="Stretch" StyleVariant="Outline" PlaceholderText="Outlined"/>
                <atom:Mentions HorizontalAlignment="Stretch" StyleVariant="Filled" PlaceholderText="Filled"/>
                <atom:Mentions HorizontalAlignment="Stretch" StyleVariant="Borderless" PlaceholderText="Borderless"/>
                <atom:Mentions HorizontalAlignment="Stretch" StyleVariant="Underlined" PlaceholderText="Underlined"/>
            </StackPanel>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="Asynchronous loading"
            Description="async.">
            <atom:Mentions HorizontalAlignment="Stretch" OptionsAsyncLoader="{Binding MentionOptionAsyncLoader}"/>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="Customize Trigger Token"
            Description="Customize Trigger Token by prefix props. Default to @, array also supported.">
            <atom:Mentions HorizontalAlignment="Stretch"
                           TriggerPrefix="{Binding MentionTriggers}"
                           CandidateTriggered="HandleCandidateTriggered"
                           PlaceholderText="input @ to mention people, # to mention tag"/>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="disabled or readOnly"
            Description="Configure disabled and readOnly.">
           <StackPanel Orientation="Vertical" Spacing="10">
               <atom:Mentions Name="DisabledMentions"
                              HorizontalAlignment="Stretch"
                              IsEnabled="False"
                              PlaceholderText="this is disabled Mentions"/>
               <atom:Mentions Name="ReadonlyMentions"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="this is readOnly Mentions"
                              IsReadOnly="True"/>
           </StackPanel>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="Placement"
            Description="Change the suggestions placement.">
            <atom:Mentions Name="PlacementMentions"
                           HorizontalAlignment="Stretch"
                           Placement="Top"/>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="Status"
            Description="Add status to Mentions with status, which could be error or warning.">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Mentions Name="ErrorMentions"
                               HorizontalAlignment="Stretch"
                               Status="Error"
                               DefaultValue="@afc163"/>
                <atom:Mentions Name="WarningMentions"
                               HorizontalAlignment="Stretch"
                               DefaultValue="@afc163"
                               Status="Warning"/>
            </StackPanel>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="autoSize"
            Description="Height autoSize.">
            <atom:Mentions Name="AutoSizeMentions" 
                           HorizontalAlignment="Stretch"
                           IsAutoSize="True"/>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="With clear icon"
            Description="Customize clear button.">
            <StackPanel Orientation="Vertical" Spacing="10">
                <atom:Mentions Name="ClearableMentions1"
                               HorizontalAlignment="Stretch"
                               IsAllowClear="True"/>
                <atom:Mentions HorizontalAlignment="Stretch"
                               Name="ClearableMentions2"
                               IsAllowClear="True"
                               Lines="3"/>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>