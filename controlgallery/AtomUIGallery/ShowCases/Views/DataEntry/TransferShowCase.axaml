<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Views.TransferShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="Basic"
            IsOccupyEntireRow="True"
            Description="The most basic usage of Transfer involves providing the source data and target keys arrays, plus the rendering and some callback functions.">
            <atom:Transfer SourceTitle="Source" TargetTitle="Target"
                           ItemsSource="{Binding BasicTransferItems}"/>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>