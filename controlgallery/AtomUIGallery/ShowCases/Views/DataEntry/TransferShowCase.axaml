        <gallery:ShowCaseItem
            Title="Search"
            IsOccupyEntireRow="True"
            Description="Transfer with a search box.">
            <StackPanel Spacing="20">
                <atom:Transfer ItemsSource="{Binding SearchTransferItems}"
                               IsFilterEnabled="True"
                               FilterPlaceholderText="Search here"
                               FilterValueSelector="{Binding TransferFilterValueSelector}"/>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
