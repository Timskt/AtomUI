        <gallery:ShowCaseItem
            Title="Tree Transfer"
            IsOccupyEntireRow="True"
            Description="Customize the render list with a Tree component.">
            <StackPanel Spacing="20">
                <atom:TreeTransfer ItemsSource="{Binding TransferTreeNodes}"
                                   IsStretchView="True"
                                   IsOneWay="{Binding TreeTransferIsOneWay}">
                    <atom:TreeTransfer.SourceView>
                        <atom:TransferTreeView IsDefaultExpandAll="True" />
                    </atom:TreeTransfer.SourceView>
                </atom:TreeTransfer>
                <atom:ToggleSwitch IsChecked="{Binding TreeTransferIsOneWay, Mode=TwoWay}"
                                   OnContent="ony way"
                                   OffContent="ony way" />
            </StackPanel>
        </gallery:ShowCaseItem>
        
        <gallery:ShowCaseItem
            Title="Status"
            IsOccupyEntireRow="True"
            Description="Add status to Transfer with status, which could be error or warning.">
            <StackPanel Spacing="20">
                <atom:ListTransfer Status="Error"/>
                <atom:ListTransfer Status="Warning"/>
            </StackPanel>
        </gallery:ShowCaseItem>

    </gallery:ShowCasePanel>
</UserControl>