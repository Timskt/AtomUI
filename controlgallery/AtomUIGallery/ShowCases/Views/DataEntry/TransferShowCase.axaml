        <gallery:ShowCaseItem
            Title="Pagination"
            IsOccupyEntireRow="True"
            Description="Store a large amount of items with pagination.">
            <StackPanel Spacing="20">
                <atom:Transfer ItemsSource="{Binding PaginationTransferItems}"
                               IsOneWay="{Binding PaginationIsOneWay}"/>
                <atom:ToggleSwitch IsChecked="{Binding PaginationIsOneWay, Mode=TwoWay}"
                                   OnContent="ony way"
                                   OffContent="ony way"/>
            </StackPanel>
        </gallery:ShowCaseItem>

