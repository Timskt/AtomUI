<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Views.MessageBoxShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:viewModels="clr-namespace:AtomUIGallery.ShowCases.ViewModels"
             x:DataType="viewModels:MessageBoxViewModel">
    <gallery:ShowCasePanel>
        <gallery:ShowCaseItem
            Title="MessageBox Style"
            Description="MessageBox supports Confirm, Information, Warning, and Error">

            <StackPanel Orientation="Vertical" Spacing="20">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBlock VerticalAlignment="Center">Native Window:</TextBlock>
                    <atom:ToggleSwitch Name="StyleCaseHostTypeSwitch" />
                </StackPanel>
                <atom:Separator Title="Normal"/>
                <WrapPanel Orientation="Horizontal" ItemSpacing="10" LineSpacing="10">
                    <Panel>
                        <atom:MessageBox PlacementTarget="ConfirmMsgBoxBtn"
                                         Title="Do you want to delete these items?"
                                         IsOpen="{Binding IsConfirmMsgBoxOpened, Mode=TwoWay}"
                                         Style="Confirm"
                                         DialogHostType="{Binding MessageBoxStyleCaseHostType}">
                            <StackPanel Orientation="Vertical" Spacing="5">
                                <TextBlock>Some descriptions</TextBlock>
                            </StackPanel>
                        </atom:MessageBox>
                        <atom:Button Name="ConfirmMsgBoxBtn">Confirm</atom:Button>
                    </Panel>
                    <Panel>
                        <atom:MessageBox PlacementTarget="InformationMsgBoxBtn"
                                         Title="This is a notification message"
                                         IsOpen="{Binding IsInformationMsgBoxOpened, Mode=TwoWay}"
                                         Style="Information"
                                         DialogHostType="{Binding MessageBoxStyleCaseHostType}">
                            <StackPanel Orientation="Vertical" Spacing="5">
                                <TextBlock>some messages...some messages...</TextBlock>
                                <TextBlock>some messages...some messages...</TextBlock>
                            </StackPanel>
                        </atom:MessageBox>
                        <atom:Button Name="InformationMsgBoxBtn">Information</atom:Button>
                    </Panel>
                    <Panel>
                        <atom:MessageBox PlacementTarget="SuccessMsgBoxBtn"
                                         Title="Operation successful"
                                         Style="Success"
                                         DialogHostType="{Binding MessageBoxStyleCaseHostType}"
                                         IsOpen="{Binding IsSuccessMsgBoxOpened, Mode=TwoWay}">
                            <StackPanel Orientation="Vertical" Spacing="5">
                                <TextBlock>some messages...some messages...</TextBlock>
                                <TextBlock>some messages...some messages...</TextBlock>
                            </StackPanel>
                        </atom:MessageBox>
                        <atom:Button Name="SuccessMsgBoxBtn">Success</atom:Button>
                    </Panel>
                    <Panel>
                        <atom:MessageBox PlacementTarget="ErrorMsgBoxBtn"
                                         Title="This is an error message"
                                         Style="Error"
                                         DialogHostType="{Binding MessageBoxStyleCaseHostType}"
                                         IsOpen="{Binding IsErrorMsgBoxOpened, Mode=TwoWay}">
                            <StackPanel Orientation="Vertical" Spacing="5">
                                <TextBlock>some messages...some messages...</TextBlock>
                                <TextBlock>some messages...some messages...</TextBlock>
                            </StackPanel>
                        </atom:MessageBox>
                        <atom:Button Name="ErrorMsgBoxBtn">Error</atom:Button>
                    </Panel>
                    <Panel>
                        <atom:MessageBox PlacementTarget="WarningMsgBoxBtn"
                                         Title="This is a warning message"
                                         Style="Warning"
                                         DialogHostType="{Binding MessageBoxStyleCaseHostType}"
                                         IsOpen="{Binding IsWarningMsgBoxOpened, Mode=TwoWay}">
                            <StackPanel Orientation="Vertical" Spacing="5">
                                <TextBlock>some messages...some messages...</TextBlock>
                                <TextBlock>some messages...some messages...</TextBlock>
                            </StackPanel>
                        </atom:MessageBox>
                        <atom:Button Name="WarningMsgBoxBtn">Warning</atom:Button>
                    </Panel>
                </WrapPanel>

                <atom:Separator Title="Static API" />
                <WrapPanel Orientation="Horizontal" ItemSpacing="10" LineSpacing="10">
                    <atom:Button Click="HandleCreateConfirmMessageBox">Confirm</atom:Button>
                    <atom:Button Click="HandleCreateInformationMessageBox">Information</atom:Button>
                    <atom:Button Click="HandleCreateSuccessMessageBox">Success</atom:Button>
                    <atom:Button Click="HandleCreateErrorMessageBox">Error</atom:Button>
                    <atom:Button Click="HandleCreateWarningMessageBox">Warning</atom:Button>
                </WrapPanel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="Use custom footer buttons"
            Description="You can use standard buttons along with custom buttons.">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Panel>
                    <atom:Button ButtonType="Primary" Name="CustomFooterMsgBoxOpenButton">
                        Open Modal
                    </atom:Button>
                    <atom:MessageBox PlacementTarget="CustomFooterMsgBoxOpenButton"
                                     IsOpen="{Binding IsCustomFooterMsgBoxOpened, Mode=TwoWay}"
                                     Title="Confirm"
                                     IsModal="True"
                                     Style="Confirm"
                                     HostMinWidth="400">
                        <atom:MessageBox.CustomButtons>
                            <atom:DialogButton Role="ActionRole">Custom Button</atom:DialogButton>
                        </atom:MessageBox.CustomButtons>
                        <StackPanel Spacing="5">
                            <TextBlock>Bla bla ...</TextBlock>
                        </StackPanel>
                    </atom:MessageBox>
                </Panel>
            </StackPanel>
        </gallery:ShowCaseItem>

        <gallery:ShowCaseItem
            Title="Manual to update destroy"
            Description="Manually updating and destroying a modal through instance.">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Panel>
                    <atom:Button Name="DelayedCloseMsgBoxOpenButton">
                        Open modal to close in 5s
                    </atom:Button>
                    <atom:MessageBox PlacementTarget="DelayedCloseMsgBoxOpenButton"
                                     IsOpen="{Binding IsDelayedCloseMsgBoxOpened, Mode=TwoWay}"
                                     Title="This is a notification message"
                                     IsModal="True"
                                     IsDragMovable="False"
                                     IsCenterOnStartup="True"
                                     Style="Success"
                                     Opened="HandleDelayedCloseMsgBoxOpened"
                                     HostWidth="400">
                        <StackPanel Spacing="10">
                            <TextBlock TextWrapping="Wrap">This modal will be destroyed after <Run Text="{Binding CountdownSeconds}"/> second.</TextBlock>
                        </StackPanel>
                    </atom:MessageBox>
                </Panel>
            </StackPanel>
        </gallery:ShowCaseItem>
    </gallery:ShowCasePanel>
</UserControl>
