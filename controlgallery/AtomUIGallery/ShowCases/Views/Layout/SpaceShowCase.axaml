<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.ShowCases.Views.SpaceShowCase"
             xmlns:atom="https://atomui.net"
             xmlns:viewModels="clr-namespace:AtomUIGallery.ShowCases.ViewModels"
             x:DataType="viewModels:SpaceViewModel">
    <atom:TabControl Name="ScenarioTabs"
                     SizeType="Large"
                     SelectedIndex="0">
        <atom:TabItem Header="Basic" Tag="Basic" />
        <atom:TabItem Header="Size" Tag="Size" />
        <atom:TabItem Header="Align" Tag="Align" />
        <atom:TabItem Header="Compact Form" Tag="CompactForm" />
        <atom:TabItem Header="Compact Button" Tag="CompactButton" />
    </atom:TabControl>
</UserControl>
