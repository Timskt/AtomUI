<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AtomUIGallery.Workspace.Views.CaseNavigation"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:viewmodels="using:AtomUIGallery.ShowCases.ViewModels"
             x:CompileBindings="True">
    <atom:NavMenu Mode="Inline" Width="260" Name="ShowCaseNavMenu"
                  atom:ScrollViewer.IsLiteMode="True"
                  ScrollViewer.AllowAutoHide="True">
        <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource General}"
                          Icon="{antdicons:AntDesignIconProvider Kind=WindowsOutlined}">
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource General_AboutUs}"
                              ItemKey="{x:Static viewmodels:AboutUsViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource General_Palette}"
                              ItemKey="{x:Static viewmodels:PaletteViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource General_Icons}"
                              ItemKey="{x:Static viewmodels:IconViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource General_Button}"
                              ItemKey="{x:Static viewmodels:ButtonViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource General_FloatButton}"
                              ItemKey="{x:Static viewmodels:FloatButtonViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource General_SplitButton}"
                              ItemKey="{x:Static viewmodels:SplitButtonViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource General_Separator}"
                              ItemKey="{x:Static viewmodels:SeparatorViewModel.ID}" />
        </atom:NavMenuNode>

        <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource Layout}"
                          Icon="{antdicons:AntDesignIconProvider Kind=LayoutOutlined}">
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource Layout_FlexPanel}"
                              ItemKey="{x:Static viewmodels:FlexPanelViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource Layout_Grid}"
                              ItemKey="{x:Static viewmodels:GridViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource Layout_Splitter}"
                              ItemKey="{x:Static viewmodels:SplitterViewModel.ID}" />
        </atom:NavMenuNode>

        <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource Navigation}"
                          Icon="{antdicons:AntDesignIconProvider Kind=MenuOutlined}">
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource Navigation_Breadcrumb}"
                              ItemKey="{x:Static viewmodels:BreadcrumbViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource Navigation_ButtonSpinner}"
                              ItemKey="{x:Static viewmodels:ButtonSpinnerViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource Navigation_ComboBox}"
                              ItemKey="{x:Static viewmodels:ComboBoxViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource Navigation_DropdownButton}"
                              ItemKey="{x:Static viewmodels:DropdownButtonViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource Navigation_TabControl}"
                              ItemKey="{x:Static viewmodels:TabControlViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource Navigation_Pagination}"
                              ItemKey="{x:Static viewmodels:PaginationViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource Navigation_Menu}"
                              ItemKey="{x:Static viewmodels:MenuViewModel.ID}" />
        </atom:NavMenuNode>

        <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataEntry}"
                          Icon="{antdicons:AntDesignIconProvider Kind=FormOutlined}">
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataEntry_CheckBox}"
                              ItemKey="{x:Static viewmodels:CheckBoxViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataEntry_ToggleSwitch}"
                              ItemKey="{x:Static viewmodels:ToggleSwitchViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataEntry_RadioButton}"
                              ItemKey="{x:Static viewmodels:RadioButtonViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataEntry_Rate}"
                              ItemKey="{x:Static viewmodels:RateViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataEntry_Slider}"
                              ItemKey="{x:Static viewmodels:SliderViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataEntry_LineEdit}"
                              ItemKey="{x:Static viewmodels:LineEditViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataEntry_AutoComplete}"
                              ItemKey="{x:Static viewmodels:AutoCompleteViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataEntry_Select}"
                              ItemKey="{x:Static viewmodels:SelectViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataEntry_Cascader}"
                              ItemKey="{x:Static viewmodels:CascaderViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataEntry_TreeSelect}"
                              ItemKey="{x:Static viewmodels:TreeSelectViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataEntry_NumberUpDown}"
                              ItemKey="{x:Static viewmodels:NumberUpDownViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataEntry_TimePicker}"
                              ItemKey="{x:Static viewmodels:TimePickerViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataEntry_DatePicker}"
                              ItemKey="{x:Static viewmodels:DatePickerViewModel.ID}" />
        </atom:NavMenuNode>

        <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataDisplay}"
                          Icon="{antdicons:AntDesignIconProvider Kind=AreaChartOutlined}">
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataDisplay_Avatar}"
                              ItemKey="{x:Static viewmodels:AvatarViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataDisplay_Calendar}"
                              ItemKey="{x:Static viewmodels:CalendarViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataDisplay_Card}"
                              ItemKey="{x:Static viewmodels:CardViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataDisplay_Carousel}"
                              ItemKey="{x:Static viewmodels:CarouselViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataDisplay_Collapse}"
                              ItemKey="{x:Static viewmodels:CollapseViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataDisplay_Descriptions}"
                              ItemKey="{x:Static viewmodels:DescriptionsViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataDisplay_Empty}"
                              ItemKey="{x:Static viewmodels:EmptyViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataDisplay_Expander}"
                              ItemKey="{x:Static viewmodels:ExpanderViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataDisplay_Tag}"
                              ItemKey="{x:Static viewmodels:TagViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataDisplay_Segmented}"
                              ItemKey="{x:Static viewmodels:SegmentedViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataDisplay_GroupBox}"
                              ItemKey="{x:Static viewmodels:GroupBoxViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataDisplay_Badge}"
                              ItemKey="{x:Static viewmodels:BadgeViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataDisplay_Statistic}"
                              ItemKey="{x:Static viewmodels:StatisticViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataDisplay_Timeline}"
                              ItemKey="{x:Static viewmodels:TimelineViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataDisplay_QRCode}"
                              ItemKey="{x:Static viewmodels:QRCodeViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataDisplay_InfoFlyout}"
                              ItemKey="{x:Static viewmodels:InfoFlyoutViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataDisplay_List}"
                              ItemKey="{x:Static viewmodels:ListViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataDisplay_TreeView}"
                              ItemKey="{x:Static viewmodels:TreeViewViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource DataDisplay_Tour}"
                              ItemKey="{x:Static viewmodels:TourViewModel.ID}" />
        </atom:NavMenuNode>

        <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource Feedback}"
                          Icon="{antdicons:AntDesignIconProvider Kind=UserSwitchOutlined}">
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource Feedback_Alert}"
                              ItemKey="{x:Static viewmodels:AlertViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource Feedback_Message}"
                              ItemKey="{x:Static viewmodels:MessageViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource Feedback_Notification}"
                              ItemKey="{x:Static viewmodels:NotificationViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource Feedback_PopupConfirm}"
                              ItemKey="{x:Static viewmodels:PopupConfirmViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource Feedback_Drawer}"
                              ItemKey="{x:Static viewmodels:DrawerViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource Feedback_Skeleton}"
                              ItemKey="{x:Static viewmodels:SkeletonViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource Feedback_Spin}"
                              ItemKey="{x:Static viewmodels:SpinViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource Feedback_Result}"
                              ItemKey="{x:Static viewmodels:ResultViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource Feedback_Watermark}"
                              ItemKey="{x:Static viewmodels:WatermarkViewModel.ID}" />
            <atom:NavMenuNode Header="{gallery:CaseNavigationLangResource Feedback_ProgressBar}"
                              ItemKey="{x:Static viewmodels:ProgressBarViewModel.ID}" />
        </atom:NavMenuNode>
    </atom:NavMenu>
</UserControl>
