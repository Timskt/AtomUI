<atom:Window xmlns="https://github.com/avaloniaui"
             xmlns:rxui="http://reactiveui.net"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:atom="using:AtomUI.Desktop.Controls"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:workspaceviews="using:AtomUIGallery.Workspace.Views"
             x:Class="AtomUIGallery.Workspace.Views.WorkspaceWindow"
             Icon="/Assets/AtomUIGallery.ico"
             IsPinCaptionButtonEnabled="True"
             WindowState="Normal"
             WindowStartupLocation="CenterScreen"
             Height="900"
             Width="1300">
    <atom:Window.Logo>
        <Image Source="/Assets/gallery-logo.png" />
    </atom:Window.Logo>
    <DockPanel LastChildFill="True"
               Margin="0 0 2 0">
        <atom:Menu DockPanel.Dock="Top" Margin="4, 0, 4, 0">
            <atom:MenuItem Header="{gallery:WorkspaceWindowLangResource  MenuItemSettings}">
                <atom:MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemWindowOptions}">
                    <atom:MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemEnableFullScreen}" 
                                   ToggleType="CheckBox" 
                                   IsChecked="True"
                                   Tag="{x:Static workspaceviews:WindowMenuItemKind.FullScreen}"/>
                    <atom:MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemEnablePin}" 
                                   ToggleType="CheckBox"
                                   IsChecked="True"
                                   Tag="{x:Static workspaceviews:WindowMenuItemKind.Pin}"/>
                    <atom:MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemEnableMinimize}" 
                                   ToggleType="CheckBox"
                                   IsChecked="True"
                                   Tag="{x:Static workspaceviews:WindowMenuItemKind.Minimize}"/>
                    <atom:MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemEnableMaximize}"
                                   ToggleType="CheckBox"
                                   IsChecked="True"
                                   Tag="{x:Static workspaceviews:WindowMenuItemKind.Maximize}"/>
                    <atom:MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemEnableMove}" 
                                   ToggleType="CheckBox"
                                   IsChecked="True"
                                   Tag="{x:Static workspaceviews:WindowMenuItemKind.Move}"/>
                    <atom:MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemEnableResize}"
                                   ToggleType="CheckBox"
                                   IsChecked="True"
                                   Tag="{x:Static workspaceviews:WindowMenuItemKind.Resize}"/>
                </atom:MenuItem>
            </atom:MenuItem>
            <atom:MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemTheme}">
                <atom:MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemDarkMode}" 
                               ToggleType="CheckBox"
                               Tag="{x:Static workspaceviews:WindowMenuItemKind.DarkMode}"/>
                <atom:MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemCompactMode}" 
                               ToggleType="CheckBox"
                               Tag="{x:Static workspaceviews:WindowMenuItemKind.Compact}"/>
                <atom:MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemEnableMotion}" 
                               ToggleType="CheckBox"
                               IsChecked="True"
                               Tag="{x:Static workspaceviews:WindowMenuItemKind.Motion}"/>
                <atom:MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemEnableWaveSpirit}" 
                               ToggleType="CheckBox"
                               IsChecked="True"
                               Tag="{x:Static workspaceviews:WindowMenuItemKind.WaveSpirit}"/>
            </atom:MenuItem>
            <atom:MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemLanguage}">
                <atom:MenuItem Header="简体中文" 
                               ToggleType="Radio"
                               IsChecked="True"
                               Tag="{x:Static workspaceviews:WindowMenuItemKind.LanguageZhCN}"
                              />
                <atom:MenuItem Header="English" 
                               ToggleType="Radio"
                               Tag="{x:Static workspaceviews:WindowMenuItemKind.LanguageEnUS}"/>
            </atom:MenuItem>
        </atom:Menu>
        <workspaceviews:CaseNavigation DockPanel.Dock="Left" />
        <rxui:RoutedViewHost Router="{Binding Router}"
                             PageTransition="{x:Null}"
                             ClipToBounds="True" />
    </DockPanel>
</atom:Window>