<atom:Window xmlns="https://github.com/avaloniaui"
             xmlns:rxui="http://reactiveui.net"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:atom="https://atomui.net"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:workspaceviews="using:AtomUIGallery.Workspace.Views"
             x:Class="AtomUIGallery.Workspace.Views.WorkspaceWindow"
             Icon="/Assets/AtomUIGallery.ico"
             IsPinCaptionButtonVisible="True"
             IsFullScreenCaptionButtonVisible="True"
             WindowState="Normal"
             WindowStartupLocation="CenterScreen"
             Height="900"
             Width="1300">
    <atom:Window.LogoTemplate>
        <DataTemplate>
            <Image Source="/Assets/gallery-logo.png" />
        </DataTemplate>
    </atom:Window.LogoTemplate>
    <DockPanel LastChildFill="True"
               Margin="0 0 2 0">
        <Menu DockPanel.Dock="Top" Margin="4, 0, 4, 0">
            <MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemSettings}">
                <MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemWindowOptions}">
                    <MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemEnableFullScreen}"
                              ToggleType="CheckBox"
                              IsChecked="True"
                              Tag="{x:Static workspaceviews:WindowMenuItemKind.FullScreen}" />
                    <MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemEnablePin}"
                              ToggleType="CheckBox"
                              IsChecked="True"
                              Tag="{x:Static workspaceviews:WindowMenuItemKind.Pin}" />
                    <MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemEnableMinimize}"
                              ToggleType="CheckBox"
                              IsChecked="True"
                              Tag="{x:Static workspaceviews:WindowMenuItemKind.Minimize}" />
                    <MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemEnableMaximize}"
                              ToggleType="CheckBox"
                              IsChecked="True"
                              Tag="{x:Static workspaceviews:WindowMenuItemKind.Maximize}" />
                    <MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemEnableMove}"
                              ToggleType="CheckBox"
                              IsChecked="True"
                              Tag="{x:Static workspaceviews:WindowMenuItemKind.Move}" />
                    <MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemEnableResize}"
                              ToggleType="CheckBox"
                              IsChecked="True"
                              Tag="{x:Static workspaceviews:WindowMenuItemKind.Resize}" />
                </MenuItem>
            </MenuItem>
            <MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemTheme}">
                <MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemDarkMode}"
                          ToggleType="CheckBox"
                          Tag="{x:Static workspaceviews:WindowMenuItemKind.DarkMode}" />
                <MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemCompactMode}"
                          ToggleType="CheckBox"
                          Tag="{x:Static workspaceviews:WindowMenuItemKind.Compact}" />
                <MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemEnableMotion}"
                          ToggleType="CheckBox"
                          IsChecked="True"
                          Tag="{x:Static workspaceviews:WindowMenuItemKind.Motion}" />
                <MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemEnableWaveSpirit}"
                          ToggleType="CheckBox"
                          IsChecked="True"
                          Tag="{x:Static workspaceviews:WindowMenuItemKind.WaveSpirit}" />
            </MenuItem>
            <MenuItem Header="{gallery:WorkspaceWindowLangResource MenuItemLanguage}">
                <MenuItem Header="简体中文"
                          ToggleType="Radio"
                          IsChecked="True"
                          Tag="{x:Static workspaceviews:WindowMenuItemKind.LanguageZhCN}" />
                <MenuItem Header="English"
                          ToggleType="Radio"
                          Tag="{x:Static workspaceviews:WindowMenuItemKind.LanguageEnUS}" />
            </MenuItem>
        </Menu>
        <workspaceviews:CaseNavigation Name="ShowCaseNavigation" DockPanel.Dock="Left" />
        <rxui:RoutedViewHost Name="RoutedViewHost" PageTransition="{x:Null}" ClipToBounds="True" />
    </DockPanel>
</atom:Window>
