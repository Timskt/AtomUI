<atom:Window xmlns="https://github.com/avaloniaui"
             xmlns:rxui="http://reactiveui.net"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:gallery="https://atomui.net/oss-controls/gallery"
             xmlns:workspaceviews="using:AtomUIGallery.Workspace.Views"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             x:Class="AtomUIGallery.Workspace.Views.WorkspaceWindow"
             Icon="/Assets/AtomUIGallery.ico"
             IsPinCaptionButtonVisible="True"
             IsFullScreenCaptionButtonVisible="True"
             WindowState="Normal"
             WindowStartupLocation="CenterScreen"
             Height="900"
             Width="1300">
    <atom:Window.LogoTemplate>
        <DataTemplate>
            <Image Source="/Assets/gallery-logo.png" />
        </DataTemplate>
    </atom:Window.LogoTemplate>
    <Panel>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20" Orientation="Horizontal">
            <atom:FlyoutHost Trigger="Hover" HorizontalAlignment="Center" VerticalAlignment="Center"
                             ShouldUseOverlayLayer="True">
                <atom:FlyoutHost.Flyout>
                    <atom:Flyout>
                        <TextBlock Width="200" Height="100" Padding="20">The most basic example.</TextBlock>
                    </atom:Flyout>
                </atom:FlyoutHost.Flyout>
                <atom:Button ButtonType="Primary">Hover me</atom:Button>
            </atom:FlyoutHost>
            
            <atom:FlyoutHost Trigger="Focus" HorizontalAlignment="Center" VerticalAlignment="Center"
                             ShouldUseOverlayLayer="True">
                <atom:FlyoutHost.Flyout>
                    <atom:Flyout>
                        <TextBlock Width="200" Height="100" Padding="20">The most basic example.</TextBlock>
                    </atom:Flyout>
                </atom:FlyoutHost.Flyout>
                <atom:Button ButtonType="Primary">Hover me</atom:Button>
            </atom:FlyoutHost>
            
            <atom:FlyoutHost Trigger="Click" HorizontalAlignment="Center" VerticalAlignment="Center"
                             ShouldUseOverlayLayer="True">
                <atom:FlyoutHost.Flyout>
                    <atom:Flyout>
                        <TextBlock Width="200" Height="100" Padding="20">The most basic example.</TextBlock>
                    </atom:Flyout>
                </atom:FlyoutHost.Flyout>
                <atom:Button ButtonType="Primary">Hover me</atom:Button>
            </atom:FlyoutHost>
        </StackPanel>
    </Panel>
</atom:Window>