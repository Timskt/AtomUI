<atom:ControlThemesProvider xmlns="https://github.com/avaloniaui"
                            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                            xmlns:atom="https://atomui.net"
                            x:Class="AtomUI.Controls.CommonControlThemesProvider"
                            Id="AtomUI.Controls.Common">
    <atom:ControlThemesProvider.ControlThemes>
        <ResourceInclude Source="Icon/Themes/IconThemes.axaml" />
        <ResourceInclude Source="ItemsControl/Themes/ItemsControlTheme.axaml" />
        <ResourceInclude Source="Embedding/Themes/EmbeddableControlRootTheme.axaml" />
    </atom:ControlThemesProvider.ControlThemes>
</atom:ControlThemesProvider>