<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:IconPresenter}" TargetType="atom:IconPresenter">
        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}" />
        <Setter Property="IconBrush" Value="{atom:SharedTokenResource ColorIconHover}" />
    </ControlTheme>
</ResourceDictionary>