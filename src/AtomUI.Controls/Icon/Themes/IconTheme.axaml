<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:Icon}" TargetType="atom:Icon">
        
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        Height="{TemplateBinding Height}"
                        Width="{TemplateBinding Width}"/>
            </ControlTemplate>
        </Setter>
        
        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Height" Value="{atom:SharedTokenResource IconSize}" />
        <Setter Property="Width" Value="{atom:SharedTokenResource IconSize}" />
        <Setter Property="FillBrush" Value="{atom:SharedTokenResource ColorIconHover}" />
        <Setter Property="StrokeBrush" Value="{atom:SharedTokenResource ColorIconHover}" />
        <Setter Property="StrokeWidth" Value="{atom:IconTokenResource StrokeWidth}" />
        <Setter Property="StrokeLineCap" Value="{atom:IconTokenResource StrokeLineCap}" />
        <Setter Property="StrokeLineJoin" Value="{atom:IconTokenResource StrokeLineJoin}" />
        
        <Style Selector="^[IconTheme=TwoTone]">
            <Setter Property="StrokeBrush" Value="{atom:SharedTokenResource ColorPrimary}" />
            <Setter Property="FillBrush" Value="{atom:SharedTokenResource ColorInfoBg}" />
        </Style>
        
        <Style Selector="^[IconTheme=MultiColor]">
            <Setter Property="StrokeBrush" Value="{atom:SharedTokenResource ColorIconHover}" />
            <Setter Property="FillBrush" Value="{atom:SharedTokenResource ColorPrimary}" />
        </Style>
        
        <Setter Property="SecondaryFillBrush" Value="{atom:IconTokenResource SecondaryFillColor}" />
        <Setter Property="SecondaryStrokeBrush" Value="{atom:IconTokenResource SecondaryStrokeColor}" />
        <Setter Property="FallbackBrush" Value="White" />
        <Setter Property="FillAnimationDuration" Value="{atom:SharedTokenResource MotionDurationMid}" />
        
    </ControlTheme>
</ResourceDictionary>