<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">

    <ControlTheme x:Key="{x:Type atom:ColorSliderThumb}" TargetType="atom:ColorSliderThumb">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="PART_Frame"
                        Background="{atom:SharedTokenResource ColorBgElevated}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Padding="2"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <Border Name="PART_InnerEllipse"
                            BorderBrush="{atom:SharedTokenResource ColorFillSecondary}"
                            CornerRadius="{TemplateBinding InnerCornerRadius}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Background="{TemplateBinding ColorValueBrush}">
                    </Border>
                </Border>
            </ControlTemplate>
        </Setter>

        <Setter Property="ClipToBounds" Value="False" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="UseLayoutRounding" Value="False" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorFillSecondary}" />
        <Setter Property="BorderThickness" Value="{atom:SharedTokenResource BorderThickness}" />
        
        <Setter Property="Width"
                Value="{atom:ColorPickerTokenResource ColorPickerSliderThumbSize}" />
        <Setter Property="Height"
                Value="{atom:ColorPickerTokenResource ColorPickerSliderThumbSize}" />
        
        <Style Selector="^:focus,^:pressed">
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorPrimaryActive}" />
        </Style>
    </ControlTheme>

</ResourceDictionary>