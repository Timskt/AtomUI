<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    xmlns:themes="using:AtomUI.Desktop.Controls.Themes"
    xmlns:converters="using:AtomUI.Desktop.Controls.Converters"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:GradientColorPickerView}" TargetType="atom:GradientColorPickerView">
        <ControlTheme.BasedOn>
            <themes:AbstractColorPickerViewTheme TargetType="atom:GradientColorPickerView" />
        </ControlTheme.BasedOn>

        <Setter Property="Template">
            <ControlTemplate TargetType="atom:GradientColorPickerView">
                <Border Name="Frame"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}"
                        Margin="{TemplateBinding Margin}"
                        MinWidth="{TemplateBinding MinWidth}"
                        MinHeight="{TemplateBinding MinHeight}"
                        ClipToBounds="False">
                    <StackPanel Name="PART_LayoutRoot"
                                Orientation="Horizontal" ClipToBounds="False">
                        <atom:ColorPickerPaletteGroup
                            Name="PART_PaletteGroup"
                            PaletteGroup="{TemplateBinding PaletteGroup}"
                            IsVisible="{TemplateBinding IsPaletteGroupEnabled}"
                            IsMotionEnabled="{TemplateBinding IsMotionEnabled}" />
                        <Rectangle Name="Separator"
                                   VerticalAlignment="Stretch" Width="1"
                                   IsVisible="{TemplateBinding IsPaletteGroupEnabled}" />
                        <StackPanel Orientation="Vertical"
                                    ClipToBounds="False"
                                    Spacing="{atom:SharedTokenResource SpacingXS}">
                            <atom:ColorBlock Name="PART_ClearColor"
                                             HorizontalAlignment="Right"
                                             IsEmptyColorMode="True"
                                             IsVisible="{TemplateBinding IsClearEnabled}" />
                            <atom:GradientColorSlider
                                Name="PART_GradientColorSlider"
                                ActivatedHsvValue="{Binding HsvValue, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}, Priority=LocalValue}"
                                GradientValue="{Binding Value, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}, Priority=LocalValue}"
                                ActivatedStopIndex="{Binding ActivatedStopIndex, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}, Priority=LocalValue}"/>
                            <StackPanel Orientation="Vertical" Name="ColorPickerContainer" ClipToBounds="False">
                                <atom:ColorSpectrum
                                    Name="ColorSpectrum"
                                    Components="SaturationValue"
                                    HsvColor="{TemplateBinding HsvValue, Mode=TwoWay}"
                                    MaxHue="{TemplateBinding MaxHue}"
                                    MaxSaturation="{TemplateBinding MaxSaturation}"
                                    MaxValue="{TemplateBinding MaxValue}"
                                    MinHue="{TemplateBinding MinHue}"
                                    MinSaturation="{TemplateBinding MinSaturation}"
                                    MinValue="{TemplateBinding MinValue}" />
                                <DockPanel LastChildFill="True" ClipToBounds="False">
                                    <atom:ColorBlock Name="ColorPreview"
                                                     Background="{TemplateBinding HsvValue, Converter={x:Static converters:HsvColorToBrushConverter.Default}}"
                                                     DockPanel.Dock="Right"
                                                     Margin="0, 2, 0, 2" />
                                    <Panel Name="SliderContainer" ClipToBounds="False">
                                        <atom:ColorSlider Name="ColorSpectrumThirdComponentSlider" DockPanel.Dock="Top"
                                                          ColorModel="Hsva"
                                                          VerticalAlignment="Top"
                                                          HsvColor="{TemplateBinding HsvValue, Mode=TwoWay}"
                                                          IsVisible="{TemplateBinding IsColorSpectrumSliderVisible}"
                                                          ThumbColorValueBrush="{TemplateBinding HsvValue, Converter={x:Static converters:HsvColorToBrushConverter.WithoutAlpha}}" />
                                        <atom:ColorSlider Name="ColorSpectrumAlphaSlider" DockPanel.Dock="Bottom"
                                                          ColorComponent="Alpha"
                                                          ColorModel="Hsva"
                                                          VerticalAlignment="Bottom"
                                                          HsvColor="{TemplateBinding HsvValue, Mode=TwoWay}"
                                                          IsVisible="{TemplateBinding IsAlphaEffectiveVisible}"
                                                          IsRoundingEnabled="True"
                                                          ThumbColorValueBrush="{TemplateBinding HsvValue, Converter={x:Static converters:HsvColorToBrushConverter.Default}}" />
                                    </Panel>
                                </DockPanel>
                                <atom:ColorPickerInput ColorValue="{TemplateBinding HsvValue, Mode=TwoWay}"
                                                       Format="{TemplateBinding Format, Mode=TwoWay}"
                                                       IsFormatEnabled="{TemplateBinding IsFormatEnabled, Mode=TwoWay}"
                                                       IsAlphaVisible="{TemplateBinding IsAlphaEffectiveVisible}"
                                                       IsClearEnabled="{TemplateBinding IsClearEnabled}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^ /template/ atom|GradientColorSlider#PART_GradientColorSlider">
            <Setter Property="IsVisible" Value="True" />
        </Style>

    </ControlTheme>
</ResourceDictionary>