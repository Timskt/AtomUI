<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:ClassModifier="internal"
    xmlns:atom="https://atomui.net">
    <ControlTheme x:Key="{x:Type atom:DataGridColumnGroupHeader}" TargetType="atom:DataGridColumnGroupHeader">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="{x:Static atom:DataGridColumnGroupHeaderThemeConstants.FramePart}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Background="{TemplateBinding Background}">
                    <ContentPresenter
                        Name="{x:Static atom:DataGridColumnGroupHeaderThemeConstants.HeaderPresenterPart}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                        VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                        Content="{TemplateBinding Header}"
                        ContentTemplate="{TemplateBinding HeaderTemplate}" />
                </Border>
            </ControlTemplate>
        </Setter>
        <Setter Property="Foreground" Value="{atom:DataGridTokenResource TableHeaderTextColor}"/>
        <Setter Property="FontWeight" Value="{atom:SharedTokenResource FontWeightStrong}"/>
        <Style Selector="^ /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        
        <Style Selector="^ /template/ Border#PART_Frame">
            <Setter Property="BorderBrush" Value="{atom:DataGridTokenResource TableBorderColor}"/>
        </Style>
        
        <Style Selector="^[SizeType=Large]">
            <Style Selector="^ /template/ Border#PART_Frame">
                <Setter Property="Padding" Value="{atom:DataGridTokenResource TablePadding}"/>
            </Style>
            <Setter Property="FontSize" Value="{atom:DataGridTokenResource TableFontSize}"/>
        </Style>
        <Style Selector="^[SizeType=Middle]">
            <Style Selector="^ /template/ Border#PART_Frame">
                <Setter Property="Padding" Value="{atom:DataGridTokenResource TablePaddingMiddle}"/>
            </Style>
            <Setter Property="FontSize" Value="{atom:DataGridTokenResource TableFontSizeMiddle}"/>
        </Style>
        <Style Selector="^[SizeType=Small]">
            <Style Selector="^ /template/ Border#PART_Frame">
                <Setter Property="Padding" Value="{atom:DataGridTokenResource TablePaddingSmall}"/>
            </Style>
            <Setter Property="FontSize" Value="{atom:DataGridTokenResource TableFontSizeSmall}"/>
        </Style>
        
    </ControlTheme>
</ResourceDictionary>