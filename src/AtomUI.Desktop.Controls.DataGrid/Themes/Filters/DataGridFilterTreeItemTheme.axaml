<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal"
    xmlns:themes="using:AtomUI.Desktop.Controls.Themes">
    <ControlTheme x:Key="{x:Type atom:DataGridFilterTreeViewItem}" TargetType="atom:DataGridFilterTreeViewItem">
        <ControlTheme.BasedOn>
            <themes:TreeViewItemTheme TargetType="atom:DataGridFilterTreeViewItem"/>
        </ControlTheme.BasedOn>
    </ControlTheme>
</ResourceDictionary>