<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:AvatarGroup}" TargetType="atom:AvatarGroup">
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="GroupSpace" Value="{atom:AvatarTokenResource GroupSpace}" />
        <Setter Property="GroupOverlapping" Value="{atom:AvatarTokenResource GroupOverlapping}" />
        <Setter Property="FoldInfoAvatarForeground"
                Value="{atom:AvatarTokenResource AvatarColor}" />
        <Setter Property="FoldInfoAvatarBackground" Value="{atom:AvatarTokenResource AvatarBg}" />
        <Setter Property="BorderThickness" Value="{atom:SharedTokenResource BorderThickness}" />
    </ControlTheme>
</ResourceDictionary>