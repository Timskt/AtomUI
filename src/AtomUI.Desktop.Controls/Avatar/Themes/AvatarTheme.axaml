<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:Avatar}" TargetType="atom:Avatar">
        <Setter Property="Template">
            <ControlTemplate>
                <Panel Name="RootLayout">
                    <Border Name="Frame"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}" />
                    <atom:IconPresenter Name="IconPresenter"
                                        Width="{TemplateBinding EffectiveIconSize}"
                                        Height="{TemplateBinding EffectiveIconSize}"
                                        Icon="{TemplateBinding Icon}"
                                        IconBrush="{TemplateBinding Foreground}"
                                        IsVisible="False"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                    <Image Name="ImagePresenter"
                           Width="{TemplateBinding Width}"
                           Height="{TemplateBinding Height}"
                           IsVisible="False"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Source="{TemplateBinding BitmapSrc}" />
                    <Svg Name="SvgPresenter"
                         Width="{TemplateBinding Width}"
                         Height="{TemplateBinding Height}"
                         IsVisible="False"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Path="{TemplateBinding Src}" />
                    <atom:TextBlock Name="PART_TextPresenter"
                                    Text="{TemplateBinding Text}"
                                    RenderTransform="{TemplateBinding TextRenderTransform}"
                                    IsVisible="False"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                </Panel>
            </ControlTemplate>
        </Setter>

        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Foreground" Value="{atom:AvatarTokenResource AvatarColor}" />
        <Setter Property="BorderBrush" Value="{atom:AvatarTokenResource GroupBorderColor}" />
        <Style Selector="^[ContentType=Icon]">
            <Setter Property="Background" Value="{atom:AvatarTokenResource AvatarBg}" />
            <Style Selector="^ /template/ atom|IconPresenter#IconPresenter">
                <Setter Property="IsVisible" Value="True" />
            </Style>
        </Style>

        <Style Selector="^[ContentType=Text]">
            <Setter Property="Background" Value="{atom:AvatarTokenResource AvatarBg}" />
            <Style Selector="^ /template/ atom|TextBlock#PART_TextPresenter">
                <Setter Property="IsVisible" Value="True" />
            </Style>
        </Style>

        <Style Selector="^[ContentType=BitmapImage]">
            <Setter Property="Background" Value="Transparent" />
            <Style Selector="^ /template/ Image#ImagePresenter">
                <Setter Property="IsVisible" Value="True" />
            </Style>
        </Style>

        <Style Selector="^[ContentType=SvgImage]">
            <Setter Property="Background" Value="Transparent" />
            <Style Selector="^ /template/ Svg#SvgPresenter">
                <Setter Property="IsVisible" Value="True" />
            </Style>
        </Style>

        <Style Selector="^[SizeType=Large]">
            <Setter Property="Width" Value="{atom:AvatarTokenResource ContainerSizeLG}" />
            <Setter Property="Height" Value="{atom:AvatarTokenResource ContainerSizeLG}" />
            <Setter Property="EffectiveIconSize"
                    Value="{atom:AvatarTokenResource TextFontSizeLG}" />
        </Style>

        <Style Selector="^[SizeType=Middle]">
            <Setter Property="Width" Value="{atom:AvatarTokenResource ContainerSize}" />
            <Setter Property="Height" Value="{atom:AvatarTokenResource ContainerSize}" />
            <Setter Property="EffectiveIconSize" Value="{atom:AvatarTokenResource TextFontSize}" />
        </Style>

        <Style Selector="^[SizeType=Small]">
            <Setter Property="Width" Value="{atom:AvatarTokenResource ContainerSizeSM}" />
            <Setter Property="Height" Value="{atom:AvatarTokenResource ContainerSizeSM}" />
            <Setter Property="EffectiveIconSize"
                    Value="{atom:AvatarTokenResource TextFontSizeSM}" />
        </Style>

        <Style Selector="^[Shape=Square]">
            <Style Selector="^[SizeType=Large]">
                <Setter Property="CornerRadius" Value="{atom:SharedTokenResource BorderRadiusLG}" />
            </Style>

            <Style Selector="^[SizeType=Middle]">
                <Setter Property="CornerRadius" Value="{atom:SharedTokenResource BorderRadius}" />
            </Style>

            <Style Selector="^[SizeType=Small]">
                <Setter Property="CornerRadius" Value="{atom:SharedTokenResource BorderRadiusSM}" />
            </Style>

            <Style Selector="^[SizeType=Custom]">
                <Setter Property="CornerRadius" Value="{atom:SharedTokenResource BorderRadius}" />
            </Style>
        </Style>

    </ControlTheme>
</ResourceDictionary>