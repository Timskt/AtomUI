<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:CountBadgeAdorner}" TargetType="atom:CountBadgeAdorner">
        <Setter Property="Template">
            <ControlTemplate>
                <atom:MotionActor Name="PART_MotionActor" ClipToBounds="False">
                    <Panel
                        Name="RootLayout">
                        <Border Name="BadgeIndicator"
                                BoxShadow="{TemplateBinding BoxShadow}"
                                Background="{TemplateBinding BadgeColor}" />
                        <atom:TextBlock
                            Name="BadgeText"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Text="{TemplateBinding CountText}" 
                            Foreground="{TemplateBinding Foreground}"/>
                    </Panel>
                </atom:MotionActor>
            </ControlTemplate>
        </Setter>

        <Setter Property="Foreground" Value="{atom:BadgeTokenResource BadgeTextColor}" />
        <Setter Property="ClipToBounds" Value="False" />
        <Setter Property="BadgeShadowSize" Value="{atom:BadgeTokenResource BadgeShadowSize}" />
        <Setter Property="BadgeShadowColor" Value="{atom:BadgeTokenResource BadgeShadowColor}" />
        <Setter Property="MotionDuration" Value="{atom:SharedTokenResource MotionDurationMid}" />
        <Setter Property="BadgeColor" Value="{atom:BadgeTokenResource BadgeColor}" />

        <Style Selector="^[IsAdornerMode=True]">
            <Style Selector="^ /template/ Panel#RootLayout">
                <Setter Property="HorizontalAlignment" Value="Right" />
                <Setter Property="VerticalAlignment" Value="Top" />
            </Style>
        </Style>
        <Style Selector="^ /template/ Border#BadgeIndicator">
            <Setter Property="Height" Value="{atom:BadgeTokenResource IndicatorHeight}" />
            <Setter Property="MinWidth" Value="{atom:BadgeTokenResource IndicatorHeight}" />
            <Setter Property="CornerRadius"
                    Value="{atom:BadgeTokenResource CountBadgeCornerRadius}" />
        </Style>
        <Style Selector="^ /template/ atom|TextBlock#BadgeText">
            <Setter Property="FontSize" Value="{atom:BadgeTokenResource TextFontSize}" />
            <Setter Property="Padding" Value="{atom:BadgeTokenResource CountBadgeTextPadding}" />
        </Style>

        <Style Selector="^[Size=Small]">
            <Style Selector="^ /template/ Border#BadgeIndicator">
                <Setter Property="Height" Value="{atom:BadgeTokenResource IndicatorHeightSM}" />
                <Setter Property="MinWidth" Value="{atom:BadgeTokenResource IndicatorHeightSM}" />
                <Setter Property="CornerRadius"
                        Value="{atom:BadgeTokenResource CountBadgeCornerRadiusSM}" />
            </Style>
            <Style Selector="^ /template/ atom|TextBlock#BadgeText">
                <Setter Property="FontSize" Value="{atom:BadgeTokenResource TextFontSizeSM}" />
            </Style>
        </Style>
    </ControlTheme>
</ResourceDictionary>