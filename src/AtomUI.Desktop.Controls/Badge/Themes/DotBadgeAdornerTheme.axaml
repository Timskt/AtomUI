<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:DotBadgeAdorner}" TargetType="atom:DotBadgeAdorner">
        <Setter Property="Template">
            <ControlTemplate>
                <DockPanel
                    Name="RootLayout"
                    LastChildFill="True"
                    ClipToBounds="False">
                    <atom:MotionActor
                        Name="PART_MotionActor"
                        ClipToBounds="False"
                        DockPanel.Dock="Left">
                        <atom:DotBadgeIndicator
                            Name="Indicator"
                            BadgeDotColor="{TemplateBinding BadgeDotColor}" />
                    </atom:MotionActor>
                    <Label Name="Label"
                           Content="{TemplateBinding Text}"
                           IsVisible="{TemplateBinding IsAdornerMode, Converter={x:Static BoolConverters.Not}}" />
                </DockPanel>
            </ControlTemplate>
        </Setter>

        <Setter Property="ClipToBounds" Value="False" />
        <Setter Property="BadgeDotColor" Value="{atom:BadgeTokenResource BadgeColor}" />
        <Setter Property="MotionDuration" Value="{atom:SharedTokenResource MotionDurationMid}" />

        <Style Selector="^[IsAdornerMode=True]">
            <Style Selector="^ /template/ DockPanel#RootLayout">
                <Setter Property="HorizontalAlignment" Value="Right" />
                <Setter Property="VerticalAlignment" Value="Top" />
            </Style>
        </Style>

        <Style Selector="^ /template/ Label#Label">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Margin" Value="{atom:BadgeTokenResource DotBadgeLabelMargin}" />
        </Style>
        
        <Style Selector="^ /template/ atom|MotionActor#PART_MotionActor">
            <Setter Property="Width" Value="{atom:BadgeTokenResource DotSize}" />
            <Setter Property="Height" Value="{atom:BadgeTokenResource DotSize}" />
        </Style>
        
        <Style Selector="^[Status=Error]">
            <Setter Property="BadgeDotColor" Value="{atom:SharedTokenResource ColorError}" />
        </Style>
             
        <Style Selector="^[Status=Success]">
            <Setter Property="BadgeDotColor" Value="{atom:SharedTokenResource ColorSuccess}" />
        </Style>
             
        <Style Selector="^[Status=Warning]">
            <Setter Property="BadgeDotColor" Value="{atom:SharedTokenResource ColorWarning}" />
        </Style>
             
        <Style Selector="^[Status=Processing]">
            <Setter Property="BadgeDotColor" Value="{atom:SharedTokenResource ColorInfo}" />
        </Style>
        
        <Style Selector="^[Status=Default]">
            <Setter Property="BadgeDotColor" Value="{atom:SharedTokenResource ColorTextPlaceholder}" />
        </Style>
    </ControlTheme>
</ResourceDictionary>