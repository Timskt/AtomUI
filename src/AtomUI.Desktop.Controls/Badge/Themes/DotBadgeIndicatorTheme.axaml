<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    xmlns:atomc="https://atomui.net/common-controls"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atomc:DotBadgeIndicator}" TargetType="atomc:DotBadgeIndicator">
        <Setter Property="BadgeShadowSize" Value="{atom:BadgeTokenResource BadgeShadowSize}"/>
        <Setter Property="BadgeShadowColor" Value="{atom:BadgeTokenResource BadgeShadowColor}"/>
    </ControlTheme>
</ResourceDictionary>
