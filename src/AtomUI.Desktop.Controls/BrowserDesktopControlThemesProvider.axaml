<atom:ControlThemesProvider xmlns="https://github.com/avaloniaui"
                            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                            xmlns:atom="https://atomui.net"
                            x:Class="AtomUI.Desktop.Controls.BrowserDesktopControlThemesProvider"
                            Id="AtomUI.Desktop.Controls">
    <atom:ControlThemesProvider.ControlThemes>
        <ResourceInclude Source="Badge/Themes/BadgeThemes.axaml" />
        <ResourceInclude Source="Primitives/Themes/WaveSpiritDecoratorTheme.axaml" />
        <ResourceInclude Source="Primitives/ArrowDecoratedBox/Themes/ArrowDecoratedBoxThemes.axaml" />
        <ResourceInclude Source="Buttons/Themes/BrowserButtonThemes.axaml" />
        <ResourceInclude Source="CheckBox/Themes/CheckBoxThemes.axaml" />
        <ResourceInclude Source="FloatButton/Themes/FloatButtonThemes.axaml" />
        <ResourceInclude Source="Flyouts/Themes/BrowserFlyoutThemes.axaml" />
        <ResourceInclude Source="GroupBox/Themes/GroupBoxTheme.axaml" />
        <ResourceInclude Source="Input/Themes/BrowserInputThemes.axaml" />
        <ResourceInclude Source="Menu/Themes/BrowserMenuThemes.axaml" />
        <ResourceInclude Source="NavMenu/Themes/NavMenuThemes.axaml" />
        <ResourceInclude Source="OptionButtonGroup/Themes/OptionButtonBoxThemes.axaml" />
        <ResourceInclude Source="Popup/Themes/PopupThemes.axaml" />
        <ResourceInclude Source="RadioButton/Themes/RadioButtonThemes.axaml" />
        <ResourceInclude Source="ScrollViewer/Themes/ScrollViewerThemes.axaml" />
        <ResourceInclude Source="Separator/Themes/SeparatorTheme.axaml" />
        <ResourceInclude Source="Switch/Themes/ToggleSwitchThemes.axaml" />
        <ResourceInclude Source="TabControl/Themes/TabControlThemes.axaml" />
    </atom:ControlThemesProvider.ControlThemes>
</atom:ControlThemesProvider>
