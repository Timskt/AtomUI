                        <Setter Property="StrokeBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorPrimaryActive}}" />
                    </Style>
                </Style>

                <Style Selector="^:danger">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorError}}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorError}}" />
                        <Setter Property="StrokeBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorError}}" />
                    </Style>

                    <Style Selector="^:pointerover">
                        <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                            <Setter Property="IconBrush"
                                    Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorBorderHover}}" />
                        </Style>
                        <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                            <Setter Property="FillBrush"
                                    Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorBorderHover}}" />
                            <Setter Property="StrokeBrush"
                                    Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorBorderHover}}" />
                        </Style>
                    </Style>

                    <Style Selector="^:pressed">
                        <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                            <Setter Property="IconBrush"
                                    Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorActive}}" />
                        </Style>
                        <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                            <Setter Property="FillBrush"
                                    Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorActive}}" />
                            <Setter Property="StrokeBrush"
                                    Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorActive}}" />
                        </Style>
                    </Style>
                </Style>
            </Style>

            <Style Selector="^ /template/ Border#ShadowsFrame">
                <Setter Property="BoxShadow" Value="{DynamicResource {x:Static atom:ButtonTokenKey.PrimaryShadow}}" />
            </Style>
            <Style Selector="^[IsDanger=True]">
                <Style Selector="^ /template/ Border#ShadowsFrame">
                    <Setter Property="BoxShadow" Value="{DynamicResource {x:Static atom:ButtonTokenKey.DangerShadow}}" />
                </Style>
            </Style>

        </Style>
        <!-- 主按钮样式结束 -->

        <!-- 链接按钮样式开始 -->
        <Style Selector="^[ButtonType=Link]">
            <Style Selector="^:not(:disabled)">
                <Setter Property="Foreground" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorLink}}" />
                <Style Selector="^/template/ Border#PART_Frame">
                    <Setter Property="Background" Value="{DynamicResource {x:Static atom:ButtonTokenKey.DefaultBg}}" />
                </Style>

                <Style Selector="^:pointerover">
                    <Setter Property="Foreground"
                            Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorLinkHover}}" />
                </Style>

                <Style Selector="^:pressed">
                    <Setter Property="Foreground"
                            Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorLinkActive}}" />
                </Style>

                <Style Selector="^:danger">
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorError}}" />

                    <Style Selector="^:pointerover">
                        <Setter Property="Foreground"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorHover}}" />
                    </Style>

                    <Style Selector="^:pressed">
                        <Setter Property="Foreground"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorActive}}" />
                    </Style>
                </Style>

                <Style Selector="^[IsGhost=True]">
                    <Setter Property="Background" Value="Transparent" />
                </Style>
            </Style>

            <Style Selector="^:disabled">
                <Setter Property="Background" Value="Transparent" />
            </Style>

            <!-- icon 的各种颜色 -->
            <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                <Setter Property="IconBrush" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorLink}}" />
            </Style>
            <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                <Setter Property="FillBrush" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorLink}}" />
                <Setter Property="StrokeBrush" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorLink}}" />
            </Style>

            <Style Selector="^:pointerover">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush"
                            Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorLinkHover}}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush"
                            Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorLinkHover}}" />
                    <Setter Property="StrokeBrush"
                            Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorLinkHover}}" />
                </Style>
            </Style>

            <Style Selector="^:pressed">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush"
                            Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorLinkActive}}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush"
                            Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorLinkActive}}" />
                    <Setter Property="StrokeBrush"
                            Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorLinkActive}}" />
                </Style>
            </Style>

            <Style Selector="^:disabled">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush"
                            Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextDisabled}}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush"
                            Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextDisabled}}" />
                    <Setter Property="StrokeBrush"
                            Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextDisabled}}" />
                </Style>
            </Style>

            <Style Selector="^:danger">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorError}}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorError}}" />
                    <Setter Property="StrokeBrush" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorError}}" />
                </Style>

                <Style Selector="^:pointerover">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorHover}}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorHover}}" />
                        <Setter Property="StrokeBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorHover}}" />
                    </Style>
                </Style>

                <Style Selector="^:pressed">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorActive}}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorActive}}" />
                        <Setter Property="StrokeBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorActive}}" />
                    </Style>
                </Style>

                <Style Selector="^:disabled">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextDisabled}}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextDisabled}}" />
                        <Setter Property="StrokeBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextDisabled}}" />
                    </Style>
                </Style>
            </Style>
        </Style>
        <!-- 链接按钮样式结束 -->

        <!-- 文字按钮样式开始 -->
        <Style Selector="^[ButtonType=Text]">
            <Style Selector="^:not(:disabled)">
                <Setter Property="Foreground" Value="{DynamicResource {x:Static atom:ButtonTokenKey.DefaultColor}}" />
                <Setter Property="Background" Value="Transparent" />

                <Style Selector="^:pointerover">
                    <Setter Property="Background" Value="{DynamicResource {x:Static atom:ButtonTokenKey.TextHoverBg}}" />
                </Style>

                <Style Selector="^:pressed">
                    <Setter Property="Background"
                            Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorBgTextActive}}" />
                </Style>

                <Style Selector="^:danger">
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorError}}" />

                    <Style Selector="^:pointerover">
                        <Setter Property="Background"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorBgHover}}" />
                        <Setter Property="Foreground"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorHover}}" />
                    </Style>

                    <Style Selector="^:pressed">
                        <Setter Property="Background"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorBgActive}}" />
                        <Setter Property="Foreground"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorActive}}" />
                    </Style>
                </Style>

            </Style>

            <Style Selector="^:disabled">
                <Setter Property="Background" Value="Transparent" />
            </Style>

            <!-- icon 的各种颜色 -->
            <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                <Setter Property="IconBrush" Value="{DynamicResource {x:Static atom:ButtonTokenKey.DefaultColor}}" />
            </Style>
            <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                <Setter Property="FillBrush" Value="{DynamicResource {x:Static atom:ButtonTokenKey.DefaultColor}}" />
                <Setter Property="StrokeBrush" Value="{DynamicResource {x:Static atom:ButtonTokenKey.DefaultColor}}" />
            </Style>

            <Style Selector="^:pointerover">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush" Value="{DynamicResource {x:Static atom:ButtonTokenKey.DefaultColor}}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush" Value="{DynamicResource {x:Static atom:ButtonTokenKey.DefaultColor}}" />
                    <Setter Property="StrokeBrush"
                            Value="{DynamicResource {x:Static atom:ButtonTokenKey.DefaultColor}}" />
                </Style>
            </Style>

            <Style Selector="^:pressed">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush" Value="{DynamicResource {x:Static atom:ButtonTokenKey.DefaultColor}}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush" Value="{DynamicResource {x:Static atom:ButtonTokenKey.DefaultColor}}" />
                    <Setter Property="StrokeBrush"
                            Value="{DynamicResource {x:Static atom:ButtonTokenKey.DefaultColor}}" />
                </Style>
            </Style>

            <Style Selector="^:disabled">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush"
                            Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextDisabled}}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush"
                            Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextDisabled}}" />
                    <Setter Property="StrokeBrush"
                            Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextDisabled}}" />
                </Style>
            </Style>

            <Style Selector="^:danger">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorError}}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorError}}" />
                    <Setter Property="StrokeBrush" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorError}}" />
                </Style>

                <Style Selector="^:pointerover">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorHover}}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorHover}}" />
                        <Setter Property="StrokeBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorHover}}" />
                    </Style>
                </Style>

                <Style Selector="^:pressed">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorActive}}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorActive}}" />
                        <Setter Property="StrokeBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorActive}}" />
                    </Style>
                </Style>

                <Style Selector="^:disabled">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextDisabled}}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextDisabled}}" />
                        <Setter Property="StrokeBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextDisabled}}" />
                    </Style>
                </Style>
            </Style>
        </Style>
        <!-- 文字按钮样式结束 -->

        <!-- 虚线按钮样式开始 -->
        <Setter Property="Template">
            <ControlTemplate TargetType="atom:Button">
                <Panel>
                    <atom:WaveSpiritDecorator Name="{x:Static atom:ButtonThemeConstants.WaveSpiritPart}"
                                              CornerRadius="{TemplateBinding EffectiveCornerRadius}"
                                              WaveType="{TemplateBinding WaveSpiritType}" />
                    <Border Name="ShadowsFrame"
                            CornerRadius="{TemplateBinding EffectiveCornerRadius}"
                            Background="{TemplateBinding Background}" />
                    <atom:DashedBorder Name="Frame"
                                       Padding="{TemplateBinding Padding}"
                                       BorderThickness="{TemplateBinding EffectiveBorderThickness}"
                                       BorderBrush="{TemplateBinding BorderBrush}"
                                       BackgroundSizing="{TemplateBinding BackgroundSizing}"
                                       CornerRadius="{TemplateBinding EffectiveCornerRadius}"
                                       Background="{TemplateBinding Background}"
                                       StrokeDashArray="{x:Static atom:ButtonTheme.DashedStyle}">
                        <DockPanel Name="{x:Static atom:ButtonThemeConstants.RootLayoutPart}"
                                   LastChildFill="True"
                                   HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                   VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
                            <antdicons:LoadingOutlined
                                Name="{x:Static atom:ButtonThemeConstants.LoadingIconPart}"
                                Margin="{Binding (atom:IconPresenter.Margin),
                                   ElementName={x:Static atom:ButtonThemeConstants.ButtonIconPart}}"
                                DockPanel.Dock="Left" />

                            <atom:IconPresenter
                                Name="{x:Static atom:ButtonThemeConstants.ButtonIconPart}"
                                Icon="{TemplateBinding Icon}"
                                DockPanel.Dock="Left">
                                <atom:IconPresenter.IsVisible>
                                    <MultiBinding
                                        Converter="{x:Static atom:ButtonTheme.IconVisibleConverter}">
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Icon" />
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="IsIconVisible" />
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="IsLoading" />
                                    </MultiBinding>
                                </atom:IconPresenter.IsVisible>
                            </atom:IconPresenter>
                            <ContentPresenter
                                Name="{x:Static atom:ButtonThemeConstants.ContentPresenterPart}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}" />
                        </DockPanel>
                    </atom:DashedBorder>
                    <Border Name="FocusVisual"
                            IsVisible="False"
                            IsHitTestVisible="False"
                            BorderThickness="{DynamicResource {x:Static atom:SharedTokenKey.FocusVisualBorderThickness}}"
                            BorderBrush="{DynamicResource {x:Static atom:SharedTokenKey.ColorFocusBorder}}"
                            CornerRadius="{TemplateBinding EffectiveCornerRadius}"
                            Margin="{DynamicResource {x:Static atom:AdornerLayerTokenKey.FocusVisualMargin}}"
                            ZIndex="1" />
                </Panel>
            </ControlTemplate>
        </Setter>

        <Style Selector="^[ButtonType=Dashed]">
            <Style Selector="^:not(:disabled)">
                <Setter Property="Foreground" Value="{DynamicResource {x:Static atom:ButtonTokenKey.DefaultColor}}" />
                <Setter Property="BorderBrush"
                        Value="{DynamicResource {x:Static atom:ButtonTokenKey.DefaultBorderColor}}" />
                <Setter Property="Background" Value="{DynamicResource {x:Static atom:ButtonTokenKey.DefaultBg}}" />

                <Style Selector="^:pointerover">
                    <Setter Property="Foreground"
                            Value="{DynamicResource {x:Static atom:ButtonTokenKey.DefaultHoverColor}}" />
                    <Setter Property="BorderBrush"
                            Value="{DynamicResource {x:Static atom:ButtonTokenKey.DefaultHoverBorderColor}}" />
                </Style>

                <Style Selector="^:pressed">
                    <Setter Property="Foreground"
                            Value="{DynamicResource {x:Static atom:ButtonTokenKey.DefaultActiveColor}}" />
                    <Setter Property="BorderBrush"
                            Value="{DynamicResource {x:Static atom:ButtonTokenKey.DefaultActiveBorderColor}}" />
                </Style>

                <Style Selector="^:danger">
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorError}}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorError}}" />

                    <Style Selector="^:pointerover">
                        <Setter Property="Foreground"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorBorderHover}}" />
                        <Setter Property="BorderBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorBorderHover}}" />
                    </Style>

                    <Style Selector="^:pressed">
                        <Setter Property="Foreground"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorActive}}" />
                        <Setter Property="BorderBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorActive}}" />
                    </Style>
                </Style>

                <Style Selector="^[IsGhost=True]">

                    <Setter Property="Foreground"
                            Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextLightSolid}}" />
                    <Setter Property="BorderBrush"
                            Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextLightSolid}}" />
                    <Setter Property="Background" Value="Transparent" />

                    <Style Selector="^:pointerover">
                        <Setter Property="Foreground"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorPrimaryHover}}" />
                        <Setter Property="BorderBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorPrimaryHover}}" />
                    </Style>

                    <Style Selector="^:pressed">
                        <Setter Property="Foreground"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorPrimaryActive}}" />
                        <Setter Property="BorderBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorPrimaryActive}}" />
                    </Style>

                    <Style Selector="^:danger">
                        <Setter Property="Foreground"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorError}}" />
                        <Setter Property="BorderBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorError}}" />

                        <Style Selector="^:pointerover">
                            <Setter Property="Foreground"
                                    Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorBorderHover}}" />
                            <Setter Property="BorderBrush"
                                    Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorBorderHover}}" />
                        </Style>

                        <Style Selector="^:pressed">
                            <Setter Property="Foreground"
                                    Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorActive}}" />
                            <Setter Property="BorderBrush"
                                    Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorActive}}" />
                        </Style>
                    </Style>
                </Style>
            </Style>

            <Style Selector="^[IsGhost=True]">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush"
                            Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextLightSolid}}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush"
                            Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextLightSolid}}" />
                    <Setter Property="StrokeBrush"
                            Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextLightSolid}}" />
                </Style>

                <Style Selector="^:pointerover">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorPrimaryHover}}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorPrimaryHover}}" />
                        <Setter Property="StrokeBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorPrimaryHover}}" />
                    </Style>
                </Style>

                <Style Selector="^:pressed">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorPrimaryActive}}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorPrimaryActive}}" />
                        <Setter Property="StrokeBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorPrimaryActive}}" />
                    </Style>
                </Style>

            </Style>

            <Style Selector="^ /template/ Border#FocusVisual">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="^:focus-visible /template/ Border#FocusVisual">
                <Setter Property="IsVisible" Value="True" />
            </Style>

            <Style Selector="^:danger">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorError}}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorError}}" />
                    <Setter Property="StrokeBrush" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorError}}" />
                </Style>

                <Style Selector="^:pointerover">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorBorderHover}}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorBorderHover}}" />
                        <Setter Property="StrokeBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorBorderHover}}" />
                    </Style>
                </Style>

                <Style Selector="^:pressed">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorActive}}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorActive}}" />
                        <Setter Property="StrokeBrush"
                                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorActive}}" />
                    </Style>
                </Style>

            </Style>

            <Style Selector="^:disabled">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush"
                            Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextDisabled}}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush"
                            Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextDisabled}}" />
                    <Setter Property="StrokeBrush"
                            Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextDisabled}}" />
                </Style>
            </Style>

            <Style Selector="^ /template/ Border#ShadowsFrame">
                <Setter Property="BoxShadow" Value="{DynamicResource {x:Static atom:ButtonTokenKey.DefaultShadow}}" />
            </Style>
            <Style Selector="^[IsDanger=True]">
                <Style Selector="^ /template/ Border#ShadowsFrame">
                    <Setter Property="BoxShadow" Value="{DynamicResource {x:Static atom:ButtonTokenKey.DangerShadow}}" />
                </Style>
            </Style>

            <Style Selector="^[SizeType=Large]">
                <Style Selector="^ /template/ atom|DashedBorder#Frame">
                    <Setter Property="Height" Value="{DynamicResource {x:Static atom:SharedTokenKey.ControlHeightLG}}" />
                </Style>
            </Style>

            <Style Selector="^[SizeType=Middle]">
                <Style Selector="^ /template/ atom|DashedBorder#Frame">
                    <Setter Property="Height" Value="{DynamicResource {x:Static atom:SharedTokenKey.ControlHeight}}" />
                </Style>
            </Style>

            <Style Selector="^[SizeType=Small]">
                <Style Selector="^ /template/ atom|DashedBorder#Frame">
                    <Setter Property="Height" Value="{DynamicResource {x:Static atom:SharedTokenKey.ControlHeightSM}}" />
                </Style>
            </Style>
        </Style>
        <!-- 虚线按钮样式结束 -->
    </Style>
</ControlTheme>