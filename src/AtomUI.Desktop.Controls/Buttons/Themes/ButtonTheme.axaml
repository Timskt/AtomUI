<ControlTheme xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:atom="https://atomui.net"
              x:Class="AtomUI.Desktop.Controls.Themes.ButtonTheme"
              TargetType="atom:Button">
    <Style Selector="^:is(atom|Button)">
        <Style Selector="^[ButtonType=Default], ^[ButtonType=Link], ^[ButtonType=Primary], ^[ButtonType=Text]">
            <Setter Property="Template">
                <ControlTemplate>
                    <Panel>
                        <atom:WaveSpiritDecorator Name="{x:Static atom:ButtonThemeConstants.WaveSpiritPart}"
                                                  CornerRadius="{TemplateBinding EffectiveCornerRadius}"
                                                  WaveType="{TemplateBinding WaveSpiritType}" />
                        <Border Name="ShadowsFrame"
                                CornerRadius="{TemplateBinding EffectiveCornerRadius}" />
                        <Border Name="Frame"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="{TemplateBinding EffectiveBorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BackgroundSizing="{TemplateBinding BackgroundSizing}"
                                CornerRadius="{TemplateBinding EffectiveCornerRadius}"
                                Background="{TemplateBinding Background}">
                            <DockPanel Name="{x:Static atom:ButtonThemeConstants.RootLayoutPart}"
                                       LastChildFill="True"
                                       HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                       VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
                                <!-- <antdicons:LoadingOutlined -->
                                <!--     Name="{x:Static atom:ButtonThemeConstants.LoadingIconPart}" -->
                                <!--     LoadingAnimation="Spin" -->
                                <!--     Margin="{CompiledBinding (atom:IconPresenter.Margin), -->
                                <!--    ElementName={x:Static atom:ButtonThemeConstants.ButtonIconPart}}" -->
                                <!--     DockPanel.Dock="Left" /> -->

                                <atom:IconPresenter
                                    Name="{x:Static atom:ButtonThemeConstants.ButtonIconPart}"
                                    Icon="{TemplateBinding Icon}"
                                    DockPanel.Dock="Left">
                                    <atom:IconPresenter.IsVisible>
                                        <MultiBinding
                                            Converter="{x:Static atom:ButtonTheme.IconVisibleConverter}">
                                            <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Icon" />
                                            <Binding RelativeSource="{RelativeSource TemplatedParent}"
                                                     Path="IsIconVisible" />
                                            <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="IsLoading" />
                                        </MultiBinding>
                                    </atom:IconPresenter.IsVisible>
                                </atom:IconPresenter>
                                <ContentPresenter
                                    Name="{x:Static atom:ButtonThemeConstants.ContentPresenterPart}"
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    IsVisible="{TemplateBinding Content, Converter={x:Static ObjectConverters.IsNotNull}}" />
                            </DockPanel>
                        </Border>
                        <!-- <Border Name="FocusVisual" -->
                        <!--         IsVisible="False" -->
                        <!--         IsHitTestVisible="False" -->
                        <!--         BorderThickness="{atom:SharedTokenResource FocusVisualBorderThickness}" -->
                        <!--         BorderBrush="{atom:SharedTokenResource ColorFocusBorder}" -->
                        <!--         CornerRadius="{TemplateBinding EffectiveCornerRadius}" -->
                        <!--         Margin="{atom:AdornerLayerTokenResource FocusVisualMargin}" -->
                        <!--         ZIndex="1" /> -->
                    </Panel>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="^[ButtonType=Dashed]">
            <Setter Property="Template">
                <ControlTemplate>
                    <Panel>
                        <atom:WaveSpiritDecorator Name="{x:Static atom:ButtonThemeConstants.WaveSpiritPart}"
                                                  CornerRadius="{TemplateBinding EffectiveCornerRadius}"
                                                  WaveType="{TemplateBinding WaveSpiritType}" />
                        <Border Name="ShadowsFrame"
                                CornerRadius="{TemplateBinding EffectiveCornerRadius}"
                                Background="{TemplateBinding Background}" />
                        <atom:DashedBorder Name="Frame"
                                           Padding="{TemplateBinding Padding}"
                                           BorderThickness="{TemplateBinding EffectiveBorderThickness}"
                                           BorderBrush="{TemplateBinding BorderBrush}"
                                           BackgroundSizing="{TemplateBinding BackgroundSizing}"
                                           CornerRadius="{TemplateBinding EffectiveCornerRadius}"
                                           Background="{TemplateBinding Background}"
                                           StrokeDashArray="{x:Static atom:ButtonTheme.DashedStyle}">
                            <DockPanel Name="{x:Static atom:ButtonThemeConstants.RootLayoutPart}"
                                       LastChildFill="True"
                                       HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                       VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
                                <!-- <antdicons:LoadingOutlined -->
                                <!--     Name="{x:Static atom:ButtonThemeConstants.LoadingIconPart}" -->
                                <!--     Margin="{Binding (atom:IconPresenter.Margin), -->
                                <!--    ElementName={x:Static atom:ButtonThemeConstants.ButtonIconPart}}" -->
                                <!--     DockPanel.Dock="Left" /> -->

                                <atom:IconPresenter
                                    Name="{x:Static atom:ButtonThemeConstants.ButtonIconPart}"
                                    Icon="{TemplateBinding Icon}"
                                    DockPanel.Dock="Left">
                                    <atom:IconPresenter.IsVisible>
                                        <MultiBinding
                                            Converter="{x:Static atom:ButtonTheme.IconVisibleConverter}">
                                            <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Icon" />
                                            <Binding RelativeSource="{RelativeSource TemplatedParent}"
                                                     Path="IsIconVisible" />
                                            <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="IsLoading" />
                                        </MultiBinding>
                                    </atom:IconPresenter.IsVisible>
                                </atom:IconPresenter>
                                <ContentPresenter
                                    Name="{x:Static atom:ButtonThemeConstants.ContentPresenterPart}"
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}" />
                            </DockPanel>
                        </atom:DashedBorder>
                        <!-- <Border Name="FocusVisual" -->
                        <!--         IsVisible="False" -->
                        <!--         IsHitTestVisible="False" -->
                        <!--         BorderThickness="{atom:SharedTokenResource FocusVisualBorderThickness}" -->
                        <!--         BorderBrush="{atom:SharedTokenResource ColorFocusBorder}" -->
                        <!--         CornerRadius="{TemplateBinding EffectiveCornerRadius}" -->
                        <!--         Margin="{atom:AdornerLayerTokenResource FocusVisualMargin}" -->
                        <!--         ZIndex="1" /> -->
                    </Panel>
                </ControlTemplate>
            </Setter>
        </Style>

        <!-- 公用样式开始 -->
        
        <Style Selector="^[IsMotionEnabled=True]">
            <Setter Property="Transitions">
                <Transitions>
                    <atom:SolidColorBrushTransition Property="Background" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}"/>
                    <atom:SolidColorBrushTransition Property="Foreground" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}"/>
                    <atom:SolidColorBrushTransition Property="BorderBrush" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}"/>
                </Transitions>
            </Setter>
        </Style>
        
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="BorderThickness" Value="{atom:SharedTokenResource BorderThickness}" />
        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}" />
        <Setter Property="IsWaveSpiritEnabled"
                Value="{atom:SharedTokenResource EnableWaveSpirit}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="ClipToBounds" Value="False" />
        <Setter Property="FocusAdorner" Value="{x:Null}" />

        <Style Selector="^[SizeType=Large]">
            <Style Selector="^ /template/ Border#Frame">
                <Setter Property="Height" Value="{atom:SharedTokenResource ControlHeightLG}" />
            </Style>
            <Setter Property="FontSize" Value="{atom:ButtonTokenResource ContentFontSizeLG}" />
            <Setter Property="CornerRadius" Value="{atom:SharedTokenResource BorderRadiusLG}" />
            <Style Selector="^:not(^[Shape=Circle])">
                <Setter Property="Padding" Value="{atom:ButtonTokenResource PaddingLG}" />
            </Style>
            <Style Selector="^:icononly">
                <Setter Property="Padding" Value="{atom:ButtonTokenResource IconOnyPaddingLG}" />
            </Style>
        </Style>

        <Style Selector="^[SizeType=Middle]">
            <Style Selector="^ /template/ Border#Frame">
                <Setter Property="Height" Value="{atom:SharedTokenResource ControlHeight}" />
            </Style>
            <Setter Property="FontSize" Value="{atom:ButtonTokenResource ContentFontSize}" />
            <Setter Property="CornerRadius" Value="{atom:SharedTokenResource BorderRadius}" />
            <Style Selector="^:not(^[Shape=Circle])">
                <Setter Property="Padding" Value="{atom:ButtonTokenResource Padding}" />
            </Style>
            <Style Selector="^:icononly">
                <Setter Property="Padding" Value="{atom:ButtonTokenResource IconOnyPadding}" />
            </Style>
        </Style>

        <Style Selector="^[SizeType=Small]">
            <Style Selector="^ /template/ Border#Frame">
                <Setter Property="Height" Value="{atom:SharedTokenResource ControlHeightSM}" />
            </Style>
            <Setter Property="FontSize" Value="{atom:ButtonTokenResource ContentFontSizeSM}" />
            <Setter Property="CornerRadius" Value="{atom:SharedTokenResource BorderRadiusSM}" />
            <Style Selector="^:not(^[Shape=Circle])">
                <Setter Property="Padding" Value="{atom:ButtonTokenResource PaddingSM}" />
            </Style>
            <Style Selector="^:icononly">
                <Setter Property="Padding" Value="{atom:ButtonTokenResource IconOnyPaddingSM}" />
            </Style>
        </Style>

        <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
            <Setter Property="IconBrush" Value="{atom:SharedTokenResource ColorTextSecondary}" />
        </Style>

        <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
            <Setter Property="FillBrush" Value="{atom:SharedTokenResource ColorTextSecondary}" />
            <Setter Property="StrokeBrush" Value="{atom:SharedTokenResource ColorTextSecondary}" />
        </Style>

        <Style Selector="^:pointerover">
            <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                <Setter Property="IconBrush" Value="{atom:ButtonTokenResource DefaultHoverColor}" />
            </Style>
            <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                <Setter Property="FillBrush" Value="{atom:ButtonTokenResource DefaultHoverColor}" />
                <Setter Property="StrokeBrush"
                        Value="{atom:ButtonTokenResource DefaultHoverColor}" />
            </Style>
        </Style>

        <Style Selector="^:pressed">
            <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                <Setter Property="IconBrush"
                        Value="{atom:ButtonTokenResource DefaultActiveColor}" />
            </Style>
            <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                <Setter Property="FillBrush"
                        Value="{atom:ButtonTokenResource DefaultActiveColor}" />
                <Setter Property="StrokeBrush"
                        Value="{atom:ButtonTokenResource DefaultActiveColor}" />
            </Style>
        </Style>

        <Style Selector="^:disabled">
            <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                <Setter Property="IconBrush" Value="{atom:SharedTokenResource ColorTextDisabled}" />
            </Style>
            <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                <Setter Property="FillBrush" Value="{atom:SharedTokenResource ColorTextDisabled}" />
                <Setter Property="StrokeBrush"
                        Value="{atom:SharedTokenResource ColorTextDisabled}" />
            </Style>
        </Style>

        <!--  text 和 icon 都存在的情况 -->
        <Style Selector="^[SizeType=Large]">
            <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                <Setter Property="Width" Value="{atom:SharedTokenResource IconSizeLG}" />
                <Setter Property="Height" Value="{atom:SharedTokenResource IconSizeLG}" />
            </Style>
            <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                <Setter Property="Width" Value="{atom:SharedTokenResource IconSizeLG}" />
                <Setter Property="Height" Value="{atom:SharedTokenResource IconSizeLG}" />
            </Style>
        </Style>
        <Style Selector="^[SizeType=Middle]">
            <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                <Setter Property="Width" Value="{atom:SharedTokenResource IconSize}" />
                <Setter Property="Height" Value="{atom:SharedTokenResource IconSize}" />
            </Style>
            <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                <Setter Property="Width" Value="{atom:SharedTokenResource IconSize}" />
                <Setter Property="Height" Value="{atom:SharedTokenResource IconSize}" />
            </Style>
        </Style>
        <Style Selector="^[SizeType=Small]">
            <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                <Setter Property="Width" Value="{atom:SharedTokenResource IconSizeSM}" />
                <Setter Property="Height" Value="{atom:SharedTokenResource IconSizeSM}" />
            </Style>
            <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                <Setter Property="Width" Value="{atom:SharedTokenResource IconSizeSM}" />
                <Setter Property="Height" Value="{atom:SharedTokenResource IconSizeSM}" />
            </Style>
        </Style>

        <Style Selector="^:icononly">
            <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon, ^ /template/ atom|Icon#PART_LoadingIcon">
                <Setter Property="Margin" Value="0" />
            </Style>
            <Style Selector="^[SizeType=Large]">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon atom|Icon">
                    <Setter Property="Width"
                            Value="{atom:ButtonTokenResource OnlyIconSizeLG}" />
                    <Setter Property="Height"
                            Value="{atom:ButtonTokenResource OnlyIconSizeLG}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="Width"
                            Value="{atom:ButtonTokenResource OnlyIconSizeLG}" />
                    <Setter Property="Height"
                            Value="{atom:ButtonTokenResource OnlyIconSizeLG}" />
                </Style>
            </Style>
            <Style Selector="^[SizeType=Middle]">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon atom|Icon">
                    <Setter Property="Width"
                            Value="{atom:ButtonTokenResource OnlyIconSize}" />
                    <Setter Property="Height"
                            Value="{atom:ButtonTokenResource OnlyIconSize}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="Width"
                            Value="{atom:ButtonTokenResource OnlyIconSize}" />
                    <Setter Property="Height"
                            Value="{atom:ButtonTokenResource OnlyIconSize}" />
                </Style>
            </Style>
            <Style Selector="^[SizeType=Small]">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon atom|Icon">
                    <Setter Property="Width"
                            Value="{atom:ButtonTokenResource OnlyIconSizeSM}" />
                    <Setter Property="Height"
                            Value="{atom:ButtonTokenResource OnlyIconSizeSM}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="Width"
                            Value="{atom:ButtonTokenResource OnlyIconSizeSM}" />
                    <Setter Property="Height"
                            Value="{atom:ButtonTokenResource OnlyIconSizeSM}" />
                </Style>
            </Style>
        </Style>

        <Style Selector="^:not(:icononly)">
            <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon, ^ /template/ atom|Icon#PART_LoadingIcon">
                <Setter Property="Margin" Value="{atom:ButtonTokenResource IconMargin}" />
            </Style>
        </Style>

        <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
            <Setter Property="IsVisible" Value="True" />
        </Style>
        <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="^:loading">
            <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                <Setter Property="IsVisible" Value="True" />
            </Style>
            <Setter Property="Opacity" Value="{atom:SharedTokenResource OpacityLoading}" />
        </Style>

        <Style Selector="^[Shape=Circle]">
            <Setter Property="Padding" Value="{atom:ButtonTokenResource CirclePadding}" />
        </Style>

        <Style Selector="^ /template/ Border#FocusVisual">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="^:focus-visible /template/ Border#FocusVisual">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Foreground"
                    Value="{atom:SharedTokenResource ColorTextDisabled}" />
            <Setter Property="BorderBrush"
                    Value="{atom:ButtonTokenResource BorderColorDisabled}" />

            <Setter Property="Background"
                    Value="{atom:SharedTokenResource ColorBgContainerDisabled}" />
        </Style>
        <!-- 公用样式结束 -->

        <!-- 默认按钮样式开始 -->
        <Style Selector="^[ButtonType=Default]">
            <Style Selector="^:not(:disabled)">
                <Setter Property="Foreground" Value="{atom:ButtonTokenResource DefaultColor}" />
                <Setter Property="BorderBrush"
                        Value="{atom:ButtonTokenResource DefaultBorderColor}" />
                <Setter Property="Background" Value="{atom:ButtonTokenResource DefaultBg}" />

                <Style Selector="^:pointerover">
                    <Setter Property="Foreground"
                            Value="{atom:ButtonTokenResource DefaultHoverColor}" />
                    <Setter Property="BorderBrush"
                            Value="{atom:ButtonTokenResource DefaultHoverBorderColor}" />
                </Style>

                <Style Selector="^:pressed">
                    <Setter Property="Foreground"
                            Value="{atom:ButtonTokenResource DefaultActiveColor}" />
                    <Setter Property="BorderBrush"
                            Value="{atom:ButtonTokenResource DefaultActiveBorderColor}" />
                </Style>

                <Style Selector="^:danger">
                    <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorError}" />
                    <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorError}" />

                    <Style Selector="^:pointerover">
                        <Setter Property="Foreground"
                                Value="{atom:SharedTokenResource ColorErrorBorderHover}" />
                        <Setter Property="BorderBrush"
                                Value="{atom:SharedTokenResource ColorErrorBorderHover}" />
                    </Style>

                    <Style Selector="^:pressed">
                        <Setter Property="Foreground"
                                Value="{atom:SharedTokenResource ColorErrorActive}" />
                        <Setter Property="BorderBrush"
                                Value="{atom:SharedTokenResource ColorErrorActive}" />
                    </Style>
                </Style>

                <Style Selector="^[IsGhost=True]">

                    <Setter Property="Foreground"
                            Value="{atom:SharedTokenResource ColorTextLightSolid}" />
                    <Setter Property="BorderBrush"
                            Value="{atom:SharedTokenResource ColorTextLightSolid}" />
                    <Setter Property="Background" Value="Transparent" />

                    <Style Selector="^:pointerover">
                        <Setter Property="Foreground"
                                Value="{atom:SharedTokenResource ColorPrimaryHover}" />
                        <Setter Property="BorderBrush"
                                Value="{atom:SharedTokenResource ColorPrimaryHover}" />
                    </Style>

                    <Style Selector="^:pressed">
                        <Setter Property="Foreground"
                                Value="{atom:SharedTokenResource ColorPrimaryActive}" />
                        <Setter Property="BorderBrush"
                                Value="{atom:SharedTokenResource ColorPrimaryActive}" />
                    </Style>

                    <Style Selector="^:danger">
                        <Setter Property="Foreground"
                                Value="{atom:SharedTokenResource ColorError}" />
                        <Setter Property="BorderBrush"
                                Value="{atom:SharedTokenResource ColorError}" />

                        <Style Selector="^:pointerover">
                            <Setter Property="Foreground"
                                    Value="{atom:SharedTokenResource ColorErrorBorderHover}" />
                            <Setter Property="BorderBrush"
                                    Value="{atom:SharedTokenResource ColorErrorBorderHover}" />
                        </Style>

                        <Style Selector="^:pressed">
                            <Setter Property="Foreground"
                                    Value="{atom:SharedTokenResource ColorErrorActive}" />
                            <Setter Property="BorderBrush"
                                    Value="{atom:SharedTokenResource ColorErrorActive}" />
                        </Style>
                    </Style>
                </Style>
            </Style>

            <!-- icon 的各种颜色 -->
            <Style Selector="^[IsGhost=True]">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush"
                            Value="{atom:SharedTokenResource ColorTextLightSolid}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush"
                            Value="{atom:SharedTokenResource ColorTextLightSolid}" />
                    <Setter Property="StrokeBrush"
                            Value="{atom:SharedTokenResource ColorTextLightSolid}" />
                </Style>

                <Style Selector="^:pointerover">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{atom:SharedTokenResource ColorPrimaryHover}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{atom:SharedTokenResource ColorPrimaryHover}" />
                        <Setter Property="StrokeBrush"
                                Value="{atom:SharedTokenResource ColorPrimaryHover}" />
                    </Style>
                </Style>

                <Style Selector="^:pressed">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{atom:SharedTokenResource ColorPrimaryActive}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{atom:SharedTokenResource ColorPrimaryActive}" />
                        <Setter Property="StrokeBrush"
                                Value="{atom:SharedTokenResource ColorPrimaryActive}" />
                    </Style>
                </Style>

            </Style>

            <Style Selector="^:danger">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush" Value="{atom:SharedTokenResource ColorError}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush" Value="{atom:SharedTokenResource ColorError}" />
                    <Setter Property="StrokeBrush" Value="{atom:SharedTokenResource ColorError}" />
                </Style>

                <Style Selector="^:pointerover">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{atom:SharedTokenResource ColorErrorBorderHover}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{atom:SharedTokenResource ColorErrorBorderHover}" />
                        <Setter Property="StrokeBrush"
                                Value="{atom:SharedTokenResource ColorErrorBorderHover}" />
                    </Style>
                </Style>

                <Style Selector="^:pressed">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{atom:SharedTokenResource ColorErrorActive}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{atom:SharedTokenResource ColorErrorActive}" />
                        <Setter Property="StrokeBrush"
                                Value="{atom:SharedTokenResource ColorErrorActive}" />
                    </Style>
                </Style>
            </Style>

            <Style Selector="^:disabled">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush"
                            Value="{atom:SharedTokenResource ColorTextDisabled}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush"
                            Value="{atom:SharedTokenResource ColorTextDisabled}" />
                    <Setter Property="StrokeBrush"
                            Value="{atom:SharedTokenResource ColorTextDisabled}" />
                </Style>
            </Style>

            <Style Selector="^ /template/ Border#ShadowsFrame">
                <Setter Property="BoxShadow" Value="{atom:ButtonTokenResource DefaultShadow}" />
            </Style>
            <Style Selector="^[IsDanger=True]">
                <Style Selector="^ /template/ Border#ShadowsFrame">
                    <Setter Property="BoxShadow" Value="{atom:ButtonTokenResource DangerShadow}" />
                </Style>
            </Style>
        </Style>
        <!-- 默认按钮样式结束 -->

        <!-- 主按钮样式开始 -->
        <Style Selector="^[ButtonType=Primary]">
            <Style Selector="^:not(:disabled)">
                <Setter Property="Foreground" Value="{atom:ButtonTokenResource PrimaryColor}" />
                <Setter Property="Background" Value="{atom:SharedTokenResource ColorPrimary}" />
                <Setter Property="BorderBrush" Value="{Binding Background, RelativeSource={RelativeSource Self}}" />
                
                <Style Selector="^:pointerover">
                    <Setter Property="Background"
                            Value="{atom:SharedTokenResource ColorPrimaryHover}" />
                </Style>

                <Style Selector="^:pressed">
                    <Setter Property="Background"
                            Value="{atom:SharedTokenResource ColorPrimaryActive}" /> 
                </Style>

                <Style Selector="^:danger">
                    <Setter Property="Background" Value="{atom:SharedTokenResource ColorError}" />
                    <Style Selector="^:pointerover">
                        <Setter Property="Background"
                                Value="{atom:SharedTokenResource ColorErrorHover}" />
                        <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorErrorHover}" />
                    </Style>

                    <Style Selector="^:pressed">
                        <Setter Property="Background"
                                Value="{atom:SharedTokenResource ColorErrorActive}" />
                        <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorErrorActive}" />
                    </Style>
                </Style>

                <Style Selector="^[IsGhost=True]">
                    <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorPrimary}" />
                    <Setter Property="BorderBrush"
                            Value="{atom:SharedTokenResource ColorPrimary}" />

                    <Setter Property="Background" Value="Transparent" />

                    <Style Selector="^:pointerover">
                        <Setter Property="Foreground"
                                Value="{atom:SharedTokenResource ColorPrimaryHover}" />
                        <Setter Property="BorderBrush"
                                Value="{atom:SharedTokenResource ColorPrimaryHover}" />
                    </Style>

                    <Style Selector="^:pressed">
                        <Setter Property="Foreground"
                                Value="{atom:SharedTokenResource ColorPrimaryActive}" />
                        <Setter Property="BorderBrush"
                                Value="{atom:SharedTokenResource ColorPrimaryActive}" />
                    </Style>

                    <Style Selector="^:danger">
                        <Setter Property="Foreground"
                                Value="{atom:SharedTokenResource ColorError}" />
                        <Setter Property="BorderBrush"
                                Value="{atom:SharedTokenResource ColorError}" />

                        <Style Selector="^:pointerover">
                            <Setter Property="Foreground"
                                    Value="{atom:SharedTokenResource ColorErrorBorderHover}" />
                            <Setter Property="BorderBrush"
                                    Value="{atom:SharedTokenResource ColorErrorBorderHover}" />
                        </Style>

                        <Style Selector="^:pressed">
                            <Setter Property="Foreground"
                                    Value="{atom:SharedTokenResource ColorErrorActive}" />
                            <Setter Property="BorderBrush"
                                    Value="{atom:SharedTokenResource ColorErrorActive}" />
                        </Style>
                    </Style>
                </Style>
                <Style Selector="^[IsGhost=False]">
                    <Setter Property="BorderThickness" Value="0" />
                </Style>
            </Style>

            <!-- icon 的各种颜色 -->
            <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                <Setter Property="IconBrush" Value="{atom:ButtonTokenResource PrimaryColor}" />
            </Style>
            <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                <Setter Property="FillBrush" Value="{atom:ButtonTokenResource PrimaryColor}" />
                <Setter Property="StrokeBrush" Value="{atom:ButtonTokenResource PrimaryColor}" />
            </Style>

            <Style Selector="^:pointerover">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush" Value="{atom:ButtonTokenResource PrimaryColor}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush" Value="{atom:ButtonTokenResource PrimaryColor}" />
                    <Setter Property="StrokeBrush"
                            Value="{atom:ButtonTokenResource PrimaryColor}" />
                </Style>
            </Style>

            <Style Selector="^:pressed">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush" Value="{atom:ButtonTokenResource PrimaryColor}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush" Value="{atom:ButtonTokenResource PrimaryColor}" />
                    <Setter Property="StrokeBrush"
                            Value="{atom:ButtonTokenResource PrimaryColor}" />
                </Style>
            </Style>

            <Style Selector="^:disabled">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush"
                            Value="{atom:SharedTokenResource ColorTextDisabled}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush"
                            Value="{atom:SharedTokenResource ColorTextDisabled}" />
                    <Setter Property="StrokeBrush"
                            Value="{atom:SharedTokenResource ColorTextDisabled}" />
                </Style>
            </Style>

            <Style Selector="^[IsGhost=True]">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush" Value="{atom:SharedTokenResource ColorPrimary}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush" Value="{atom:SharedTokenResource ColorPrimary}" />
                    <Setter Property="StrokeBrush"
                            Value="{atom:SharedTokenResource ColorPrimary}" />
                </Style>

                <Style Selector="^:pointerover">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{atom:SharedTokenResource ColorPrimaryHover}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{atom:SharedTokenResource ColorPrimaryHover}" />
                        <Setter Property="StrokeBrush"
                                Value="{atom:SharedTokenResource ColorPrimaryHover}" />
                    </Style>
                </Style>

                <Style Selector="^:pressed">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{atom:SharedTokenResource ColorPrimaryActive}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{atom:SharedTokenResource ColorPrimaryActive}" />
                        <Setter Property="StrokeBrush"
                                Value="{atom:SharedTokenResource ColorPrimaryActive}" />
                    </Style>
                </Style>

                <Style Selector="^:danger">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{atom:SharedTokenResource ColorError}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{atom:SharedTokenResource ColorError}" />
                        <Setter Property="StrokeBrush"
                                Value="{atom:SharedTokenResource ColorError}" />
                    </Style>

                    <Style Selector="^:pointerover">
                        <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                            <Setter Property="IconBrush"
                                    Value="{atom:SharedTokenResource ColorErrorBorderHover}" />
                        </Style>
                        <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                            <Setter Property="FillBrush"
                                    Value="{atom:SharedTokenResource ColorErrorBorderHover}" />
                            <Setter Property="StrokeBrush"
                                    Value="{atom:SharedTokenResource ColorErrorBorderHover}" />
                        </Style>
                    </Style>

                    <Style Selector="^:pressed">
                        <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                            <Setter Property="IconBrush"
                                    Value="{atom:SharedTokenResource ColorErrorActive}" />
                        </Style>
                        <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                            <Setter Property="FillBrush"
                                    Value="{atom:SharedTokenResource ColorErrorActive}" />
                            <Setter Property="StrokeBrush"
                                    Value="{atom:SharedTokenResource ColorErrorActive}" />
                        </Style>
                    </Style>
                </Style>
            </Style>

            <Style Selector="^ /template/ Border#ShadowsFrame">
                <Setter Property="BoxShadow" Value="{atom:ButtonTokenResource PrimaryShadow}" />
            </Style>
            <Style Selector="^[IsDanger=True]">
                <Style Selector="^ /template/ Border#ShadowsFrame">
                    <Setter Property="BoxShadow" Value="{atom:ButtonTokenResource DangerShadow}" />
                </Style>
            </Style>

        </Style>
        <!-- 主按钮样式结束 -->

        <!-- 链接按钮样式开始 -->
        <Style Selector="^[ButtonType=Link]">
            <Style Selector="^:not(:disabled)">
                <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorLink}" />
                <Style Selector="^/template/ Border#PART_Frame">
                    <Setter Property="Background" Value="{atom:ButtonTokenResource DefaultBg}" />
                </Style>

                <Style Selector="^:pointerover">
                    <Setter Property="Foreground"
                            Value="{atom:SharedTokenResource ColorLinkHover}" />
                </Style>

                <Style Selector="^:pressed">
                    <Setter Property="Foreground"
                            Value="{atom:SharedTokenResource ColorLinkActive}" />
                </Style>

                <Style Selector="^:danger">
                    <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorError}" />

                    <Style Selector="^:pointerover">
                        <Setter Property="Foreground"
                                Value="{atom:SharedTokenResource ColorErrorHover}" />
                    </Style>

                    <Style Selector="^:pressed">
                        <Setter Property="Foreground"
                                Value="{atom:SharedTokenResource ColorErrorActive}" />
                    </Style>
                </Style>

                <Style Selector="^[IsGhost=True]">
                    <Setter Property="Background" Value="Transparent" />
                </Style>
            </Style>

            <Style Selector="^:disabled">
                <Setter Property="Background" Value="Transparent" />
            </Style>

            <!-- icon 的各种颜色 -->
            <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                <Setter Property="IconBrush" Value="{atom:SharedTokenResource ColorLink}" />
            </Style>
            <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                <Setter Property="FillBrush" Value="{atom:SharedTokenResource ColorLink}" />
                <Setter Property="StrokeBrush" Value="{atom:SharedTokenResource ColorLink}" />
            </Style>

            <Style Selector="^:pointerover">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush"
                            Value="{atom:SharedTokenResource ColorLinkHover}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush"
                            Value="{atom:SharedTokenResource ColorLinkHover}" />
                    <Setter Property="StrokeBrush"
                            Value="{atom:SharedTokenResource ColorLinkHover}" />
                </Style>
            </Style>

            <Style Selector="^:pressed">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush"
                            Value="{atom:SharedTokenResource ColorLinkActive}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush"
                            Value="{atom:SharedTokenResource ColorLinkActive}" />
                    <Setter Property="StrokeBrush"
                            Value="{atom:SharedTokenResource ColorLinkActive}" />
                </Style>
            </Style>

            <Style Selector="^:disabled">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush"
                            Value="{atom:SharedTokenResource ColorTextDisabled}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush"
                            Value="{atom:SharedTokenResource ColorTextDisabled}" />
                    <Setter Property="StrokeBrush"
                            Value="{atom:SharedTokenResource ColorTextDisabled}" />
                </Style>
            </Style>

            <Style Selector="^:danger">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush" Value="{atom:SharedTokenResource ColorError}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush" Value="{atom:SharedTokenResource ColorError}" />
                    <Setter Property="StrokeBrush" Value="{atom:SharedTokenResource ColorError}" />
                </Style>

                <Style Selector="^:pointerover">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{atom:SharedTokenResource ColorErrorHover}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{atom:SharedTokenResource ColorErrorHover}" />
                        <Setter Property="StrokeBrush"
                                Value="{atom:SharedTokenResource ColorErrorHover}" />
                    </Style>
                </Style>

                <Style Selector="^:pressed">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{atom:SharedTokenResource ColorErrorActive}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{atom:SharedTokenResource ColorErrorActive}" />
                        <Setter Property="StrokeBrush"
                                Value="{atom:SharedTokenResource ColorErrorActive}" />
                    </Style>
                </Style>

                <Style Selector="^:disabled">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{atom:SharedTokenResource ColorTextDisabled}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{atom:SharedTokenResource ColorTextDisabled}" />
                        <Setter Property="StrokeBrush"
                                Value="{atom:SharedTokenResource ColorTextDisabled}" />
                    </Style>
                </Style>
            </Style>
        </Style>
        <!-- 链接按钮样式结束 -->

        <!-- 文字按钮样式开始 -->
        <Style Selector="^[ButtonType=Text]">
            <Style Selector="^:not(:disabled)">
                <Setter Property="Foreground" Value="{atom:ButtonTokenResource DefaultColor}" />
                <Setter Property="Background" Value="Transparent" />

                <Style Selector="^:pointerover">
                    <Setter Property="Background" Value="{atom:ButtonTokenResource TextHoverBg}" />
                </Style>

                <Style Selector="^:pressed">
                    <Setter Property="Background"
                            Value="{atom:SharedTokenResource ColorBgTextActive}" />
                </Style>

                <Style Selector="^:danger">
                    <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorError}" />

                    <Style Selector="^:pointerover">
                        <Setter Property="Background"
                                Value="{atom:SharedTokenResource ColorErrorBgHover}" />
                        <Setter Property="Foreground"
                                Value="{atom:SharedTokenResource ColorErrorHover}" />
                    </Style>

                    <Style Selector="^:pressed">
                        <Setter Property="Background"
                                Value="{atom:SharedTokenResource ColorErrorBgActive}" />
                        <Setter Property="Foreground"
                                Value="{atom:SharedTokenResource ColorErrorActive}" />
                    </Style>
                </Style>

            </Style>

            <Style Selector="^:disabled">
                <Setter Property="Background" Value="Transparent" />
            </Style>

            <!-- icon 的各种颜色 -->
            <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                <Setter Property="IconBrush" Value="{atom:ButtonTokenResource DefaultColor}" />
            </Style>
            <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                <Setter Property="FillBrush" Value="{atom:ButtonTokenResource DefaultColor}" />
                <Setter Property="StrokeBrush" Value="{atom:ButtonTokenResource DefaultColor}" />
            </Style>

            <Style Selector="^:pointerover">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush" Value="{atom:ButtonTokenResource DefaultColor}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush" Value="{atom:ButtonTokenResource DefaultColor}" />
                    <Setter Property="StrokeBrush"
                            Value="{atom:ButtonTokenResource DefaultColor}" />
                </Style>
            </Style>

            <Style Selector="^:pressed">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush" Value="{atom:ButtonTokenResource DefaultColor}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush" Value="{atom:ButtonTokenResource DefaultColor}" />
                    <Setter Property="StrokeBrush"
                            Value="{atom:ButtonTokenResource DefaultColor}" />
                </Style>
            </Style>

            <Style Selector="^:disabled">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush"
                            Value="{atom:SharedTokenResource ColorTextDisabled}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush"
                            Value="{atom:SharedTokenResource ColorTextDisabled}" />
                    <Setter Property="StrokeBrush"
                            Value="{atom:SharedTokenResource ColorTextDisabled}" />
                </Style>
            </Style>

            <Style Selector="^:danger">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush" Value="{atom:SharedTokenResource ColorError}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush" Value="{atom:SharedTokenResource ColorError}" />
                    <Setter Property="StrokeBrush" Value="{atom:SharedTokenResource ColorError}" />
                </Style>

                <Style Selector="^:pointerover">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{atom:SharedTokenResource ColorErrorHover}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{atom:SharedTokenResource ColorErrorHover}" />
                        <Setter Property="StrokeBrush"
                                Value="{atom:SharedTokenResource ColorErrorHover}" />
                    </Style>
                </Style>

                <Style Selector="^:pressed">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{atom:SharedTokenResource ColorErrorActive}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{atom:SharedTokenResource ColorErrorActive}" />
                        <Setter Property="StrokeBrush"
                                Value="{atom:SharedTokenResource ColorErrorActive}" />
                    </Style>
                </Style>

                <Style Selector="^:disabled">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{atom:SharedTokenResource ColorTextDisabled}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{atom:SharedTokenResource ColorTextDisabled}" />
                        <Setter Property="StrokeBrush"
                                Value="{atom:SharedTokenResource ColorTextDisabled}" />
                    </Style>
                </Style>
            </Style>
        </Style>
        <!-- 文字按钮样式结束 -->

        <!-- 虚线按钮样式开始 -->
        <Setter Property="Template">
            <ControlTemplate TargetType="atom:Button">
                <Panel>
                    <atom:WaveSpiritDecorator Name="{x:Static atom:ButtonThemeConstants.WaveSpiritPart}"
                                              CornerRadius="{TemplateBinding EffectiveCornerRadius}"
                                              WaveType="{TemplateBinding WaveSpiritType}" />
                    <Border Name="ShadowsFrame"
                            CornerRadius="{TemplateBinding EffectiveCornerRadius}"
                            Background="{TemplateBinding Background}" />
                    <atom:DashedBorder Name="Frame"
                                       Padding="{TemplateBinding Padding}"
                                       BorderThickness="{TemplateBinding EffectiveBorderThickness}"
                                       BorderBrush="{TemplateBinding BorderBrush}"
                                       BackgroundSizing="{TemplateBinding BackgroundSizing}"
                                       CornerRadius="{TemplateBinding EffectiveCornerRadius}"
                                       Background="{TemplateBinding Background}"
                                       StrokeDashArray="{x:Static atom:ButtonTheme.DashedStyle}">
                        <DockPanel Name="{x:Static atom:ButtonThemeConstants.RootLayoutPart}"
                                   LastChildFill="True"
                                   HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                   VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
                            <!-- <antdicons:LoadingOutlined -->
                            <!--     Name="{x:Static atom:ButtonThemeConstants.LoadingIconPart}" -->
                            <!--     Margin="{Binding (atom:IconPresenter.Margin), -->
                            <!--        ElementName={x:Static atom:ButtonThemeConstants.ButtonIconPart}}" -->
                            <!--     DockPanel.Dock="Left" /> -->

                            <atom:IconPresenter
                                Name="{x:Static atom:ButtonThemeConstants.ButtonIconPart}"
                                Icon="{TemplateBinding Icon}"
                                DockPanel.Dock="Left">
                                <atom:IconPresenter.IsVisible>
                                    <MultiBinding
                                        Converter="{x:Static atom:ButtonTheme.IconVisibleConverter}">
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Icon" />
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="IsIconVisible" />
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="IsLoading" />
                                    </MultiBinding>
                                </atom:IconPresenter.IsVisible>
                            </atom:IconPresenter>
                            <ContentPresenter
                                Name="{x:Static atom:ButtonThemeConstants.ContentPresenterPart}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}" />
                        </DockPanel>
                    </atom:DashedBorder>
                    <!-- <Border Name="FocusVisual" -->
                    <!--         IsVisible="False" -->
                    <!--         IsHitTestVisible="False" -->
                    <!--         BorderThickness="{atom:SharedTokenResource FocusVisualBorderThickness}" -->
                    <!--         BorderBrush="{atom:SharedTokenResource ColorFocusBorder}" -->
                    <!--         CornerRadius="{TemplateBinding EffectiveCornerRadius}" -->
                    <!--         Margin="{atom:AdornerLayerTokenResource FocusVisualMargin}" -->
                    <!--         ZIndex="1" /> -->
                </Panel>
            </ControlTemplate>
        </Setter>

        <Style Selector="^[ButtonType=Dashed]">
            <Style Selector="^:not(:disabled)">
                <Setter Property="Foreground" Value="{atom:ButtonTokenResource DefaultColor}" />
                <Setter Property="BorderBrush"
                        Value="{atom:ButtonTokenResource DefaultBorderColor}" />
                <Setter Property="Background" Value="{atom:ButtonTokenResource DefaultBg}" />

                <Style Selector="^:pointerover">
                    <Setter Property="Foreground"
                            Value="{atom:ButtonTokenResource DefaultHoverColor}" />
                    <Setter Property="BorderBrush"
                            Value="{atom:ButtonTokenResource DefaultHoverBorderColor}" />
                </Style>

                <Style Selector="^:pressed">
                    <Setter Property="Foreground"
                            Value="{atom:ButtonTokenResource DefaultActiveColor}" />
                    <Setter Property="BorderBrush"
                            Value="{atom:ButtonTokenResource DefaultActiveBorderColor}" />
                </Style>

                <Style Selector="^:danger">
                    <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorError}" />
                    <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorError}" />

                    <Style Selector="^:pointerover">
                        <Setter Property="Foreground"
                                Value="{atom:SharedTokenResource ColorErrorBorderHover}" />
                        <Setter Property="BorderBrush"
                                Value="{atom:SharedTokenResource ColorErrorBorderHover}" />
                    </Style>

                    <Style Selector="^:pressed">
                        <Setter Property="Foreground"
                                Value="{atom:SharedTokenResource ColorErrorActive}" />
                        <Setter Property="BorderBrush"
                                Value="{atom:SharedTokenResource ColorErrorActive}" />
                    </Style>
                </Style>

                <Style Selector="^[IsGhost=True]">

                    <Setter Property="Foreground"
                            Value="{atom:SharedTokenResource ColorTextLightSolid}" />
                    <Setter Property="BorderBrush"
                            Value="{atom:SharedTokenResource ColorTextLightSolid}" />
                    <Setter Property="Background" Value="Transparent" />

                    <Style Selector="^:pointerover">
                        <Setter Property="Foreground"
                                Value="{atom:SharedTokenResource ColorPrimaryHover}" />
                        <Setter Property="BorderBrush"
                                Value="{atom:SharedTokenResource ColorPrimaryHover}" />
                    </Style>

                    <Style Selector="^:pressed">
                        <Setter Property="Foreground"
                                Value="{atom:SharedTokenResource ColorPrimaryActive}" />
                        <Setter Property="BorderBrush"
                                Value="{atom:SharedTokenResource ColorPrimaryActive}" />
                    </Style>

                    <Style Selector="^:danger">
                        <Setter Property="Foreground"
                                Value="{atom:SharedTokenResource ColorError}" />
                        <Setter Property="BorderBrush"
                                Value="{atom:SharedTokenResource ColorError}" />

                        <Style Selector="^:pointerover">
                            <Setter Property="Foreground"
                                    Value="{atom:SharedTokenResource ColorErrorBorderHover}" />
                            <Setter Property="BorderBrush"
                                    Value="{atom:SharedTokenResource ColorErrorBorderHover}" />
                        </Style>

                        <Style Selector="^:pressed">
                            <Setter Property="Foreground"
                                    Value="{atom:SharedTokenResource ColorErrorActive}" />
                            <Setter Property="BorderBrush"
                                    Value="{atom:SharedTokenResource ColorErrorActive}" />
                        </Style>
                    </Style>
                </Style>
            </Style>

            <Style Selector="^[IsGhost=True]">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush"
                            Value="{atom:SharedTokenResource ColorTextLightSolid}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush"
                            Value="{atom:SharedTokenResource ColorTextLightSolid}" />
                    <Setter Property="StrokeBrush"
                            Value="{atom:SharedTokenResource ColorTextLightSolid}" />
                </Style>

                <Style Selector="^:pointerover">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{atom:SharedTokenResource ColorPrimaryHover}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{atom:SharedTokenResource ColorPrimaryHover}" />
                        <Setter Property="StrokeBrush"
                                Value="{atom:SharedTokenResource ColorPrimaryHover}" />
                    </Style>
                </Style>

                <Style Selector="^:pressed">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{atom:SharedTokenResource ColorPrimaryActive}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{atom:SharedTokenResource ColorPrimaryActive}" />
                        <Setter Property="StrokeBrush"
                                Value="{atom:SharedTokenResource ColorPrimaryActive}" />
                    </Style>
                </Style>

            </Style>

            <Style Selector="^ /template/ Border#FocusVisual">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="^:focus-visible /template/ Border#FocusVisual">
                <Setter Property="IsVisible" Value="True" />
            </Style>

            <Style Selector="^:danger">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush" Value="{atom:SharedTokenResource ColorError}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush" Value="{atom:SharedTokenResource ColorError}" />
                    <Setter Property="StrokeBrush" Value="{atom:SharedTokenResource ColorError}" />
                </Style>

                <Style Selector="^:pointerover">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{atom:SharedTokenResource ColorErrorBorderHover}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{atom:SharedTokenResource ColorErrorBorderHover}" />
                        <Setter Property="StrokeBrush"
                                Value="{atom:SharedTokenResource ColorErrorBorderHover}" />
                    </Style>
                </Style>

                <Style Selector="^:pressed">
                    <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                        <Setter Property="IconBrush"
                                Value="{atom:SharedTokenResource ColorErrorActive}" />
                    </Style>
                    <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                        <Setter Property="FillBrush"
                                Value="{atom:SharedTokenResource ColorErrorActive}" />
                        <Setter Property="StrokeBrush"
                                Value="{atom:SharedTokenResource ColorErrorActive}" />
                    </Style>
                </Style>

            </Style>

            <Style Selector="^:disabled">
                <Style Selector="^ /template/ atom|IconPresenter#PART_ButtonIcon">
                    <Setter Property="IconBrush"
                            Value="{atom:SharedTokenResource ColorTextDisabled}" />
                </Style>
                <Style Selector="^ /template/ atom|Icon#PART_LoadingIcon">
                    <Setter Property="FillBrush"
                            Value="{atom:SharedTokenResource ColorTextDisabled}" />
                    <Setter Property="StrokeBrush"
                            Value="{atom:SharedTokenResource ColorTextDisabled}" />
                </Style>
            </Style>

            <Style Selector="^ /template/ Border#ShadowsFrame">
                <Setter Property="BoxShadow" Value="{atom:ButtonTokenResource DefaultShadow}" />
            </Style>
            <Style Selector="^[IsDanger=True]">
                <Style Selector="^ /template/ Border#ShadowsFrame">
                    <Setter Property="BoxShadow" Value="{atom:ButtonTokenResource DangerShadow}" />
                </Style>
            </Style>

            <Style Selector="^[SizeType=Large]">
                <Style Selector="^ /template/ atom|DashedBorder#Frame">
                    <Setter Property="Height" Value="{atom:SharedTokenResource ControlHeightLG}" />
                </Style>
            </Style>

            <Style Selector="^[SizeType=Middle]">
                <Style Selector="^ /template/ atom|DashedBorder#Frame">
                    <Setter Property="Height" Value="{atom:SharedTokenResource ControlHeight}" />
                </Style>
            </Style>

            <Style Selector="^[SizeType=Small]">
                <Style Selector="^ /template/ atom|DashedBorder#Frame">
                    <Setter Property="Height" Value="{atom:SharedTokenResource ControlHeightSM}" />
                </Style>
            </Style>
        </Style>
        <!-- 虚线按钮样式结束 -->
    </Style>
</ControlTheme>