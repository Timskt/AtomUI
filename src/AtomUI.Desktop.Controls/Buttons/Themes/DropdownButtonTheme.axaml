<ControlTheme xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:atom="https://atomui.net"
              xmlns:antdicons="https://atomui.net/icons/antdesign"
              xmlns:themes="using:AtomUI.Desktop.Controls.Themes"
              TargetType="{x:Type atom:DropdownButton}"
              x:Class="AtomUI.Desktop.Controls.Themes.DropdownButtonTheme">
    <ControlTheme.BasedOn>
        <themes:ButtonTheme TargetType="{x:Type atom:DropdownButton}" />
    </ControlTheme.BasedOn>

    <Style Selector="^:is(atom|DropdownButton)">
        <Style Selector="^[ButtonType=Default]">
            <Setter Property="Template">
                <ControlTemplate>
                    <Panel>
                        <atom:WaveSpiritDecorator Name="{x:Static atom:ButtonThemeConstants.WaveSpiritPart}"
                                                  CornerRadius="{TemplateBinding EffectiveCornerRadius}"
                                                  WaveType="{TemplateBinding WaveSpiritType}" />
                        <Border Name="ShadowsFrame"
                                CornerRadius="{TemplateBinding EffectiveCornerRadius}"
                                Background="{TemplateBinding Background}" />
                        <Border Name="Frame"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="{TemplateBinding EffectiveBorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BackgroundSizing="{TemplateBinding BackgroundSizing}"
                                CornerRadius="{TemplateBinding EffectiveCornerRadius}"
                                Background="{TemplateBinding Background}">
                            <DockPanel Name="{x:Static atom:ButtonThemeConstants.RootLayoutPart}"
                                       LastChildFill="True">
                                <atom:IconPresenter
                                    Name="{x:Static atom:DropdownButtonThemeConstants.DropdownIndicatorPart}"
                                    DockPanel.Dock="Right"
                                    VerticalAlignment="Center"
                                    Icon="{TemplateBinding OpenIndicator}"
                                    IconBrush="{TemplateBinding Foreground}"
                                    IsMotionEnabled="False"
                                    IsVisible="{TemplateBinding IsShowOpenIndicator}" />
                                <StackPanel Name="{x:Static atom:ButtonThemeConstants.MainInfoLayoutPart}"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            Orientation="Horizontal"
                                            IsVisible="{TemplateBinding IsContentVisible}">
                                    <antdicons:LoadingOutlined
                                        Name="{x:Static atom:ButtonThemeConstants.LoadingIconPart}"
                                        Margin="{Binding (atom:IconPresenter.Margin), 
                                   ElementName={x:Static atom:ButtonThemeConstants.ButtonIconPart}}" />
                                    <atom:IconPresenter
                                        Name="{x:Static atom:ButtonThemeConstants.ButtonIconPart}"
                                        Icon="{TemplateBinding Icon}"
                                        IsVisible="{TemplateBinding Icon, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                    <ContentPresenter
                                        Name="{x:Static atom:ButtonThemeConstants.ContentPresenterPart}"
                                        Content="{TemplateBinding Content}"
                                        ContentTemplate="{TemplateBinding ContentTemplate}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </Panel>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="^[ButtonType=Primary]">
            <Setter Property="Template">
                <ControlTemplate>
                    <Panel>
                        <atom:WaveSpiritDecorator Name="{x:Static atom:ButtonThemeConstants.WaveSpiritPart}"
                                                  CornerRadius="{TemplateBinding EffectiveCornerRadius}"
                                                  WaveType="{TemplateBinding WaveSpiritType}" />
                        <Border Name="Frame"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="{TemplateBinding EffectiveBorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BackgroundSizing="{TemplateBinding BackgroundSizing}"
                                CornerRadius="{TemplateBinding EffectiveCornerRadius}"
                                Background="{TemplateBinding Background}">
                            <DockPanel Name="{x:Static atom:ButtonThemeConstants.RootLayoutPart}"
                                       LastChildFill="True">
                                <atom:IconPresenter
                                    Name="{x:Static atom:DropdownButtonThemeConstants.DropdownIndicatorPart}"
                                    DockPanel.Dock="Right"
                                    VerticalAlignment="Center"
                                    Icon="{TemplateBinding OpenIndicator}"
                                    IconBrush="{TemplateBinding Foreground}"
                                    IsMotionEnabled="False"
                                    IsVisible="{TemplateBinding IsShowOpenIndicator}" />
                                <StackPanel Name="{x:Static atom:ButtonThemeConstants.MainInfoLayoutPart}"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            Orientation="Horizontal"
                                            IsVisible="{TemplateBinding IsContentVisible}">
                                    <antdicons:LoadingOutlined
                                        Name="{x:Static atom:ButtonThemeConstants.LoadingIconPart}"
                                        Margin="{Binding (atom:IconPresenter.Margin), 
                                   ElementName={x:Static atom:ButtonThemeConstants.ButtonIconPart}}" />
                                    <atom:IconPresenter
                                        Name="{x:Static atom:ButtonThemeConstants.ButtonIconPart}"
                                        Icon="{TemplateBinding Icon}"
                                        IsVisible="{TemplateBinding Icon, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                    <ContentPresenter
                                        Name="{x:Static atom:ButtonThemeConstants.ContentPresenterPart}"
                                        Content="{TemplateBinding Content}"
                                        ContentTemplate="{TemplateBinding ContentTemplate}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </Panel>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="^[ButtonType=Link]">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="Frame"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            BorderThickness="{TemplateBinding EffectiveBorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BackgroundSizing="{TemplateBinding BackgroundSizing}"
                            CornerRadius="{TemplateBinding EffectiveCornerRadius}">
                        <DockPanel Name="{x:Static atom:ButtonThemeConstants.RootLayoutPart}"
                                   LastChildFill="True">
                            <atom:IconPresenter
                                Name="{x:Static atom:DropdownButtonThemeConstants.DropdownIndicatorPart}"
                                DockPanel.Dock="Right"
                                VerticalAlignment="Center"
                                Icon="{TemplateBinding OpenIndicator}"
                                IconBrush="{TemplateBinding Foreground}"
                                IsMotionEnabled="False"
                                IsVisible="{TemplateBinding IsShowOpenIndicator}" />
                            <StackPanel Name="{x:Static atom:ButtonThemeConstants.MainInfoLayoutPart}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal"
                                        IsVisible="{TemplateBinding IsContentVisible}">
                                <antdicons:LoadingOutlined Name="{x:Static atom:ButtonThemeConstants.LoadingIconPart}"
                                                           Margin="{Binding (atom:IconPresenter.Margin), 
                                   ElementName={x:Static atom:ButtonThemeConstants.ButtonIconPart}}" />
                                <atom:IconPresenter
                                    Name="{x:Static atom:ButtonThemeConstants.ButtonIconPart}"
                                    Icon="{TemplateBinding Icon}"
                                    IsVisible="{TemplateBinding Icon, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                <ContentPresenter
                                    Name="{x:Static atom:ButtonThemeConstants.ContentPresenterPart}"
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="^[ButtonType=Text]">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="Frame"
                            Padding="{TemplateBinding Padding}"
                            BorderThickness="{TemplateBinding EffectiveBorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BackgroundSizing="{TemplateBinding BackgroundSizing}"
                            CornerRadius="{TemplateBinding EffectiveCornerRadius}"
                            Background="{TemplateBinding Background}">
                        <DockPanel Name="{x:Static atom:ButtonThemeConstants.RootLayoutPart}"
                                   LastChildFill="True">
                            <atom:IconPresenter
                                Name="{x:Static atom:DropdownButtonThemeConstants.DropdownIndicatorPart}"
                                DockPanel.Dock="Right"
                                VerticalAlignment="Center"
                                Icon="{TemplateBinding OpenIndicator}"
                                IconBrush="{TemplateBinding Foreground}"
                                IsMotionEnabled="False"
                                IsVisible="{TemplateBinding IsShowOpenIndicator}" />
                            <StackPanel Name="{x:Static atom:ButtonThemeConstants.MainInfoLayoutPart}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal"
                                        IsVisible="{TemplateBinding IsContentVisible}">
                                <antdicons:LoadingOutlined Name="{x:Static atom:ButtonThemeConstants.LoadingIconPart}"
                                                           Margin="{Binding (atom:IconPresenter.Margin), 
                                   ElementName={x:Static atom:ButtonThemeConstants.ButtonIconPart}}" />
                                <atom:IconPresenter
                                    Name="{x:Static atom:ButtonThemeConstants.ButtonIconPart}"
                                    Icon="{TemplateBinding Icon}"
                                    IsVisible="{TemplateBinding Icon, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                <ContentPresenter
                                    Name="{x:Static atom:ButtonThemeConstants.ContentPresenterPart}"
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <!-- 默认下拉按钮样式开始 -->
        <Style Selector="^[ButtonType=Default]">
            <Setter Property="MarginToAnchor"
                    Value="{DynamicResource {x:Static atom:PopupHostTokenKey.MarginToAnchor}}" />
            <Style Selector="^ /template/ atom|IconPresenter#PART_DropdownIndicator">
                <Setter Property="Width" Value="{DynamicResource {x:Static atom:SharedTokenKey.IconSizeSM}}" />
                <Setter Property="Height" Value="{DynamicResource {x:Static atom:SharedTokenKey.IconSizeSM}}" />
            </Style>

            <Style Selector="^[SizeType=Large]">
                <Style Selector="^ /template/ atom|IconPresenter#PART_DropdownIndicator">
                    <Setter Property="Margin"
                            Value="{DynamicResource {x:Static atom:ButtonTokenKey.ExtraContentMarginLG}}" />
                </Style>
            </Style>

            <Style Selector="^[SizeType=Middle]">
                <Style Selector="^ /template/ atom|IconPresenter#PART_DropdownIndicator">
                    <Setter Property="Margin"
                            Value="{DynamicResource {x:Static atom:ButtonTokenKey.ExtraContentMargin}}" />
                </Style>
            </Style>

            <Style Selector="^[SizeType=Small]">
                <Style Selector="^ /template/ atom|IconPresenter#PART_DropdownIndicator">
                    <Setter Property="Margin"
                            Value="{DynamicResource {x:Static atom:ButtonTokenKey.ExtraContentMarginSM}}" />
                </Style>
            </Style>
        </Style>
        <!-- 默认下拉按钮样式结束 -->

        <!-- 主要下拉按钮样式开始 -->
        <Style Selector="^[ButtonType=Primary]">
            <Setter Property="MarginToAnchor"
                    Value="{DynamicResource {x:Static atom:PopupHostTokenKey.MarginToAnchor}}" />
            <Style Selector="^ /template/ atom|IconPresenter#PART_DropdownIndicator">
                <Setter Property="Width" Value="{DynamicResource {x:Static atom:SharedTokenKey.IconSizeSM}}" />
                <Setter Property="Height" Value="{DynamicResource {x:Static atom:SharedTokenKey.IconSizeSM}}" />
            </Style>

            <Style Selector="^[SizeType=Large]">
                <Style Selector="^ /template/ atom|IconPresenter#PART_DropdownIndicator">
                    <Setter Property="Margin"
                            Value="{DynamicResource {x:Static atom:ButtonTokenKey.ExtraContentMarginLG}}" />
                </Style>
            </Style>

            <Style Selector="^[SizeType=Middle]">
                <Style Selector="^ /template/ atom|IconPresenter#PART_DropdownIndicator">
                    <Setter Property="Margin"
                            Value="{DynamicResource {x:Static atom:ButtonTokenKey.ExtraContentMargin}}" />
                </Style>
            </Style>

            <Style Selector="^[SizeType=Small]">
                <Style Selector="^ /template/ atom|IconPresenter#PART_DropdownIndicator">
                    <Setter Property="Margin"
                            Value="{DynamicResource {x:Static atom:ButtonTokenKey.ExtraContentMarginSM}}" />
                </Style>
            </Style>
        </Style>
        <!-- 主要下拉按钮样式结束 -->

        <!-- 链接下拉按钮样式开始 -->
        <Style Selector="^[ButtonType=Link]">
            <Setter Property="MarginToAnchor"
                    Value="{DynamicResource {x:Static atom:PopupHostTokenKey.MarginToAnchor}}">
            </Setter>
            <Setter Property="Background" Value="Transparent" />
            <Style Selector="^ /template/ atom|IconPresenter#PART_DropdownIndicator">
                <Setter Property="Width" Value="{DynamicResource {x:Static atom:SharedTokenKey.IconSizeSM}}" />
                <Setter Property="Height" Value="{DynamicResource {x:Static atom:SharedTokenKey.IconSizeSM}}" />
            </Style>

            <Style Selector="^[SizeType=Large]">
                <Style Selector="^ /template/ atom|IconPresenter#PART_DropdownIndicator">
                    <Setter Property="Margin"
                            Value="{DynamicResource {x:Static atom:ButtonTokenKey.ExtraContentMarginLG}}" />
                </Style>
            </Style>

            <Style Selector="^[SizeType=Middle]">
                <Style Selector="^ /template/ atom|IconPresenter#PART_DropdownIndicator">
                    <Setter Property="Margin"
                            Value="{DynamicResource {x:Static atom:ButtonTokenKey.ExtraContentMargin}}" />
                </Style>
            </Style>

            <Style Selector="^[SizeType=Small]">
                <Style Selector="^ /template/ atom|IconPresenter#PART_DropdownIndicator">
                    <Setter Property="Margin"
                            Value="{DynamicResource {x:Static atom:ButtonTokenKey.ExtraContentMarginSM}}" />
                </Style>
            </Style>
        </Style>
        <!-- 链接下拉按钮样式结束 -->

        <!-- 文字下拉按钮样式开始 -->
        <Style Selector="^[ButtonType=Text]">
            <Setter Property="MarginToAnchor"
                    Value="{DynamicResource {x:Static atom:PopupHostTokenKey.MarginToAnchor}}" />
            <Style Selector="^ /template/ atom|IconPresenter#PART_DropdownIndicator">
                <Setter Property="Width" Value="{DynamicResource {x:Static atom:SharedTokenKey.IconSizeSM}}" />
                <Setter Property="Height" Value="{DynamicResource {x:Static atom:SharedTokenKey.IconSizeSM}}" />
            </Style>

            <Style Selector="^[SizeType=Large]">
                <Style Selector="^ /template/ atom|IconPresenter#PART_DropdownIndicator">
                    <Setter Property="Margin"
                            Value="{DynamicResource {x:Static atom:ButtonTokenKey.ExtraContentMarginLG}}" />
                </Style>
            </Style>

            <Style Selector="^[SizeType=Middle]">
                <Style Selector="^ /template/ atom|IconPresenter#PART_DropdownIndicator">
                    <Setter Property="Margin"
                            Value="{DynamicResource {x:Static atom:ButtonTokenKey.ExtraContentMargin}}" />
                </Style>
            </Style>

            <Style Selector="^[SizeType=Small]">
                <Style Selector="^ /template/ atom|IconPresenter#PART_DropdownIndicator">
                    <Setter Property="Margin"
                            Value="{DynamicResource {x:Static atom:ButtonTokenKey.ExtraContentMarginSM}}" />
                </Style>
            </Style>
        </Style>
        <!-- 文字下拉按钮样式开始 -->

    </Style>

</ControlTheme>