<ControlTheme TargetType="atom:ToggleIconButton"
              xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:atom="https://atomui.net"
              x:Class="AtomUI.Desktop.Controls.Themes.ToggleIconButtonTheme"
              x:ClassModifier="internal">
    <Setter Property="Template">
        <ControlTemplate TargetType="atom:ToggleIconButton">
            <Border
                Name="Frame"
                BorderThickness="{TemplateBinding BorderThickness}"
                BorderBrush="{TemplateBinding BorderBrush}"
                CornerRadius="{TemplateBinding CornerRadius}"
                Background="{TemplateBinding Background}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Padding="{TemplateBinding Padding}">
                <Panel Name="PART_RootLayout">
                    <atom:IconPresenter
                        Name="PART_CheckedIconPresenter"
                        Icon="{TemplateBinding CheckedIcon}"
                        IsVisible="{TemplateBinding IsChecked}"
                        Width="{TemplateBinding IconWidth}"
                        Height="{TemplateBinding IconHeight}"
                        IconBrush="{TemplateBinding IconBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsMotionEnabled="{TemplateBinding IsMotionEnabled}" />
                    <atom:IconPresenter
                        Name="PART_UnCheckedIconPresenter"
                        Icon="{TemplateBinding UnCheckedIcon}"
                        Width="{TemplateBinding IconWidth}"
                        Height="{TemplateBinding IconHeight}"
                        IsVisible="{TemplateBinding IsChecked, Converter={x:Static BoolConverters.Not}}"
                        IconBrush="{TemplateBinding IconBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsMotionEnabled="{TemplateBinding IsMotionEnabled}" />
                </Panel>
            </Border>
        </ControlTemplate>
    </Setter>

    <Style Selector="^:is(atom|ToggleIconButton)">
        <Setter Property="IconWidth" Value="{atom:SharedTokenResource IconSizeSM}" />
        <Setter Property="IconHeight" Value="{atom:SharedTokenResource IconSizeSM}" />
        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}" />
        <Setter Property="CornerRadius" Value="{atom:SharedTokenResource BorderRadiusSM}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />

        <Setter Property="IconBrush"
                Value="{atom:SharedTokenResource ColorIcon}" />

        <Style Selector="^[IsMotionEnabled=True]">
            <Setter Property="Transitions">
                <Transitions>
                    <atom:SolidColorBrushTransition Property="Background" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="^:pointerover">
            <Setter Property="IconBrush"
                    Value="{atom:SharedTokenResource ColorIconHover}" />
        </Style>

        <Style Selector="^:pressed">
            <Setter Property="IconBrush"
                    Value="{atom:SharedTokenResource ColorText}" />
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="IconBrush"
                    Value="{atom:SharedTokenResource ColorTextDisabled}" />
        </Style>

    </Style>
</ControlTheme>