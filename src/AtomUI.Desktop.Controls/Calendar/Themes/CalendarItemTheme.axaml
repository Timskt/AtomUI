<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    xmlns:antdicons="https://atomui.net/icons/antdesign"
    x:ClassModifier="internal">
    <atom:DoubleToGridLengthConverter x:Key="DoubleToGridLengthConverter" />
    <ControlTheme x:Key="{x:Type atom:CalendarItem}" TargetType="atom:CalendarItem">
        <Setter Property="Template">
            <ControlTemplate>
                <Border
                    Name="PART_ItemFrame">
                    <DockPanel
                        Name="PART_ItemRootLayout"
                        LastChildFill="True">
                        <Grid Name="PART_HeaderLayout"
                              ColumnDefinitions="Auto, Auto, *, Auto, Auto"
                              DockPanel.Dock="Top">
                            <atom:IconButton
                                Name="PART_PreviousButton"
                                Icon="{antdicons:AntDesignIconProvider DoubleLeftOutlined}"
                                Grid.Column="0" />
                            <atom:IconButton
                                Name="PART_PreviousMonthButton"
                                Icon="{antdicons:AntDesignIconProvider LeftOutlined}"
                                IsVisible="{TemplateBinding IsMonthViewMode}"
                                Grid.Column="1" />
                            <atom:HeadTextButton
                                Name="PART_HeaderButton"
                                Grid.Column="2"
                                IsMotionEnabled="{TemplateBinding IsMotionEnabled}"/>
                            <atom:IconButton
                                Name="PART_NextMonthButton"
                                Icon="{antdicons:AntDesignIconProvider RightOutlined}"
                                IsVisible="{TemplateBinding IsMonthViewMode}"
                                Grid.Column="3" />
                            <atom:IconButton
                                Name="PART_NextButton"
                                Icon="{antdicons:AntDesignIconProvider DoubleRightOutlined}"
                                Grid.Column="4" />
                        </Grid>

                        <Grid Name="PART_MonthView"
                              HorizontalAlignment="Stretch"
                              IsVisible="False">
                            <Grid.RowDefinitions>
                                <RowDefinition
                                    Height="{TemplateBinding DayTitleHeight}" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                        </Grid>
                        <Grid Name="PART_YearView"
                              IsVisible="False">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                        </Grid>
                    </DockPanel>
                </Border>
            </ControlTemplate>
        </Setter>

        <Setter Property="DayTitleTemplate">
            <Template x:DataType="x:String">
                <atom:TextBlock Text="{Binding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Template>
        </Setter>

        <Style Selector="^ /template/ Grid#PART_HeaderLayout">
            <Setter Property="Margin" Value="{atom:CalendarTokenResource HeaderMargin}" />
        </Style>

        <Style Selector="^ /template/ atom|IconButton">
            <Setter Property="IconWidth" Value="{atom:SharedTokenResource IconSizeSM}" />
            <Setter Property="IconHeight" Value="{atom:SharedTokenResource IconSizeSM}" />
            <Setter Property="IconBrush"
                    Value="{atom:SharedTokenResource ColorTextDescription}" />
        </Style>
        
        <Style Selector="^ /template/ atom|IconButton:pointerover">
            <Setter Property="IconBrush" Value="{atom:SharedTokenResource ColorText}" />
        </Style>
        
        <Style Selector="^ /template/ atom|IconButton:pressed">
            <Setter Property="IconBrush" Value="{atom:SharedTokenResource ColorText}" />
        </Style>
    </ControlTheme>
</ResourceDictionary>