<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:Calendar}" TargetType="atom:Calendar">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="PART_Frame"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Background="{TemplateBinding Background}"
                        Padding="{TemplateBinding Padding}">
                    <Panel Name="PART_Root"
                           ClipToBounds="True">
                        <atom:CalendarItem Name="PART_CalendarItem"
                                           IsMotionEnabled="{TemplateBinding IsMotionEnabled}"/>
                    </Panel>
                </Border>
            </ControlTemplate>
        </Setter>
        
        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}"/>
        <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorBorder}"/>
        <Setter Property="BorderThickness" Value="{atom:SharedTokenResource BorderThickness}"/>
        <Setter Property="CornerRadius" Value="{atom:SharedTokenResource BorderRadius}"/>
        <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgContainer}"/>
        <Setter Property="Padding" Value="{atom:CalendarTokenResource PanelContentPadding}"/>
        <Setter Property="MinWidth" Value="{atom:CalendarTokenResource ItemPanelMinWidth}"/>
        <Setter Property="MinHeight" Value="{atom:CalendarTokenResource ItemPanelMinHeight}"/>
    </ControlTheme>
</ResourceDictionary>