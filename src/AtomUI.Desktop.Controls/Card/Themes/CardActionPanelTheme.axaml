<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    xmlns:converters="using:Avalonia.Controls.Converters"
    x:ClassModifier="internal">
    <converters:CornerRadiusFilterConverter x:Key="CornerRadiusFilterConverter"
                                            Filter="BottomLeft, BottomRight"/>
    <ControlTheme x:Key="{x:Type atom:CardActionPanel}" TargetType="atom:CardActionPanel">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="Frame" 
                        CornerRadius="{TemplateBinding CornerRadius, Converter={StaticResource CornerRadiusFilterConverter}}"
                        Background="{TemplateBinding Background}">
                    <UniformGrid Name="{x:Static atom:CardActionPanelThemeConstants.GridPanelPart}"
                                 ColumnSpacing="1"/>
                </Border>
            </ControlTemplate>
        </Setter>
        <Setter Property="Padding" Value="0, 1, 0, 0"/>
        <Setter Property="MinHeight" Value="{atom:SharedTokenResource ControlHeightLG}"/>
        <Setter Property="FontSize" Value="{atom:SharedTokenResource FontSize}"/>
     
        <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorTextDescription}"/>
        <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorBorderSecondary}"/>
        <Setter Property="BorderThickness" Value="{atom:SharedTokenResource BorderThickness}"/>
        <Style Selector="^:pointerover">
            <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorPrimary}"/>
        </Style>
        
        <Style Selector="^ /template/ Border#Frame">
            <Setter Property="Background" Value="{atom:CardTokenResource ActionsBg}"/>
        </Style>

        <Style Selector="^[IsMotionEnabled=True]">
            <Setter Property="Transitions">
                <Transitions>
                    <atom:SolidColorBrushTransition Property="Foreground" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}" />
                </Transitions>
            </Setter>
        </Style>

    </ControlTheme>
</ResourceDictionary>