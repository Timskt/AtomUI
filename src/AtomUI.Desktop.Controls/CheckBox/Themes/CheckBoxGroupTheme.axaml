<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:CheckBoxGroup}" TargetType="atom:CheckBoxGroup">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="Frame"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <atom:CheckBoxItemsControl Name="PART_CheckBoxItems"
                                                ItemTemplate="{TemplateBinding ItemTemplate}"
                                                ItemSpacing="{TemplateBinding ItemSpacing}"
                                                LineSpacing="{TemplateBinding LineSpacing}"
                                                Orientation="{TemplateBinding Orientation}"
                                                IsMotionEnabled="{TemplateBinding IsMotionEnabled}"/>
                </Border>
            </ControlTemplate>
        </Setter>

        <Setter Property="ClipToBounds" Value="False" />
        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}" />
        <Setter Property="ItemTemplate">
            <DataTemplate x:DataType="atom:ICheckBoxOption">
                <atom:TextBlock Text="{Binding Content}" />
            </DataTemplate>
        </Setter>
        <Setter Property="ItemSpacing" Value="{atom:SharedTokenResource SpacingXS}" />
        <Setter Property="LineSpacing" Value="{atom:SharedTokenResource SpacingXS}" />
        
    </ControlTheme>
</ResourceDictionary>