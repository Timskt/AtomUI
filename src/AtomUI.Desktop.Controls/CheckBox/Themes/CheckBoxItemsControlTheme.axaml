<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    xmlns:atomc="https://atomui.net/common-controls"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atomc:CheckBoxItemsControl}" TargetType="atomc:CheckBoxItemsControl">
        <Setter Property="Template">
            <ControlTemplate>
                <ItemsPresenter Name="{x:Static atom:OptionButtonGroupThemeConstants.ItemsPresenterPart}"
                                ItemsPanel="{TemplateBinding ItemsPanel}" />
            </ControlTemplate>
        </Setter>

        <Setter Property="ItemsPanel">
            <ItemsPanelTemplate>
                <WrapPanel
                    Orientation="{Binding (atomc:CheckBoxItemsControl).Orientation, RelativeSource={RelativeSource TemplatedParent}}"
                    ItemSpacing="{Binding (atomc:CheckBoxItemsControl).ItemSpacing, RelativeSource={RelativeSource TemplatedParent}}"
                    LineSpacing="{Binding (atomc:CheckBoxItemsControl).LineSpacing, RelativeSource={RelativeSource TemplatedParent}}"/>
            </ItemsPanelTemplate>
        </Setter>

        <Setter Property="ItemSpacing" Value="{DynamicResource {x:Static atom:SharedTokenKey.SpacingXS}}" />
        <Setter Property="LineSpacing" Value="{DynamicResource {x:Static atom:SharedTokenKey.SpacingXS}}" />
        <Setter Property="ClipToBounds" Value="False" />
        
    </ControlTheme>
</ResourceDictionary>