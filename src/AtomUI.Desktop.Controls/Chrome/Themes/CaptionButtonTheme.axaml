<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:CaptionButton}" TargetType="atom:CaptionButton">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="{x:Static atom:CaptionButtonThemeConstants.FramePart}"
                        Background="{TemplateBinding Background}"
                        Padding="{TemplateBinding Padding}"
                        CornerRadius="{TemplateBinding EffectiveCornerRadius}">
                    <Panel Name="{x:Static atom:CaptionButtonThemeConstants.RootLayoutPart}">
                        <atom:IconPresenter
                            Name="{x:Static atom:CaptionButtonThemeConstants.NormalIconPresenterPart}"
                            Icon="{TemplateBinding NormalIcon}"
                            Width="{TemplateBinding IconWidth}"
                            Height="{TemplateBinding IconHeight}"
                            IsVisible="{TemplateBinding IsChecked, Converter={x:Static BoolConverters.Not}}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                        <atom:IconPresenter
                            Name="{x:Static atom:CaptionButtonThemeConstants.CheckedIconPresenterPart}"
                            Icon="{TemplateBinding CheckedIcon}"
                            IsVisible="{TemplateBinding IsChecked}"
                            Width="{TemplateBinding IconWidth}"
                            Height="{TemplateBinding IconHeight}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Panel>
                </Border>
            </ControlTemplate>
        </Setter>

        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Padding" Value="{atom:ChromeTokenResource CaptionButtonPadding}" />
        <Setter Property="Foreground" Value="{atom:ChromeTokenResource ActiveColor}" />
        
        <Style Selector="^ /template/ atom|IconPresenter">
            <Setter Property="IconBrush" Value="{atom:ChromeTokenResource ActiveColor}" />
        </Style>
        
        <Setter Property="Background" Value="{atom:ChromeTokenResource ActiveBgColor}" />
       
        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{atom:ChromeTokenResource ActiveHoverBgColor}" />
        </Style>
        
        <Style Selector="^:pressed">
            <Setter Property="Background" Value="{atom:ChromeTokenResource ActivePressedBgColor}" />
        </Style>
        
        <Style Selector="^[IsWindowActive=False]">
            <Style Selector="^ /template/ atom|IconPresenter">
                <Setter Property="IconBrush"
                        Value="{atom:ChromeTokenResource InactiveColor}" />
            </Style>
            <Setter Property="Background" Value="{atom:ChromeTokenResource InactiveBgColor}" />
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{atom:ChromeTokenResource InactiveHoverBgColor}" />
            </Style>
        </Style>

        <Style Selector="^[IsMotionEnabled=True]">
            <Setter Property="Transitions">
                <Transitions>
                    <atom:SolidColorBrushTransition Property="Background" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}" />
                </Transitions>
            </Setter>
        </Style>

    </ControlTheme>
</ResourceDictionary>