<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <atom:StringToTextBlockConverter x:Key="StringToTextBlockConverter" VerticalAlignment="Center" />
    <ControlTheme x:Key="{x:Type atom:CollapseItem}" TargetType="atom:CollapseItem">
        <Setter Property="Template">
            
            <ControlTemplate>
                <DockPanel Name="PART_MainLayout"
                           LastChildFill="True">
                    <Border Name="PART_HeaderDecorator"
                            DockPanel.Dock="Top"
                            BorderThickness="{TemplateBinding HeaderBorderThickness}"
                            Padding="{TemplateBinding HeaderPadding}">
                        <Grid ColumnDefinitions="Auto, *, Auto, Auto">
                            <atom:IconButton
                                Name="PART_ExpandButton"
                                Grid.Column="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsMotionEnabled="{TemplateBinding IsMotionEnabled}"
                                Icon="{TemplateBinding ExpandIcon}"
                                IsVisible="{TemplateBinding IsShowExpandIcon}"
                                IsEnabled="{TemplateBinding IsEnabled}"/>
                            <ContentPresenter Name="PART_HeaderPresenter"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              HorizontalContentAlignment="Left"
                                              VerticalContentAlignment="Center"
                                              Margin="0, 1, 0, 0"
                                              Content="{TemplateBinding Header}"
                                              ContentTemplate="{TemplateBinding HeaderTemplate}"
                                              Grid.Column="1" />
                            <ContentPresenter
                                Name="PART_AddOnContentPresenter"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                HorizontalContentAlignment="Left"
                                VerticalContentAlignment="Center"
                                Content="{TemplateBinding AddOnContent}"
                                ContentTemplate="{TemplateBinding AddOnContentTemplate}"
                                Grid.Column="2" />
                        </Grid>
                    </Border>
                    <atom:LayoutAwareMotionActor
                        Name="PART_ContentMotionActor"
                        ClipToBounds="True">
                        <ContentPresenter Name="PART_ContentPresenter"
                                          Content="{TemplateBinding Content, Converter={StaticResource StringToTextBlockConverter}}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          BorderThickness="{TemplateBinding ContentBorderThickness}"
                                          Padding="{TemplateBinding ContentPadding}"/>
                    </atom:LayoutAwareMotionActor>
                </DockPanel>
            </ControlTemplate>
        </Setter>

        <Setter Property="MotionDuration" Value="{atom:SharedTokenResource MotionDurationSlow}" />
        <Style Selector="^ /template/ Border#PART_HeaderDecorator">
            <Setter Property="Background" Value="{atom:CollapseTokenResource HeaderBg}" />
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorBorder}" />
        </Style>

        <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorBorder}" />
        </Style>

        <Style Selector="^ /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorTextHeading}" />
        </Style>

        <Style Selector="^ /template/ atom|IconButton#PART_ExpandButton">
            <Setter Property="IconWidth" Value="{atom:SharedTokenResource IconSizeSM}" />
            <Setter Property="IconHeight" Value="{atom:SharedTokenResource IconSizeSM}" />
        </Style>

        <Style Selector="^[IsSelected=True]">
            <Style Selector="^ /template/ atom|IconButton#PART_ExpandButton">
                <Setter Property="RenderTransform" Value="rotate(90deg)" />
            </Style>
        </Style>

        <Style Selector="^[SizeType=Large]">
            <Setter Property="HeaderPadding"
                    Value="{atom:CollapseTokenResource CollapseHeaderPaddingLG}" />
            <Setter Property="ContentPadding"
                    Value="{atom:CollapseTokenResource CollapseContentPaddingLG}" />
        </Style>
        <Style Selector="^[SizeType=Middle]">
            <Setter Property="HeaderPadding"
                    Value="{atom:CollapseTokenResource HeaderPadding}" />
            <Setter Property="ContentPadding"
                    Value="{atom:CollapseTokenResource ContentPadding}" />
        </Style>
        <Style Selector="^[SizeType=Small]">
            <Setter Property="HeaderPadding"
                    Value="{atom:CollapseTokenResource CollapseHeaderPaddingSM}" />
            <Setter Property="ContentPadding"
                    Value="{atom:CollapseTokenResource CollapseContentPaddingSM}" />
        </Style>

        <Style Selector="^[SizeType=Large]">
            <Style Selector="^ /template/ Border#PART_HeaderDecorator">
                <Setter Property="TextElement.FontSize"
                        Value="{atom:SharedTokenResource FontSizeLG}" />
                <Setter Property="TextBlock.LineHeight"
                        Value="{atom:SharedTokenResource FontHeightLG}" />
            </Style>
        </Style>
        <Style Selector="^[SizeType=Middle]">
            <Style Selector="^ /template/ Border#PART_HeaderDecorator">
                <Setter Property="TextElement.FontSize"
                        Value="{atom:SharedTokenResource FontSize}" />
                <Setter Property="TextBlock.LineHeight"
                        Value="{atom:SharedTokenResource FontHeight}" />
            </Style>
        </Style>
        <Style Selector="^[SizeType=Small]">
            <Style Selector="^ /template/ Border#PART_HeaderDecorator">
                <Setter Property="TextElement.FontSize"
                        Value="{atom:SharedTokenResource FontSize}" />
                <Setter Property="TextBlock.LineHeight"
                        Value="{atom:SharedTokenResource FontHeight}" />
            </Style>
        </Style>

        <Style Selector="^[TriggerType=Header]">
            <Style Selector="^ /template/ Border#PART_HeaderDecorator">
                <Setter Property="Cursor" Value="Hand" />
            </Style>
        </Style>

        <Style Selector="^[TriggerType=Icon]">
            <Style Selector="^ /template/ atom|IconButton#PART_ExpandButton">
                <Setter Property="Cursor" Value="Hand" />
            </Style>
        </Style>

        <Style Selector="^[ExpandIconPosition=Start]">
            
            <Style Selector="^[SizeType=Large]">
                <Style Selector="^ /template/ atom|IconButton#PART_ExpandButton">
                    <Setter Property="Grid.Column" Value="0" />
                    <Setter Property="Margin"
                            Value="{atom:CollapseTokenResource LeftExpandButtonMarginLG}" />
                </Style>
            </Style>
            <Style Selector="^[SizeType=Middle]">
                <Style Selector="^ /template/ atom|IconButton#PART_ExpandButton">
                    <Setter Property="Grid.Column" Value="0" />
                    <Setter Property="Margin"
                            Value="{atom:CollapseTokenResource LeftExpandButtonMargin}" />
                </Style>
            </Style>
            <Style Selector="^[SizeType=Small]">
                <Style Selector="^ /template/ atom|IconButton#PART_ExpandButton">
                    <Setter Property="Grid.Column" Value="0" />
                    <Setter Property="Margin"
                            Value="{atom:CollapseTokenResource LeftExpandButtonMarginSM}" />
                </Style>
            </Style>
           
        </Style>

        <Style Selector="^[ExpandIconPosition=End]">
            <Style Selector="^[SizeType=Large]">
                <Style Selector="^ /template/ atom|IconButton#PART_ExpandButton">
                    <Setter Property="Grid.Column" Value="3" />
                    <Setter Property="Margin"
                            Value="{atom:CollapseTokenResource RightExpandButtonMarginLG}" />
                </Style>
            </Style>
            <Style Selector="^[SizeType=Middle]">
                <Style Selector="^ /template/ atom|IconButton#PART_ExpandButton">
                    <Setter Property="Grid.Column" Value="3" />
                    <Setter Property="Margin"
                            Value="{atom:CollapseTokenResource RightExpandButtonMargin}" />
                </Style>
            </Style>
            <Style Selector="^[SizeType=Small]">
                <Style Selector="^ /template/ atom|IconButton#PART_ExpandButton">
                    <Setter Property="Grid.Column" Value="3" />
                    <Setter Property="Margin"
                            Value="{atom:CollapseTokenResource RightExpandButtonMarginSM}" />
                </Style>
            </Style>
        </Style>

        <Style Selector="^[IsBorderless=True]">
            <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="{atom:CollapseTokenResource HeaderBg}" />
            </Style>
        </Style>

        <Style Selector="^[IsGhostStyle=True]">
            <Style Selector="^ /template/ Border#PART_HeaderDecorator">
                <Setter Property="Background" Value="{atom:CollapseTokenResource ContentBg}" />
            </Style>
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorTextDisabled}" />
            <Style Selector="^ /template/ Border#PART_HeaderDecorator ContentPresenter">
                <Setter Property="Foreground"
                        Value="{atom:SharedTokenResource ColorTextDisabled}" />
            </Style>
        </Style>

        <Style Selector="^[IsMotionEnabled=True]">
            <Setter Property="Transitions">
                <Transitions>
                    <ThicknessTransition Property="HeaderBorderThickness" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}" />
                    <ThicknessTransition Property="ContentBorderThickness" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}" />
                </Transitions>
            </Setter>
        </Style>

    </ControlTheme>
</ResourceDictionary>