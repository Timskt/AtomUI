<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    xmlns:antdicons="https://atomui.net/icons/antdesign"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:ComboBoxHandle}" TargetType="atom:ComboBoxHandle">
        <Setter Property="Template">
            <ControlTemplate>
                <atom:IconButton
                    Name="PART_OpenIndicatorButton"
                    IsMotionEnabled="{TemplateBinding IsMotionEnabled}"
                    IsEnabled="{TemplateBinding IsEnabled}"
                    Icon="{antdicons:AntDesignIconProvider DownOutlined}"
                    VerticalAlignment="Center"/>
            </ControlTemplate>
        </Setter>

        <Style Selector="^ /template/ atom|IconButton#PART_OpenIndicatorButton">
            <Setter Property="IconWidth" Value="{atom:SharedTokenResource IconSizeSM}" />
            <Setter Property="IconHeight"
                    Value="{atom:SharedTokenResource IconSizeSM}" />
        </Style>
        
        <Style Selector="^ /template/ atom|IconButton#PART_OpenIndicatorButton:pointerover">
            <Setter Property="IconBrush"
                    Value="{atom:ButtonSpinnerTokenResource HandleHoverColor}" />
        </Style>
        <Style Selector="^ /template/ atom|IconButton#PART_OpenIndicatorButton:pressed">
            <Setter Property="IconBrush"
                    Value="{atom:SharedTokenResource ColorPrimaryActive}" />
        </Style>
    </ControlTheme>
</ResourceDictionary>