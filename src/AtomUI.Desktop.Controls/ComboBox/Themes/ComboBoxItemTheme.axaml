<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <atom:StringToTextBlockConverter x:Key="StringToTextBlockConverter" VerticalAlignment="Center" />
    <ControlTheme x:Key="{x:Type atom:ComboBoxItem}" TargetType="atom:ComboBoxItem">
        <Setter Property="Template">
            <ControlTemplate>
                <ContentPresenter
                    Name="ContentPresenter"
                    Content="{TemplateBinding Content, Converter={StaticResource StringToTextBlockConverter}}"
                    ContentTemplate="{TemplateBinding ContentTemplate}"
                    HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                    VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}"
                    Margin="{atom:ComboBoxTokenResource ItemMargin}" />
            </ControlTemplate>
        </Setter>

        <Setter Property="Foreground" Value="{atom:ComboBoxTokenResource ItemColor}" />
        <Setter Property="Background" Value="{atom:ComboBoxTokenResource ItemBgColor}" />
        <Setter Property="Padding" Value="{atom:ComboBoxTokenResource ItemPadding}" />
        <Setter Property="CornerRadius" Value="{atom:SharedTokenResource BorderRadiusSM}" />

        <Style Selector="^:pointerover">
            <Setter Property="Foreground" Value="{atom:ComboBoxTokenResource ItemHoverColor}" />
            <Setter Property="Background"
                    Value="{atom:ComboBoxTokenResource ItemHoverBgColor}" />
        </Style>

        <Style Selector="^:selected">
            <Setter Property="Foreground"
                    Value="{atom:ComboBoxTokenResource ItemSelectedColor}" />
            <Setter Property="Background"
                    Value="{atom:ComboBoxTokenResource ItemSelectedBgColor}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Foreground"
                    Value="{atom:SharedTokenResource ColorTextDisabled}" />
        </Style>


        <Style Selector="^[IsMotionEnabled=True]">
            <Setter Property="Transitions">
                <Transitions>
                    <atom:SolidColorBrushTransition Property="Background" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}" />
                </Transitions>
            </Setter>
        </Style>
    </ControlTheme>
</ResourceDictionary>