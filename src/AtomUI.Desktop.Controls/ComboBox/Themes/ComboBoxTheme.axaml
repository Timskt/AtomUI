<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:ComboBox}" TargetType="atom:ComboBox">
        <Setter Property="Template">
            <ControlTemplate>
                <Panel>
                    <atom:AddOnDecoratedBox
                        Name="{x:Static atom:AddOnDecoratedBox.AddOnDecoratedBoxPart}"
                        Focusable="True"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        StyleVariant="{TemplateBinding StyleVariant}"
                        SizeType="{TemplateBinding SizeType}"
                        Status="{TemplateBinding Status}"
                        LeftAddOn="{TemplateBinding LeftAddOn}"
                        LeftAddOnTemplate="{TemplateBinding LeftAddOnTemplate}"
                        RightAddOn="{TemplateBinding RightAddOn}"
                        RightAddOnTemplate="{TemplateBinding RightAddOnTemplate}"
                        IsEnabled="{TemplateBinding IsEnabled}"
                        ContentLeftAddOn="{TemplateBinding ContentLeftAddOn}"
                        ContentLeftAddOnTemplate="{TemplateBinding ContentLeftAddOnTemplate}">
                        <atom:AddOnDecoratedBox.ContentRightAddOn>
                             <StackPanel Orientation="Horizontal" Spacing="{atom:SharedTokenResource SpacingXS}">
                                 <ContentPresenter Name="PART_ContentRightAddOnPresenter" />
                                 <ContentPresenter
                                     Name="PART_FormFeedBack"
                                     VerticalAlignment="Stretch"
                                     VerticalContentAlignment="Center"
                                     HorizontalAlignment="Right" />
                                 <atom:ComboBoxHandle Name="PART_ComboBoxHandle" />
                             </StackPanel>
                        </atom:AddOnDecoratedBox.ContentRightAddOn>
                        <Panel>
                            <atom:TextBlock
                                Name="PlaceholderText"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                TextTrimming="CharacterEllipsis"
                                Opacity="0.3"
                                IsVisible="{TemplateBinding SelectingItemsControl.SelectedItem, Converter={x:Static ObjectConverters.IsNull}}"
                                Text="{TemplateBinding PlaceholderText}" />
                            <ContentPresenter
                                Name="SelectedContentPresenter"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding ItemTemplate}" />
                        </Panel>
                    </atom:AddOnDecoratedBox>

                    <atom:Popup Name="PART_Popup"
                                WindowManagerAddShadowHint="False"
                                IsLightDismissEnabled="False"
                                Placement="BottomEdgeAlignedLeft"
                                IsOpen="{TemplateBinding IsDropDownOpen, Mode=TwoWay}">
                        <Border
                            Name="PopupFrame"
                            MaxHeight="{TemplateBinding MaxDropDownHeight}"
                            MinWidth="{TemplateBinding EffectivePopupWidth}"
                            Padding="{TemplateBinding PopupContentPadding}">
                            <atom:ScrollViewer IsScrollChainingEnabled="False"
                                               IsMotionEnabled="{TemplateBinding IsMotionEnabled}"
                                               IsLiteMode="{TemplateBinding atom:ScrollViewer.IsLiteMode}"
                                               AllowAutoHide="{TemplateBinding atom:ScrollViewer.AllowAutoHide}">
                                <ItemsPresenter
                                    Name="PART_ItemsPresenter"
                                    ItemsPanel="{TemplateBinding ItemsPanel}"
                                    Grid.IsSharedSizeScope="True" />
                            </atom:ScrollViewer>
                        </Border>
                    </atom:Popup>
                </Panel>
            </ControlTemplate>
        </Setter>

        <Setter Property="atom:ScrollViewer.IsLiteMode" Value="True" />
        <Setter Property="atom:ScrollViewer.AllowAutoHide" Value="True" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}" />
        <Setter Property="PopupContentPadding" Value="{atom:ComboBoxTokenResource PopupContentPadding}" />
        <Setter Property="OptionFontSize" Value="{atom:SharedTokenResource FontSize}" />
        <Setter Property="ItemHeight" Value="{atom:SharedTokenResource ControlHeight}" />
        
        <Style Selector="^[SizeType=Large]">
            <Setter Property="FontSize" Value="{atom:SharedTokenResource FontSizeLG}" />
        </Style>
        <Style Selector="^[SizeType=Middle]">
            <Setter Property="FontSize" Value="{atom:SharedTokenResource FontSize}" />
        </Style>
        <Style Selector="^[SizeType=Small]">
            <Setter Property="FontSize" Value="{atom:SharedTokenResource FontSizeSM}" />
            <Style Selector="^ /template/ ContentPresenter#SelectedContentPresenter">
                <Setter Property="Margin" Value="0, 1, 0, 1" />
            </Style>
        </Style>

        <Style Selector="^ /template/ atom|Popup#PART_Popup">
            <Setter Property="MarginToAnchor"
                    Value="{atom:PopupHostTokenResource MarginToAnchor}" />
            <Setter Property="PopupRootShadow" Value="{atom:PopupHostTokenResource PopupRootShadow}" />
        </Style>
        <Style Selector="^ /template/ Border#PopupFrame">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgElevated}" />
            <Setter Property="CornerRadius"
                    Value="{atom:PopupHostTokenResource BorderRadius}" />
        </Style>

        <Style Selector="^[StyleVariant=Borderless]">
            <Style Selector="^:error">
                <Style Selector="^ /template/ ContentPresenter#SelectedContentPresenter">
                    <Setter Property="Foreground"
                            Value="{atom:SharedTokenResource ColorErrorText}" />
                </Style>
            </Style>
            <Style Selector="^:warning">
                <Style Selector="^ /template/ ContentPresenter#SelectedContentPresenter">
                    <Setter Property="Foreground"
                            Value="{atom:SharedTokenResource ColorWarningText}" />
                </Style>
            </Style>
        </Style>

        <Style Selector="^[StyleVariant=Filled]">
            <Style Selector="^:error">
                <Style Selector="^ /template/ ContentPresenter#SelectedContentPresenter">
                    <Setter Property="Foreground"
                            Value="{atom:SharedTokenResource ColorErrorText}" />
                </Style>
            </Style>
            <Style Selector="^:warning">
                <Style Selector="^ /template/ ContentPresenter#SelectedContentPresenter">
                    <Setter Property="Foreground"
                            Value="{atom:SharedTokenResource ColorWarningText}" />
                </Style>
            </Style>
        </Style>
    </ControlTheme>
</ResourceDictionary>