<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    xmlns:calendarView="clr-namespace:AtomUI.Desktop.Controls.CalendarView"
    x:ClassModifier="internal">
    <atom:StringToTextBlockConverter x:Key="StringToTextBlockConverter" VerticalAlignment="Center"
                                     HorizontalAlignment="Center" />
    <ControlTheme x:Key="{x:Type calendarView:CalendarDayButton}" TargetType="calendarView:CalendarDayButton">
        <Setter Property="Template">
            <ControlTemplate>
                <Panel>
                    <Border Name="RangeIndicator"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            IsVisible="False"/>
                    <Border Name="RangeStartIndicator"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            IsVisible="False"/>
                    <Border Name="RangeEndIndicator"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            IsVisible="False"/>
                    <ContentPresenter
                        Name="Content"
                        Padding="{TemplateBinding Padding}"
                        Foreground="{TemplateBinding Foreground}"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding EffectiveCornerRadius}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        FontSize="{TemplateBinding FontSize}"
                        Content="{TemplateBinding Content, Converter={StaticResource StringToTextBlockConverter}}"
                        ContentTemplate="{TemplateBinding ContentTemplate}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                        VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                </Panel>
            </ControlTemplate>
        </Setter>

        <Setter Property="ClickMode" Value="Release" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorTextLabel}" />
        <Setter Property="CornerRadius" Value="{atom:SharedTokenResource BorderRadiusSM}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="{atom:SharedTokenResource FontSize}" />
        
        <Style Selector="^ /template/ Border#RangeIndicator">
            <Setter Property="Height" Value="{atom:CalendarTokenResource CellHeight}" />
        </Style>
        
        <Style Selector="^ /template/ Border#RangeStartIndicator">
            <Setter Property="Height" Value="{atom:CalendarTokenResource CellHeight}" />
            <Setter Property="Width" Value="{atom:CalendarTokenResource CellWidth}" />
        </Style>
        
        <Style Selector="^ /template/ Border#RangeEndIndicator">
            <Setter Property="Height" Value="{atom:CalendarTokenResource CellHeight}" />
            <Setter Property="Width" Value="{atom:CalendarTokenResource CellWidth}" />
        </Style>

        <Style Selector="^ /template/ ContentPresenter#Content">
            <Setter Property="Width" Value="{atom:CalendarTokenResource CellWidth}" />
            <Setter Property="Height" Value="{atom:CalendarTokenResource CellHeight}" />
            <Setter Property="Margin" Value="{atom:CalendarTokenResource CellMargin}" />
        </Style>

        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{atom:CalendarTokenResource CellHoverBg}" />
        </Style>

        <Style Selector="^:inactive">
            <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorTextDisabled}" />
        </Style>

        <Style Selector="^:today">
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorPrimary}" />
            <Setter Property="BorderThickness" Value="{atom:SharedTokenResource BorderThickness}" />
        </Style>
        
        <Style Selector="^:selected:not(:inactive)">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorPrimary}" />
            <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorWhite}" />
            
            <Style Selector="^:range-middle">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorTextLabel}" />
                <Style Selector="^ /template/ Border#RangeIndicator">
                    <Setter Property="IsVisible" Value="True" />
                    <Setter Property="Background" Value="{atom:CalendarTokenResource CellActiveWithRangeBg}" />
                </Style>
            </Style>
            
            <Style Selector="^:range-start">
                <Style Selector="^ /template/ Border#RangeStartIndicator">
                    <Setter Property="IsVisible" Value="True" />
                    <Setter Property="Background" Value="{atom:CalendarTokenResource CellActiveWithRangeBg}" />
                </Style>
            </Style>
            
            <Style Selector="^:range-end">
                <Style Selector="^ /template/ Border#RangeEndIndicator">
                    <Setter Property="IsVisible" Value="True" />
                    <Setter Property="Background" Value="{atom:CalendarTokenResource CellActiveWithRangeBg}" />
                </Style>
            </Style>
        </Style>

        <Style Selector="^[IsMotionEnabled=True]">
            <Setter Property="Transitions">
                <Transitions>
                    <atom:SolidColorBrushTransition Property="Background" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationFast}" />
                    <atom:SolidColorBrushTransition Property="Foreground" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationFast}" />
                </Transitions>
            </Setter>
        </Style>

    </ControlTheme>
</ResourceDictionary>