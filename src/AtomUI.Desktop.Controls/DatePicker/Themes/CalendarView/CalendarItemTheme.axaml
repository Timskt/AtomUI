<ControlTheme
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    xmlns:antdicons="https://atomui.net/icons/antdesign"
    xmlns:calendarView="clr-namespace:AtomUI.Desktop.Controls.CalendarView"
    x:Class="AtomUI.Desktop.Controls.Themes.CalendarItemTheme"
    xmlns:themes="using:AtomUI.Desktop.Controls.Themes"
    TargetType="calendarView:CalendarItem"
    x:ClassModifier="internal">
    <Setter Property="Template">
        <ControlTemplate TargetType="calendarView:CalendarItem">
            <Border
                Name="PART_ItemFrame"
                MinWidth="{TemplateBinding MinWidth}"
                MinHeight="{TemplateBinding MinHeight}">
                <DockPanel
                    Name="PART_ItemRootLayout"
                    LastChildFill="True">
                    <Border Name="PART_HeaderFrame"
                            DockPanel.Dock="Top"
                            BorderThickness="{TemplateBinding HeaderBorderThickness, Converter={x:Static themes:CalendarItemTheme.BorderThicknessFilterConverter}}">
                        <Grid Name="PART_HeaderLayout"
                              MinWidth="{atom:DatePickerTokenResource MonthViewMinWidth}"
                              MinHeight="{atom:SharedTokenResource ControlHeight}">
                            <atom:HeadTextButton
                                Name="PART_HeaderButton"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                IsMotionEnabled="{TemplateBinding IsMotionEnabled}" />

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                <atom:IconButton
                                    Name="PART_PreviousButton"
                                    Icon="{antdicons:AntDesignIconProvider DoubleLeftOutlined}" />
                                <atom:IconButton
                                    Name="PART_PreviousMonthButton"
                                    IsVisible="{TemplateBinding IsMonthViewMode}"
                                    Icon="{antdicons:AntDesignIconProvider LeftOutlined}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <atom:IconButton
                                    Name="PART_NextMonthButton"
                                    Icon="{antdicons:AntDesignIconProvider RightOutlined}"
                                    IsVisible="{TemplateBinding IsMonthViewMode}" />
                                <atom:IconButton
                                    Name="PART_NextButton"
                                    Icon="{antdicons:AntDesignIconProvider DoubleRightOutlined}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <UniformGrid Name="PART_MonthViewLayout"
                                 Columns="1"
                                 IsVisible="False">
                        <Grid Name="PART_MonthView"
                              HorizontalAlignment="Stretch"
                              IsVisible="{TemplateBinding IsVisible}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                        </Grid>
                    </UniformGrid>

                    <Grid Name="PART_YearView"
                          IsVisible="False">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                    </Grid>
                </DockPanel>
            </Border>
        </ControlTemplate>
    </Setter>

    <Style Selector="^:is(calendarView|CalendarItem)">
        <Setter Property="DayTitleTemplate">
            <Template x:DataType="x:String">
                <atom:TextBlock Text="{Binding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Template>
        </Setter>

        <Setter Property="MinHeight" Value="{atom:DatePickerTokenResource ItemPanelMinHeight}" />
        <Setter Property="MinWidth" Value="{atom:DatePickerTokenResource ItemPanelMinWidth}" />
        <Setter Property="HeaderBorderThickness"
                Value="{atom:SharedTokenResource BorderThickness}" />

        <Style Selector="^ /template/ Border#PART_HeaderFrame">
            <Setter Property="Margin" Value="{atom:DatePickerTokenResource HeaderMargin}" />
            <Setter Property="Padding" Value="{atom:DatePickerTokenResource HeaderPadding}" />
            <Setter Property="BorderBrush"
                    Value="{atom:SharedTokenResource ColorBorderSecondary}" />
        </Style>

        <Style Selector="^ /template/ atom|IconButton">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="IconWidth" Value="{atom:SharedTokenResource IconSizeSM}" />
            <Setter Property="IconHeight" Value="{atom:SharedTokenResource IconSizeSM}" />
            <Setter Property="IconBrush"
                    Value="{atom:SharedTokenResource ColorTextDescription}" />
        </Style>
        
        <Style Selector="^ /template/ atom|IconButton:pointerover">
            <Setter Property="IconBrush" Value="{atom:SharedTokenResource ColorText}" />
        </Style>
        
        <Style Selector="^ /template/ atom|IconButton:pressed">
            <Setter Property="IconBrush" Value="{atom:SharedTokenResource ColorText}" />
        </Style>

        <Style Selector="^ /template/ Grid#PART_MonthView">
            <Setter Property="MinWidth" Value="{atom:DatePickerTokenResource MonthViewMinWidth}" />
        </Style>

    </Style>
</ControlTheme>
