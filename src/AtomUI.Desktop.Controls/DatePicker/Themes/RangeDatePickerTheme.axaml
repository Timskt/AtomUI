<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:RangeDatePicker}" TargetType="atom:RangeDatePicker">
        <ControlTheme.BasedOn>
            <atom:RangeInfoPickerInputTheme TargetType="atom:RangeDatePicker" />
        </ControlTheme.BasedOn>
        <Setter Property="AmText" Value="{atom:TimePickerLangResource AMText}" />
        <Setter Property="PmText" Value="{atom:TimePickerLangResource PMText}" />
    </ControlTheme>
</ResourceDictionary>