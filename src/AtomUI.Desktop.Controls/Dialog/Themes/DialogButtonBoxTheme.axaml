<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    xmlns:converters="clr-namespace:AtomUI.Desktop.Controls.Converters"
    x:ClassModifier="internal">
    <converters:OverlayDialogResizerVisibleConverter x:Key="OverlayDialogResizerVisibleConverter" />
    <ControlTheme x:Key="{x:Type atom:DialogButtonBox}" TargetType="atom:DialogButtonBox">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="Frame">
                    <Grid ColumnDefinitions="*, Auto, *"
                          RowDefinitions="*">
                        <DockPanel Name="{x:Static atom:DialogButtonBoxThemeConstants.LeftGroupPart}"
                                   Grid.Row="0"
                                   Grid.Column="0"
                                   LastChildFill="True"/>
                        <DockPanel Name="{x:Static atom:DialogButtonBoxThemeConstants.CenterGroupPart}"
                                   LastChildFill="True"
                                   Grid.Row="0"
                                   Grid.Column="1" />
                        <DockPanel Name="{x:Static atom:DialogButtonBoxThemeConstants.RightGroupPart}"
                                   LastChildFill="True"
                                   Grid.Row="0"
                                   Grid.Column="2" />
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>

        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}" />
        <Setter Property="ClipToBounds" Value="False" />
        <Style Selector="^ /template/ DockPanel">
            <Setter Property="HorizontalSpacing" Value="{atom:DialogTokenResource ButtonGroupSpacing}" />
        </Style>

        <Setter Property="OkButtonText" Value="{atom:DialogLangResource Ok}" />
        <Setter Property="OpenButtonText" Value="{atom:DialogLangResource Open}" />
        <Setter Property="SaveButtonText" Value="{atom:DialogLangResource Save}" />
        <Setter Property="CancelButtonText"
                Value="{atom:DialogLangResource Cancel}" />
        <Setter Property="CloseButtonText" Value="{atom:DialogLangResource Close}" />
        <Setter Property="DiscardButtonText"
                Value="{atom:DialogLangResource Discard}" />
        <Setter Property="ApplyButtonText" Value="{atom:DialogLangResource Apply}" />
        <Setter Property="ResetButtonText" Value="{atom:DialogLangResource Reset}" />
        <Setter Property="ReloadButtonText"
                Value="{atom:DialogLangResource Reload}" />
        <Setter Property="RestoreDefaultsButtonText"
                Value="{atom:DialogLangResource RestoreDefaults}" />
        <Setter Property="HelpButtonText" Value="{atom:DialogLangResource Help}" />
        <Setter Property="SaveAllButtonText"
                Value="{atom:DialogLangResource SaveAll}" />
        <Setter Property="YesButtonText" Value="{atom:DialogLangResource Yes}" />
        <Setter Property="YesToAllButtonText"
                Value="{atom:DialogLangResource YesToAll}" />
        <Setter Property="NoButtonText" Value="{atom:DialogLangResource No}" />
        <Setter Property="NoToAllButtonText"
                Value="{atom:DialogLangResource NoToAll}" />
        <Setter Property="AbortButtonText" Value="{atom:DialogLangResource Abort}" />
        <Setter Property="RetryButtonText" Value="{atom:DialogLangResource Retry}" />
        <Setter Property="IgnoreButtonText"
                Value="{atom:DialogLangResource Ignore}" />

    </ControlTheme>
</ResourceDictionary>