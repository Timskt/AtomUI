<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    xmlns:converters="clr-namespace:AtomUI.Desktop.Controls.Converters"
    x:ClassModifier="internal">
    <converters:OverlayDialogResizerVisibleConverter x:Key="OverlayDialogResizerVisibleConverter" />
    <ControlTheme x:Key="{x:Type atom:DialogButtonBox}" TargetType="atom:DialogButtonBox">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="Frame">
                    <Grid ColumnDefinitions="*, Auto, *"
                          RowDefinitions="*">
                        <DockPanel Name="{x:Static atom:DialogButtonBoxThemeConstants.LeftGroupPart}"
                                   Grid.Row="0"
                                   Grid.Column="0"
                                   LastChildFill="True"/>
                        <DockPanel Name="{x:Static atom:DialogButtonBoxThemeConstants.CenterGroupPart}"
                                   LastChildFill="True"
                                   Grid.Row="0"
                                   Grid.Column="1" />
                        <DockPanel Name="{x:Static atom:DialogButtonBoxThemeConstants.RightGroupPart}"
                                   LastChildFill="True"
                                   Grid.Row="0"
                                   Grid.Column="2" />
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>

        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}" />
        <Setter Property="ClipToBounds" Value="False" />
        <Style Selector="^ /template/ DockPanel">
            <Setter Property="HorizontalSpacing" Value="{atom:DialogTokenResource ButtonGroupSpacing}" />
        </Style>

        <Setter Property="OkButtonText" Value="{DynamicResource {x:Static atom:DialogLangResourceKey.Ok}}" />
        <Setter Property="OpenButtonText" Value="{DynamicResource {x:Static atom:DialogLangResourceKey.Open}}" />
        <Setter Property="SaveButtonText" Value="{DynamicResource {x:Static atom:DialogLangResourceKey.Save}}" />
        <Setter Property="CancelButtonText"
                Value="{DynamicResource {x:Static atom:DialogLangResourceKey.Cancel}}" />
        <Setter Property="CloseButtonText" Value="{DynamicResource {x:Static atom:DialogLangResourceKey.Close}}" />
        <Setter Property="DiscardButtonText"
                Value="{DynamicResource {x:Static atom:DialogLangResourceKey.Discard}}" />
        <Setter Property="ApplyButtonText" Value="{DynamicResource {x:Static atom:DialogLangResourceKey.Apply}}" />
        <Setter Property="ResetButtonText" Value="{DynamicResource {x:Static atom:DialogLangResourceKey.Reset}}" />
        <Setter Property="ReloadButtonText"
                Value="{DynamicResource {x:Static atom:DialogLangResourceKey.Reload}}" />
        <Setter Property="RestoreDefaultsButtonText"
                Value="{DynamicResource {x:Static atom:DialogLangResourceKey.RestoreDefaults}}" />
        <Setter Property="HelpButtonText" Value="{DynamicResource {x:Static atom:DialogLangResourceKey.Help}}" />
        <Setter Property="SaveAllButtonText"
                Value="{DynamicResource {x:Static atom:DialogLangResourceKey.SaveAll}}" />
        <Setter Property="YesButtonText" Value="{DynamicResource {x:Static atom:DialogLangResourceKey.Yes}}" />
        <Setter Property="YesToAllButtonText"
                Value="{DynamicResource {x:Static atom:DialogLangResourceKey.YesToAll}}" />
        <Setter Property="NoButtonText" Value="{DynamicResource {x:Static atom:DialogLangResourceKey.No}}" />
        <Setter Property="NoToAllButtonText"
                Value="{DynamicResource {x:Static atom:DialogLangResourceKey.NoToAll}}" />
        <Setter Property="AbortButtonText" Value="{DynamicResource {x:Static atom:DialogLangResourceKey.Abort}}" />
        <Setter Property="RetryButtonText" Value="{DynamicResource {x:Static atom:DialogLangResourceKey.Retry}}" />
        <Setter Property="IgnoreButtonText"
                Value="{DynamicResource {x:Static atom:DialogLangResourceKey.Ignore}}" />

    </ControlTheme>
</ResourceDictionary>