<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:OverlayDialogMask}" TargetType="atom:OverlayDialogMask">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="Frame" Background="{TemplateBinding Background}"/>
            </ControlTemplate>
        </Setter>
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgMask}"/>
        <Setter Property="AnimationDuration" Value="{atom:SharedTokenResource MotionDurationMid}"/>
    </ControlTheme>
</ResourceDictionary>
