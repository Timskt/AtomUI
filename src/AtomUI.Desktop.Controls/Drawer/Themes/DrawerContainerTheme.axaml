<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:DrawerContainer}" TargetType="atom:DrawerContainer">
        <Setter Property="Template">
            <ControlTemplate>
                <Panel Name="RootLayout">
                    <Border Name="Mask"
                            IsVisible="{TemplateBinding IsShowMask}"
                            Background="{TemplateBinding Background}" />
                    <atom:MotionActor
                        Name="PART_InfoContainerMotionActor"
                        Opacity="0.0">
                        <atom:DrawerInfoContainer
                            Name="PART_InfoContainer" 
                            Placement="{TemplateBinding Placement}"
                            Title="{TemplateBinding Title}"
                            Footer="{TemplateBinding Footer}"
                            FooterTemplate="{TemplateBinding FooterTemplate}"
                            Extra="{TemplateBinding Extra}"
                            ExtraTemplate="{TemplateBinding ExtraTemplate}"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            IsMotionEnabled="{TemplateBinding IsMotionEnabled}"
                            IsShowCloseButton="{TemplateBinding IsShowCloseButton}"
                            DialogSize="{TemplateBinding DialogSize}"/>
                    </atom:MotionActor>
                </Panel>
            </ControlTemplate>
        </Setter>
        
        <Setter Property="MotionDuration"
                Value="{atom:SharedTokenResource MotionDurationSlow}" />
        <Setter Property="Background"
                Value="{atom:SharedTokenResource ColorBgMask}" />

        <Style Selector="^[IsMotionEnabled=True]">
            <Setter Property="Transitions">
                <Transitions>
                    <atom:SolidColorBrushTransition Property="Background" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}" />
                </Transitions>
            </Setter>
        </Style>

    </ControlTheme>
</ResourceDictionary>
