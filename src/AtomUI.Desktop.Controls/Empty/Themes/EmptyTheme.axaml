<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:Empty}" TargetType="atom:Empty">
        <Setter Property="Template">
            <ControlTemplate>
                <StackPanel Orientation="Vertical">
                    <Svg Name="PART_SvgImage"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
                    <atom:TextBlock Name="Description"
                                    HorizontalAlignment="Center"
                                    TextWrapping="Wrap"
                                    Text="{TemplateBinding Description}"/>
                </StackPanel>
            </ControlTemplate>
        </Setter>
        
        <Setter Property="Description" Value="{atom:CommonLangResource NoData}"/>
        
        <Style Selector="^[SizeType=Large]">
            <Style Selector="^ /template/ Svg#PART_SvgImage">
                <Setter Property="Height" Value="{atom:EmptyTokenResource EmptyImgHeight}"/>
            </Style>
        </Style>
        
        <Style Selector="^[SizeType=Middle]">
            <Style Selector="^ /template/ Svg#PART_SvgImage">
                <Setter Property="Height" Value="{atom:EmptyTokenResource EmptyImgHeightMD}"/>
            </Style>
        </Style>
        
        <Style Selector="^[SizeType=Small]">
            <Style Selector="^ /template/ Svg#PART_SvgImage">
                <Setter Property="Height" Value="{atom:EmptyTokenResource EmptyImgHeightSM}"/>
            </Style>
        </Style>
        
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="BorderColor" Value="{atom:SharedTokenResource ColorFill}"/>
        <Setter Property="BorderColorSecondary" Value="{atom:SharedTokenResource ColorBorderSecondary}"/>
        <Setter Property="ShadowColor" Value="{atom:SharedTokenResource ColorFillTertiary}"/>
        <Setter Property="ContentColor" Value="{atom:SharedTokenResource ColorFillQuaternary}"/>
        <Setter Property="BgColor" Value="{atom:SharedTokenResource ColorBgElevated}"/>
        
        <Style Selector="^[SizeType=Large]">
            <Style Selector="^ /template/ atom|TextBlock#Description">
                <Setter Property="Margin" Value="{atom:EmptyTokenResource DescriptionMargin}"/>
            </Style>
        </Style>
        
        <Style Selector="^[SizeType=Middle]">
            <Style Selector="^ /template/ atom|TextBlock#Description">
                <Setter Property="Margin" Value="{atom:EmptyTokenResource DescriptionMarginSM}"/>
            </Style>
        </Style>
        
        <Style Selector="^[SizeType=Small]">
            <Style Selector="^ /template/ atom|TextBlock#Description">
                <Setter Property="Margin" Value="{atom:EmptyTokenResource DescriptionMarginSM}"/>
            </Style>
        </Style>
        
        <Style Selector="^ /template/ atom|TextBlock#Description">
            <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorTextDescription}"/>
        </Style>
        
    </ControlTheme>
</ResourceDictionary>