<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:BackTopFloatButtonHost}" TargetType="atom:BackTopFloatButtonHost">
        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}" />
        <Setter Property="Placement" Value="BottomRight" />
        <Setter Property="FloatOffsetX" Value="{atom:FloatButtonTokenResource FloatOffsetX}" />
        <Setter Property="FloatOffsetY" Value="{atom:FloatButtonTokenResource FloatOffsetY}" />
        <Setter Property="MotionDuration" Value="{atom:SharedTokenResource MotionDurationMid}" />
    </ControlTheme>
</ResourceDictionary>