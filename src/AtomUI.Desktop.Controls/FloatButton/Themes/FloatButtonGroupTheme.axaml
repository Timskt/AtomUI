<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:FloatButtonGroup}" TargetType="atom:FloatButtonGroup">
        
        <Style Selector="^[Trigger=Default]">
            <Setter Property="Template">
                <ControlTemplate>
                    <atom:FloatButtonItemsControl Name="ItemsControl"
                                                  BoxShadow="{TemplateBinding BoxShadow}"
                                                  Shape="{TemplateBinding Shape}"/>
                </ControlTemplate>
            </Setter>
        </Style>
        
        <Style Selector="^:not(^[Trigger=Default])">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}">
                        <Canvas>
                            <atom:FloatButton Name="Trigger"
                                              Icon="{TemplateBinding Icon}"
                                              Shape="{TemplateBinding Shape}"
                                              ButtonType="{TemplateBinding ButtonType}" />
                            <atom:MotionActor Name="{x:Static atom:BaseMotionActor.MotionActorPart}"
                                              ClipToBounds="False">
                                <atom:FloatButtonItemsControl Name="ItemsControl"
                                                              BoxShadow="{TemplateBinding BoxShadow}"
                                                              Shape="{TemplateBinding Shape}"
                                                              MenuPlacement="{TemplateBinding MenuPlacement}" />
                            </atom:MotionActor>
                        </Canvas>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Setter Property="Background" Value="Transparent" />
        <Setter Property="ClipToBounds" Value="False" />
        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}" />
        <Setter Property="MenuMotionDuration" Value="{atom:SharedTokenResource MotionDurationMid}" />

        <Style Selector="^[Shape=Square]">
            <Setter Property="BoxShadow" Value="{atom:SharedTokenResource BoxShadowsSecondary}" />
        </Style>

        <Style Selector="^[MenuPlacement=Top], ^[MenuPlacement=Bottom]">
            <Setter Property="Width" Value="{atom:FloatButtonTokenResource FloatButtonSize}" />
            <Style Selector="^ /template/ atom|FloatButtonItemsControl#ItemsControl">
                <Setter Property="Orientation" Value="Vertical" />
            </Style>
        </Style>
        
        <Style Selector="^[MenuPlacement=Left], ^[MenuPlacement=Right]">
            <Setter Property="Height" Value="{atom:FloatButtonTokenResource FloatButtonSize}" />
            <Style Selector="^ /template/ atom|FloatButtonItemsControl#ItemsControl">
                <Setter Property="Orientation" Value="Horizontal" />
            </Style>
        </Style>

        <Style Selector="^[IsOpen=True]">
            <Style Selector="^ /template/ atom|FloatButton#Trigger">
                <Setter Property="Icon" Value="{Binding CloseIcon, RelativeSource={RelativeSource TemplatedParent}}" />
            </Style>
        </Style>

    </ControlTheme>
</ResourceDictionary>