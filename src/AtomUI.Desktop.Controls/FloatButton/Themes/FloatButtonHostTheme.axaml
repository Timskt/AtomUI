<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:FloatButtonHost}" TargetType="atom:FloatButtonHost">
        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}" />
        <Setter Property="Placement" Value="BottomRight" />
        <Setter Property="FloatOffsetX" Value="{atom:FloatButtonTokenResource FloatOffsetX}" />
        <Setter Property="FloatOffsetY" Value="{atom:FloatButtonTokenResource FloatOffsetY}" />
        
        <Style Selector="^[Shape=Circle][IsDotBadge=True]">
            <Setter Property="BadgeOffset" Value="-10, 4" />
        </Style>
        <Style Selector="^[Shape=Circle][IsDotBadge=False]">
            <Setter Property="BadgeOffset" Value="-10, -2" />
        </Style>
        <Style Selector="^[Shape=Square][IsDotBadge=True]">
            <Setter Property="BadgeOffset" Value="-5, -1" />
        </Style>
        <Style Selector="^[Shape=Square][IsDotBadge=False]">
            <Setter Property="BadgeOffset" Value="-10, -5" />
        </Style>
    </ControlTheme>
</ResourceDictionary>