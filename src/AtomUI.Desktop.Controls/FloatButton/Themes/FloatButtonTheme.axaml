<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:FloatButton}" TargetType="atom:FloatButton">
        <ControlTheme.BasedOn>
            <atom:AbstractFloatButtonTheme TargetType="atom:FloatButton"/>
        </ControlTheme.BasedOn>
    </ControlTheme>
</ResourceDictionary>