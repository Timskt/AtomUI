<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:atom="https://atomui.net"
                    x:ClassModifier="internal">
    <atom:MenuFlyoutPresenterTheme x:Key="{x:Type atom:MenuFlyoutPresenter}" TargetType="atom:MenuFlyoutPresenter"/>
    <atom:TreeViewFlyoutPresenterTheme x:Key="{x:Type atom:TreeViewFlyoutPresenter}" TargetType="atom:TreeViewFlyoutPresenter"/>
    <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="FlyoutHostTheme.axaml"/>
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>