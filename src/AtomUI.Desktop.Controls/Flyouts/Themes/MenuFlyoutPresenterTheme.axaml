<ControlTheme xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:atom="https://atomui.net"
              x:Class="AtomUI.Desktop.Controls.Themes.MenuFlyoutPresenterTheme"
              TargetType="atom:MenuFlyoutPresenter"
              x:ClassModifier="internal">
    <Setter Property="Template">
        <ControlTemplate TargetType="atom:MenuFlyoutPresenter">
            <atom:ArrowDecoratedBox Name="{x:Static atom:AbstractArrowDecoratedBox.ArrowDecoratorPart}"
                                    IsArrowVisible="{TemplateBinding IsArrowVisible}"
                                    ArrowPosition="{TemplateBinding ArrowPosition}"
                                    Padding="{TemplateBinding Padding}"
                                    MaxHeight="{TemplateBinding MaxPopupHeight}">
                <atom:ScrollViewer IsScrollChainingEnabled="False"
                                   IsMotionEnabled="{TemplateBinding IsMotionEnabled}"
                                   IsLiteMode="{TemplateBinding atom:ScrollViewer.IsLiteMode}"
                                   AllowAutoHide="{TemplateBinding atom:ScrollViewer.AllowAutoHide}">
                    <ItemsPresenter Name="PART_ItemsPresenter"
                                    ItemsPanel="{TemplateBinding ItemsPanel}"
                                    KeyboardNavigation.TabNavigation="Continue"
                                    Grid.IsSharedSizeScope="True" />
                </atom:ScrollViewer>
            </atom:ArrowDecoratedBox>
        </ControlTemplate>
    </Setter>

    <Style Selector="^:is(atom|MenuFlyoutPresenter)">
        <Setter Property="atom:ScrollViewer.IsLiteMode" Value="True" />
        <Setter Property="atom:ScrollViewer.AllowAutoHide" Value="True" />
        <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgElevated}" />
        <Setter Property="CornerRadius" Value="{atom:PopupHostTokenResource BorderRadius}" />
        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}" />
        <Setter Property="Padding" Value="{atom:MenuTokenResource MenuPopupContentPadding}" />
        <Setter Property="ItemHeight" Value="{atom:MenuTokenResource ItemHeight}" />

        <Style Selector="^ /template/ atom|ArrowDecoratedBox#PART_ArrowDecorator">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgElevated}" />
            <Setter Property="MinWidth" Value="{atom:MenuTokenResource MenuPopupMinWidth}" />
            <Setter Property="MaxWidth" Value="{atom:MenuTokenResource MenuPopupMaxWidth}" />
        </Style>
    </Style>

</ControlTheme>
