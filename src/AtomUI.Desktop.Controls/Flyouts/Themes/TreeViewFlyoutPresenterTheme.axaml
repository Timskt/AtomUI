<ControlTheme xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:atom="https://atomui.net"
              x:Class="AtomUI.Desktop.Controls.Themes.TreeViewFlyoutPresenterTheme"
              TargetType="atom:TreeViewFlyoutPresenter"
              x:ClassModifier="internal">
    <Setter Property="Template">
        <ControlTemplate>
            <atom:ArrowDecoratedBox Name="{x:Static atom:AbstractArrowDecoratedBox.ArrowDecoratorPart}"
                                    IsShowArrow="{TemplateBinding IsShowArrow}"
                                    ArrowPosition="{TemplateBinding ArrowPosition}"
                                    BackgroundSizing="{TemplateBinding BackgroundSizing}"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Padding="{TemplateBinding Padding}">
                <ItemsPresenter Name="ItemsPresenter"
                                ItemsPanel="{TemplateBinding ItemsPanel}" />
            </atom:ArrowDecoratedBox>
        </ControlTemplate>
    </Setter>
    
    <Style Selector="^:is(atom|TreeViewFlyoutPresenter)">
        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}" />
        <Setter Property="CornerRadius" Value="{atom:PopupHostTokenResource BorderRadius}" />
        <Setter Property="Padding" Value="{atom:TreeFlyoutTokenResource PopupContentPadding}" />
        
        <Style Selector="^ /template/ atom|ArrowDecoratedBox#PART_ArrowDecorator">
            <Setter Property="Background" Value="{atom:TreeFlyoutTokenResource PopupBgColor}" />
            <Setter Property="MinWidth" Value="{atom:TreeFlyoutTokenResource PopupMinWidth}" />
            <Setter Property="MaxWidth" Value="{atom:TreeFlyoutTokenResource PopupMaxWidth}" />
            <Setter Property="MinHeight" Value="{atom:TreeFlyoutTokenResource PopupMinHeight}" />
            <Setter Property="MaxHeight" Value="{atom:TreeFlyoutTokenResource PopupMaxHeight}" />
        </Style>
    </Style>

</ControlTheme>