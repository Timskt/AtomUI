<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net">
    <ControlTheme x:Key="{x:Type atom:FormItem}" TargetType="atom:FormItem">
        <Setter Property="Template">
            <ControlTemplate>
                <Grid Name="{x:Static atom:FormItemThemeConstants.RootLayoutPart}">
                    <Panel Name="PART_LabelLayout" 
                            VerticalAlignment="Top"
                            IsVisible="{TemplateBinding LabelText, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <ContentPresenter Name="CustomRequiredMarkPresenter"
                                              Content="{TemplateBinding CustomRequireMark}"
                                              ContentTemplate="{TemplateBinding CustomRequireMarkTemplate}"
                                              IsVisible="False"
                                              VerticalAlignment="Center" />
                            <ContentPresenter Name="CustomOptionalMarkPresenter"
                                              Content="{TemplateBinding CustomOptionalMark}"
                                              ContentTemplate="{TemplateBinding CustomOptionalMarkTemplate}"
                                              IsVisible="False"
                                              VerticalAlignment="Center" />
                            <TextBlock Text="*" Name="{x:Static atom:FormItemThemeConstants.DefaultRequireMarkPart}"
                                       IsVisible="False"
                                       VerticalAlignment="Center" />
                            <TextBlock Name="{x:Static atom:FormItemThemeConstants.LabelPart}"
                                       Text="{TemplateBinding LabelText}"
                                       VerticalAlignment="Center"
                                       TextWrapping="{TemplateBinding LabelWrapping}" 
                                       MaxWidth="{TemplateBinding LabelMaxWidth}"/>
                            <atom:IconPresenter Name="TooltipIconPresenter"
                                                Icon="{TemplateBinding TooltipIcon}"
                                                VerticalAlignment="Center"
                                                Cursor="Help"
                                                atom:ToolTip.Tip="{TemplateBinding Tooltip}"
                                                IsVisible="{TemplateBinding Tooltip, Converter={x:Static ObjectConverters.IsNotNull}}" />
                            <TextBlock Text="{DynamicResource {x:Static atom:CommonLangResourceKey.Optional}}"
                                       Name="OptionalMark"
                                       IsVisible="False"
                                       VerticalAlignment="Center" />
                            <TextBlock Text=":" Name="{x:Static atom:FormItemThemeConstants.ColonPart}"
                                       IsVisible="{TemplateBinding IsColonVisible}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Panel>
                    
                    <StackPanel Name="{x:Static atom:FormItemThemeConstants.ChildrenLayoutPart}"
                                Orientation="Vertical">
                        <Border MinHeight="{Binding #PART_LabelLayout.Bounds.Height}"
                                Name="ContentFrame">
                            <ContentPresenter Name="ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              MaxWidth="{Binding #ContentFrame.Bounds.Width}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Name="{x:Static atom:FormItemThemeConstants.ErrorMsgPart}"
                                   Inlines="{TemplateBinding ErrorMessageInlines}"/>
                    </StackPanel>
                </Grid>
            </ControlTemplate>
        </Setter>

        <Setter Property="ClipToBounds" Value="False" />

        <Style Selector="^[ValidateStatus=Error]">
            <Style Selector="^ /template/ TextBlock#PART_ErrorMsg">
                <Setter Property="Foreground" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorErrorText}}" />
            </Style>
        </Style>

        <Style Selector="^[ValidateStatus=Warning]">
            <Style Selector="^ /template/ TextBlock#PART_ErrorMsg">
                <Setter Property="Foreground" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorWarningText}}" />
            </Style>
        </Style>

        <Style Selector="^ /template/ TextBlock#PART_Colon">
            <Setter Property="Margin" Value="{DynamicResource {x:Static atom:FormTokenKey.LabelColonMargin}}" />
        </Style>

        <Style Selector="^ /template/ TextBlock#PART_DefaultRequireMark">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static atom:FormTokenKey.LabelRequiredMarkColor}}" />
        </Style>
        
        <Style Selector="^[Layout=Vertical]">
            <Style Selector="^ /template/ Panel#PART_LabelLayout">
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="Margin" Value="{DynamicResource {x:Static atom:FormTokenKey.VerticalLabelMargin}}" />
            </Style>
        </Style>
        
        <Style Selector="^ /template/ TextBlock#PART_Label">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static atom:FormTokenKey.LabelColor}}" />
            <Setter Property="FontSize" Value="{DynamicResource {x:Static atom:FormTokenKey.LabelFontSize}}" />
        </Style>
        
        <Style Selector="^ /template/ Panel#PART_LabelLayout StackPanel">
            <Setter Property="Spacing"
                    Value="{DynamicResource {x:Static atom:SharedTokenKey.SpacingXXS}}" />
        </Style>

        <Style Selector="^ /template/ atom|IconPresenter#TooltipIconPresenter">
            <Setter Property="Width" Value="{DynamicResource {x:Static atom:SharedTokenKey.IconSize}}" />
            <Setter Property="Height" Value="{DynamicResource {x:Static atom:SharedTokenKey.IconSize}}" />
            <Setter Property="IconBrush" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorIcon}}" />
        </Style>

        <Style Selector="^[SizeType=Large]">
            <Style Selector="^ /template/ Panel#PART_LabelLayout">
                <Setter Property="MinHeight"
                        Value="{DynamicResource {x:Static atom:SharedTokenKey.ControlHeightLG}}" />
            </Style>
        </Style>
        <Style Selector="^[SizeType=Middle]">
            <Style Selector="^ /template/ Panel#PART_LabelLayout">
                <Setter Property="MinHeight"
                        Value="{DynamicResource {x:Static atom:SharedTokenKey.ControlHeight}}" />
            </Style>
        </Style>
        <Style Selector="^[SizeType=Small]">
            <Style Selector="^ /template/ Panel#PART_LabelLayout">
                <Setter Property="MinHeight"
                        Value="{DynamicResource {x:Static atom:SharedTokenKey.ControlHeightSM}}" />
            </Style>
        </Style>
        
        <Style Selector="^[RequiredMark=Default][IsRequired=True][IsValueItem=True]">
            <Style Selector="^ /template/ TextBlock#PART_DefaultRequireMark">
                <Setter Property="IsVisible" Value="True" />
            </Style>
        </Style>
        
        <Style Selector="^[RequiredMark=Optional][IsRequired=False][IsValueItem=True]">
            <Style Selector="^ /template/ TextBlock#OptionalMark">
                <Setter Property="IsVisible" Value="True" />
            </Style>
        </Style>
        
        <Style Selector="^[RequiredMark=Customize][HasCustomRequireMark=True][IsValueItem=True][IsRequired=True]">
            <Style Selector="^ /template/ ContentPresenter#CustomRequiredMarkPresenter">
                <Setter Property="IsVisible" Value="True" />
            </Style>
        </Style>
        
        <Style Selector="^[RequiredMark=Customize][HasCustomOptionalMark=True][IsValueItem=True][IsRequired=False]">
            <Style Selector="^ /template/ ContentPresenter#CustomOptionalMarkPresenter">
                <Setter Property="IsVisible" Value="True" />
            </Style>
        </Style>
        
        <Style Selector="^[HasErrorOrWarningMsg=False]">
            <Style Selector="^ /template/ StackPanel#PART_ChildrenLayout">
                <Setter Property="Spacing"
                        Value="{DynamicResource {x:Static atom:FormTokenKey.FormItemSpacing}}" />
            </Style>
            <Style Selector="^ /template/ TextBlock#PART_ErrorMsg">
                <Setter Property="MaxHeight" Value="0" />
            </Style>
        </Style>
        
        <Style Selector="^[HasErrorOrWarningMsg=True]">
            <Style Selector="^ /template/ TextBlock#PART_ErrorMsg">
                <Setter Property="MinHeight" Value="{DynamicResource {x:Static atom:FormTokenKey.FormItemSpacing}}" />
            </Style>
            
        </Style>

    </ControlTheme>
</ResourceDictionary>