<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:antdicons="https://atomui.net/icons/antdesign"
    xmlns:atom="https://atomui.net">
    <ControlTheme x:Key="{x:Type atom:Form}" TargetType="atom:Form">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="Frame"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ItemsPresenter Name="PART_ItemsPresenter">
                        <ItemsPresenter.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="{Binding FormLayoutOrientation, RelativeSource={RelativeSource AncestorType=atom:Form}}"
                                            Spacing="{Binding FormLayoutSpacing, RelativeSource={RelativeSource AncestorType=atom:Form}}"/>
                            </ItemsPanelTemplate>
                        </ItemsPresenter.ItemsPanel>
                    </ItemsPresenter>
                </Border>
            </ControlTemplate>
        </Setter>
        
        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}"/>
        <Setter Property="ClipToBounds" Value="False"/>
        <Style Selector="^[FormLayout=Inline]">
            <Setter Property="FormLayoutSpacing" Value="{atom:FormTokenResource InlineItemSpacing}" />
        </Style>
        <Setter Property="ErrorMessageForeground" Value="{atom:SharedTokenResource ColorErrorText}" />
        <Setter Property="WarningMessageForeground" Value="{atom:SharedTokenResource ColorWarningText}" />
        
        <Setter Property="FeedbackTemplate">
            <DataTemplate DataType="atom:Form">
                <atom:FormValidateFeedback SuccessFeedback="{Binding SuccessFeedback}"
                                           SuccessFeedbackTemplate="{Binding SuccessFeedbackTemplate}"
                                           ErrorFeedback="{Binding ErrorFeedback}"
                                           ErrorFeedbackTemplate="{Binding ErrorFeedbackTemplate}"
                                           WarningFeedback="{Binding WarningFeedback}"
                                           WarningFeedbackTemplate="{Binding WarningFeedbackTemplate}"
                                           ValidatingFeedback="{Binding WarningFeedback}"
                                           ValidatingFeedbackTemplate="{Binding ValidatingFeedbackTemplate}"/>
            </DataTemplate>
        </Setter>
        
        <Setter Property="SuccessFeedbackTemplate">
            <DataTemplate>
                <antdicons:CheckCircleFilled
                    FillBrush="{atom:SharedTokenResource ColorSuccess}"
                    Width="{atom:SharedTokenResource IconSize}"
                    Height="{atom:SharedTokenResource IconSize}"/>
            </DataTemplate>
        </Setter>
        <Setter Property="ErrorFeedbackTemplate">
            <DataTemplate>
                <antdicons:CloseCircleFilled
                    FillBrush="{atom:SharedTokenResource ColorError}"
                    Width="{atom:SharedTokenResource IconSize}"
                    Height="{atom:SharedTokenResource IconSize}"/>
            </DataTemplate>
        </Setter>
        <Setter Property="WarningFeedbackTemplate">
            <DataTemplate>
                <antdicons:ExclamationCircleFilled
                    FillBrush="{atom:SharedTokenResource ColorWarning}"
                    />
            </DataTemplate>
        </Setter>
        <Setter Property="ValidatingFeedbackTemplate">
            <DataTemplate>
                <antdicons:LoadingOutlined
                    LoadingAnimation="Spin"
                    StrokeBrush="{atom:SharedTokenResource ColorIcon}"/>
            </DataTemplate>
        </Setter>
        
        <Setter Property="ItemDeleteButtonIcon">
            <atom:IconTemplate>
                <antdicons:MinusCircleOutlined/>
            </atom:IconTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>