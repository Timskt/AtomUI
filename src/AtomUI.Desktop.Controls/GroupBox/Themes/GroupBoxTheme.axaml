<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:GroupBox}" TargetType="atom:GroupBox">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="PART_Frame"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Margin="{TemplateBinding Margin}">
                    <DockPanel LastChildFill="True">
                        <Panel Name="PART_HeaderContainer"
                               DockPanel.Dock="Top">
                            <Decorator Name="PART_HeaderContent"
                                       VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <atom:IconPresenter
                                        Name="PART_HeaderIconPresenter"
                                        IsVisible="{TemplateBinding HeaderIcon, Converter={x:Static ObjectConverters.IsNotNull}}"
                                        Icon="{TemplateBinding HeaderIcon}" />
                                    <atom:TextBlock Name="PART_HeaderPresenter"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    Text="{TemplateBinding HeaderTitle}"
                                                    FontSize="{TemplateBinding HeaderFontSize}"
                                                    Foreground="{TemplateBinding HeaderTitleColor}"
                                                    FontStyle="{TemplateBinding HeaderFontStyle}"
                                                    FontWeight="{TemplateBinding HeaderFontWeight}" />
                                </StackPanel>
                            </Decorator>
                        </Panel>

                        <ContentPresenter Name="PART_ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Margin="{TemplateBinding Padding}"/>
                    </DockPanel>
                </Border>
            </ControlTemplate>
        </Setter>

        <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgContainer}" />
        <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorBorder}" />
        <Setter Property="BorderThickness" Value="{atom:SharedTokenResource BorderThickness}" />
        <Setter Property="CornerRadius" Value="{atom:SharedTokenResource BorderRadius}" />
        <Setter Property="HeaderTitleColor" Value="{atom:SharedTokenResource ColorText}" />
        <Setter Property="HeaderFontSize" Value="{atom:SharedTokenResource FontSize}" />

        <Style Selector="^ /template/ Panel#PART_HeaderContainer">
            <Setter Property="Margin" Value="{atom:GroupBoxTokenResource HeaderContainerMargin}" />
        </Style>

        <Style Selector="^ /template/ Decorator#PART_HeaderContent">
            <Setter Property="Padding" Value="{atom:GroupBoxTokenResource HeaderContentPadding}" />
        </Style>

        <Style Selector="^ /template/ atom|IconPresenter#PART_HeaderIconPresenter">
            <Setter Property="Margin" Value="{atom:GroupBoxTokenResource HeaderIconMargin}" />
            <Setter Property="IconBrush" Value="{atom:SharedTokenResource ColorText}" />
            <Setter Property="Width" Value="{atom:SharedTokenResource IconSizeLG}" />
            <Setter Property="Height" Value="{atom:SharedTokenResource IconSizeLG}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Setter Property="Padding" Value="{atom:GroupBoxTokenResource ContentPadding}" />

        <Style Selector="^[HeaderTitlePosition=Left]">
            <Style Selector="^ /template/ Decorator#PART_HeaderContent">
                <Setter Property="HorizontalAlignment" Value="Left" />
            </Style>
        </Style>

        <Style Selector="^[HeaderTitlePosition=Center]">
            <Style Selector="^ /template/ Decorator#PART_HeaderContent">
                <Setter Property="HorizontalAlignment" Value="Center" />
            </Style>
        </Style>

        <Style Selector="^[HeaderTitlePosition=Right]">
            <Style Selector="^ /template/ Decorator#PART_HeaderContent">
                <Setter Property="HorizontalAlignment" Value="Right" />
            </Style>
        </Style>

    </ControlTheme>
</ResourceDictionary>