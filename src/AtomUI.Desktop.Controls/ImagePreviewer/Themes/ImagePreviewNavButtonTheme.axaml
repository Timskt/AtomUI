<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:ImagePreviewNavButton}" TargetType="atom:ImagePreviewNavButton">
        <ControlTheme.BasedOn>
            <atom:IconButtonTheme TargetType="atom:ImagePreviewNavButton" />
        </ControlTheme.BasedOn>
        
        <Style Selector="^:is(atom|ImagePreviewNavButton)">
            <Setter Property="IconWidth" Value="{atom:ImagePreviewerTokenResource PreviewOperationSize}"/>
            <Setter Property="IconHeight" Value="{atom:ImagePreviewerTokenResource PreviewOperationSize}"/>
            <Setter Property="Background" Value="{atom:ImagePreviewerTokenResource NavButtonBgColor}"/>
            <Setter Property="IconBrush" Value="{atom:ImagePreviewerTokenResource PreviewOperationColor}"/>
            <Setter Property="Padding" Value="{atom:SharedTokenResource PaddingXS}"/>
        
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{atom:ImagePreviewerTokenResource NavButtonBgHoverColor}"/>
                <Setter Property="IconBrush" Value="{atom:ImagePreviewerTokenResource PreviewOperationHoverColor}"/>
            </Style>
        
            <Style Selector="^:disabled">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="IconBrush" Value="{atom:ImagePreviewerTokenResource PreviewOperationColorDisabled}"/>
            </Style>
        </Style>

    </ControlTheme>
</ResourceDictionary>