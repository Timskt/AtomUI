<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:ImagePreviewerCover}" TargetType="atom:ImagePreviewerCover">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        Padding="{TemplateBinding Padding}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <Panel>
                        <atom:ImagePreviewRenderer Source="{TemplateBinding ImageSource}" Stretch="Uniform" />
                        <Border Name="Mask" 
                                Opacity="{TemplateBinding MaskOpacity}"
                                IsVisible="{TemplateBinding IsShowCoverMask}">
                            <ContentPresenter Name="MaskContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}" />
                        </Border>
                    </Panel>
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^[IsShowCoverMask=True]">
            <Setter Property="Cursor" Value="Hand" />
        </Style>
      
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}" />
        <Style Selector="^ /template/ Border#Mask">
            <Setter Property="Background" Value="{atom:ImagePreviewerTokenResource MaskBgColor}" />
            <Setter Property="TemplatedControl.Foreground"
                    Value="{atom:SharedTokenResource ColorTextLightSolid}" />
        </Style>

        <Style Selector="^:pointerover">
            <Setter Property="MaskOpacity" Value="1" />
        </Style>

        <Style Selector="^[IsMotionEnabled=True]">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="MaskOpacity" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationSlow}" />
                </Transitions>
            </Setter>
        </Style>

    </ControlTheme>
</ResourceDictionary>