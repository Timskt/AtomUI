<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    xmlns:antdicons="https://atomui.net/icons/antdesign"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:ImageViewer}" TargetType="atom:ImageViewer">
        <Setter Property="Template">
            <ControlTemplate>
                <Panel>
                    <Canvas Name="PART_ImageViewerScene">
                        <atom:ImagePreviewRenderer
                            Name="PART_ImageRenderer"
                            Source="{TemplateBinding CurrentImage}" Stretch="Uniform"
                            RenderTransform="{TemplateBinding ImageRenderTransform}"
                            RenderTransformOrigin="{x:Static RelativePoint.Center}" />
                    </Canvas>
                    <atom:ImagePreviewNavButton Name="PART_PreviousButton"
                                                Icon="{antdicons:AntDesignIconProvider LeftOutlined}"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                IsVisible="{TemplateBinding IsMultiImages}"
                                                IsEnabled="{TemplateBinding IsFirstImage, Converter={x:Static BoolConverters.Not}}" />
                    <atom:ImagePreviewNavButton Name="PART_NextButton"
                                                Icon="{antdicons:AntDesignIconProvider RightOutlined}"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                IsVisible="{TemplateBinding IsMultiImages}"
                                                IsEnabled="{TemplateBinding IsLastImage, Converter={x:Static BoolConverters.Not}}" />
                    <atom:ImagePreviewFloatToolbar
                        CurrentIndex="{TemplateBinding CurrentIndex}"
                        Count="{TemplateBinding Count}"
                        IsScaleDownEnabled="{TemplateBinding IsScaleDownEnabled}"
                        IsScaleUpEnabled="{TemplateBinding IsScaleUpEnabled}"
                        IsImageFitToWindow="{TemplateBinding IsImageFitToWindow}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom" />
                    <atom:WindowMediaQueryIndicator Name="PART_MediaQueryIndicator" />
                </Panel>
            </ControlTemplate>
        </Setter>

        <Style Selector="^ /template/ atom|ImagePreviewNavButton">
            <Setter Property="Margin" Value="{atom:SharedTokenResource Margin}" />
        </Style>
        <Style Selector="^ /template/ Image#PART_ImageRenderer">
            <Setter Property="Cursor" Value="DragMove" />
        </Style>

        <Style Selector="^[IsMotionEnabled=True]">
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="ImageRenderTransform" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}" />
                    <DoubleTransition Property="ImageTranslateX" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationFast}" />
                    <DoubleTransition Property="ImageTranslateY" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationFast}" />
                </Transitions>
            </Setter>
        </Style>
    </ControlTheme>
</ResourceDictionary>