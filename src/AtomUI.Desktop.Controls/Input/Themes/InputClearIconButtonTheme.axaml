<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:InputClearIconButton}" TargetType="atom:InputClearIconButton">
        <ControlTheme.BasedOn>
            <atom:IconButtonTheme TargetType="{x:Type atom:InputClearIconButton}" />
        </ControlTheme.BasedOn>
        
        <Setter Property="IconWidth"
                Value="{atom:SharedTokenResource IconSize}" />
        
        <Setter Property="IconHeight"
                Value="{atom:SharedTokenResource IconSize}" />

        <Setter Property="IconBrush"
                Value="{atom:SharedTokenResource ColorTextQuaternary}" />
        
        <Style Selector="^:pointerover">
            <Setter Property="IconBrush"
                    Value="{atom:SharedTokenResource ColorTextTertiary}" />
        </Style>
        
        <Style Selector="^:pressed">
            <Setter Property="IconBrush"
                    Value="{atom:SharedTokenResource ColorText}" />
        </Style>
    </ControlTheme>
</ResourceDictionary>
