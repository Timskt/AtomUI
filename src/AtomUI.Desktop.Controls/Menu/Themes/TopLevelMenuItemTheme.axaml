<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="TopLevelMenuItemTheme" TargetType="atom:MenuItem">
        <Setter Property="Template">
            <ControlTemplate>
                <Panel>
                    <Border Name="Frame"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center">
                        <ContentPresenter Name="HeaderPresenter"
                                          RecognizesAccessKey="True"
                                          Content="{TemplateBinding Header}"
                                          ContentTemplate="{TemplateBinding HeaderTemplate}" />
                    </Border>
                    <atom:Popup Name="PART_Popup"
                                WindowManagerAddShadowHint="False"
                                IsLightDismissEnabled="False"
                                Placement="BottomEdgeAlignedLeft"
                                ShouldUseOverlayLayer="{TemplateBinding ShouldUseOverlayPopup}"
                                IsOpen="{TemplateBinding IsSubMenuOpen, Mode=TwoWay}">
                        <Border Name="PopupFrame"
                                MaxHeight="{TemplateBinding MaxPopupHeight}"
                                Padding="{TemplateBinding PopupPadding}">
                            <atom:ScrollViewer
                                IsScrollChainingEnabled="False"
                                IsMotionEnabled="{TemplateBinding IsMotionEnabled}"
                                IsLiteMode="{TemplateBinding atom:ScrollViewer.IsLiteMode}"
                                AllowAutoHide="{TemplateBinding atom:ScrollViewer.AllowAutoHide}">
                                <ItemsPresenter
                                    Name="PART_ItemsPresenter"
                                    ItemsPanel="{TemplateBinding ItemsPanel}"
                                    Grid.IsSharedSizeScope="True"
                                    KeyboardNavigation.TabNavigation="Continue" />
                            </atom:ScrollViewer>
                        </Border>
                    </atom:Popup>
                </Panel>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:toplevel">
            <Style Selector="^ /template/ Border#Frame">
                <Setter Property="Cursor" Value="Hand" />
            </Style>
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="atom:ScrollViewer.IsLiteMode" Value="True" />
            <Setter Property="atom:ScrollViewer.AllowAutoHide" Value="True" />

            <Setter Property="PopupPadding"
                    Value="{atom:MenuTokenResource MenuPopupContentPadding}" />
            <Setter Property="ItemHeight" Value="{atom:MenuTokenResource ItemHeight}" />

            <Style Selector="^:pointerover">
                <Setter Property="Background"
                        Value="{atom:MenuTokenResource TopLevelItemHoverBg}" />
                <Setter Property="Foreground"
                        Value="{atom:MenuTokenResource TopLevelItemHoverColor}" />
            </Style>

            <Style Selector="^[IsSubMenuOpen=True]">
                <Setter Property="Background"
                        Value="{atom:MenuTokenResource TopLevelItemHoverBg}" />
                <Setter Property="Foreground"
                        Value="{atom:MenuTokenResource TopLevelItemHoverColor}" />
            </Style>

            <Style Selector="^[SizeType=Large]">
                <Setter Property="CornerRadius"
                        Value="{atom:MenuTokenResource TopLevelItemBorderRadiusLG}" />
                <Setter Property="MinHeight" Value="{atom:SharedTokenResource ControlHeightLG}" />
                <Setter Property="Padding" Value="{atom:MenuTokenResource TopLevelItemPaddingLG}" />
                <Setter Property="FontSize"
                        Value="{atom:MenuTokenResource TopLevelItemFontSizeLG}" />
                <Style Selector="^ /template/ ContentPresenter#HeaderPresenter">
                    <Setter Property="LineHeight"
                            Value="{atom:MenuTokenResource TopLevelItemLineHeightLG}" />
                </Style>
            </Style>

            <Style Selector="^[SizeType=Middle]">
                <Setter Property="CornerRadius"
                        Value="{atom:MenuTokenResource TopLevelItemBorderRadius}" />
                <Setter Property="MinHeight" Value="{atom:SharedTokenResource ControlHeight}" />
                <Setter Property="Padding" Value="{atom:MenuTokenResource TopLevelItemPadding}" />
                <Setter Property="FontSize" Value="{atom:MenuTokenResource TopLevelItemFontSize}" />
                <Style Selector="^ /template/ ContentPresenter#HeaderPresenter">
                    <Setter Property="LineHeight"
                            Value="{atom:MenuTokenResource TopLevelItemLineHeight}" />
                </Style>
            </Style>

            <Style Selector="^[SizeType=Small]">
                <Setter Property="CornerRadius"
                        Value="{atom:MenuTokenResource TopLevelItemBorderRadiusSM}" />
                <Setter Property="MinHeight" Value="{atom:SharedTokenResource ControlHeightSM}" />
                <Setter Property="Padding" Value="{atom:MenuTokenResource TopLevelItemPaddingSM}" />
                <Setter Property="FontSize"
                        Value="{atom:MenuTokenResource TopLevelItemFontSizeSM}" />
                <Style Selector="^ /template/ ContentPresenter#HeaderPresenter">
                    <Setter Property="LineHeight"
                            Value="{atom:MenuTokenResource TopLevelItemLineHeightSM}" />
                </Style>
            </Style>

            <Style Selector="^ /template/ Border#PopupFrame">
                <Setter Property="Background"
                        Value="{atom:SharedTokenResource ColorBgElevated}" />
                <Setter Property="CornerRadius"
                        Value="{atom:PopupHostTokenResource BorderRadius}" />
                <Setter Property="MinWidth"
                        Value="{atom:MenuTokenResource MenuPopupMinWidth}" />
                <Setter Property="MaxWidth"
                        Value="{atom:MenuTokenResource MenuPopupMaxWidth}" />
            </Style>

            <Style Selector="^ /template/ atom|Popup#PART_Popup">
                <Setter Property="MarginToAnchor"
                        Value="{atom:MenuTokenResource TopLevelItemPopupMarginToAnchor}" />
                <Setter Property="PopupRootShadow"
                        Value="{atom:PopupHostTokenResource PopupRootShadow}" />
                <Setter Property="OverlayHostShadow"
                        Value="{atom:PopupHostTokenResource OverlayHostShadow}" />
            </Style>
            
            <Style Selector="^[ShouldUseOverlayPopup=False] /template/ atom|Popup#PART_Popup">
                <Setter Property="MarginToAnchor" Value="1" />
            </Style>

            <Style Selector="^:disabled">
                <Setter Property="Foreground"
                        Value="{atom:MenuTokenResource ItemDisabledColor}" />
            </Style>
        </Style>

    </ControlTheme>
</ResourceDictionary>
