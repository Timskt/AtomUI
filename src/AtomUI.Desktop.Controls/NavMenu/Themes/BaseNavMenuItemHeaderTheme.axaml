<ControlTheme
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    TargetType="atom:BaseNavMenuItemHeader"
    x:Class="AtomUI.Desktop.Controls.Themes.BaseNavMenuItemHeaderTheme"
    x:ClassModifier="internal">

    <Style Selector="^:is(atom|BaseNavMenuItemHeader)">
        <Style Selector="^ /template/ ContentPresenter#ItemTextPresenter">
            <Setter Property="Margin" Value="{atom:NavMenuTokenResource ItemMargin}" />
        </Style>

        <Setter Property="Cursor" Value="Hand" />

        <Setter Property="Padding" Value="{atom:NavMenuTokenResource ItemContentPadding}" />
        <Setter Property="CornerRadius" Value="{atom:NavMenuTokenResource ItemBorderRadius}" />
        <Setter Property="Foreground"
                Value="{atom:NavMenuTokenResource ItemColor}" />
        <Setter Property="Background" Value="{atom:NavMenuTokenResource ItemBg}" />

        <Style Selector="^[HasSubMenu=False]">
            <Style Selector="^:pointerover">
                <Setter Property="Foreground"
                        Value="{atom:NavMenuTokenResource ItemHoverColor}" />
                <Setter Property="Background" Value="{atom:NavMenuTokenResource ItemHoverBg}" />
            </Style>
        </Style>
        
        <Style Selector="^[IsSelected=True]">
            <Setter Property="Foreground"
                    Value="{atom:NavMenuTokenResource ItemSelectedColor}" />
            <Setter Property="Background"
                    Value="{atom:NavMenuTokenResource ItemSelectedBg}" />
        </Style>
        
        <Style Selector="^[IsInSelectedPath=True]">
            <Setter Property="Foreground"
                    Value="{atom:NavMenuTokenResource ItemSelectedColor}" />
        </Style>
        
        <Style Selector="^[HasSubMenu=True]">
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{atom:NavMenuTokenResource ItemHoverBg}" />
            </Style>
        </Style>

        <Style Selector="^[IsDarkStyle=True]">
            <Setter Property="Foreground"
                    Value="{atom:NavMenuTokenResource DarkItemColor}" />
            <Setter Property="Background" Value="{atom:NavMenuTokenResource DarkItemBg}" />
            <Style Selector="^[HasSubMenu=False]">
                <Style Selector="^:pointerover">
                    <Setter Property="Foreground"
                            Value="{atom:NavMenuTokenResource DarkItemHoverColor}" />
                    <Setter Property="Background"
                            Value="{atom:NavMenuTokenResource DarkItemHoverBg}" />
                </Style>
            </Style>
            <Style Selector="^[HasSubMenu=True]">
                <Style Selector="^:pointerover">
                    <Setter Property="Foreground"
                            Value="{atom:NavMenuTokenResource DarkItemHoverColor}" />
                </Style>
            </Style>
            
            <Style Selector="^[IsSelected=True]">
                <Setter Property="Foreground"
                        Value="{atom:NavMenuTokenResource DarkItemSelectedColor}" />
                <Setter Property="Background"
                        Value="{atom:NavMenuTokenResource DarkItemSelectedBg}" />
            </Style>
            
            <Style Selector="^[IsInSelectedPath=True]">
                <Setter Property="Foreground"
                        Value="{atom:NavMenuTokenResource DarkItemSelectedColor}" />
            </Style>
        </Style>

        <Style Selector="^ /template/ atom|Icon#MenuIndicatorIcon">
            <Setter Property="IsVisible" Value="True" />
            <Setter Property="Width" Value="{atom:NavMenuTokenResource MenuArrowSize}" />
            <Setter Property="Height" Value="{atom:NavMenuTokenResource MenuArrowSize}" />
            <Setter Property="FillBrush" Value="{atom:NavMenuTokenResource ItemColor}" />
            <Setter Property="StrokeBrush" Value="{atom:NavMenuTokenResource ItemColor}" />
        </Style>

        <Style Selector="^[IsSelected=True], ^[IsInSelectedPath=True]">
            <Style Selector="^ /template/ atom|Icon#MenuIndicatorIcon">
                <Setter Property="FillBrush"
                        Value="{atom:NavMenuTokenResource ItemSelectedColor}" />
                <Setter Property="StrokeBrush"
                        Value="{atom:NavMenuTokenResource ItemSelectedColor}" />
            </Style>
        </Style>

        <Style Selector="^:disabled">
            <Style Selector="^ /template/ atom|Icon#MenuIndicatorIcon">
                <Setter Property="FillBrush"
                        Value="{atom:NavMenuTokenResource ItemDisabledColor}" />
                <Setter Property="StrokeBrush"
                        Value="{atom:NavMenuTokenResource ItemDisabledColor}" />
            </Style>
        </Style>

        <Style Selector="^[IsDarkStyle=True]">
            <Style Selector="^ /template/ atom|Icon#MenuIndicatorIcon">
                <Setter Property="FillBrush" Value="{atom:NavMenuTokenResource DarkItemColor}" />
                <Setter Property="StrokeBrush" Value="{atom:NavMenuTokenResource DarkItemColor}" />
            </Style>

            <Style Selector="^[IsSelected=True], ^[IsInSelectedPath=True]">
                <Style Selector="^ /template/ atom|Icon#MenuIndicatorIcon">
                    <Setter Property="FillBrush"
                            Value="{atom:NavMenuTokenResource DarkItemSelectedColor}" />
                    <Setter Property="StrokeBrush"
                            Value="{atom:NavMenuTokenResource DarkItemSelectedColor}" />
                </Style>
            </Style>

            <Style Selector="^:disabled">
                <Style Selector="^ /template/ atom|Icon#MenuIndicatorIcon">
                    <Setter Property="FillBrush"
                            Value="{atom:NavMenuTokenResource DarkItemDisabledColor}" />
                    <Setter Property="StrokeBrush"
                            Value="{atom:NavMenuTokenResource DarkItemDisabledColor}" />
                </Style>
            </Style>
        </Style>

        <Style Selector="^[HasSubMenu=False]">
            <Style Selector="^ /template/ atom|Icon#MenuIndicatorIcon">
                <Setter Property="IsVisible" Value="False" />
            </Style>
        </Style>

        <Style Selector="^ /template/ atom|IconPresenter#ItemIconPresenter">
            <Setter Property="IsVisible" Value="False" />
            <Setter Property="Margin"
                    Value="{atom:NavMenuTokenResource ItemMargin}" />
            <Setter Property="Width"
                    Value="{atom:NavMenuTokenResource ItemIconSize}" />
            <Setter Property="Height"
                    Value="{atom:NavMenuTokenResource ItemIconSize}" />
            <Setter Property="IconBrush"
                    Value="{atom:NavMenuTokenResource ItemColor}" />
        </Style>

        <Style Selector="^:pointerover">
            <Style Selector="^ /template/ atom|IconPresenter#ItemIconPresenter">
                <Setter Property="IconBrush"
                        Value="{atom:NavMenuTokenResource ItemHoverColor}" />
            </Style>
        </Style>

        <Style Selector="^[IsSelected=True], ^[IsInSelectedPath=True]">
            <Style Selector="^ /template/ atom|IconPresenter#ItemIconPresenter">
                <Setter Property="IconBrush"
                        Value="{atom:NavMenuTokenResource ItemSelectedColor}" />
            </Style>
        </Style>

        <Style Selector="^[IsDarkStyle=True]">
            <Style Selector="^ /template/ atom|IconPresenter#ItemIconPresenter">
                <Setter Property="IconBrush"
                        Value="{atom:NavMenuTokenResource DarkItemColor}" />
            </Style>
            <Style Selector="^:pointerover">
                <Style Selector="^ /template/ atom|IconPresenter#ItemIconPresenter">
                    <Setter Property="IconBrush"
                            Value="{atom:NavMenuTokenResource DarkItemHoverColor}" />
                </Style>
            </Style>

            <Style Selector="^[IsSelected=True], ^[IsInSelectedPath=True]">
                <Style Selector="^ /template/ atom|IconPresenter#ItemIconPresenter">
                    <Setter Property="IconBrush"
                            Value="{atom:NavMenuTokenResource DarkItemSelectedColor}" />
                </Style>
            </Style>
            
        </Style>

        <Style Selector="^:icon">
            <Style Selector="^ /template/ atom|IconPresenter#ItemIconPresenter">
                <Setter Property="IsVisible" Value="True" />
            </Style>
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Foreground"
                    Value="{atom:NavMenuTokenResource ItemDisabledColor}" />
        </Style>
        
        <Style Selector="^ /template/ atom|IconPresenter#ItemIconPresenter:disabled">
            <Setter Property="IconBrush"
                    Value="{atom:NavMenuTokenResource ItemDisabledColor}" />
        </Style>

        <Style Selector="^[IsDarkStyle=True]">
            <Style Selector="^:disabled">
                <Setter Property="Foreground"
                        Value="{atom:NavMenuTokenResource DarkItemDisabledColor}" />
            </Style>
            <Style Selector="^ /template/ atom|IconPresenter#ItemIconPresenter:disabled">
                <Setter Property="IconBrush"
                        Value="{atom:NavMenuTokenResource DarkItemDisabledColor}" />
            </Style>
        </Style>
    </Style>
</ControlTheme>