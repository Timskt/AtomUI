<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:NotificationProgressBar}" TargetType="atom:NotificationProgressBar">
        <Setter Property="ProgressIndicatorThickness" Value="{atom:NotificationTokenResource NotificationProgressHeight}"/>
        <Setter Property="ProgressIndicatorBrush" Value="{atom:NotificationTokenResource NotificationProgressBg}"/>
    </ControlTheme>
</ResourceDictionary>