<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <atom:StringToTextBlockConverter x:Key="StringToTextBlockConverter" VerticalAlignment="Center"/>
    <ControlTheme x:Key="{x:Type atom:Pagination}" TargetType="atom:Pagination">
        <Setter Property="Template">
            <ControlTemplate>
                <StackPanel Name="PART_RootLayout"
                            Orientation="Horizontal"
                            IsVisible="{TemplateBinding IsEffectiveVisible}">
                    <ContentPresenter Name="PART_TotalInfoPresenter"
                                      IsVisible="{TemplateBinding IsShowTotalInfo}"
                                      Content="{TemplateBinding TotalInfoText, Mode=Default, Converter={StaticResource StringToTextBlockConverter}}" />
                    <atom:PaginationNav
                        Name="PART_Nav"
                        IsMotionEnabled="{TemplateBinding IsMotionEnabled}"
                        SizeType="{TemplateBinding SizeType}" />
                    <ContentPresenter Name="PART_SizeChangerPresenter"
                                      IsVisible="{TemplateBinding IsShowSizeChanger}"
                                      Content="{TemplateBinding SizeChanger}" />
                    <ContentPresenter Name="PART_QuickJumperBarPresenter"
                                      IsVisible="{TemplateBinding IsShowQuickJumper}"
                                      Content="{TemplateBinding QuickJumperBar}" />
                </StackPanel>
            </ControlTemplate>
        </Setter>
        
        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}"/>
        <Setter Property="PageText" Value="{atom:PaginationLangResource PageText}"/>
        <Setter Property="TotalInfoTemplate" Value="{atom:PaginationLangResource TotalInfoFormat}"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Style Selector="^[Align=Start]">
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style Selector="^[Align=Center]">
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style Selector="^[Align=End]">
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
        
        <Style Selector="^[SizeType=Large]">
            <Style Selector="^ /template/ StackPanel#PART_RootLayout">
                <Setter Property="Spacing" Value="{atom:PaginationTokenResource PaginationLayoutSpacing}"/>
            </Style>
        </Style>
        <Style Selector="^[SizeType=Middle]">
            <Style Selector="^ /template/ StackPanel#PART_RootLayout">
                <Setter Property="Spacing" Value="{atom:PaginationTokenResource PaginationLayoutSpacing}"/>
            </Style>
        </Style>
        <Style Selector="^[SizeType=Small]">
            <Style Selector="^ /template/ StackPanel#PART_RootLayout">
                <Setter Property="Spacing" Value="{atom:PaginationTokenResource PaginationLayoutMiniSpacing}"/>
            </Style>
        </Style>
        <Style Selector="^:disabled">
            <Setter Property="Foreground"
                    Value="{atom:PaginationTokenResource ItemActiveColorDisabled}" />
        </Style>
    </ControlTheme>
</ResourceDictionary>