<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <atom:StringToTextBlockConverter x:Key="StringToTextBlockConverter" VerticalAlignment="Center"/>
    <ControlTheme x:Key="{x:Type atom:QuickJumperBar}" TargetType="atom:QuickJumperBar">
        <Setter Property="Template">
            <ControlTemplate>
                <StackPanel Name="PART_RootLayout"
                            Orientation="Horizontal">
                    <ContentPresenter Name="PART_JumpToContentPresenter"
                                      Content="{TemplateBinding JumpToText, Mode=Default, Converter={StaticResource StringToTextBlockConverter}}"/>
                    <atom:LineEdit Name="PART_PageLineEdit"
                                   SizeType="{TemplateBinding SizeType}"/>
                    <ContentPresenter Name="PART_PageContentPresenter"
                                      Content="{TemplateBinding PageText, Mode=Default, Converter={StaticResource StringToTextBlockConverter}}"/>
                </StackPanel>
            </ControlTemplate>
        </Setter>
        
        <Setter Property="JumpToText" Value="{atom:PaginationLangResource JumpToText}"/>
        <Setter Property="PageText" Value="{atom:PaginationLangResource PageText}"/>
        
        <Style Selector="^ /template/ StackPanel#PART_RootLayout">
            <Setter Property="Spacing" Value="{atom:PaginationTokenResource PaginationLayoutSpacing}"/>
        </Style>
        
        <Style Selector="^ /template/ atom|LineEdit#PART_PageLineEdit">
            <Setter Property="Width" Value="{atom:PaginationTokenResource PaginationQuickJumperInputWidth}"/>
        </Style>
    </ControlTheme>
</ResourceDictionary>