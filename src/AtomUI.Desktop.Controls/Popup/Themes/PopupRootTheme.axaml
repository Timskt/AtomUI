<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type PopupRoot}" TargetType="PopupRoot">
        <Setter Property="Template">
            <ControlTemplate>
                <atom:PopupMotionActor Name="{x:Static atom:BaseMotionActor.MotionActorPart}"
                                       ClipToBounds="False">
                    <Panel ClipToBounds="False">
                        <Border Name="PART_TransparencyFallback" IsHitTestVisible="False" />
                        <VisualLayerManager ClipToBounds="False">
                            <atom:ShadowsAwareContainer>
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}" />
                            </atom:ShadowsAwareContainer>
                        </VisualLayerManager>
                    </Panel>
                </atom:PopupMotionActor>
            </ControlTemplate>
        </Setter>

        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorText}" />
        <Setter Property="TransparencyLevelHint" Value="Transparent" />
        <Setter Property="FontSize" Value="{atom:SharedTokenResource FontSize}" />
        <Setter Property="FontFamily" Value="{atom:SharedTokenResource FontFamily}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="FontStyle" Value="Normal" />

    </ControlTheme>
</ResourceDictionary>