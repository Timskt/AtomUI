<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:atom="https://atomui.net">
    <Style Selector="Border.addon-decorated-box">
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="TemplatedControl.Foreground" Value="{atom:SharedTokenResource ColorTextDisabled}" />

        <Style Selector="^ ContentPresenter#PART_LeftAddOn">
            <Setter Property="Background" Value="{atom:AddOnDecoratedBoxTokenResource AddonBg}" />
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorBorder}" />
        </Style>

        <Style Selector="^ ContentPresenter#PART_RightAddOn">
            <Setter Property="Background" Value="{atom:AddOnDecoratedBoxTokenResource AddonBg}" />
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorBorder}" />
        </Style>

        <Style Selector="^ DockPanel#ContentLayout">
            <Setter Property="HorizontalSpacing" Value="{atom:SharedTokenResource SpacingXXS}" />
        </Style>
    </Style>

    <!-- ==================== 尺寸 ==================== -->
    <Style Selector="Border.addon-decorated-box:large">
        <Setter Property="CornerRadius" Value="{atom:SharedTokenResource BorderRadiusLG}" />
        <Style Selector="^ ContentPresenter#PART_LeftAddOn">
            <Setter Property="Padding" Value="{atom:AddOnDecoratedBoxTokenResource PaddingLG}" />
        </Style>
        <Style Selector="^ ContentPresenter#PART_RightAddOn">
            <Setter Property="Padding" Value="{atom:AddOnDecoratedBoxTokenResource PaddingLG}" />
        </Style>
        <Style Selector="^ Border#PART_ContentFrame">
            <Setter Property="Padding" Value="{atom:AddOnDecoratedBoxTokenResource PaddingLG}" />
        </Style>
        <Style Selector="^ ContentPresenter#PART_ContentPresenter">
            <Setter Property="LineHeight" Value="{atom:SharedTokenResource FontHeightLG}" />
            <Setter Property="MinHeight" Value="{atom:SharedTokenResource FontHeightLG}" />
        </Style>
    </Style>

    <Style Selector="Border.addon-decorated-box:middle">
        <Setter Property="CornerRadius" Value="{atom:SharedTokenResource BorderRadius}" />
        <Style Selector="^ ContentPresenter#PART_LeftAddOn">
            <Setter Property="Padding" Value="{atom:AddOnDecoratedBoxTokenResource Padding}" />
        </Style>
        <Style Selector="^ ContentPresenter#PART_RightAddOn">
            <Setter Property="Padding" Value="{atom:AddOnDecoratedBoxTokenResource Padding}" />
        </Style>
        <Style Selector="^ Border#PART_ContentFrame">
            <Setter Property="Padding" Value="{atom:AddOnDecoratedBoxTokenResource Padding}" />
        </Style>
        <Style Selector="^ ContentPresenter#PART_ContentPresenter">
            <Setter Property="LineHeight" Value="{atom:SharedTokenResource FontHeight}" />
            <Setter Property="MinHeight" Value="{atom:SharedTokenResource FontHeight}" />
        </Style>
    </Style>

    <Style Selector="Border.addon-decorated-box:small">
        <Setter Property="CornerRadius" Value="{atom:SharedTokenResource BorderRadiusSM}" />
        <Style Selector="^ ContentPresenter#PART_LeftAddOn">
            <Setter Property="Padding" Value="{atom:AddOnDecoratedBoxTokenResource PaddingSM}" />
        </Style>
        <Style Selector="^ ContentPresenter#PART_RightAddOn">
            <Setter Property="Padding" Value="{atom:AddOnDecoratedBoxTokenResource PaddingSM}" />
        </Style>
        <Style Selector="^ Border#PART_ContentFrame">
            <Setter Property="Padding" Value="{atom:AddOnDecoratedBoxTokenResource PaddingSM}" />
        </Style>
        <Style Selector="^ ContentPresenter#PART_ContentPresenter">
            <Setter Property="LineHeight" Value="{atom:SharedTokenResource FontHeightSM}" />
            <Setter Property="MinHeight" Value="{atom:SharedTokenResource FontHeightSM}" />
            <Setter Property="Margin" Value="{atom:AddOnDecoratedBoxTokenResource ContentMargin}" />
        </Style>
    </Style>

    <!-- ==================== 状态色 ==================== -->
    <!-- status 不同的时候左右附加区域的主体色设置 -->
    <Style Selector="Border.addon-decorated-box:error">
        <Style Selector="^ ContentPresenter#PART_LeftAddOn">
            <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorErrorText}" />
        </Style>
        <Style Selector="^ ContentPresenter#PART_RightAddOn">
            <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorErrorText}" />
        </Style>
    </Style>

    <Style Selector="Border.addon-decorated-box:warning">
        <Style Selector="^ ContentPresenter#PART_LeftAddOn">
            <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorWarningText}" />
        </Style>
        <Style Selector="^ ContentPresenter#PART_RightAddOn">
            <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorWarningText}" />
        </Style>
    </Style>

    <!-- ==================== 变体：outlined ==================== -->
    <Style Selector="Border.addon-decorated-box:outlined">
        <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorBorder}" />

        <Style Selector="^:inner-box-hover">
            <Setter Property="BorderBrush" Value="{atom:AddOnDecoratedBoxTokenResource HoverBorderColor}" />
        </Style>
        <Style Selector="^:focus-within">
            <Setter Property="BorderBrush" Value="{atom:AddOnDecoratedBoxTokenResource ActiveBorderColor}" />
        </Style>
        <Style Selector="^:pressed">
            <Setter Property="BorderBrush" Value="{atom:AddOnDecoratedBoxTokenResource ActiveBorderColor}" />
        </Style>

        <Style Selector="^:error">
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorError}" />
            <Style Selector="^ ContentPresenter#PART_LeftAddOn">
                <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorError}" />
            </Style>
            <Style Selector="^ ContentPresenter#PART_RightAddOn">
                <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorError}" />
            </Style>
            <Style Selector="^:inner-box-hover">
                <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorErrorBorderHover}" />
            </Style>
            <Style Selector="^:focus-within">
                <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorError}" />
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorError}" />
            </Style>
        </Style>

        <Style Selector="^:warning">
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorWarning}" />
            <Style Selector="^ ContentPresenter#PART_LeftAddOn">
                <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorWarning}" />
            </Style>
            <Style Selector="^ ContentPresenter#PART_RightAddOn">
                <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorWarning}" />
            </Style>
            <Style Selector="^:inner-box-hover">
                <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorWarningBorderHover}" />
            </Style>
            <Style Selector="^:focus-within">
                <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorWarning}" />
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorWarning}" />
            </Style>
        </Style>
    </Style>

    <!-- ==================== 变体：filled ==================== -->
    <Style Selector="Border.addon-decorated-box:filled">
        <Setter Property="Background" Value="{atom:SharedTokenResource ColorFillTertiary}" />
        <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorFillTertiary}" />

        <Style Selector="^:inner-box-hover">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorFillSecondary}" />
        </Style>
        <Style Selector="^:focus-within">
            <Setter Property="BorderBrush" Value="{atom:AddOnDecoratedBoxTokenResource ActiveBorderColor}" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="^:pressed">
            <Setter Property="BorderBrush" Value="{atom:AddOnDecoratedBoxTokenResource ActiveBorderColor}" />
        </Style>

        <Style Selector="^ ContentPresenter#PART_LeftAddOn">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorFillTertiary}" />
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorFillTertiary}" />
        </Style>
        <Style Selector="^ ContentPresenter#PART_RightAddOn">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorFillTertiary}" />
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorFillTertiary}" />
        </Style>

        <Style Selector="^:error">
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorErrorBg}" />
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorErrorBg}" />
            <Style Selector="^:inner-box-hover">
                <Setter Property="Background" Value="{atom:SharedTokenResource ColorErrorBgHover}" />
            </Style>
            <Style Selector="^:focus-within">
                <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorError}" />
                <Setter Property="Background" Value="{atom:AddOnDecoratedBoxTokenResource ActiveBg}" />
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorError}" />
            </Style>
            <Style Selector="^ ContentPresenter#PART_LeftAddOn">
                <Setter Property="Background" Value="{atom:SharedTokenResource ColorErrorBg}" />
            </Style>
            <Style Selector="^ ContentPresenter#PART_RightAddOn">
                <Setter Property="Background" Value="{atom:SharedTokenResource ColorErrorBg}" />
            </Style>
        </Style>

        <Style Selector="^:warning">
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorWarningBg}" />
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorWarningBg}" />
            <Style Selector="^:inner-box-hover">
                <Setter Property="Background" Value="{atom:SharedTokenResource ColorWarningBgHover}" />
            </Style>
            <Style Selector="^:focus-within">
                <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorWarning}" />
                <Setter Property="Background" Value="{atom:AddOnDecoratedBoxTokenResource ActiveBg}" />
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorWarning}" />
            </Style>
            <Style Selector="^ ContentPresenter#PART_LeftAddOn">
                <Setter Property="Background" Value="{atom:SharedTokenResource ColorWarningBg}" />
            </Style>
            <Style Selector="^ ContentPresenter#PART_RightAddOn">
                <Setter Property="Background" Value="{atom:SharedTokenResource ColorWarningBg}" />
            </Style>
        </Style>
    </Style>

    <!-- ==================== 变体：borderless ==================== -->
    <Style Selector="Border.addon-decorated-box:borderless">
        <Style Selector="^ ContentPresenter#PART_LeftAddOn">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="^ ContentPresenter#PART_RightAddOn">
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </Style>

    <!-- ==================== 变体：underlined ==================== -->
    <Style Selector="Border.addon-decorated-box:underlined">
        <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorBorder}" />

        <Style Selector="^:inner-box-hover">
            <Setter Property="BorderBrush" Value="{atom:AddOnDecoratedBoxTokenResource HoverBorderColor}" />
        </Style>
        <Style Selector="^:focus-within">
            <Setter Property="BorderBrush" Value="{atom:AddOnDecoratedBoxTokenResource ActiveBorderColor}" />
        </Style>
        <Style Selector="^:pressed">
            <Setter Property="BorderBrush" Value="{atom:AddOnDecoratedBoxTokenResource ActiveBorderColor}" />
        </Style>

        <Style Selector="^:error">
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorError}" />
            <Style Selector="^:inner-box-hover">
                <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorErrorBorderHover}" />
            </Style>
            <Style Selector="^:focus-within">
                <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorError}" />
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorError}" />
            </Style>
        </Style>

        <Style Selector="^:warning">
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorWarning}" />
            <Style Selector="^:inner-box-hover">
                <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorWarningBorderHover}" />
            </Style>
            <Style Selector="^:focus-within">
                <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorWarning}" />
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorWarning}" />
            </Style>
        </Style>

        <Style Selector="^ ContentPresenter#PART_LeftAddOn">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="^ ContentPresenter#PART_RightAddOn">
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </Style>

    <!-- ==================== 禁用状态 ==================== -->
    <Style Selector="Border.addon-decorated-box:disabled">
        <Style Selector="^ ContentPresenter#PART_LeftAddOn">
            <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorTextDisabled}" />
        </Style>
        <Style Selector="^ ContentPresenter#PART_RightAddOn">
            <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorTextDisabled}" />
        </Style>

        <Style Selector="^:outlined">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgContainerDisabled}" />
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorBorder}" />
            <Style Selector="^ ContentPresenter#PART_LeftAddOn">
                <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgContainerDisabled}" />
                <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorBorder}" />
            </Style>
            <Style Selector="^ ContentPresenter#PART_RightAddOn">
                <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgContainerDisabled}" />
                <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorBorder}" />
            </Style>
        </Style>

        <Style Selector="^:filled">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgContainerDisabled}" />
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorBorder}" />
            <Style Selector="^ ContentPresenter#PART_LeftAddOn">
                <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgContainerDisabled}" />
                <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorBorder}" />
            </Style>
            <Style Selector="^ ContentPresenter#PART_RightAddOn">
                <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgContainerDisabled}" />
                <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorBorder}" />
            </Style>
        </Style>

        <Style Selector="^:underlined">
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorBorder}" />
        </Style>
    </Style>
</Styles>