<ControlTheme xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              x:Class="AtomUI.Desktop.Controls.Primitives.Themes.ArrowDecoratedBoxTheme"
              xmlns:atom="https://atomui.net"
              TargetType="atom:ArrowDecoratedBox">
    <Setter Property="Template">
        <ControlTemplate TargetType="atom:ArrowDecoratedBox">
            <DockPanel Name="ContentLayout" LastChildFill="True">
                <Panel Name="ArrowPositionLayout">
                    <LayoutTransformControl
                        Name="PART_ArrowIndicatorLayout"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        IsVisible="{TemplateBinding IsShowArrow}"
                        Opacity="{TemplateBinding ArrowOpacity}">
                        <atom:ArrowIndicator
                            Name="PART_ArrowIndicator"
                            FilledColor="{TemplateBinding Background}"
                            ArrowSize="{TemplateBinding ArrowSize}"
                            StrokeBrush="{atom:ArrowDecoratedBoxTokenResource ArrowStrokeColor}"
                            StrokeThickness="{atom:ArrowDecoratedBoxTokenResource ArrowStrokeThickness}"/>
                    </LayoutTransformControl>
                </Panel>
                <Border
                    Name="PART_ContentDecorator"
                    Margin="0"
                    BackgroundSizing="{TemplateBinding BackgroundSizing}"
                    Background="{TemplateBinding Background}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Padding="{TemplateBinding Padding}">
                    <ContentPresenter
                        Name="ContentPresenter"
                        Content="{TemplateBinding Content}"
                        ContentTemplate="{TemplateBinding ContentTemplate}" />
                </Border>
            </DockPanel>
        </ControlTemplate>
    </Setter>

    <Style Selector="^:is(atom|ArrowDecoratedBox)">
        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}" />
        <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorText}" />
        <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgElevated}" />
        <Setter Property="MinHeight" Value="{atom:SharedTokenResource ControlHeight}" />
        <Setter Property="Padding" Value="{atom:ArrowDecoratedBoxTokenResource Padding}" />
        <Setter Property="ArrowSize" Value="{atom:ArrowDecoratedBoxTokenResource ArrowSize}" />
        <Setter Property="CornerRadius" Value="{atom:SharedTokenResource BorderRadius}" />

        <Style Selector="^[ArrowDirection=Top]">
            <Style Selector="^ /template/ Panel#ArrowPositionLayout">
                <Setter Property="DockPanel.Dock" Value="Top" />
            </Style>
        </Style>
        <Style Selector="^[ArrowDirection=Right]">
            <Style Selector="^ /template/ LayoutTransformControl#PART_ArrowIndicatorLayout">
                <Setter Property="LayoutTransform" Value="rotate(90deg)" />
            </Style>
            <Style Selector="^ /template/ Panel#ArrowPositionLayout">
                <Setter Property="DockPanel.Dock" Value="Right" />
            </Style>
        </Style>
        <Style Selector="^[ArrowDirection=Bottom]">
            <Style Selector="^ /template/ LayoutTransformControl#PART_ArrowIndicatorLayout">
                <Setter Property="LayoutTransform" Value="rotate(180deg)" />
            </Style>
            <Style Selector="^ /template/ Panel#ArrowPositionLayout">
                <Setter Property="DockPanel.Dock" Value="Bottom" />
            </Style>
        </Style>
        <Style Selector="^[ArrowDirection=Left]">
            <Style Selector="^ /template/ LayoutTransformControl#PART_ArrowIndicatorLayout">
                <Setter Property="LayoutTransform" Value="rotate(-90deg)" />
            </Style>
            <Style Selector="^ /template/ Panel#ArrowPositionLayout">
                <Setter Property="DockPanel.Dock" Value="Left" />
            </Style>
        </Style>
    </Style>

</ControlTheme>