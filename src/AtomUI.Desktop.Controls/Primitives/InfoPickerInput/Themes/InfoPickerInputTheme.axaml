<ControlTheme xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:atom="https://atomui.net"
              x:Class="AtomUI.Desktop.Controls.Primitives.Themes.InfoPickerInputTheme"
              TargetType="atom:InfoPickerInput">
    <Setter Property="Template">
        <ControlTemplate TargetType="atom:InfoPickerInput">
            <Panel>
                <atom:AddOnDecoratedBox
                    Name="{x:Static atom:AddOnDecoratedBox.AddOnDecoratedBoxPart}"
                    Focusable="True"
                    MinWidth="{TemplateBinding MinWidth}"
                    StyleVariant="{TemplateBinding StyleVariant}"
                    SizeType="{TemplateBinding SizeType}"
                    Status="{TemplateBinding Status}"
                    IsEnabled="{TemplateBinding IsEnabled}"
                    LeftAddOn="{TemplateBinding LeftAddOn}"
                    LeftAddOnTemplate="{TemplateBinding LeftAddOn}"
                    RightAddOn="{TemplateBinding RightAddOn}"
                    RightAddOnTemplate="{TemplateBinding RightAddOnTemplate}"
                    ContentLeftAddOn="{TemplateBinding ContentLeftAddOn}"
                    HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                    VerticalAlignment="{TemplateBinding VerticalAlignment}"
                    ContentLeftAddOnTemplate="{TemplateBinding ContentLeftAddOnTemplate}"
                    CompactSpaceItemPosition="{TemplateBinding CompactSpaceItemPosition}"
                    CompactSpaceOrientation="{TemplateBinding CompactSpaceOrientation}"
                    IsUsedInCompactSpace="{TemplateBinding IsUsedInCompactSpace}">
                    <atom:AddOnDecoratedBox.ContentRightAddOn>
                        <StackPanel Orientation="Horizontal" Spacing="{atom:SharedTokenResource SpacingXS}">
                            <atom:PickerClearUpButton
                                Name="{x:Static atom:InfoPickerInputThemeConstants.ClearUpButtonPart}" />
                            <ContentPresenter Name="PART_ContentRightAddOnPresenter" />
                        </StackPanel>
                    </atom:AddOnDecoratedBox.ContentRightAddOn>
                    <atom:TextBox Name="{x:Static atom:InfoPickerInputThemeConstants.InfoInputBoxPart}"
                                  HorizontalContentAlignment="Stretch"
                                  VerticalContentAlignment="Center"
                                  VerticalAlignment="Stretch"
                                  HorizontalAlignment="Stretch"
                                  BorderThickness="0"
                                  TextWrapping="NoWrap"
                                  AcceptsReturn="False"
                                  Width="{TemplateBinding PreferredInputWidth}"
                                  IsAllowClear="False"
                                  IsEnableRevealButton="False"
                                  Text="{TemplateBinding Text}"
                                  PlaceholderText="{TemplateBinding PlaceholderText}"
                                  DataValidationErrors.Errors="{TemplateBinding DataValidationErrors.Errors}"
                                  SizeType="{TemplateBinding SizeType}"
                                  IsReadOnly="{TemplateBinding IsReadOnly}" />
                </atom:AddOnDecoratedBox>
            </Panel>
        </ControlTemplate>
    </Setter>

    <Style Selector="^:is(atom|InfoPickerInput)">
        <Setter Property="KeyboardNavigation.TabNavigation" Value="Once" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}" />
        <Setter Property="MarginToAnchor" Value="{atom:PopupHostTokenResource MarginToAnchor}" />
        <Setter Property="ShouldUseOverlayPopup" Value="True" />
        
        <Style Selector="^ /template/ atom|TextBox#PART_InfoInputBox">
            <Setter Property="Foreground"
                    Value="{atom:SharedTokenResource ColorText}" />
        </Style>

        <Style Selector="^:flyout-open">
            <Style Selector="^ /template/ atom|TextBox#PART_InfoInputBox">
                <Setter Property="Foreground"
                        Value="{atom:SharedTokenResource ColorTextTertiary}" />
            </Style>
        </Style>

        <Style Selector="^:disabled">
            <Style Selector="^ /template/ atom|TextBox">
                <Setter Property="Foreground"
                        Value="{atom:SharedTokenResource ColorTextDisabled}" />
            </Style>
        </Style>

        <Style Selector="^[SizeType=Large]">
            <Setter Property="FontSize" Value="{atom:SharedTokenResource FontSizeLG}" />
        </Style>
        <Style Selector="^[SizeType=Middle]">
            <Setter Property="FontSize" Value="{atom:SharedTokenResource FontSize}" />
        </Style>
        <Style Selector="^[SizeType=Small]">
            <Setter Property="FontSize" Value="{atom:SharedTokenResource FontSizeSM}" />
        </Style>

    </Style>

</ControlTheme>