<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:RadioButtonGroup}" TargetType="atom:RadioButtonGroup">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="Frame"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <ItemsPresenter Name="PART_ItemsPresenter"
                                    ItemsPanel="{TemplateBinding ItemsPanel}" />
                </Border>
            </ControlTemplate>
        </Setter>

        <Setter Property="ClipToBounds" Value="False" />
        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}" />

        <Setter Property="ItemsPanel">
            <ItemsPanelTemplate>
                <WrapPanel
                    Orientation="{Binding (atom:RadioButtonGroup).Orientation, RelativeSource={RelativeSource TemplatedParent}}"
                    ItemSpacing="{Binding (atom:RadioButtonGroup).ItemSpacing, RelativeSource={RelativeSource TemplatedParent}}"
                    LineSpacing="{Binding (atom:RadioButtonGroup).LineSpacing, RelativeSource={RelativeSource TemplatedParent}}" />
            </ItemsPanelTemplate>
        </Setter>

        <Setter Property="ItemSpacing" Value="{atom:SharedTokenResource SpacingXS}" />
        <Setter Property="LineSpacing" Value="{atom:SharedTokenResource SpacingXS}" />

        <Setter Property="ItemTemplate">
            <DataTemplate x:DataType="atom:IRadioButtonOption">
                <atom:TextBlock Text="{Binding Content}" />
            </DataTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>