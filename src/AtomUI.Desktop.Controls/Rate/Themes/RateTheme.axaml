<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    xmlns:atomc="https://atomui.net/common-controls"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:Rate}" TargetType="atom:Rate">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="Frame"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderBrush}">
                    <atomc:RateItemsControl Name="PART_RateItems"
                                            Character="{TemplateBinding Character}"
                                            StarColor="{TemplateBinding StarColor}"
                                            StarBgColor="{TemplateBinding StarBgColor}"
                                            IsAllowClear="{TemplateBinding IsAllowClear}"
                                            IsAllowHalf="{TemplateBinding IsAllowHalf}"
                                            IsMotionEnabled="{TemplateBinding IsMotionEnabled}"
                                            FontSize="{TemplateBinding FontSize}" />
                </Border>
            </ControlTemplate>
        </Setter>
        <Setter Property="Focusable" Value="True" />
        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}" />
        <Setter Property="StarColor" Value="{atom:RateTokenResource StarColor}" />
        <Setter Property="StarBgColor" Value="{atom:RateTokenResource StarBg}" />
        <Setter Property="ClipToBounds" Value="False" />
    </ControlTheme>
</ResourceDictionary>
