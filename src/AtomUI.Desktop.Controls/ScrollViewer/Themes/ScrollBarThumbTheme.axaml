<ControlTheme TargetType="atom:ScrollBarThumb"
              xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:atom="https://atomui.net"
              x:Class="AtomUI.Desktop.Controls.Themes.ScrollBarThumbTheme">
    <Setter Property="Template">
        <ControlTemplate TargetType="atom:ScrollBarThumb">
            <Border Name="Frame"
                    UseLayoutRounding="False"
                    Background="{TemplateBinding Background}"
                    Margin="{TemplateBinding Margin}"
                    CornerRadius="{TemplateBinding CornerRadius}" />
        </ControlTemplate>
    </Setter>

    <Style Selector="^[IsMotionEnabled=True]">
        <Setter Property="Transitions">
            <Transitions>
                <atom:SolidColorBrushTransition Property="Background" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}"/>
                <DoubleTransition Property="Width" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}"/>
                <DoubleTransition Property="Height" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}"/>
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="^:is(atom|ScrollBarThumb)">
        <Setter Property="Background" Value="{atom:ScrollViewerTokenResource ThumbBg}" />
        <Setter Property="CornerRadius"
                Value="{atom:ScrollViewerTokenResource ThumbCornerRadius}" />

        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{atom:ScrollViewerTokenResource ThumbHoverBg}" />
            <Style Selector="^[IsLiteMode=True]">
                <Setter Property="IsExpanded" Value="True" />
            </Style>
        </Style>

        <Style Selector="^:pressed">
            <Setter Property="Background" Value="{atom:ScrollViewerTokenResource ThumbActiveBg}" />
            <Style Selector="^[IsLiteMode=True]">
                <Setter Property="IsExpanded" Value="True" />
            </Style>
        </Style>

        <Style Selector="^[Orientation=Vertical]">
            <Style Selector="^[IsLiteMode=True]">
                <Setter Property="Width"
                        Value="{atom:ScrollViewerTokenResource LiteModeThumbThickness}" />
                <Style Selector="^[IsExpanded=True]">
                    <Setter Property="Width"
                            Value="{atom:ScrollViewerTokenResource NormalModeThumbThickness}" />
                </Style>
            </Style>
            <Style Selector="^[IsLiteMode=False]">
                <Setter Property="Width"
                        Value="{atom:ScrollViewerTokenResource NormalModeThumbThickness}" />
            </Style>
        </Style>
        <Style Selector="^[Orientation=Horizontal]">
            <Style Selector="^[IsLiteMode=True]">
                <Setter Property="Height"
                        Value="{atom:ScrollViewerTokenResource LiteModeThumbThickness}" />

                <Style Selector="^[IsExpanded=True]">
                    <Setter Property="Height"
                            Value="{atom:ScrollViewerTokenResource NormalModeThumbThickness}" />
                </Style>

            </Style>
            <Style Selector="^[IsLiteMode=False]">
                <Setter Property="Height"
                        Value="{atom:ScrollViewerTokenResource NormalModeThumbThickness}" />
            </Style>
        </Style>
    </Style>

</ControlTheme>