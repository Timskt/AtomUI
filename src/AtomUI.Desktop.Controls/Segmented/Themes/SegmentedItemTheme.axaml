<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <atom:StringToTextBlockConverter x:Key="StringToTextBlockConverter" VerticalAlignment="Center" />
    <ControlTheme x:Key="{x:Type atom:SegmentedItem}" TargetType="atom:SegmentedItem">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="Frame"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <DockPanel LastChildFill="True">
                        <atom:IconPresenter Name="IconPresenter"
                                             Icon="{TemplateBinding Icon}"
                                             IsVisible="{TemplateBinding Icon, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        <ContentPresenter Name="Content"
                                          HorizontalContentAlignment="Center"
                                          VerticalContentAlignment="Center"
                                          Content="{TemplateBinding Content, Converter={StaticResource StringToTextBlockConverter}}"
                                          IsVisible="{TemplateBinding Content, Converter={x:Static ObjectConverters.IsNotNull}}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}" />
                    </DockPanel>
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^[IsEnabled=True]">
            <Setter Property="Cursor" Value="Hand" />
            <Style Selector="^ /template/ atom|IconPresenter#IconPresenter">
                <Setter Property="IconBrush"
                        Value="{atom:SegmentedTokenResource ItemColor}" />
            </Style>

            <Style Selector="^:selected">
                <Setter Property="Foreground"
                        Value="{atom:SegmentedTokenResource ItemSelectedColor}" />
                <Setter Property="Background"
                        Value="{atom:SegmentedTokenResource ItemSelectedBg}" />

                <Style Selector="^ /template/ atom|IconPresenter#IconPresenter">
                    <Setter Property="IconBrush"
                            Value="{atom:SegmentedTokenResource ItemSelectedColor}" />
                </Style>
            </Style>

            <Style Selector="^:not(^:selected)">
                <Setter Property="Foreground" Value="{atom:SegmentedTokenResource ItemColor}" />
                <Setter Property="Background" Value="Transparent" />

                <Style Selector="^:pointerover">
                    <Setter Property="Foreground"
                            Value="{atom:SegmentedTokenResource ItemHoverColor}" />
                    <Setter Property="Background"
                            Value="{atom:SegmentedTokenResource ItemHoverBg}" />
                    <Style Selector="^ /template/ atom|IconPresenter#IconPresenter">
                        <Setter Property="IconBrush"
                                Value="{atom:SegmentedTokenResource ItemHoverColor}" />
                    </Style>
                </Style>

                <Style Selector="^:pressed">
                    <Setter Property="Background"
                            Value="{atom:SegmentedTokenResource ItemActiveBg}" />
                    <Style Selector="^ /template/ atom|IconPresenter#IconPresenter">
                        <Setter Property="IconBrush"
                                Value="{atom:SegmentedTokenResource ItemSelectedColor}" />
                    </Style>
                </Style>
            </Style>
        </Style>

        <Style Selector="^[SizeType=Large]">
            <Setter Property="CornerRadius"
                    Value="{atom:SharedTokenResource BorderRadius}" />
            <Setter Property="FontSize"
                    Value="{atom:SharedTokenResource FontSizeLG}" />
            <Setter Property="MinHeight"
                    Value="{atom:SegmentedTokenResource ItemMinHeightLG}" />
            <Setter Property="Padding"
                    Value="{atom:SegmentedTokenResource SegmentedItemPadding}" />
        </Style>

        <Style Selector="^[SizeType=Middle]">
            <Setter Property="CornerRadius"
                    Value="{atom:SharedTokenResource BorderRadiusSM}" />
            <Setter Property="FontSize"
                    Value="{atom:SharedTokenResource FontSize}" />
            <Setter Property="MinHeight"
                    Value="{atom:SegmentedTokenResource ItemMinHeight}" />
            <Setter Property="Padding"
                    Value="{atom:SegmentedTokenResource SegmentedItemPadding}" />
        </Style>

        <Style Selector="^[SizeType=Small]">
            <Setter Property="CornerRadius"
                    Value="{atom:SharedTokenResource BorderRadiusXS}" />
            <Setter Property="FontSize"
                    Value="{atom:SharedTokenResource FontSize}" />
            <Setter Property="MinHeight"
                    Value="{atom:SegmentedTokenResource ItemMinHeightSM}" />
            <Setter Property="Padding"
                    Value="{atom:SegmentedTokenResource SegmentedItemPaddingSM}" />
        </Style>
        
        <Style Selector="^:has-icon">
            <Style Selector="^ /template/ ContentPresenter#Content">
                <Setter Property="Margin"
                        Value="{atom:SegmentedTokenResource SegmentedItemContentMargin}" />
            </Style>
        </Style>
        
        <Style Selector="^[SizeType=Large]">
            <Style Selector="^ /template/ atom|IconPresenter#IconPresenter">
                <Setter Property="Width"
                        Value="{atom:SharedTokenResource IconSizeLG}" />
                <Setter Property="Height"
                        Value="{atom:SharedTokenResource IconSizeLG}" />
            </Style>
        </Style>

        <Style Selector="^[SizeType=Middle]">
            <Style Selector="^ /template/ atom|IconPresenter#IconPresenter">
                <Setter Property="Width"
                        Value="{atom:SharedTokenResource IconSize}" />
                <Setter Property="Height"
                        Value="{atom:SharedTokenResource IconSize}" />
            </Style>
        </Style>

        <Style Selector="^[SizeType=Small]">
            <Style Selector="^ /template/ atom|IconPresenter#IconPresenter">
                <Setter Property="Width"
                        Value="{atom:SharedTokenResource IconSizeSM}" />
                <Setter Property="Height"
                        Value="{atom:SharedTokenResource IconSizeSM}" />
            </Style>
        </Style>
        
        <Style Selector="^:disabled">
            <Setter Property="Foreground"
                    Value="{atom:SharedTokenResource ColorTextDisabled}" />
        </Style>

    </ControlTheme>
</ResourceDictionary>