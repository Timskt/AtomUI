<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    xmlns:atomc="https://atomui.net/common-controls"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:Segmented}" TargetType="atom:Segmented">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="Frame"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}"
                        ClipToBounds="True">
                    <ItemsPresenter Name="PART_ItemsPresenter">
                        <ItemsPresenter.ItemsPanel>
                            <ItemsPanelTemplate>
                                <atomc:SegmentedStackPanel IsExpanding="{Binding IsExpanding, RelativeSource={RelativeSource AncestorType=atom:Segmented}}"/>
                            </ItemsPanelTemplate>
                        </ItemsPresenter.ItemsPanel>
                    </ItemsPresenter>
                </Border>
            </ControlTemplate>
        </Setter>
        
        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}" />
        <Setter Property="Padding" Value="{atom:SegmentedTokenResource TrackPadding}" />
        <Setter Property="Background" Value="{atom:SegmentedTokenResource TrackBg}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="SelectedThumbBg" Value="{atom:SegmentedTokenResource ItemSelectedBg}" />
        <Setter Property="SelectedThumbBoxShadows" Value="{atom:SharedTokenResource BoxShadowsTertiary}" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Style Selector="^[IsExpanding=True]">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        
        <Style Selector="^[SizeType=Large]">
            <Setter Property="CornerRadius" Value="{atom:SharedTokenResource BorderRadiusLG}" />
            <Setter Property="SelectedThumbCornerRadius" Value="{atom:SharedTokenResource BorderRadius}" />
        </Style>
                
        <Style Selector="^[SizeType=Middle]">
            <Setter Property="CornerRadius" Value="{atom:SharedTokenResource BorderRadius}" />
            <Setter Property="SelectedThumbCornerRadius" Value="{atom:SharedTokenResource BorderRadiusSM}" />
        </Style>
                
        <Style Selector="^[SizeType=Small]">
            <Setter Property="CornerRadius" Value="{atom:SharedTokenResource BorderRadiusSM}" />
            <Setter Property="SelectedThumbCornerRadius" Value="{atom:SharedTokenResource BorderRadiusXS}" />
        </Style>
        
        <Setter Property="ItemTemplate">
            <DataTemplate>
                <atom:TextBlock Text="{Binding}" />
            </DataTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>
