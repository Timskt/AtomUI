<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:SelectCandidateListItem}" TargetType="atom:SelectCandidateListItem">
        <ControlTheme.BasedOn>
            <atom:ListViewItemTheme TargetType="atom:SelectCandidateListItem" />
        </ControlTheme.BasedOn>

        <Style Selector="^:is(atom|SelectCandidateListItem)">
            <Setter Property="FontSize" Value="{atom:SelectTokenResource OptionFontSize}"/>
            <Setter Property="MinHeight" Value="{atom:SelectTokenResource OptionHeight}"/>
            <Style Selector="^[IsSelected=False][IsCandidateSelected=True]">
                <Setter Property="Background" Value="{atom:ListViewTokenResource ItemHoverBgColor}" />
            </Style>

            <Style Selector="^[IsHideSelectedOptions=True][IsSelected=True]">
                <Setter Property="IsVisible" Value="False" />
            </Style>

            <Style Selector="^[IsGroupItem=False][IsSelected=True]">
                <Setter Property="FontWeight" Value="{atom:SelectTokenResource OptionSelectedFontWeight}"/>
                <Setter Property="Foreground" Value="{atom:SelectTokenResource OptionSelectedColor}"/>
                <Setter Property="Background" Value="{atom:SelectTokenResource OptionSelectedBg}"/>
            </Style>
        </Style>
    </ControlTheme>
</ResourceDictionary>