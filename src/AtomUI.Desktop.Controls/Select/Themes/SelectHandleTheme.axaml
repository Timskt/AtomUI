<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    xmlns:antdicons="https://atomui.net/icons/antdesign"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:SelectHandle}" TargetType="atom:SelectHandle">
        <Setter Property="FilterIndicatorTemplate">
            <atom:IconTemplate>
                <antdicons:SearchOutlined />
            </atom:IconTemplate>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate>
                <Panel>
                    <StackPanel Name="IconLayout" Orientation="Horizontal">
                        <Panel>
                            <atom:IconPresenter Name="OpenIndicator"
                                                Icon="{TemplateBinding CurrentIndicatorIcon}"
                                                IsVisible="{TemplateBinding IsCurrentIndicatorVisible}" />
                            <atom:InputClearIconButton
                                Name="PART_ClearButton"
                                IsMotionEnabled="{TemplateBinding IsMotionEnabled}"
                                IsVisible="False" />
                        </Panel>
                        <ContentPresenter
                            Name="FormFeedBack"
                            VerticalAlignment="Stretch"
                            VerticalContentAlignment="Center"
                            HorizontalAlignment="Right"
                            IsVisible="{TemplateBinding IsFormFeedbackVisible}"
                            Content="{TemplateBinding FormFeedback}" />
                    </StackPanel>
                </Panel>
            </ControlTemplate>
        </Setter>

        <Style Selector="^ /template/ atom|Icon">
            <Setter Property="StrokeBrush"
                    Value="{atom:SharedTokenResource ColorTextQuaternary}" />
            <Setter Property="Width" Value="{atom:SharedTokenResource IconSize}" />
            <Setter Property="Height" Value="{atom:SharedTokenResource IconSize}" />
        </Style>

        <Style Selector="^ /template/ atom|IconPresenter">
            <Setter Property="IconBrush"
                    Value="{atom:SharedTokenResource ColorTextQuaternary}" />
            <Setter Property="Width" Value="{atom:SharedTokenResource IconSize}" />
            <Setter Property="Height" Value="{atom:SharedTokenResource IconSize}" />
        </Style>

        <Style Selector="^[IsAllowClear=True][IsSelectionEmpty=False]">
            <Style Selector="^[IsInputHover=True], ^[IsInputPressed=True]">
                <Style Selector="^ /template/ atom|IconPresenter#OpenIndicator">
                    <Setter Property="IsVisible" Value="False" />
                </Style>
                <Style Selector="^ /template/ atom|InputClearIconButton#PART_ClearButton">
                    <Setter Property="IsVisible" Value="True" />
                </Style>
            </Style>
        </Style>

        <Style Selector="^ /template/ StackPanel#IconLayout">
            <Setter Property="Spacing" Value="{atom:SharedTokenResource SpacingXS}" />
        </Style>
    </ControlTheme>
</ResourceDictionary>
