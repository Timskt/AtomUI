<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:SelectResultOptionsBox}" TargetType="atom:SelectResultOptionsBox">
        <Setter Property="Template">
            <ControlTemplate>
                <Panel Name="RootLayout">
                    <atom:SelectWrapPanel Name="PART_DefaultPanel"
                                          IsVisible="{TemplateBinding IsResponsiveTagMode, Converter={x:Static BoolConverters.Not}}" />
                    <atom:SelectMaxTagAwarePanel
                        Name="PART_MaxCountAwarePanel"
                        Orientation="Horizontal"
                        MaxTagCount="{TemplateBinding MaxTagCount}"
                        IsVisible="{TemplateBinding IsResponsiveTagMode}"/>
                </Panel>
            </ControlTemplate>
        </Setter>

        <Style Selector="^ /template/ atom|SelectWrapPanel#PART_DefaultPanel">
            <Setter Property="ItemSpacing" Value="{atom:SharedTokenResource SpacingXXS}" />
            <Setter Property="LineSpacing" Value="{atom:SharedTokenResource SpacingXXS}" />
        </Style>

        <Style Selector="^ /template/ atom|SelectMaxTagAwarePanel#PART_MaxCountAwarePanel">
            <Setter Property="Spacing" Value="{atom:SharedTokenResource SpacingXXS}" />
        </Style>
    </ControlTheme>
</ResourceDictionary>
