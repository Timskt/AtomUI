<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    xmlns:themes="using:AtomUI.Desktop.Controls.Themes"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:SelectTag}" TargetType="atom:SelectTag">
        <ControlTheme.BasedOn>
            <themes:TagTheme TargetType="atom:SelectTag" />
        </ControlTheme.BasedOn>

        <Style Selector="^:is(atom|SelectTag)">
            <Setter Property="IsBordered" Value="False" />
            <Setter Property="Background" Value="{atom:SelectTokenResource MultipleItemBg}" />
            <Setter Property="IsClosable" Value="True" />
            <Setter Property="FontSize" Value="{atom:SelectTokenResource OptionFontSize}" />

            <Style Selector="^:disabled">
                <Setter Property="Background"
                        Value="{atom:SelectTokenResource MultipleSelectorBgDisabled}" />
                <Setter Property="Foreground"
                        Value="{atom:SelectTokenResource MultipleItemColorDisabled}" />
                <Setter Property="IsClosable" Value="False" />
            </Style>

            <Style Selector="^[SizeType=Large]">
                <Setter Property="Height" Value="{atom:SelectTokenResource MultipleItemHeightLG}" />
            </Style>

            <Style Selector="^[SizeType=Middle]">
                <Setter Property="Height" Value="{atom:SelectTokenResource MultipleItemHeight}" />
            </Style>

            <Style Selector="^[SizeType=Small]">
                <Setter Property="Height" Value="{atom:SelectTokenResource MultipleItemHeightSM}" />
            </Style>

        </Style>

    </ControlTheme>
</ResourceDictionary>