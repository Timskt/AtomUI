<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:Separator}" TargetType="atom:Separator">
        <Setter Property="Template">
            <ControlTemplate>
                <atom:TextBlock Name="PART_Title"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Padding="0"
                       Text="{TemplateBinding Title}"
                       FontSize="{TemplateBinding FontSize}"
                       Foreground="{TemplateBinding TitleColor}"
                       IsVisible="{TemplateBinding Title, Converter={x:Static ObjectConverters.IsNotNull}}"/>
            </ControlTemplate>
        </Setter>
        
        <Setter Property="TitleColor" Value="{atom:SharedTokenResource ColorTextHeading}" />
        <Setter Property="LineColor" Value="{atom:SharedTokenResource ColorSplit}" />
        
        <Setter Property="TextPaddingInline" Value="{atom:SeparatorTokenResource TextPaddingInline}" />
        <Setter Property="OrientationMarginPercent" Value="{atom:SeparatorTokenResource OrientationMarginPercent}" />
        <Setter Property="LineWidth" Value="{atom:SharedTokenResource LineWidth}" />
        
        <Style Selector="^[IsPlain=True]">
            <Style Selector="^ /template/ atom|TextBlock#PART_Title">
                <Setter Property="FontSize" Value="{atom:SharedTokenResource FontSize}" />
                <Setter Property="FontWeight" Value="Normal" />
            </Style>
        </Style>
        <Style Selector="^[IsPlain=False]">
            <Style Selector="^ /template/ atom|TextBlock#PART_Title">
                <Setter Property="FontSize" Value="{atom:SharedTokenResource FontSizeLG}" />
                <Setter Property="FontWeight" Value="500" />
            </Style>
        </Style>

        <Style Selector="^[Orientation=Horizontal]">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style Selector="^ /template/ atom|TextBlock#PART_Title">
                <Setter Property="IsVisible" Value="True" />
            </Style>
            
            <Style Selector="^:not(:has-title)">
                <Style Selector="^[SizeType=Small]">
                    <Setter Property="Margin" Value="{atom:SeparatorTokenResource HorizontalMarginBlockSM}"/>
                </Style>
            
                <Style Selector="^[SizeType=Middle]">
                    <Setter Property="Margin" Value="{atom:SeparatorTokenResource HorizontalMarginBlock}"/>
                </Style>
            
                <Style Selector="^[SizeType=Large]">
                    <Setter Property="Margin" Value="{atom:SeparatorTokenResource HorizontalMarginBlockLG}"/>
                </Style>
            </Style>
            <Style Selector="^:has-title">
                <Style Selector="^[SizeType=Small]">
                    <Setter Property="Margin" Value="{atom:SeparatorTokenResource HorizontalWithTextGutterMargin}"/>
                </Style>
            </Style>
  
        </Style>
        
        <Style Selector="^[Orientation=Vertical]">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style Selector="^ /template/ atom|TextBlock#PART_Title">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            
            <Setter Property="VerticalMarginInline" Value="{atom:SeparatorTokenResource VerticalMarginInline}"/>
        </Style>
        
    </ControlTheme>
</ResourceDictionary>