<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:Slider}" TargetType="atom:Slider">
        <Setter Property="Template">
            <ControlTemplate>
                <atom:SliderTrack Name="PART_Track"
                                  IsMotionEnabled="{TemplateBinding IsMotionEnabled}"
                                  IsEnabled="{TemplateBinding IsEnabled}"
                                  IsDirectionReversed="{TemplateBinding IsDirectionReversed}"
                                  Minimum="{TemplateBinding Minimum}"
                                  Maximum="{TemplateBinding Maximum}"
                                  Orientation="{TemplateBinding Orientation}"
                                  Value="{TemplateBinding Value, Mode=TwoWay}"
                                  RangeValue="{TemplateBinding RangeValue, Mode=TwoWay}"
                                  IsRangeMode="{TemplateBinding IsRangeMode}"
                                  MarkLabelFontFamily="{TemplateBinding FontFamily}"
                                  MarkLabelFontSize="{TemplateBinding FontSize}"
                                  Marks="{TemplateBinding Marks}"
                                  IsIncluded="{TemplateBinding IsIncluded}">
                    <atom:SliderTrack.StartSliderThumb>
                        <atom:SliderThumb Name="PART_StartThumb"
                                          IsMotionEnabled="{Binding IsMotionEnabled, RelativeSource={RelativeSource AncestorType=atom:Slider}}"
                                          atom:ToolTip.Placement="Top"
                                          atom:ToolTip.ShowDelay="20" />
                    </atom:SliderTrack.StartSliderThumb>
                    <atom:SliderTrack.EndSliderThumb>
                        <atom:SliderThumb Name="PART_EndThumb"
                                          IsMotionEnabled="{Binding IsMotionEnabled, RelativeSource={RelativeSource AncestorType=atom:Slider}}"
                                          atom:ToolTip.Placement="Top"
                                          atom:ToolTip.ShowDelay="20" />
                    </atom:SliderTrack.EndSliderThumb>
                </atom:SliderTrack>
            </ControlTemplate>
        </Setter>

        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Focusable" Value="False" />

        <Style Selector="^[Orientation=Vertical]">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>
        
        <Style Selector="^ /template/ atom|SliderTrack#PART_Track">
            <Setter Property="TrackGrooveBrush" Value="{atom:SliderTokenResource RailBg}" />
            <Setter Property="TrackBarBrush" Value="{atom:SliderTokenResource TrackBg}" />
            <Setter Property="MarkBorderBrush" Value="{atom:SliderTokenResource MarkBorderColor}" />
            <Setter Property="MarkBorderActiveBrush"
                    Value="{atom:SliderTokenResource MarkBorderColorActive}" />
        </Style>
        <Style Selector="^:pointerover">
            <Style Selector="^ /template/ atom|SliderThumb[IsFocused=False]:not(:pointerover)">
                <Setter Property="BorderBrush"
                        Value="{atom:SliderTokenResource ThumbCircleBorderHoverColor}" />
            </Style>
        </Style>

        <Style Selector="^ /template/ atom|SliderTrack[Orientation=Horizontal]">
            <Setter Property="Padding" Value="{atom:SliderTokenResource SliderPaddingHorizontal}" />
        </Style>

        <Style Selector="^ /template/ atom|SliderTrack[Orientation=Vertical]">
            <Setter Property="Padding" Value="{atom:SliderTokenResource SliderPaddingVertical}" />
        </Style>

        <Style Selector="^ /template/ atom|SliderTrack:pointerover">
            <Setter Property="TrackGrooveBrush" Value="{atom:SliderTokenResource RailHoverBg}" />
            <Setter Property="TrackBarBrush" Value="{atom:SliderTokenResource TrackHoverBg}" />
            <Setter Property="MarkBorderBrush"
                    Value="{atom:SliderTokenResource MarkBorderColorHover}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style Selector="^:disabled">
            <Style Selector="^ /template/ atom|SliderTrack">
                <Setter Property="TrackBarBrush" Value="{atom:SliderTokenResource TrackBgDisabled}" />
                <Setter Property="MarkBorderActiveBrush" Value="{atom:SliderTokenResource ThumbCircleBorderColorDisabled}" />
                <Setter Property="MarkBorderBrush"
                        Value="{atom:SliderTokenResource ThumbCircleBorderColorDisabled}" />
            </Style>
            
            <Style Selector="^ /template/ atom|SliderThumb">
                <Setter Property="BorderBrush"
                        Value="{atom:SliderTokenResource ThumbCircleBorderColorDisabled}" />
            </Style>
        </Style>
    </ControlTheme>
</ResourceDictionary>