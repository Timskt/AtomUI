<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:SliderTrack}" TargetType="atom:SliderTrack">
        <Setter Property="SliderTrackSize" Value="{atom:SliderTokenResource SliderTrackSize}" />
        <Setter Property="SliderMarkSize" Value="{atom:SliderTokenResource MarkSize}" />
        <Setter Property="SliderRailSize" Value="{atom:SliderTokenResource RailSize}" />
        <Setter Property="MarkBackgroundBrush" Value="{atom:SharedTokenResource ColorBgElevated}" />
        <Setter Property="MarkBorderThickness"
                Value="{atom:SliderTokenResource ThumbCircleBorderThickness}" />
        <Setter Property="MarkLabelBrush" Value="{atom:SharedTokenResource ColorText}" />
        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}" />

        <Style Selector="^:disabled">
            <Setter Property="MarkLabelBrush"
                    Value="{atom:SharedTokenResource ColorTextDisabled}" />
        </Style>

        <Style Selector="^[IsMotionEnabled=True]">
            <Setter Property="Transitions">
                <Transitions>
                    <atom:SolidColorBrushTransition Property="TrackGrooveBrush" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}" />
                    <atom:SolidColorBrushTransition Property="TrackBarBrush" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}" />
                    <atom:SolidColorBrushTransition Property="MarkBorderBrush" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}" />
                </Transitions>
            </Setter>
        </Style>
    </ControlTheme>
</ResourceDictionary>