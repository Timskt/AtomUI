<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:CompactSpaceAddOn}" TargetType="atom:CompactSpaceAddOn">
        <Setter Property="Template">
            <ControlTemplate>
                <ContentPresenter Content="{TemplateBinding Content}"
                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                  HorizontalContentAlignment="Center"
                                  VerticalContentAlignment="Center"
                                  CornerRadius="{TemplateBinding EffectiveCornerRadius}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}"
                                  Background="{TemplateBinding Background}" 
                                  Padding="{TemplateBinding Padding}"/>
            </ControlTemplate>
        </Setter>

        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="BorderThickness" Value="{atom:SharedTokenResource BorderThickness}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />

        <Style Selector="^[SizeType=Large]">
            <Setter Property="FontSize"
                    Value="{atom:SharedTokenResource FontSizeLG}" />
            <Setter Property="CornerRadius"
                    Value="{atom:SharedTokenResource BorderRadiusLG}" />
            <Setter Property="Padding"
                    Value="{atom:SpaceTokenResource AddOnPaddingLG}" />
            <Setter Property="MinHeight" Value="{atom:SharedTokenResource ControlHeightLG}" />
        </Style>
        <Style Selector="^[SizeType=Middle]">
            <Setter Property="FontSize"
                    Value="{atom:SharedTokenResource FontSize}" />
            <Setter Property="CornerRadius"
                    Value="{atom:SharedTokenResource BorderRadius}" />
            <Setter Property="Padding"
                    Value="{atom:SpaceTokenResource AddOnPadding}" />
            <Setter Property="MinHeight" Value="{atom:SharedTokenResource ControlHeight}" />
        </Style>
        <Style Selector="^[SizeType=Small]">
            <Setter Property="FontSize"
                    Value="{atom:SharedTokenResource FontSizeSM}" />
            <Setter Property="CornerRadius"
                    Value="{atom:SharedTokenResource BorderRadiusSM}" />
            <Setter Property="Padding"
                    Value="{atom:SpaceTokenResource AddOnPaddingSM}" />
            <Setter Property="MinHeight" Value="{atom:SharedTokenResource ControlHeightSM}" />
        </Style>
        
        <Style Selector="^[Status=Error]">
            <Setter Property="Foreground"
                    Value="{atom:SharedTokenResource ColorErrorText}" />
        </Style>
        
        <Style Selector="^[Status=Warning]">
            <Setter Property="Foreground"
                    Value="{atom:SharedTokenResource ColorWarningText}" />
        </Style>
        
        <Style Selector="^[StyleVariant=Outline]">
            <Setter Property="Background"
                    Value="{atom:SpaceTokenResource AddonBg}" />
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorBorder}" />
            
            <Style Selector="^[Status=Error]">
                <Setter Property="BorderBrush"
                        Value="{atom:SharedTokenResource ColorError}" />
            </Style>
        
            <Style Selector="^[Status=Warning]">
                <Setter Property="BorderBrush"
                        Value="{atom:SharedTokenResource ColorWarning}" />
            </Style>
        </Style>

        <Style Selector="^[StyleVariant=Filled]">
            <Setter Property="Background"
                    Value="{atom:SpaceTokenResource AddonBg}" />
            
            <Style Selector="^[Status=Error]">
                <Setter Property="Background"
                        Value="{atom:SharedTokenResource ColorErrorBg}" />
            </Style>
        
            <Style Selector="^[Status=Warning]">
                <Setter Property="Background"
                        Value="{atom:SharedTokenResource ColorWarningBg}" />
            </Style>
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorBorder}" />
            <Setter Property="Foreground"
                    Value="{atom:SharedTokenResource ColorTextDisabled}" />
            <Setter Property="Background"
                    Value="{atom:SharedTokenResource ColorBgContainerDisabled}" />
        </Style>
    </ControlTheme>
</ResourceDictionary>