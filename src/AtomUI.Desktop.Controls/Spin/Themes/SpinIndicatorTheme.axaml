<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:SpinIndicator}" TargetType="atom:SpinIndicator">
        <Setter Property="Template">
            <ControlTemplate>
                <ContentPresenter
                    Name="PART_CustomIndicatorPresenter"
                    Content="{TemplateBinding CustomIndicator}"
                    ContentTemplate="{TemplateBinding CustomIndicatorTemplate}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"/>
            </ControlTemplate>
        </Setter>
        
        <Setter Property="MotionEasingCurve" Value="LinearEasing" />
        <Setter Property="MotionDuration"
                Value="{atom:SpinTokenResource IndicatorDuration}" />
        <Setter Property="DotBgBrush" Value="{atom:SharedTokenResource ColorPrimary}" />

        <Style Selector="^[SizeType=Large]">
            <Setter Property="DotSize" Value="{atom:SpinTokenResource DotSizeLG}" />
        </Style>

        <Style Selector="^[SizeType=Middle]">
            <Setter Property="DotSize" Value="{atom:SpinTokenResource DotSize}" />
        </Style>

        <Style Selector="^[SizeType=Small]">
            <Setter Property="DotSize" Value="{atom:SpinTokenResource DotSizeSM}" />
        </Style>

        <Style Selector="^[SizeType=Large]">
            <Setter Property="CustomIndicatorSize" Value="{atom:SpinTokenResource IndicatorSizeLG}" />
            <Style Selector="^ /template/ ContentPresenter#PART_CustomIndicatorPresenter">
                <Setter Property="Width" Value="{atom:SpinTokenResource IndicatorSizeLG}" />
                <Setter Property="Height" Value="{atom:SpinTokenResource IndicatorSizeLG}" />
            </Style>
        </Style>

        <Style Selector="^[SizeType=Middle]">
            <Setter Property="CustomIndicatorSize" Value="{atom:SpinTokenResource IndicatorSize}" />
            <Style Selector="^ /template/ ContentPresenter#PART_CustomIndicatorPresenter">
                <Setter Property="Width" Value="{atom:SpinTokenResource IndicatorSize}" />
                <Setter Property="Height" Value="{atom:SpinTokenResource IndicatorSize}" />
            </Style>
        </Style>

        <Style Selector="^[SizeType=Small]">
            <Setter Property="CustomIndicatorSize" Value="{atom:SpinTokenResource IndicatorSizeSM}" />
            <Style Selector="^ /template/ ContentPresenter#PART_CustomIndicatorPresenter">
                <Setter Property="Width" Value="{atom:SpinTokenResource IndicatorSizeSM}" />
                <Setter Property="Height" Value="{atom:SpinTokenResource IndicatorSizeSM}" />
            </Style>
        </Style>
    </ControlTheme>
</ResourceDictionary>