<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:StatisticCountUp}" TargetType="atom:StatisticCountUp">
        <Setter Property="Template">
            <ControlTemplate>
                <TextBlock Text="{TemplateBinding FormattedValue}"/>
            </ControlTemplate>
        </Setter>
        
        <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorTextHeading}"/>
        <Setter Property="FontSize" Value="{atom:StatisticTokenResource ContentFontSize}"/>

        <Style Selector="^">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="AnimatingValue" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationVerySlow}" Easing="ExponentialEaseOut" />
                </Transitions>
            </Setter>
        </Style>
    </ControlTheme>
</ResourceDictionary>