<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    xmlns:antdicons="https://atomui.net/icons/antdesign"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:BaseTabScrollViewer}" TargetType="atom:BaseTabScrollViewer">
        <Setter Property="Template">
            <ControlTemplate>
                <Panel Name="RootLayout">
                    <Border Name="PART_ScrollStartEdgeIndicator"
                            IsHitTestVisible="False" />
                    <Border Name="PART_ScrollEndEdgeIndicator"
                            IsHitTestVisible="False" />

                    <DockPanel Name="ScrollViewLayout">
                        <atom:IconButton Name="PART_ScrollMenuIndicator"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Stretch"
                                         Icon="{antdicons:AntDesignIconProvider EllipsisOutlined}" />
                        <atom:TabScrollContentPresenter
                            Name="ScrollViewContent"
                            TabStripPlacement="{TemplateBinding TabStripPlacement}"
                            Margin="{TemplateBinding Padding}"
                            HorizontalSnapPointsAlignment="{TemplateBinding HorizontalSnapPointsAlignment}"
                            HorizontalSnapPointsType="{TemplateBinding HorizontalSnapPointsType}"
                            VerticalSnapPointsAlignment="{TemplateBinding VerticalSnapPointsAlignment}"
                            VerticalSnapPointsType="{TemplateBinding VerticalSnapPointsType}">
                            <atom:TabScrollContentPresenter.GestureRecognizers>
                                <ScrollGestureRecognizer
                                    CanHorizontallyScroll="{Binding CanHorizontallyScroll, RelativeSource={RelativeSource AncestorType=atom:TabScrollContentPresenter}}"
                                    CanVerticallyScroll="{Binding CanVerticallyScroll, RelativeSource={RelativeSource AncestorType=atom:TabScrollContentPresenter}}"
                                    IsScrollInertiaEnabled="{Binding (ScrollViewer.IsScrollInertiaEnabled), RelativeSource={RelativeSource AncestorType=atom:TabScrollContentPresenter}}" />
                            </atom:TabScrollContentPresenter.GestureRecognizers>
                        </atom:TabScrollContentPresenter>
                    </DockPanel>
                </Panel>
            </ControlTemplate>
        </Setter>
        
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="EdgeShadowStartColor" Value="{atom:SharedTokenResource ColorFillSecondary}"/>
        <Setter Property="MenuEdgeThickness" Value="{atom:TabControlTokenResource MenuEdgeThickness}"/>
        
        <Style Selector="^ /template/ atom|IconButton#PART_ScrollMenuIndicator">
            <Setter Property="IconWidth" Value="{atom:SharedTokenResource IconSize}"/>
            <Setter Property="IconHeight" Value="{atom:SharedTokenResource IconSize}"/>
            <Setter Property="IconBrush" Value="{atom:SharedTokenResource ColorTextSecondary}"/>
        </Style>
        
        <Style Selector="^[TabStripPlacement=Top]">
            <Style Selector="^ /template/ atom|TabScrollContentPresenter#ScrollViewContent">
                <Setter Property="DockPanel.Dock" Value="Left"/>
            </Style>
            
            <Style Selector="^ /template/ atom|IconButton#PART_ScrollMenuIndicator">
                <Setter Property="DockPanel.Dock" Value="Right"/>
                <Setter Property="Padding" Value="{atom:TabControlTokenResource MenuIndicatorPaddingHorizontal}"/>
            </Style>
            
            <Style Selector="^ /template/ Border#PART_ScrollStartEdgeIndicator">
                <Setter Property="Width" Value="{atom:TabControlTokenResource MenuEdgeThickness}"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="VerticalAlignment" Value="Stretch"/>
            </Style>
            
            <Style Selector="^ /template/ Border#PART_ScrollEndEdgeIndicator">
                <Setter Property="Width" Value="{atom:TabControlTokenResource MenuEdgeThickness}"/>
                <Setter Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="VerticalAlignment" Value="Stretch"/>
            </Style>
        </Style>
        
        <Style Selector="^[TabStripPlacement=Right]">
            <Style Selector="^ /template/ atom|TabScrollContentPresenter#ScrollViewContent">
                <Setter Property="DockPanel.Dock" Value="Top"/>
            </Style>
            
            <Style Selector="^ /template/ atom|IconButton#PART_ScrollMenuIndicator">
                <Setter Property="DockPanel.Dock" Value="Bottom"/>
                <Setter Property="Padding" Value="{atom:TabControlTokenResource MenuIndicatorPaddingVertical}"/>
            </Style>
            
            <Style Selector="^ /template/ Border#PART_ScrollStartEdgeIndicator">
                <Setter Property="Height" Value="{atom:TabControlTokenResource MenuEdgeThickness}"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="VerticalAlignment" Value="Top"/>
            </Style>
            
            <Style Selector="^ /template/ Border#PART_ScrollEndEdgeIndicator">
                <Setter Property="Height" Value="{atom:TabControlTokenResource MenuEdgeThickness}"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="VerticalAlignment" Value="Bottom"/>
            </Style>
        </Style>
        
        <Style Selector="^[TabStripPlacement=Bottom]">
            <Style Selector="^ /template/ atom|TabScrollContentPresenter#ScrollViewContent">
                <Setter Property="DockPanel.Dock" Value="Left"/>
            </Style>
            
            <Style Selector="^ /template/ atom|IconButton#PART_ScrollMenuIndicator">
                <Setter Property="DockPanel.Dock" Value="Right"/>
                <Setter Property="Padding" Value="{atom:TabControlTokenResource MenuIndicatorPaddingHorizontal}"/>
            </Style>
            
            <Style Selector="^ /template/ Border#PART_ScrollStartEdgeIndicator">
                <Setter Property="Width" Value="{atom:TabControlTokenResource MenuEdgeThickness}"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="VerticalAlignment" Value="Stretch"/>
            </Style>
            
            <Style Selector="^ /template/ Border#PART_ScrollEndEdgeIndicator">
                <Setter Property="Width" Value="{atom:TabControlTokenResource MenuEdgeThickness}"/>
                <Setter Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="VerticalAlignment" Value="Stretch"/>
            </Style>
        </Style>
        
        <Style Selector="^[TabStripPlacement=Left]">
            <Style Selector="^ /template/ atom|TabScrollContentPresenter#ScrollViewContent">
                <Setter Property="DockPanel.Dock" Value="Top"/>
            </Style>
            
            <Style Selector="^ /template/ atom|IconButton#PART_ScrollMenuIndicator">
                <Setter Property="DockPanel.Dock" Value="Bottom"/>
                <Setter Property="Padding" Value="{atom:TabControlTokenResource MenuIndicatorPaddingVertical}"/>
            </Style>
            
            <Style Selector="^ /template/ Border#PART_ScrollStartEdgeIndicator">
                <Setter Property="Height" Value="{atom:TabControlTokenResource MenuEdgeThickness}"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="VerticalAlignment" Value="Top"/>
            </Style>
            
            <Style Selector="^ /template/ Border#PART_ScrollEndEdgeIndicator">
                <Setter Property="Height" Value="{atom:TabControlTokenResource MenuEdgeThickness}"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="VerticalAlignment" Value="Bottom"/>
            </Style>
        </Style>
        
    </ControlTheme>
</ResourceDictionary>