<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    xmlns:themes="using:AtomUI.Desktop.Controls.Themes"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Static atom:TabItemThemeConstants.CardTabItemThemeId}" TargetType="atom:TabItem">
        <ControlTheme.BasedOn>
            <themes:BaseTabItemTheme TargetType="atom:TabItem" />
        </ControlTheme.BasedOn>
        <Setter Property="Template">
            <ControlTemplate>
                <Panel>
                    <Border Name="Frame"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Margin="{TemplateBinding Margin}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            Padding="{TemplateBinding Padding}">
                        <StackPanel Orientation="Horizontal">
                            <atom:IconPresenter Name="ItemIconPresenter"
                                                Icon="{TemplateBinding Icon}"
                                                IsVisible="{TemplateBinding Icon, Converter={x:Static ObjectConverters.IsNotNull}}" />
                            <ContentPresenter Name="ContentPresenter"
                                              Content="{TemplateBinding Header}"
                                              ContentTemplate="{TemplateBinding HeaderTemplate, Converter={x:Static atom:BaseTabItemTheme.StringToTextBlockConverter}}" />
                            <atom:IconButton Name="{x:Static atom:TabItemThemeConstants.ItemCloseButtonPart}"
                                             Icon="{TemplateBinding CloseIcon}"
                                             Opacity="{TemplateBinding CloseButtonOpacity}"
                                             VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Rectangle Name="LineMask" Fill="{TemplateBinding Background}" Margin="{TemplateBinding LineMaskMargin}"/>
                </Panel>
            </ControlTemplate>
        </Setter>

        <Setter Property="Margin" Value="{atom:TabControlTokenResource HorizontalItemMargin}" />
        <Setter Property="Background" Value="{atom:TabControlTokenResource CardBg}" />
        <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorBorderSecondary}" />

        <Style Selector="^:selected">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgContainer}" />
        </Style>

        <Style Selector="^[TabStripPlacement=Top], ^[TabStripPlacement=Bottom]">
            
            <Setter Property="Margin" Value="{atom:TabControlTokenResource HorizontalItemMargin}" />
            <Style Selector="^[SizeType=Large]">
                <Setter Property="Padding" Value="{atom:TabControlTokenResource CardPaddingLG}" />
            </Style>

            <Style Selector="^[SizeType=Middle]">
                <Setter Property="Padding" Value="{atom:TabControlTokenResource CardPadding}" />
            </Style>

            <Style Selector="^[SizeType=Small]">
                <Setter Property="Padding" Value="{atom:TabControlTokenResource CardPaddingSM}" />
            </Style>
        </Style>

        <Style Selector="^[TabStripPlacement=Left], ^[TabStripPlacement=Right]">
            <Style Selector="^[SizeType=Large]">
                <Setter Property="Padding"
                        Value="{atom:TabControlTokenResource VerticalItemPadding}" />
            </Style>

            <Style Selector="^[SizeType=Middle]">
                <Setter Property="Padding"
                        Value="{atom:TabControlTokenResource VerticalItemPadding}" />
            </Style>

            <Style Selector="^[SizeType=Small]">
                <Setter Property="Padding"
                        Value="{atom:TabControlTokenResource VerticalItemPadding}" />
            </Style>
        </Style>

        <!-- 分为上、右、下、左 -->
        <Style Selector="^[TabStripPlacement=Top]">
            <Style Selector="^ /template/ atom|IconPresenter#ItemIconPresenter">
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
            
            <Style Selector="^ /template/ Rectangle#LineMask">
                <Setter Property="VerticalAlignment" Value="Bottom" />
                <Setter Property="Height"
                        Value="{atom:SharedTokenResource LineWidth}" />
            </Style>
        </Style>

        <Style Selector="^[TabStripPlacement=Right]">
            <Style Selector="^ /template/ atom|IconPresenter#ItemIconPresenter">
                <Setter Property="HorizontalAlignment" Value="Center" />
            </Style>
            <Style Selector="^ /template/ Rectangle#LineMask">
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="Width"
                        Value="{atom:SharedTokenResource LineWidth}" />
            </Style>
        </Style>

        <Style Selector="^[TabStripPlacement=Bottom]">
            <Style Selector="^ /template/ atom|IconPresenter#ItemIconPresenter">
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
            
            <Style Selector="^ /template/ Rectangle#LineMask">
                <Setter Property="VerticalAlignment" Value="Top" />
                <Setter Property="Height"
                        Value="{atom:SharedTokenResource LineWidth}" />
            </Style>
        </Style>

        <Style Selector="^[TabStripPlacement=Left]">
            <Style Selector="^ /template/ atom|IconPresenter#ItemIconPresenter">
                <Setter Property="HorizontalAlignment" Value="Center" />
            </Style>
            <Style Selector="^ /template/ Rectangle#LineMask">
                <Setter Property="HorizontalAlignment" Value="Right" />
                <Setter Property="Width"
                        Value="{atom:SharedTokenResource LineWidth}" />
            </Style>
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Background"
                    Value="{atom:SharedTokenResource ColorBgContainerDisabled}" />
        </Style>

        <Style Selector="^[IsMotionEnabled=True]">
            <Setter Property="Transitions">
                <Transitions>
                    <atom:SolidColorBrushTransition Property="Foreground" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}" />
                    <atom:SolidColorBrushTransition Property="Background" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}" />
                    <DoubleTransition Property="CloseButtonOpacity" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}" />
                </Transitions>
            </Setter>
        </Style>

    </ControlTheme>
</ResourceDictionary>
