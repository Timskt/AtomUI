<ControlTheme xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:atom="https://atomui.net"
              x:Class="AtomUI.Desktop.Controls.Themes.BaseTabStripItemTheme"
              TargetType="atom:TabStripItem"
              x:ClassModifier="internal">
    <Setter Property="Template">
        <ControlTemplate TargetType="atom:TabStripItem">
            <Border Name="Frame"
                    Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}"
                    Margin="{TemplateBinding Margin}">
                <StackPanel Name="ContentLayout" Orientation="Horizontal">
                    <ContentPresenter Name="ContentPresenter"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate, Converter={x:Static atom:BaseTabStripItemTheme.StringToTextBlockConverter}}" />
                </StackPanel>
            </Border>
        </ControlTemplate>
    </Setter>

    <Style Selector="^[HasIcon=True][IsClosable=False]">
        <Setter Property="Template">
            <ControlTemplate TargetType="atom:TabStripItem">
                <Border Name="Frame"
                        Background="{TemplateBinding Background}"
                        Padding="{TemplateBinding Padding}"
                        Margin="{TemplateBinding Margin}">
                    <StackPanel Name="ContentLayout" Orientation="Horizontal">
                        <atom:IconPresenter Name="ItemIconPresenter"
                                            Icon="{TemplateBinding Icon}" />
                        <ContentPresenter Name="ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate, Converter={x:Static atom:BaseTabStripItemTheme.StringToTextBlockConverter}}" />
                    </StackPanel>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="^[HasIcon=False][IsClosable=True]">
        <Setter Property="Template">
            <ControlTemplate TargetType="atom:TabStripItem">
                <Border Name="Frame"
                        Background="{TemplateBinding Background}"
                        Padding="{TemplateBinding Padding}"
                        Margin="{TemplateBinding Margin}">
                    <StackPanel Name="ContentLayout" Orientation="Horizontal">
                        <ContentPresenter Name="ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate, Converter={x:Static atom:BaseTabStripItemTheme.StringToTextBlockConverter}}" />
                        <atom:IconButton Name="PART_ItemCloseButton"
                                         Icon="{TemplateBinding CloseIcon}"
                                         Opacity="{TemplateBinding CloseButtonOpacity}"
                                         VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="^[HasIcon=True][IsClosable=True]">
        <Setter Property="Template">
            <ControlTemplate TargetType="atom:TabStripItem">
                <Border Name="Frame"
                        Background="{TemplateBinding Background}"
                        Padding="{TemplateBinding Padding}"
                        Margin="{TemplateBinding Margin}">
                    <StackPanel Name="ContentLayout" Orientation="Horizontal">
                        <atom:IconPresenter Name="ItemIconPresenter"
                                            Icon="{TemplateBinding Icon}" />
                        <ContentPresenter Name="ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate, Converter={x:Static atom:BaseTabStripItemTheme.StringToTextBlockConverter}}" />
                        <atom:IconButton Name="PART_ItemCloseButton"
                                         Icon="{TemplateBinding CloseIcon}"
                                         Opacity="{TemplateBinding CloseButtonOpacity}"
                                         VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="^:is(atom|TabStripItem)">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{atom:TabControlTokenResource ItemColor}" />
        <Setter Property="Background" Value="Transparent" />

        <Style Selector="^ /template/ atom|IconButton#PART_ItemCloseButton">
            <Setter Property="Margin" Value="{atom:TabControlTokenResource CloseIconMargin}" />
            <Setter Property="IconWidth" Value="{atom:SharedTokenResource IconSizeSM}" />
            <Setter Property="IconHeight" Value="{atom:SharedTokenResource IconSizeSM}" />
        </Style>

        <Style Selector="^ /template/ atom|IconPresenter#ItemIconPresenter">
            <Setter Property="Margin" Value="{atom:TabControlTokenResource ItemIconMargin}" />
            <Setter Property="IconBrush" Value="{TemplateBinding Foreground}" />
        </Style>

        <Style Selector="^:pointerover">
            <Setter Property="Foreground" Value="{atom:TabControlTokenResource ItemHoverColor}" />
        </Style>

        <Style Selector="^:selected">
            <Setter Property="Foreground" Value="{atom:TabControlTokenResource ItemSelectedColor}" />
        </Style>

        <Style Selector="^[SizeType=Large]">
            <Setter Property="FontSize" Value="{atom:TabControlTokenResource TitleFontSizeLG}" />
            <Style Selector="^ /template/ atom|IconPresenter#ItemIconPresenter">
                <Setter Property="Width"
                        Value="{atom:SharedTokenResource IconSize}" />
                <Setter Property="Height"
                        Value="{atom:SharedTokenResource IconSize}" />
            </Style>
        </Style>

        <Style Selector="^[SizeType=Middle]">
            <Setter Property="FontSize" Value="{atom:TabControlTokenResource TitleFontSize}" />
            <Style Selector="^ /template/ atom|IconPresenter#ItemIconPresenter">
                <Setter Property="Width"
                        Value="{atom:SharedTokenResource IconSize}" />
                <Setter Property="Height"
                        Value="{atom:SharedTokenResource IconSize}" />
            </Style>
        </Style>

        <Style Selector="^[SizeType=Small]">
            <Setter Property="FontSize" Value="{atom:TabControlTokenResource TitleFontSizeSM}" />
            <Style Selector="^ /template/ atom|IconPresenter#ItemIconPresenter">
                <Setter Property="Width"
                        Value="{atom:SharedTokenResource IconSizeSM}" />
                <Setter Property="Height"
                        Value="{atom:SharedTokenResource IconSizeSM}" />
            </Style>
        </Style>

        <!-- 分为上、右、下、左 -->
        <Style Selector="^[TabStripPlacement=Top]">
            <Style Selector="^ /template/ atom|IconPresenter#ItemIconPresenter">
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
        </Style>

        <Style Selector="^[TabStripPlacement=Right]">
            <Style Selector="^ /template/ atom|IconPresenter#ItemIconPresenter">
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
        </Style>

        <Style Selector="^[TabStripPlacement=Bottom]">
            <Style Selector="^ /template/ atom|IconPresenter#ItemIconPresenter">
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
        </Style>

        <Style Selector="^[TabStripPlacement=Left]">
            <Style Selector="^ /template/ atom|IconPresenter#ItemIconPresenter">
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorTextDisabled}" />
        </Style>

        <Style Selector="^ /template/ atom|IconButton#PART_ItemCloseButton">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="^[IsClosable=True]">
            <Style Selector="^ /template/ atom|IconButton#PART_ItemCloseButton">
                <Setter Property="IsVisible" Value="True" />
            </Style>
            <Setter Property="CloseButtonOpacity" Value="0.0" />
            <Style Selector="^[IsAutoHideCloseButton=False]">
                <Setter Property="CloseButtonOpacity" Value="1.0" />
            </Style>
            <Style Selector="^[IsAutoHideCloseButton=True]">
                <Style Selector="^:pointerover">
                    <Setter Property="CloseButtonOpacity" Value="1.0" />
                </Style>
            </Style>
        </Style>

        <Style Selector="^[IsMotionEnabled=True]">
            <Setter Property="Transitions">
                <Transitions>
                    <atom:SolidColorBrushTransition Property="Foreground" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}" />
                    <atom:SolidColorBrushTransition Property="Background" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}" />
                    <DoubleTransition Property="CloseButtonOpacity" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}" />
                </Transitions>
            </Setter>
        </Style>

    </Style>
</ControlTheme>
