<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    xmlns:themes="using:AtomUI.Desktop.Controls.Themes"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Static atom:TabStripThemeConstants.TabStripItemThemeId}" TargetType="atom:TabStripItem">
        <ControlTheme.BasedOn>
            <themes:BaseTabStripItemTheme TargetType="atom:TabStripItem" />
        </ControlTheme.BasedOn>

        <Style Selector="^[TabStripPlacement=Top], ^[TabStripPlacement=Bottom]">
            <Setter Property="Margin" Value="{atom:TabControlTokenResource HorizontalItemMargin}" />
            <Style Selector="^[SizeType=Large]">
                <Style Selector="^ /template/ Border#Frame">
                    <Setter Property="Padding" Value="{atom:TabControlTokenResource HorizontalItemPaddingLG}"/>
                </Style>
            </Style>
            
            <Style Selector="^[SizeType=Middle]">
                <Style Selector="^ /template/ Border#Frame">
                    <Setter Property="Padding" Value="{atom:TabControlTokenResource HorizontalItemPadding}"/>
                </Style>
            </Style>
            
            <Style Selector="^[SizeType=Small]">
                <Style Selector="^ /template/ Border#Frame">
                    <Setter Property="Padding" Value="{atom:TabControlTokenResource HorizontalItemPaddingSM}"/>
                </Style>
            </Style>
        </Style>

        <Style Selector="^[TabStripPlacement=Left], ^[TabStripPlacement=Right]">
            <Style Selector="^[SizeType=Large]">
                <Style Selector="^ /template/ Border#Frame">
                    <Setter Property="Padding" Value="{atom:TabControlTokenResource VerticalItemPadding}"/>
                </Style>
            </Style>
            
            <Style Selector="^[SizeType=Middle]">
                <Style Selector="^ /template/ Border#Frame">
                    <Setter Property="Padding" Value="{atom:TabControlTokenResource VerticalItemPadding}"/>
                </Style>
            </Style>
            
            <Style Selector="^[SizeType=Small]">
                <Style Selector="^ /template/ Border#Frame">
                    <Setter Property="Padding" Value="{atom:TabControlTokenResource VerticalItemPadding}"/>
                </Style>
            </Style>
        </Style>
    </ControlTheme>
</ResourceDictionary>