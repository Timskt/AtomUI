<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:HyperLinkTextBlock}" TargetType="atom:HyperLinkTextBlock">
        <Setter Property="Template">
            <ControlTemplate>
                <atom:TextBlock Name="{x:Static atom:HyperLinkTextBlockThemeConstants.TextPart}"
                           FontWeight="{TemplateBinding FontWeight}"
                           FontStyle="{TemplateBinding FontStyle}"
                           FontSize="{TemplateBinding FontSize}"
                           Text="{TemplateBinding Text}"/>
            </ControlTemplate>
        </Setter>
        
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgContainer}" />
        <Setter Property="IsMotionEnabled" Value="{atom:SharedTokenResource EnableMotion}" />
        
        <Style Selector="^[IsEnabled=True]">
            <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorLink}" />
            
            <Style Selector="^:pointerover">
                <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorLinkHover}" />
            </Style>
            
            <Style Selector="^:pressed">
                <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorLinkActive}" />
            </Style>
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorTextDisabled}" />
        </Style>
        
    </ControlTheme>
</ResourceDictionary>