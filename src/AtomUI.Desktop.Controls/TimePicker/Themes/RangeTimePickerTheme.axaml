<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    xmlns:timepickerlange="using:AtomUI.Desktop.Controls.TimePickerLang"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:RangeTimePicker}" TargetType="atom:RangeTimePicker">
        <ControlTheme.BasedOn>
            <atom:RangeInfoPickerInputTheme TargetType="atom:RangeTimePicker" />
        </ControlTheme.BasedOn>
        
        <Setter Property="AmText" Value="{DynamicResource {x:Static timepickerlange:TimePickerLangResourceKey.AMText}}" />
        <Setter Property="PmText" Value="{DynamicResource {x:Static timepickerlange:TimePickerLangResourceKey.PMText}}" />
    </ControlTheme>
</ResourceDictionary>