<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:ClassModifier="internal"
    xmlns:timepickerlange="using:AtomUI.Desktop.Controls.TimePickerLang"
    xmlns:atom="https://atomui.net">
    <ControlTheme x:Key="{x:Type atom:TimePicker}" TargetType="atom:TimePicker">
        <ControlTheme.BasedOn>
            <atom:InfoPickerInputTheme TargetType="atom:TimePicker" />
        </ControlTheme.BasedOn>
        <Setter Property="AmText" Value="{atom:TimePickerLangResource AMText}" />
        <Setter Property="PmText" Value="{atom:TimePickerLangResource PMText}" />
    </ControlTheme>
</ResourceDictionary>