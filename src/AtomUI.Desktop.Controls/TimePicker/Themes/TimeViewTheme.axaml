<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:TimeView}" TargetType="atom:TimeView">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="PART_MainFrame"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}">
                    <Grid Name="PART_RootLayout"
                          RowDefinitions="Auto, Auto, *">
                        <atom:TextBlock Name="PART_HeaderText"
                                   Grid.Row="0"
                                   IsVisible="{TemplateBinding IsShowHeader}" />
                        <Rectangle Grid.Row="1"
                                   HorizontalAlignment="Stretch"
                                   Height="{TemplateBinding SpacerWidth}"
                                   IsVisible="{TemplateBinding IsShowHeader}" />
                        <Grid Name="PART_PickerContainer"
                              Grid.Row="2"
                              ColumnDefinitions="*, Auto, *, Auto, *, Auto, *">
                            <Panel Name="PART_HourHost"
                                   Grid.Column="0">
                                <atom:ScrollViewer
                                    IsScrollChainingEnabled="False"
                                    HorizontalScrollBarVisibility="Disabled"
                                    VerticalScrollBarVisibility="Hidden">
                                    <atom:DateTimePickerPanel Name="PART_HourSelector"
                                                              PanelType="Hour"
                                                              ShouldLoop="True"
                                                              IsMotionEnabled="{TemplateBinding IsMotionEnabled}" />
                                </atom:ScrollViewer>
                            </Panel>
                            <Rectangle Name="PART_FirstSpacer"
                                       Grid.Column="1"
                                       HorizontalAlignment="Center"
                                       Width="{TemplateBinding SpacerWidth}" />
                            <Panel Name="PART_MinuteHost"
                                   Grid.Column="2">
                                <atom:ScrollViewer
                                    IsScrollChainingEnabled="False"
                                    HorizontalScrollBarVisibility="Disabled"
                                    VerticalScrollBarVisibility="Hidden">
                                    <atom:DateTimePickerPanel Name="PART_MinuteSelector"
                                                              PanelType="Minute"
                                                              ShouldLoop="True"
                                                              IsMotionEnabled="{TemplateBinding IsMotionEnabled}" />
                                </atom:ScrollViewer>
                            </Panel>
                            <Rectangle Name="PART_SecondSpacer"
                                       Grid.Column="3"
                                       HorizontalAlignment="Center"
                                       Width="{TemplateBinding SpacerWidth}" />
                            <Panel Name="PART_SecondHost"
                                   Grid.Column="4">
                                <atom:ScrollViewer
                                    IsScrollChainingEnabled="False"
                                    HorizontalScrollBarVisibility="Disabled"
                                    VerticalScrollBarVisibility="Hidden">
                                    <atom:DateTimePickerPanel Name="PART_SecondSelector"
                                                              PanelType="Second"
                                                              ShouldLoop="True"
                                                              IsMotionEnabled="{TemplateBinding IsMotionEnabled}" />
                                </atom:ScrollViewer>
                            </Panel>
                            <Rectangle Name="PART_ThirdSpacer"
                                       Grid.Column="5"
                                       HorizontalAlignment="Center"
                                       Width="{TemplateBinding SpacerWidth}" />
                            <Panel Name="PART_PeriodHost"
                                   Grid.Column="6">
                                <atom:ScrollViewer
                                    IsScrollChainingEnabled="False"
                                    HorizontalScrollBarVisibility="Disabled"
                                    VerticalScrollBarVisibility="Hidden">
                                    <atom:DateTimePickerPanel Name="PART_PeriodSelector"
                                                              PanelType="TimePeriod"
                                                              ShouldLoop="False"
                                                              IsMotionEnabled="{TemplateBinding IsMotionEnabled}" />
                                </atom:ScrollViewer>
                            </Panel>
                        </Grid>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>

        <Setter Property="ItemHeight" Value="{atom:TimePickerTokenResource ItemHeight}" />
        <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgElevated}" />
  
        <Setter Property="AmText" Value="{atom:TimePickerLangResource AMText}" />
        <Setter Property="PmText" Value="{atom:TimePickerLangResource PMText}" />
        
        <Style Selector="^ /template/ atom|TextBlock#PART_HeaderText">
            <Setter Property="Height" Value="{atom:TimePickerTokenResource ItemHeight}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="{atom:TimePickerTokenResource HeaderMargin}" />
        </Style>
        
        <Style Selector="^ /template/ atom|DateTimePickerPanel">
            <Setter Property="ItemHeight" Value="{atom:TimePickerTokenResource ItemHeight}" />
        </Style>
        
        <Style Selector="^ /template/ Rectangle">
            <Setter Property="Fill" Value="{atom:SharedTokenResource ColorBorderSecondary}" />
        </Style>
        
        <Style Selector="^ /template/ Panel#PART_HourHost">
            <Setter Property="Width" Value="{atom:TimePickerTokenResource ItemWidth}" />
        </Style>
        
        <Style Selector="^ /template/ Panel#PART_MinuteHost">
            <Setter Property="Width" Value="{atom:TimePickerTokenResource ItemWidth}" />
        </Style>
        
        <Style Selector="^ /template/ Panel#PART_SecondHost">
            <Setter Property="Width" Value="{atom:TimePickerTokenResource ItemWidth}" />
        </Style>
        
        <Style Selector="^ /template/ Panel#PART_PeriodHost">
            <Setter Property="Width" Value="{atom:TimePickerTokenResource ItemWidth}" />
        </Style>
        
    </ControlTheme>
</ResourceDictionary>