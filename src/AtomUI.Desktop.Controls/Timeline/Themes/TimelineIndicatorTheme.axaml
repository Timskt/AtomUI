<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    xmlns:atomc="https://atomui.net/common-controls"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atomc:TimelineIndicator}" TargetType="atomc:TimelineIndicator">
        <Setter Property="Template">
            <ControlTemplate>
                <atom:IconPresenter
                    Name="PART_IconPresenter"
                    Icon="{TemplateBinding IndicatorIcon}"/> 
            </ControlTemplate>
        </Setter>
        
        <Setter Property="RelativeLineHeight" Value="{DynamicResource {x:Static atom:SharedTokenKey.RelativeLineHeight}}"/>
        <Setter Property="IndicatorDotBorderWidth" Value="{DynamicResource {x:Static atom:TimelineTokenKey.IndicatorDotBorderWidth}}"/>
        <Setter Property="IndicatorDotSize" Value="{DynamicResource {x:Static atom:TimelineTokenKey.IndicatorDotSize}}"/>
        <Setter Property="DefaultIndicatorColor" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorPrimary}}"/>
        <Setter Property="IndicatorTailWidth" Value="{DynamicResource {x:Static atom:TimelineTokenKey.IndicatorTailWidth}}"/>
        <Setter Property="IndicatorTailColor" Value="{DynamicResource {x:Static atom:TimelineTokenKey.IndicatorTailColor}}"/>
        
        <Style Selector="^ /template/ atom|IconPresenter#PART_IconPresenter">
            <Setter Property="Width" Value="{DynamicResource {x:Static atom:TimelineTokenKey.IndicatorSize}}"/>
            <Setter Property="Height" Value="{DynamicResource {x:Static atom:TimelineTokenKey.IndicatorSize}}"/>
        </Style>
        
        <Style Selector="^ /template/ atom|IconPresenter#PART_IconPresenter">
            <Setter Property="IconBrush" Value="{TemplateBinding IndicatorColor}"/>
        </Style>
        
    </ControlTheme>
</ResourceDictionary>