<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:DefaultTourIndicator}" TargetType="atom:DefaultTourIndicator">

        <Setter Property="ItemSpacing" Value="{DynamicResource {x:Static atom:SharedTokenKey.SpacingXXS}}" />
        <Setter Property="IndicatorSize" Value="{DynamicResource {x:Static atom:TourTokenKey.IndicatorSize}}" />
        <Setter Property="IndicatorColor" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorFill}}" />
        <Setter Property="IndicatorActiveColor"
                Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorPrimary}}" />
        
        <Style Selector="^[StyleType=Primary]">
            <Setter Property="IndicatorColor"
                    Value="{DynamicResource {x:Static atom:TourTokenKey.PrimaryPrevBtnBg}}" />
            <Setter Property="IndicatorActiveColor"
                    Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextLightSolid}}" />
        </Style>
    </ControlTheme>
</ResourceDictionary>