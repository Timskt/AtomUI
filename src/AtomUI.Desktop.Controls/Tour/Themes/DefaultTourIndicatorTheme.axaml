<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:DefaultTourIndicator}" TargetType="atom:DefaultTourIndicator">

        <Setter Property="ItemSpacing" Value="{atom:SharedTokenResource SpacingXXS}" />
        <Setter Property="IndicatorSize" Value="{atom:TourTokenResource IndicatorSize}" />
        <Setter Property="IndicatorColor" Value="{atom:SharedTokenResource ColorFill}" />
        <Setter Property="IndicatorActiveColor"
                Value="{atom:SharedTokenResource ColorPrimary}" />
        
        <Style Selector="^[StyleType=Primary]">
            <Setter Property="IndicatorColor"
                    Value="{atom:TourTokenResource PrimaryPrevBtnBg}" />
            <Setter Property="IndicatorActiveColor"
                    Value="{atom:SharedTokenResource ColorTextLightSolid}" />
        </Style>
    </ControlTheme>
</ResourceDictionary>