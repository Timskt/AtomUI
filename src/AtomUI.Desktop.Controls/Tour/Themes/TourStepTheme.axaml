<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:TourStep}" TargetType="atom:TourStep">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="Frame" Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}">
                    <DockPanel LastChildFill="True" Name="RootLayout">
                        <DockPanel LastChildFill="True"
                                   DockPanel.Dock="Top">
                            <atom:DialogCaptionButton
                                Name="CloseButton"
                                DockPanel.Dock="Right"
                                NormalIcon="{TemplateBinding CloseIcon}"
                                IsMotionEnabled="{TemplateBinding IsMotionEnabled}" />
                            <ContentPresenter Name="Title"
                                              Content="{TemplateBinding Title}"
                                              ContentTemplate="{TemplateBinding TitleTemplate}" />
                        </DockPanel>
                        <StackPanel Orientation="Vertical" Name="ContentLayout">
                            <ContentPresenter Name="CoverPresenter"
                                              Content="{TemplateBinding Cover}"
                                              ContentTemplate="{TemplateBinding CoverTemplate}" />
                            <ContentPresenter Name="DescriptionPresenter"
                                              Content="{TemplateBinding Description}"
                                              ContentTemplate="{TemplateBinding DescriptionTemplate}" />
                        </StackPanel>
                    </DockPanel>
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^ /template/ atom|DialogCaptionButton">
            <Setter Property="Width" Value="{DynamicResource {x:Static atom:TourTokenKey.CloseBtnSize}}" />
            <Setter Property="Height" Value="{DynamicResource {x:Static atom:TourTokenKey.CloseBtnSize}}" />
            <Setter Property="IconWidth" Value="{DynamicResource {x:Static atom:SharedTokenKey.IconSize}}" />
            <Setter Property="IconHeight" Value="{DynamicResource {x:Static atom:SharedTokenKey.IconSize}}" />
        </Style>

        <Style Selector="^ /template/ ContentPresenter#Title">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static atom:TourTokenKey.HeaderColor}}" />
            <Setter Property="FontWeight" Value="{DynamicResource {x:Static atom:SharedTokenKey.FontWeightStrong}}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
           
        <Style Selector="^[StyleType=Primary]">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextLightSolid}}" />
            
            <Style Selector="^ /template/ ContentPresenter#Title">
                <Setter Property="Foreground" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextLightSolid}}" />
            </Style>
            
            <Style Selector="^ /template/ atom|DialogCaptionButton#CloseButton">
                <Setter Property="IconBrush" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextLightSolid}}" />
            </Style>
            
            <Style Selector="^ /template/ atom|DialogCaptionButton#CloseButton:pointerover">
                <Setter Property="IconBrush" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextLightSolid}}" />
            </Style>
        
            <Style Selector="^ /template/ atom|DialogCaptionButton#CloseButton:pressed">
                <Setter Property="IconBrush" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorTextLightSolid}}" />
            </Style>
            
        </Style>

        <Style Selector="^ /template/ DockPanel#RootLayout">
            <Setter Property="VerticalSpacing" Value="{DynamicResource {x:Static atom:SharedTokenKey.SpacingXS}}" />
        </Style>
        
        <Style Selector="^ /template/ StackPanel#ContentLayout">
            <Setter Property="Spacing" Value="{DynamicResource {x:Static atom:SharedTokenKey.SpacingXS}}" />
        </Style>

        <Setter Property="IsVisible" Value="False" />
        <Style Selector="^[IsSelected=True]">
            <Setter Property="IsVisible" Value="True" />
        </Style>

    </ControlTheme>
</ResourceDictionary>