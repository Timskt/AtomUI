<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    xmlns:antdicons="https://atomui.net/icons/antdesign"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:Tour}" TargetType="atom:Tour">
        <Setter Property="Template">
            <ControlTemplate TargetType="atom:Tour">
                <atom:Popup Name="{x:Static atom:PopupThemeConstants.PopupPart}"
                            WindowManagerAddShadowHint="False"
                            IsLightDismissEnabled="False"
                            IsDetectMouseClickEnabled="False"
                            IsMotionEnabled="False"
                            ShouldUseOverlayLayer="True">
                    <atom:ArrowDecoratedBox Name="{x:Static atom:AbstractArrowDecoratedBox.ArrowDecoratorPart}"
                                            IsShowArrow="{TemplateBinding CurrentShowArrow}"
                                            ArrowPosition="{TemplateBinding ArrowPosition}">
                        <atom:TourStepsView Name="StepsView"
                                            ItemsSource="{Binding Steps, RelativeSource={RelativeSource TemplatedParent}}"
                                            SelectedIndex="{TemplateBinding CurrentIndex, Mode=TwoWay}"
                                            IsMotionEnabled="{TemplateBinding IsMotionEnabled}"
                                            StyleType="{TemplateBinding StyleType}"
                                            IsShowArrow="{TemplateBinding IsShowArrow}"
                                            IsPointAtCenter="{TemplateBinding IsPointAtCenter}"
                                            Placement="{TemplateBinding Placement}"
                                            IsShowMask="{TemplateBinding IsShowMask}"
                                            CloseIcon="{TemplateBinding CloseIcon}"
                                            IsScrollIntoView="{TemplateBinding IsScrollIntoView}"
                                            CurrentStyleType="{TemplateBinding CurrentStyleType}"/>
                    </atom:ArrowDecoratedBox>
                </atom:Popup>
            </ControlTemplate>
        </Setter>
        
        <Setter Property="Placement" Value="Bottom" />
        <Setter Property="MaskBackground" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorBgMask}}" />
        <Setter Property="IsMotionEnabled" Value="{DynamicResource {x:Static atom:SharedTokenKey.EnableMotion}}" />
        
        <Style Selector="^ /template/ atom|ArrowDecoratedBox#PART_ArrowDecorator">
            <Setter Property="CornerRadius" Value="{DynamicResource {x:Static atom:TourTokenKey.TourBorderRadius}}" />
            <Setter Property="Background" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorBgElevated}}" />
        </Style>

        <Style Selector="^ /template/ atom|Popup#PART_Popup">
            <Setter Property="MaskShadows" Value="{DynamicResource {x:Static atom:SharedTokenKey.BoxShadowsTertiary}}" />
        </Style>
        
        <Style Selector="^ /template/ atom|ArrowDecoratedBox#PART_ArrowDecorator">
            <Setter Property="Background" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorBgElevated}}" />
        </Style>
        
        <Style Selector="^[StyleType=Primary]">
            <Style Selector="^ /template/ atom|ArrowDecoratedBox#PART_ArrowDecorator">
                <Setter Property="Background" Value="{DynamicResource {x:Static atom:SharedTokenKey.ColorPrimary}}" />
            </Style>
        </Style>
                
        <Setter Property="CloseIcon">
            <atom:IconTemplate><antdicons:CloseOutlined/></atom:IconTemplate>
        </Setter>
        
    </ControlTheme>
</ResourceDictionary>