<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    xmlns:transferLang="clr-namespace:AtomUI.Desktop.Controls.Transfer"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:TransferSelectDropdown}" TargetType="atom:TransferSelectDropdown">
        <ControlTheme.BasedOn>
            <atom:IconButtonTheme TargetType="atom:TransferSelectDropdown" />
        </ControlTheme.BasedOn>
  
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="IconWidth" Value="{DynamicResource {x:Static atom:SharedTokenKey.FontSizeIcon}}" />
        <Setter Property="IconHeight" Value="{DynamicResource {x:Static atom:SharedTokenKey.FontSizeIcon}}" />
        <Setter Property="SelectAllText" Value="{DynamicResource {x:Static atom:TransferLangResourceKey.SelectAll}}" />
        <Setter Property="DeSelectAllText" Value="{DynamicResource {x:Static atom:TransferLangResourceKey.DeSelectAll}}" />
        <Setter Property="InvertSelectCurrentPageText" Value="{DynamicResource {x:Static atom:TransferLangResourceKey.InvertSelectCurrentPage}}" />
        <Setter Property="SelectCurrentPageText" Value="{DynamicResource {x:Static atom:TransferLangResourceKey.SelectCurrentPage}}" />
        <Setter Property="RemoveCurrentPageText" Value="{DynamicResource {x:Static atom:TransferLangResourceKey.RemoveCurrentPage}}" />
        <Setter Property="RemoveAllText" Value="{DynamicResource {x:Static atom:TransferLangResourceKey.RemoveAll}}" />
    </ControlTheme>
</ResourceDictionary>