<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:TransferSelectDropdown}" TargetType="atom:TransferSelectDropdown">
        <ControlTheme.BasedOn>
            <atom:IconButtonTheme TargetType="atom:TransferSelectDropdown" />
        </ControlTheme.BasedOn>
  
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="IconWidth" Value="{atom:SharedTokenResource FontSizeIcon}" />
        <Setter Property="IconHeight" Value="{atom:SharedTokenResource FontSizeIcon}" />
        <Setter Property="SelectAllText" Value="{atom:TransferLangResource SelectAll}" />
        <Setter Property="DeSelectAllText" Value="{atom:TransferLangResource DeSelectAll}" />
        <Setter Property="InvertSelectCurrentPageText" Value="{atom:TransferLangResource InvertSelectCurrentPage}" />
        <Setter Property="SelectCurrentPageText" Value="{atom:TransferLangResource SelectCurrentPage}" />
        <Setter Property="RemoveCurrentPageText" Value="{atom:TransferLangResource RemoveCurrentPage}" />
        <Setter Property="RemoveAllText" Value="{atom:TransferLangResource RemoveAll}" />
    </ControlTheme>
</ResourceDictionary>