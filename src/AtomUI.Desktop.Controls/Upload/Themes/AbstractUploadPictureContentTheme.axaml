<ControlTheme xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:atom="https://atomui.net"
              x:Class="AtomUI.Desktop.Controls.Themes.AbstractUploadPictureContentTheme"
              TargetType="atom:Button"
              x:ClassModifier="internal">
    <Style Selector="^:is(atom|AbstractUploadPictureContent)">
        <Setter Property="Background" Value="Transparent" />

        <Setter Property="CornerRadius" Value="{atom:SharedTokenResource BorderRadiusLG}" />
        <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorBorder}" />
        <Setter Property="BorderThickness" Value="{atom:SharedTokenResource BorderThickness}" />
        <Setter Property="Padding" Value="{atom:SharedTokenResource PaddingXS}" />
        <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorTextSecondary}" />
        
        <Style Selector="^[Status=Failed]">
            <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorError}" />
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorError}" />
        </Style>
        
        <Style Selector="^[Status=Cancelled]">
            <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorError}" />
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorError}" />
        </Style>
        
        <Style Selector="^ /template/ Border#Mask">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgMask}" />
            <Setter Property="TemplatedControl.Foreground"
                    Value="{atom:SharedTokenResource ColorTextLightSolid}" />
        </Style>

        <Style Selector="^:pointerover">
            <Setter Property="MaskOpacity" Value="1" />
        </Style>
        
        <Style Selector="^ /template/ atom|IconButton">
            <Setter Property="IconBrush" Value="{atom:SharedTokenResource ColorTextLightSolid}" />
            <Setter Property="IconWidth" Value="{atom:SharedTokenResource FontSizeLG}" />
            <Setter Property="IconHeight" Value="{atom:SharedTokenResource FontSizeLG}" />
        </Style>
        
        <Style Selector="^ /template/ atom|IconButton:pointerover">
            <Setter Property="IconBrush" Value="{atom:SharedTokenResource ColorTextLightSolid}" />
        </Style>
    </Style>

</ControlTheme>