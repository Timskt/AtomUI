<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:UploadPictureShapePendingContent}" TargetType="atom:UploadPictureShapePendingContent">
        <ControlTheme.BasedOn>
            <atom:AbstractUploadPictureContentTheme TargetType="atom:UploadPictureShapePendingContent" />
        </ControlTheme.BasedOn>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="Frame"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <Border Name="ContentFrame"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            ClipToBounds="True">
                        <StackPanel Name="ContentLayout"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{atom:UploadLangResource Pending}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Border>
            </ControlTemplate>
        </Setter>

        <Setter Property="Width" Value="{atom:UploadTokenResource PictureCardSize}" />
        <Setter Property="Height" Value="{atom:UploadTokenResource PictureCardSize}" />
    </ControlTheme>
</ResourceDictionary>