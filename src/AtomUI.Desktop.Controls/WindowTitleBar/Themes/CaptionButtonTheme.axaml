<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:CaptionButton}" TargetType="atom:CaptionButton">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="PART_Frame"
                        Background="{TemplateBinding Background}"
                        Padding="{TemplateBinding Padding}"
                        CornerRadius="{TemplateBinding EffectiveCornerRadius}"
                        HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                        VerticalAlignment="{TemplateBinding VerticalAlignment}">
                    <atom:IconPresenter
                        Name="PART_IconPresenter"
                        Icon="{TemplateBinding EffectiveIcon}"
                        Width="{TemplateBinding IconWidth}"
                        Height="{TemplateBinding IconHeight}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsMotionEnabled="{TemplateBinding IsMotionEnabled}" />
                </Border>
            </ControlTemplate>
        </Setter>

        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Padding" Value="{atom:WindowTitleBarTokenResource CaptionButtonPadding}" />
        <Setter Property="Foreground" Value="{atom:WindowTitleBarTokenResource ActiveColor}" />
        
        <Style Selector="^ /template/ atom|IconPresenter">
            <Setter Property="IconBrush" Value="{atom:WindowTitleBarTokenResource ActiveColor}" />
        </Style>
        
        <Setter Property="Background" Value="{atom:WindowTitleBarTokenResource ActiveBgColor}" />
       
        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{atom:WindowTitleBarTokenResource ActiveHoverBgColor}" />
        </Style>
        
        <Style Selector="^:pressed">
            <Setter Property="Background" Value="{atom:WindowTitleBarTokenResource ActivePressedBgColor}" />
        </Style>
        
        <Style Selector="^[IsWindowActive=False]">
            <Style Selector="^ /template/ atom|IconPresenter">
                <Setter Property="IconBrush"
                        Value="{atom:WindowTitleBarTokenResource InactiveColor}" />
            </Style>
            <Setter Property="Background" Value="{atom:WindowTitleBarTokenResource InactiveBgColor}" />
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{atom:WindowTitleBarTokenResource InactiveHoverBgColor}" />
            </Style>
        </Style>

        <Style Selector="^[IsMotionEnabled=True]">
            <Setter Property="Transitions">
                <Transitions>
                    <atom:SolidColorBrushTransition Property="Background" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}" />
                </Transitions>
            </Setter>
        </Style>

    </ControlTheme>
</ResourceDictionary>
