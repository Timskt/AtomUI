<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atom="https://atomui.net"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type atom:WindowsCaptionButton}" TargetType="atom:WindowsCaptionButton">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="PART_Frame"
                        Background="{TemplateBinding Background}"
                        Padding="{TemplateBinding Padding}"
                        CornerRadius="{TemplateBinding EffectiveCornerRadius}">
                    <Panel Name="PART_RootLayout">
                        <atom:IconPresenter
                            Name="PART_NormalIconPresenter"
                            Icon="{TemplateBinding NormalIcon}"
                            Width="{TemplateBinding IconWidth}"
                            Height="{TemplateBinding IconHeight}"
                            IsMotionEnabled="{TemplateBinding IsMotionEnabled}"
                            IsVisible="{TemplateBinding IsChecked, Converter={x:Static BoolConverters.Not}}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                        <atom:IconPresenter
                            Name="PART_CheckedIconPresenter"
                            Icon="{TemplateBinding CheckedIcon}"
                            IsVisible="{TemplateBinding IsChecked}"
                            Width="{TemplateBinding IconWidth}"
                            Height="{TemplateBinding IconHeight}"
                            IsMotionEnabled="{TemplateBinding IsMotionEnabled}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Panel>
                </Border>
            </ControlTemplate>
        </Setter>
        
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="{atom:WindowTitleBarTokenResource ActiveColor}" />
        
        <Style Selector="^ /template/ atom|IconPresenter">
            <Setter Property="IconBrush" Value="{atom:WindowTitleBarTokenResource ActiveColor}" />
        </Style>
        
        <Setter Property="Background" Value="Transparent" />
        
        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{atom:WindowTitleBarTokenResource ActiveHoverBgColor}" />
        </Style>

        <Style Selector="^:pressed">
            <Setter Property="Background" Value="{atom:WindowTitleBarTokenResource ActivePressedBgColor}" />
        </Style>
        
        <Style Selector="^[IsCloseButton=True]">
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{atom:WindowTitleBarTokenResource WindowsCloseButtonHoverBgColor}" />
                
                <Style Selector="^ /template/ atom|IconPresenter">
                    <Setter Property="IconBrush" Value="{atom:WindowTitleBarTokenResource WindowsCloseButtonHoverColor}" />
                </Style>
                
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="Background" Value="{atom:WindowTitleBarTokenResource WindowsCloseButtonPressedBgColor}" />
                
                <Style Selector="^ /template/ atom|IconPresenter">
                    <Setter Property="IconBrush" Value="{atom:WindowTitleBarTokenResource WindowsCloseButtonHoverColor}" />
                </Style>
            </Style>
        </Style>
        
        <Style Selector="^[IsWindowActive=False]">
            <Style Selector="^ /template/ atom|IconPresenter">
                <Setter Property="IconBrush"
                        Value="{atom:WindowTitleBarTokenResource InactiveColor}" />
            </Style>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{atom:WindowTitleBarTokenResource InactiveHoverBgColor}" />
            </Style>
            
            <Style Selector="^[IsCloseButton=True]">
                <Style Selector="^:pointerover">
                    <Setter Property="Background" Value="{atom:WindowTitleBarTokenResource WindowsCloseButtonHoverBgColor}" />
                    <Style Selector="^ /template/ atom|IconPresenter">
                        <Setter Property="IconBrush" Value="{atom:WindowTitleBarTokenResource WindowsCloseButtonHoverColor}" />
                    </Style>
                </Style>
            </Style>
        </Style>
        
        <Style Selector="^[IsMotionEnabled=True]">
            <Setter Property="Transitions">
                <Transitions>
                    <atom:SolidColorBrushTransition Property="Background" Duration="{atom:SharedTokenResourceValue Kind=MotionDurationMid}" />
                </Transitions>
            </Setter>
        </Style>
        
    </ControlTheme>
</ResourceDictionary>